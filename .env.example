# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Optional first-run bootstrap account (empty by default) ---
# Uncomment only if you are starting with a fresh identity DB.
# DEEZSPOTAG_BOOTSTRAP_USER=
# DEEZSPOTAG_BOOTSTRAP_PASS=

# --- API token (optional: leave blank to let the app auto-generate one) ---
# DEEZSPOTAG_API_TOKEN=

# --- Synology/NAS runtime user mapping ---
# Set to the host user/group that own the bind-mounted folders.
PUID=1000
PGID=1000

# --- Host paths for Docker volumes ---
# Local defaults (auto-created by Compose if missing):
DEEZSPOTAG_DATA_PATH=./DeezSpoTag.Workers/Data
DEEZSPOTAG_APPDATA_PATH=./DeezSpoTag.Workers/Data
DEEZSPOTAG_DATA_PROTECTION_KEYS_DIR=./DeezSpoTag.Workers/Data/security/data-protection-keys
APPLE_WRAPPER_DATA_PATH=./Data/apple-wrapper/data
APPLE_WRAPPER_SESSION_PATH=./Data/apple-wrapper/session
# Wrapper container runs as root by default (required by upstream wrapper chroot/mknod behavior).
APPLE_WRAPPER_UID=0
APPLE_WRAPPER_GID=0
# Wrapper argument env file (used by wrapper runtime defaults and optional helper mode).
APPLE_WRAPPER_ENV_FILE=Tools/AppleMusicWrapper/docker/apple-wrapper.env
DOWNLOADS_PATH=./Downloads
LIBRARY_PATH=./Library

# Apple wrapper control mode:
# - shared (default): login/2FA via shared mounted paths (portable; no docker.sock needed)
# - helper: legacy Docker CLI helper orchestration
DEEZSPOTAG_APPLE_WRAPPER_CONTROL_MODE=shared

# --- Local dotnet parity mode (optional) ---
# When running only apple-wrapper in Docker and DeezSpoTag.Web via dotnet run,
# export these in your shell before dotnet run:
# DEEZSPOTAG_DATA_DIR=DeezSpoTag.Workers/Data
# DEEZSPOTAG_CONFIG_DIR=DeezSpoTag.Workers/Data
# DEEZSPOTAG_APPLE_WRAPPER_HOST=127.0.0.1
# DEEZSPOTAG_APPLE_WRAPPER_CONTROL_MODE=shared
# DEEZSPOTAG_APPLE_WRAPPER_SHARED_DATA_DIR=/absolute/path/to/apple-wrapper/data
# DEEZSPOTAG_APPLE_WRAPPER_SHARED_SESSION_DIR=/absolute/path/to/apple-wrapper/session

# --- Image tags ---
# GHCR defaults used by docker-compose.yml (pulled on every start).
# CI publishes main-branch updates to `:prerelease` by default.
# Switch to `:latest` only when you intentionally want stable channel only.
DEEZSPOTAG_IMAGE=ghcr.io/lauqnan14/deezspotag:prerelease
APPLE_WRAPPER_IMAGE=ghcr.io/lauqnan14/deezspotag-apple-wrapper:prerelease
