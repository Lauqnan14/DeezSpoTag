# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Admin account (created on first run if it doesn't exist) ---
DEEZSPOTAG_BOOTSTRAP_USER=admin
DEEZSPOTAG_BOOTSTRAP_PASS=Change-Me-Strong-Pass1

# --- API token (optional: leave blank to let the app auto-generate one) ---
# DEEZSPOTAG_API_TOKEN=

# --- Host paths for Docker volumes ---
DOWNLOADS_PATH=/path/to/downloads
LIBRARY_PATH=/path/to/music

# --- Image tags (defaults point to GHCR published images) ---
# For local dev builds, override to local names:
# DEEZSPOTAG_IMAGE=deezspotag-dev:latest
# APPLE_WRAPPER_IMAGE=deezspotag-apple-wrapper-dev:latest
DEEZSPOTAG_IMAGE=ghcr.io/lauqnan14/deezspotag:latest
APPLE_WRAPPER_IMAGE=ghcr.io/lauqnan14/deezspotag-apple-wrapper:latest

# --- Optional: runtime build/version label injected into the app log ---
# Used when building the deezspotag image locally via docker compose build.
DEEZSPOTAG_BUILD_VERSION=latest
