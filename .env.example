# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Optional first-run bootstrap account (empty by default) ---
# Uncomment only if you are starting with a fresh identity DB.
# DEEZSPOTAG_BOOTSTRAP_USER=
# DEEZSPOTAG_BOOTSTRAP_PASS=

# --- API token (optional: leave blank to let the app auto-generate one) ---
# DEEZSPOTAG_API_TOKEN=

# --- Synology/NAS runtime user mapping ---
# Set to your NAS user/group that own the bind-mounted folders.
PUID=1026
PGID=100

# --- Host paths for Docker volumes ---
# Auto-created by Compose if missing:
DEEZSPOTAG_DATA_PATH=/volume1/docker/deezspotag/data
DEEZSPOTAG_APPDATA_PATH=/volume1/docker/deezspotag/app-data
APPLE_WRAPPER_DATA_PATH=/volume1/docker/deezspotag/apple-wrapper/data
APPLE_WRAPPER_SESSION_PATH=/volume1/docker/deezspotag/apple-wrapper/session
# Wrapper argument env file used by apple-wrapperctl.sh login/2FA flow:
APPLE_WRAPPER_ENV_FILE=Tools/AppleMusicWrapper/docker/apple-wrapper.env
# Must already exist (Compose is configured to fail if missing):
DOWNLOADS_PATH=/volume1/downloads
LIBRARY_PATH=/volume1/music

# --- Image tags (defaults point to GHCR published images) ---
# For local dev builds, override to local names:
# DEEZSPOTAG_IMAGE=deezspotag-web-dev:latest
# APPLE_WRAPPER_IMAGE=deezspotag-apple-wrapper-dev:latest
DEEZSPOTAG_IMAGE=ghcr.io/lauqnan14/deezspotag-web:latest
APPLE_WRAPPER_IMAGE=ghcr.io/lauqnan14/deezspotag-apple-wrapper:latest
