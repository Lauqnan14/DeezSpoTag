FROM mcr.microsoft.com/dotnet/sdk:8.0-bookworm-slim AS watch
WORKDIR /src
ARG ESSENTIA_TF_WHEEL_URL=https://files.pythonhosted.org/packages/f0/5f/7283634ee1d5d195d75986adc98a2309fab2df121a4618f3826eb2073d29/essentia_tensorflow-2.1b6.dev1389-cp311-cp311-manylinux_2_17_x86_64.manylinux2014_x86_64.whl

# Runtime deps used by the app in dev mode (parity with runtime image),
# plus the non-root user used by the container.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates curl aria2 openssl \
      python3 python3-venv python3-pip \
      ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/venv/bin/pip install --no-cache-dir "numpy>=1.25" pyyaml six \
    && wheel_filename="$(basename "${ESSENTIA_TF_WHEEL_URL}")" \
    && wheel_path="/tmp/${wheel_filename}" \
    && aria2c \
      --allow-overwrite=true \
      --continue=true \
      --file-allocation=none \
      --max-connection-per-server=8 \
      --split=8 \
      --min-split-size=1M \
      --connect-timeout=30 \
      --timeout=60 \
      --retry-wait=5 \
      --max-tries=0 \
      --summary-interval=15 \
      --dir=/tmp \
      --out="${wheel_filename}" \
      "${ESSENTIA_TF_WHEEL_URL}" \
    && /opt/venv/bin/pip install --no-cache-dir --no-deps "${wheel_path}" \
    && rm -f "${wheel_path}" \
    && groupadd --gid 1001 appuser \
    && useradd --uid 1001 --gid 1001 --create-home --shell /bin/bash appuser

# Cache analyzer models inside the watch image so local dev containers do not depend
# on host model files unless explicitly overridden.
RUN set -eux; \
    models_dir=/opt/deezspotag/models; \
    mkdir -p "${models_dir}"; \
    fetch_model() { \
      file="$1"; \
      url="$2"; \
      curl -fL -o "${models_dir}/${file}" "${url}"; \
    }; \
    fetch_model "msd-musicnn-1.pb" "https://essentia.upf.edu/models/feature-extractors/musicnn/msd-musicnn-1.pb"; \
    fetch_model "mood_happy-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/mood_happy/mood_happy-msd-musicnn-1.pb"; \
    fetch_model "mood_sad-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/mood_sad/mood_sad-msd-musicnn-1.pb"; \
    fetch_model "mood_relaxed-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/mood_relaxed/mood_relaxed-msd-musicnn-1.pb"; \
    fetch_model "mood_aggressive-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/mood_aggressive/mood_aggressive-msd-musicnn-1.pb"; \
    fetch_model "mood_party-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/mood_party/mood_party-msd-musicnn-1.pb"; \
    fetch_model "mood_acoustic-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/mood_acoustic/mood_acoustic-msd-musicnn-1.pb"; \
    fetch_model "mood_electronic-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/mood_electronic/mood_electronic-msd-musicnn-1.pb"; \
    fetch_model "voice_instrumental-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/voice_instrumental/voice_instrumental-msd-musicnn-1.pb"; \
    fetch_model "tonal_atonal-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/tonal_atonal/tonal_atonal-msd-musicnn-1.pb"; \
    fetch_model "danceability-msd-musicnn-1.pb" "https://essentia.upf.edu/models/classification-heads/danceability/danceability-msd-musicnn-1.pb"; \
    fetch_model "deam-msd-musicnn-2.pb" "https://essentia.upf.edu/models/classification-heads/deam/deam-msd-musicnn-2.pb"; \
    fetch_model "discogs-effnet-bs64-1.pb" "https://essentia.upf.edu/models/feature-extractors/discogs-effnet/discogs-effnet-bs64-1.pb"; \
    fetch_model "approachability_regression-discogs-effnet-1.pb" "https://essentia.upf.edu/models/classification-heads/approachability/approachability_regression-discogs-effnet-1.pb"; \
    fetch_model "engagement_regression-discogs-effnet-1.pb" "https://essentia.upf.edu/models/classification-heads/engagement/engagement_regression-discogs-effnet-1.pb"; \
    fetch_model "genre_discogs400-discogs-effnet-1.pb" "https://essentia.upf.edu/models/classification-heads/genre_discogs400/genre_discogs400-discogs-effnet-1.pb"; \
    fetch_model "genre_discogs400-discogs-effnet-1.json" "https://essentia.upf.edu/models/classification-heads/genre_discogs400/genre_discogs400-discogs-effnet-1.json"

ENV VIBE_ANALYZER_PYTHON=/opt/venv/bin/python3 \
    SHAZAM_PYTHON=/opt/venv/bin/python3 \
    VIBE_ANALYZER_MODELS=/opt/deezspotag/models \
    PATH=/opt/venv/bin:$PATH

USER appuser

EXPOSE 8668
