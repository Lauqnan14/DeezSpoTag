# Wrapper arguments passed to the service.
# Example (login):
# WRAPPER_ARGS="-H 127.0.0.1 -D 10020 -M 20020 -A 30020 -L user:pass -F"
# args="-H 127.0.0.1 -D 10020 -M 20020 -A 30020 -L user:pass -F"
# Example (run only):
# WRAPPER_ARGS="-H 127.0.0.1 -D 10020 -M 20020 -A 30020"
# args="-H 127.0.0.1 -D 10020 -M 20020 -A 30020"
WRAPPER_ARGS="-H 127.0.0.1 -D 10020 -M 20020 -A 30020"
args="-H 127.0.0.1 -D 10020 -M 20020 -A 30020"
