@{
    ViewData["Title"] = "About - DeezSpoTag";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var references = new[]
    {
        new { Project = "Apple Music Downloader (runv2)", Creators = "Sendy McSenderson and contributors", Url = "https://github.com/zhaarey/apple-music-downloader" },
        new { Project = "Apple Music API", Creators = "Myp3a and contributors", Url = "https://github.com/Myp3a/apple-music-api" },
        new { Project = "apmyx", Creators = "rwnk-12 and contributors", Url = "https://github.com/rwnk-12/apmyx-gui" },
        new { Project = "MusicMover", Creators = "MusicMoveArr and contributors", Url = "https://github.com/MusicMoveArr/MusicMover" },
        new { Project = "Quality Scanner (whatsmybitrate-main)", Creators = "oren-cohen and contributors", Url = "https://github.com/oren-cohen/whatsmybitrate" },
        new { Project = "ShazamIO", Creators = "dotX12 and contributors", Url = "https://github.com/dotX12/ShazamIO" },
        new { Project = "SeinopSys PersonalSite", Creators = "SeinopSys and contributors", Url = "https://github.com/SeinopSys/PersonalSite" },
        new { Project = "SoulSync", Creators = "Nezreka and contributors", Url = "https://github.com/Nezreka/SoulSync" },
        new { Project = "SpotiFLAC Desktop", Creators = "afkarxyz and contributors", Url = "https://github.com/afkarxyz/SpotiFLAC" },
        new { Project = "SPotiFLAC Mobile", Creators = "zarzet and contributors", Url = "https://github.com/zarzet/SpotiFLAC-Mobile" },
        new { Project = "Wolframe Spotify Canvas", Creators = "squeeeezy and contributors", Url = "https://github.com/squeeeezy/Wolframe-spotify-canvas" },
        new { Project = "Boomplay Music Downloader", Creators = "OkoyaUsman and contributors", Url = "https://github.com/OkoyaUsman/boomplay" },
        new { Project = "deemix", Creators = "bambanah and contributors", Url = "https://github.com/bambanah/deemix" },
        new { Project = "lidify", Creators = "Chevron7Locked and contributors", Url = "https://github.com/Chevron7Locked/lidify" },
        new { Project = "OneTagger", Creators = "Marekkon5 and contributors", Url = "https://github.com/Marekkon5/onetagger" },
        new { Project = "MusicBrainz Picard", Creators = "MetaBrainz and contributors", Url = "https://github.com/metabrainz/picard" },
        new { Project = "puddletag", Creators = "puddletag contributors", Url = "https://github.com/puddletag/puddletag" },
        new { Project = "Qobuz Artist Discography", Creators = "pawllo01 and contributors", Url = "https://github.com/pawllo01/qobuz-artist-discography" },
        new { Project = "ReFreezer", Creators = "DJDoubleD and contributors", Url = "https://github.com/DJDoubleD/ReFreezer" },
        new { Project = "spotizerr-phoenix", Creators = "spotizerrphoenix contributors", Url = "https://lavaforge.org/spotizerrphoenix/spotizerr-phoenix" },
        new { Project = "syrics-web", Creators = "akashrchandran and contributors", Url = "https://github.com/akashrchandran/syrics-web-react" },
        new { Project = "wrapper", Creators = "WorldObservationLog and contributors", Url = "https://github.com/WorldObservationLog/wrapper" },
        new { Project = "ATL .NET", Creators = "Zeugma440 and contributors", Url = "https://github.com/Zeugma440/atldotnet" },
        new { Project = "tone", Creators = "sandreas and contributors", Url = "https://github.com/sandreas/tone" }
    };

    var sortedReferences = references
        .OrderBy(x => x.Project, System.StringComparer.OrdinalIgnoreCase)
        .ToArray();
}

@section Styles {
<style>
.about-page {
    padding: 20px;
    padding-bottom: 100px;
    color: var(--text-primary);
}

.about-hero {
    background: linear-gradient(145deg, color-mix(in srgb, var(--bg-tertiary) 88%, var(--primary-color)), var(--bg-secondary));
    border: 1px solid color-mix(in srgb, var(--primary-color) 25%, var(--border-secondary));
    border-radius: 14px;
    padding: 22px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
}

.about-title {
    margin: 0 0 8px 0;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
}

.about-subtitle {
    margin: 0;
    color: var(--text-muted);
    max-width: 760px;
    line-height: 1.55;
}

.about-section {
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 14px;
}

.about-section-head {
    border-bottom: 1px solid var(--border-secondary);
    padding: 18px 20px;
}

.about-section-title {
    margin: 0 0 5px 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
}

.about-section-subtle {
    margin: 0;
    color: var(--text-muted);
}

.about-reference-grid {
    padding: 20px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 14px;
}

.about-reference-card {
    border: 1px solid var(--border-secondary);
    border-radius: 12px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--bg-darker);
    min-height: 178px;
}

.about-reference-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
}

.about-project-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
}

.about-project-creators {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.45;
    font-size: 0.94rem;
}

.about-source-pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border-secondary);
    border-radius: 999px;
    padding: 4px 9px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-secondary);
    white-space: nowrap;
}

.about-repo-link {
    margin-top: auto;
    width: fit-content;
    border: 1px solid var(--border-secondary);
    border-radius: 8px;
    background: var(--bg-secondary);
    color: var(--primary-color);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 8px 12px;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
}

.about-repo-link:hover {
    border-color: color-mix(in srgb, var(--primary-color) 55%, var(--border-secondary));
    background: color-mix(in srgb, var(--bg-secondary) 78%, var(--primary-color));
    color: var(--primary-color);
}

@@media (max-width: 900px) {
    .about-reference-grid {
        grid-template-columns: 1fr;
    }
}
</style>
}

<div class="container-fluid d-flex flex-column gap-4 about-page">
    <section class="about-hero">
        <div>
            <h1 class="about-title">About DeezSpoTag</h1>
            <p class="about-subtitle">
                DeezSpoTag exists because of open-source maintainers, contributors, and users who share ideas and tools.
                This page credits the projects and creators referenced in the build and workflow design.
            </p>
        </div>
    </section>

    <section class="about-section">
        <div class="about-section-head">
            <h2 class="about-section-title">Referenced Projects</h2>
        </div>
        <div class="about-reference-grid">
            @foreach (var item in sortedReferences)
            {
                var host = item.Url;
                if (System.Uri.TryCreate(item.Url, System.UriKind.Absolute, out var itemUri))
                {
                    host = itemUri.Host;
                }
                <article class="about-reference-card">
                    <div class="about-reference-top">
                        <h3 class="about-project-title">@item.Project</h3>
                        <span class="about-source-pill">@host</span>
                    </div>
                    <p class="about-project-creators">@item.Creators</p>
                    <a class="about-repo-link" href="@item.Url" target="_blank" rel="noopener noreferrer">
                        Open Repository <i class="fas fa-arrow-up-right-from-square ms-1"></i>
                    </a>
                </article>
            }
        </div>
    </section>
</div>
