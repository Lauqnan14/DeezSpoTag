@{
    ViewData["Title"] = "Library Albums";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/library.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/library-artist-hero.css" asp-append-version="true" />

<div class="library-page artist-page artist-neo" data-artist-id="@ViewData["ArtistId"]">
    <div class="library-breadcrumbs">
        <a href="/Library">Library</a>
        <span>/</span>
        <span>Artist</span>
    </div>
    <header class="hero-modern">
        <div class="hero-modern__top">
            <div class="hero-modern__avatar" id="artistAvatar">
                <div class="avatar-placeholder">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.4">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                </div>
            </div>
            <div class="hero-modern__info">
                <div class="hero-modern__header">
                    <div class="hero-modern__title-row">
                        <span class="hero-modern__verified" id="artistVerifiedBadge" style="display:none;">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="#3b82f6"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                        </span>
                        <h1 class="hero-modern__name" id="artistName">Artist</h1>
                    </div>
                    <div class="hero-modern__actions">
                        <button id="artistActionsToggle" class="hero-modern__menu-btn" type="button" aria-label="Artist actions" aria-expanded="false" aria-haspopup="menu" aria-controls="artistActionsDropdown">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                        </button>
                        <div class="actions-dropdown" id="artistActionsDropdown" aria-label="Artist actions menu">
                            <button id="watchlistToggle" class="dropdown-item" type="button" data-watchlist-toggle>
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                                <span>Monitor Artist</span>
                            </button>
                            <button id="spotifyIdEdit" class="dropdown-item" type="button" aria-label="Edit Spotify ID">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                <span>Edit Spotify ID</span>
                            </button>
                            <button id="appleIdEdit" class="dropdown-item" type="button" aria-label="Edit Apple Music ID">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                <span>Edit Apple Music ID</span>
                            </button>
                            <div class="dropdown-divider"></div>
                            <button id="spotify-cache-refresh-button" class="dropdown-item" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                                <span>Update Cache</span>
                            </button>
                            <button id="spotify-match-reset-button" class="dropdown-item" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 3-6.708"/><path d="M3 3v6h6"/></svg>
                                <span>Reset Match</span>
                            </button>
                            <div class="dropdown-status" id="spotify-cache-status">Spotify refresh: idle</div>
                            <div class="dropdown-cache-controls" id="spotify-cache-panel">
                                <div class="sync-checkboxes">
                                    <label class="sync-checkbox-label">
                                        <input type="checkbox" id="sync-include-avatar" checked />
                                        <span>Avatar</span>
                                    </label>
                                    <label class="sync-checkbox-label">
                                        <input type="checkbox" id="sync-include-background" checked />
                                        <span>Background Art</span>
                                    </label>
                                    <label class="sync-checkbox-label">
                                        <input type="checkbox" id="sync-include-bio" />
                                        <span>Background Info</span>
                                    </label>
                                </div>
                                <select id="spotify-cache-push-target" class="form-select">
                                    <option value="plex">Plex</option>
                                    <option value="jellyfin">Jellyfin</option>
                                    <option value="both">Both</option>
                                </select>
                                <button id="spotify-cache-push-button" class="btn btn-secondary action-btn" type="button">Push to Server</button>
                            </div>
                            <div class="dropdown-divider"></div>
                            <div class="dropdown-section">
                                <div class="dropdown-section__title">Visuals</div>
                                <div class="dropdown-visuals-actions">
                                    <button class="btn btn-secondary action-btn action-btn-sm" id="artist-visuals-reset" type="button">Reset to auto</button>
                                </div>
                                <div class="dropdown-visuals-grid" id="artist-visuals-grid"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="hero-modern__genres" id="artistGenres"></div>
                <div class="hero-modern__stats">
                    <div class="stat-item">
                        <span class="stat-value" id="artistMonthlyListeners">—</span>
                        <span class="stat-label">monthly listeners</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <span class="stat-value" id="artistFollowers">—</span>
                        <span class="stat-label">followers</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <span class="stat-value" id="artistRank">—</span>
                        <span class="stat-label">world rank</span>
                    </div>
                </div>
                <div class="hero-modern__meta">
                    <span class="meta-pill" id="artistPopularityPill">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        <span id="artistPopularity">—</span>
                    </span>
                    <span class="meta-pill" id="artistDiscographyPill">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="3"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/></svg>
                        <span id="artistTotalAlbums">—</span> releases
                    </span>
                    <a class="meta-pill meta-pill--link" id="artistSpotifyId" href="#" target="_blank" rel="noopener noreferrer">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                        <span>Open in Spotify</span>
                    </a>
                </div>
            </div>
        </div>
        <div class="hero-modern__bio" id="spotifyBioPanel">
            <p class="bio-text" id="artistBiography">Biography unavailable.</p>
            <button type="button"
                    class="bio-toggle"
                    id="artistBiographyToggle"
                    aria-controls="artistBiography"
                    aria-expanded="false"
                    hidden>
                See more
            </button>
        </div>
    </header>

    <main class="content">
        <section class="apple-layout">
            <div class="apple-section apple-section--hero-row">
                <div class="panel glass apple-pinned" id="spotifyReleasesPanel">
                    <div class="panel__head">
                        <h2>Latest Release</h2>
                    </div>
                    <div class="latest-release" id="latestReleaseCard"></div>
                </div>
                <div class="panel glass top-tracks-panel" id="spotifyTopTracksPanel">
                    <div class="panel__head">
                        <h2><a id="topSongsTracklistLink" class="top-songs-tracklist-link is-disabled" href="#" aria-disabled="true">Top Songs</a></h2>
                    </div>
                    <div class="neo-track-list" id="spotifyTopTracksList"></div>
                </div>
            </div>

            <div class="apple-section">
                <div class="panel glass" id="discographyPanel">
                    <div class="panel__head discography-head" id="discographyFilters">
                        <div class="discography-head__left">
                            <h2>Discography</h2>
                            <div class="discography-filters discography-filters--type">
                                <button class="filter-chip active" data-filter-group="type" data-filter="popular" type="button">Popular releases</button>
                                <button class="filter-chip" data-filter-group="type" data-filter="albums" type="button">Albums</button>
                                <button class="filter-chip" data-filter-group="type" data-filter="singles-eps" type="button">Singles and EPs</button>
                            </div>
                        </div>
                        <div class="discography-head__right">
                            <h2>Library</h2>
                            <div class="discography-filters discography-filters--availability">
                                <button class="filter-chip active" data-filter-group="availability" data-filter="all" type="button">All</button>
                                <button class="filter-chip" data-filter-group="availability" data-filter="in-library" type="button">In Library</button>
                                <button class="filter-chip" data-filter-group="availability" data-filter="missing" type="button">Missing</button>
                            </div>
                        </div>
                    </div>
                    <div class="album-grid neo-grid strip wrap-grid artist-grid-7" id="discographyGrid"></div>
                </div>
            </div>

            <div class="apple-section" data-lazy-apple="true">
                <div class="panel glass" id="appleAtmosPanel">
                    <div class="panel__head">
                        <h2>Apple Music Atmos</h2>
                    </div>
                    <div id="appleAtmosGrid" class="apple-grid wrap-grid artist-grid-7">
                        <div class="apple-lazy-placeholder">
                            <div class="loading-spinner"></div>
                            <p>Scroll to load Apple Music content</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="apple-section">
                <div class="panel glass" id="spotifyAppearsPanel">
                    <div class="panel__head">
                        <h2>Appears On</h2>
                    </div>
                    <div class="album-grid neo-grid strip strip--avatars wrap-grid artist-grid-7"></div>
                </div>
            </div>

            <div class="apple-section">
                <div class="panel glass related-panel">
                    <div class="panel__head">
                        <h2>Similar Artists</h2>
                    </div>
                    <div id="relatedArtists" class="related-artists-shelf wrap-grid">
                        <div class="empty-card">Related artists not available yet.</div>
                    </div>
                </div>
            </div>

            <div class="apple-section" data-lazy-apple="true">
                <div class="panel glass" id="appleVideosPanel">
                    <div class="panel__head">
                        <h2>Apple Music Videos</h2>
                    </div>
                    <div class="video-selection-bar" id="artist-video-selection-bar">
                        <div class="selection-left">
                            <span id="artist-selection-count">0 selected</span>
                        </div>
                        <div class="selection-actions">
                            <button class="action-btn action-btn-sm" id="artist-view-selected" type="button">View selected only</button>
                            <button class="action-btn action-btn-sm btn-secondary" id="artist-clear-selected" type="button">Clear</button>
                        </div>
                    </div>
                    <div id="appleVideosGrid" class="apple-grid video-grid wrap-grid artist-video-style"></div>
                    <div id="appleVideosLoading" class="apple-loading" style="display:none;">
                        <div class="loading-spinner"></div>
                        <p>Loading more videos...</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

</div>

<script src="~/js/library-artist-hero.js" asp-append-version="true"></script>
<script src="~/js/library.js" asp-append-version="true"></script>
