@{
    ViewData["Title"] = "Library";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/library.css" asp-append-version="true" />

<div class="library-page library-index">
    <nav id="libraryLetterNav" class="alpha-jump-nav" aria-label="Artist letter navigation" hidden></nav>
    <header class="index-hero">
        <div class="index-hero__info">
            <h1 class="index-hero__title">Your Library</h1>
            <div class="index-hero__stats">
                <span class="index-stat" id="libraryArtistCount">—</span>
                <span class="index-stat-label">artists</span>
                <span class="index-stat-divider"></span>
                <span class="index-stat" id="libraryAlbumCount">—</span>
                <span class="index-stat-label">albums</span>
                <span class="index-stat-divider"></span>
                <span class="index-stat" id="libraryTrackCount">—</span>
                <span class="index-stat-label">tracks</span>
            </div>
            <div class="index-hero__scan-status">
                <span class="index-scan-indicator" id="libraryScanIndicator"></span>
                <span id="libraryLastScan">—</span>
            </div>
        </div>
        <div class="index-hero__actions">
            <button id="indexActionsToggle" class="hero-modern__menu-btn" type="button" aria-label="Library actions" aria-expanded="false">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
            </button>
            <div class="actions-dropdown" id="indexActionsDropdown">
                <button id="scanLibrary" class="dropdown-item" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="21 3 21 9 15 9"/></svg>
                    <span>Scan Library</span>
                </button>
                <button id="cancelLibraryScan" class="dropdown-item" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    <span>Cancel Scan</span>
                </button>
                <div class="dropdown-divider"></div>
                <button id="refreshLibrary" class="dropdown-item" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                    <span>Refresh Library</span>
                </button>
                <button id="refreshImages" class="dropdown-item" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <span>Refresh Images</span>
                </button>
                <div class="dropdown-divider"></div>
                <button id="cleanupLibrary" class="dropdown-item" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                    <span>Cleanup Missing</span>
                </button>
                <button id="resolveUnmatchedArtists" class="dropdown-item" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 20c0-3.313 2.686-6 6-6s6 2.687 6 6"/><path d="M17 4h4v4"/><path d="M21 4l-4 4"/></svg>
                    <span>Resolve Unmatched Artists</span>
                </button>
                <button id="clearLibrary" class="dropdown-item dropdown-item--danger" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    <span>Clear Library</span>
                </button>
            </div>
        </div>
    </header>

    <main class="index-content">
        <section class="index-section">
            <div class="index-section__head">
                <h2>Artists</h2>
                <div class="index-browse-controls">
                    <div class="index-search-wrapper">
                        <svg class="index-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input id="librarySearchInput" type="search" placeholder="Search artists..." autocomplete="off" class="index-search-input" />
                    </div>
                    <select id="librarySortSelect" class="index-filter-select">
                        <option value="name-asc">A–Z</option>
                        <option value="name-desc">Z–A</option>
                    </select>
                    <select id="libraryViewSelect" class="index-filter-select"></select>
                </div>
            </div>
            <div class="library-view">
                <span id="libraryResultsMeta">Loading artists...</span>
            </div>
            <div id="artistsGrid" class="artist-grid"></div>
        </section>
    </main>
</div>

<div id="unmatchedArtistsModal" class="app-modal hidden">
    <div class="app-modal-backdrop" data-close-unmatched-modal></div>
    <div class="app-modal-dialog unmatched-artists-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="unmatchedArtistsTitle">
        <div class="app-modal-header">
            <h3 id="unmatchedArtistsTitle" class="app-modal-title">Resolve Unmatched Spotify Artists</h3>
            <button type="button" class="app-modal-close" id="closeUnmatchedArtistsModal" aria-label="Close">×</button>
        </div>
        <div class="app-modal-body">
            <div class="unmatched-artists-modal__toolbar">
                <input id="unmatchedArtistsSearch" class="app-modal-input" type="search" placeholder="Filter artists..." autocomplete="off" />
                <button id="refreshUnmatchedArtists" type="button" class="btn-secondary action-btn action-btn-sm">Refresh</button>
                <button id="applyHighConfidenceUnmatchedArtists" type="button" class="btn-primary action-btn action-btn-sm">Apply High-Confidence</button>
            </div>
            <div id="unmatchedArtistsStatus" class="unmatched-artists-modal__status">Loading unmatched artists...</div>
            <div id="unmatchedArtistsList" class="unmatched-artists-modal__list"></div>
        </div>
    </div>
</div>

<script src="~/js/library-interactions.js" asp-append-version="true"></script>
<script src="~/js/library.js" asp-append-version="true"></script>
<script src="~/js/library-soundtracks.js" asp-append-version="true"></script>
<script src="~/js/library-watchlists.js" asp-append-version="true"></script>
<script src="~/js/library-apple-extras.js" asp-append-version="true"></script>
<script src="~/js/library-bootstrap.js" asp-append-version="true"></script>
