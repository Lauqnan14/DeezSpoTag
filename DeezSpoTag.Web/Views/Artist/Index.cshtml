@{
    ViewData["Title"] = "Artist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<link rel="stylesheet" href="~/css/loading-state-shared.css" asp-append-version="true" />
<style>
.deezer-artist-page {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 24px;
    width: 100%;
    max-width: none;
    margin: 0;
}

.artist-hero {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: var(--bg-secondary);
    min-height: 260px;
}

.artist-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(120deg, rgba(8, 12, 20, 0.88), rgba(8, 12, 20, 0.35)),
        var(--hero-image, none);
    background-size: cover;
    background-position: center;
    z-index: 0;
}

.artist-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 24px;
    align-items: center;
    padding: 28px;
}

.artist-hero__avatar {
    width: var(--art-avatar-size);
    height: var(--art-avatar-size);
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border: 3px solid rgba(255, 255, 255, 0.2);
    background: var(--bg-tertiary);
}

.artist-hero__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.artist-hero__meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
    color: var(--text-primary);
    min-width: 0;
    width: 100%;
}

.artist-hero__kicker {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-secondary);
}

.artist-hero__title {
    font-size: 44px;
    font-weight: 700;
    margin: 0;
}

.artist-hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    align-items: center;
    color: var(--text-secondary);
    font-size: 14px;
}

.artist-hero__genres {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.artist-hero__genre {
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 12px;
    color: var(--text-secondary);
}

.artist-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
}

.artist-hero__actions .download-destination-select {
    min-width: 220px;
}

.artist-hero__actions .action-btn--wide,
.artist-hero__actions .download-destination-select {
    width: 220px;
}

.section-card {
    background: var(--bg-tertiary);
    border-radius: 16px;
    padding: 20px 22px;
    border: 1px solid var(--border-secondary);
    min-width: 0;
}

.section-title {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 16px 0;
    color: var(--text-primary);
}

.top-tracks-panel .neo-track-list {
    display: flex;
    flex-direction: column;
}

.top-songs-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 18px;
    overflow: hidden;
}

.top-song-item {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    min-height: 62px;
    border-top: 1px solid color-mix(in srgb, var(--primary-color) 18%, transparent);
    padding: 7px 0;
    position: relative;
    transition: background 0.15s ease;
}

.top-song-item[data-spotify-url] {
    cursor: pointer;
}

.top-song-item[data-spotify-url]:hover .top-song-item__title {
    color: var(--text-primary);
}

.top-song-item__thumb {
    width: 42px;
    height: 42px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    position: relative;
    display: block;
    text-decoration: none;
}

.top-song-item__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.top-song-item.is-playing .top-song-item__thumb,
.top-song-item.is-playing .top-song-item__thumb img {
    border-radius: 50%;
}

.top-song-item.is-playing .top-song-item__thumb img {
    animation: track-art-spin 4.0s linear infinite;
}

.top-song-item__play {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 6px;
    display: grid;
    place-items: center;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease, visibility 0.15s ease, color 0.15s ease, background 0.15s ease;
    z-index: 1;
}

.top-song-item__play .playback-glyph {
    width: 21px;
    height: 21px;
    display: inline-grid;
    place-items: center;
}

.top-song-item__play .playback-icon {
    width: 100%;
    height: 100%;
    display: block;
    fill: currentColor;
}

.top-song-item__play .playback-icon--pause {
    display: none;
}

.top-song-item__play.is-playing .playback-icon--play {
    display: none;
}

.top-song-item__play.is-playing .playback-icon--pause {
    display: block;
}

.top-song-item:hover .top-song-item__play,
.top-song-item:focus-within .top-song-item__play {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
}

.top-song-item__play:hover,
.top-song-item__play:focus-visible {
    background: transparent;
    color: var(--primary-color);
}

.top-song-item__play.is-starting {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    color: var(--primary-color);
    background: color-mix(in srgb, var(--primary-color) 10%, transparent);
    animation: playback-request-pulse 0.9s ease-in-out infinite;
}

.top-song-item__placeholder {
    width: 100%;
    height: 100%;
    background: color-mix(in srgb, var(--text-secondary) 22%, transparent);
}

.top-song-item__info {
    min-width: 0;
}

.top-song-item__title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
}

.top-song-item__title {
    font-size: 16px;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none;
    display: block;
}

.top-song-item__explicit {
    width: 20px;
    height: 20px;
    border: 1px solid var(--border-primary);
    border-radius: 999px;
    background: color-mix(in srgb, var(--panel-strong) 78%, transparent);
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 800;
    line-height: 1;
    flex: 0 0 auto;
}

.top-song-item__album {
    margin-top: 4px;
    font-size: 13px;
    line-height: 1.25;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.top-song-item__more {
    width: 26px;
    height: 26px;
    border: 1px solid var(--border-primary);
    border-radius: 999px;
    background: transparent;
    color: var(--text-secondary);
    display: inline-grid;
    place-items: center;
    text-decoration: none;
    cursor: pointer;
    opacity: 0.95;
}

.top-song-item__more:hover,
.top-song-item__more:focus-visible {
    background: color-mix(in srgb, var(--primary-color) 14%, transparent);
    border-color: var(--primary-color);
    color: var(--text-primary);
    opacity: 1;
}

@@keyframes track-art-spin {
    from {
        transform: rotate(0deg);
    }
    to {
        transform: rotate(360deg);
    }
}

.top-songs-tracklist-link {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
}

.top-songs-tracklist-link.is-disabled {
    opacity: 0.8;
    cursor: default;
    pointer-events: none;
}

.artist-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 18px;
}

.artist-tab {
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid var(--border-secondary);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.artist-tab.active {
    background: var(--primary-color);
    color: #fff;
    border-color: transparent;
}

.discography-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--art-grid-min), 1fr));
    gap: 16px;
}

.discography-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
}

.discography-card img {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    object-fit: cover;
    background: var(--bg-quaternary);
}

.discography-cover-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    border: 1px solid var(--border-primary);
    background: color-mix(in srgb, var(--bg-quaternary) 84%, #000 16%);
    color: var(--text-secondary);
    display: grid;
    place-items: center;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.discography-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
    word-break: break-word;
}

.discography-meta {
    font-size: 12px;
    color: var(--text-secondary);
}

.empty-state {
    color: var(--text-muted);
    font-size: 14px;
    padding: 10px 0;
}

.similar-grid,
.playlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--art-grid-min), 1fr));
    gap: 16px;
}

.similar-card,
.playlist-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: inherit;
}

.similar-card img,
.playlist-card img {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    object-fit: cover;
    background: var(--bg-quaternary);
}

.similar-name,
.playlist-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
    word-break: break-word;
}

@@media (max-width: 900px) {
    .deezer-artist-page {
        padding: 16px;
        gap: 20px;
    }

    .section-card {
        padding: 16px;
        border-radius: 14px;
    }

    .artist-hero__content {
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 20px 18px;
        gap: 16px;
    }

    .artist-hero__title {
        font-size: 34px;
    }

    .artist-hero__avatar {
        width: var(--art-avatar-size);
        height: var(--art-avatar-size);
    }

    .artist-hero__stats,
    .artist-hero__genres {
        justify-content: center;
    }

    .artist-hero__actions {
        width: 100%;
        justify-content: center;
    }

    .artist-hero__actions .action-btn--wide,
    .artist-hero__actions .download-destination-select {
        width: min(100%, 320px);
    }
}

@@media (max-width: 1260px) {
    .top-songs-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        column-gap: 16px;
    }
}

@@media (max-width: 940px) {
    .top-songs-grid {
        grid-template-columns: 1fr;
    }

    .top-song-item__title,
    .top-song-item__album {
        font-size: 15px;
    }

    .artist-tabs {
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        gap: 8px;
        padding-bottom: 2px;
    }

    .artist-tab {
        flex: 0 0 auto;
    }

    .discography-grid,
    .similar-grid,
    .playlist-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }
}

@@media (max-width: 640px) {
    .deezer-artist-page {
        padding: 12px;
        gap: 16px;
    }

    .artist-hero {
        border-radius: 16px;
        min-height: 0;
    }

    .artist-hero__content {
        padding: 16px 14px;
        gap: 12px;
    }

    .artist-hero__avatar {
        width: 112px;
        height: 112px;
    }

    .artist-hero__title {
        font-size: 28px;
    }

    .artist-hero__kicker {
        font-size: 11px;
        letter-spacing: 1.6px;
    }

    .artist-hero__stats {
        font-size: 13px;
    }

    .artist-hero__genre {
        font-size: 11px;
    }

    .artist-hero__actions {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
    }

    .artist-hero__actions .download-destination-select {
        width: 100%;
    }

    .artist-hero__actions .action-btn--wide {
        width: 100%;
    }

    .artist-hero__actions .action-btn {
        width: 100%;
    }

    .top-songs-grid {
        grid-template-columns: 1fr;
    }

    .top-song-item {
        grid-template-columns: 42px minmax(0, 1fr) auto;
        gap: 10px;
        min-height: 62px;
    }

    .top-song-item__thumb {
        width: 42px;
        height: 42px;
    }

    .top-song-item__more {
        width: 26px;
        height: 26px;
    }

    .section-title {
        font-size: 18px;
        margin-bottom: 12px;
    }

    .discography-grid,
    .similar-grid,
    .playlist-grid {
        gap: 10px;
    }
}

@@media (max-width: 420px) {
    .artist-hero__title {
        font-size: 24px;
    }

    .artist-tab {
        font-size: 12px;
        padding: 7px 12px;
    }

    .top-song-item__title {
        font-size: 14px;
    }

    .top-song-item__album {
        font-size: 12px;
    }
}
</style>
}

<div id="artist-content" class="deezer-artist-page">
    <div class="loading-section">
        <div class="loading-spinner"></div>
        <p>Loading artist...</p>
    </div>
</div>

@section Scripts {
<script>
let currentArtistId = '@ViewData["ArtistId"]' || new URLSearchParams(window.location.search).get('id') || '';
let currentArtistSource = '@ViewData["Source"]' || new URLSearchParams(window.location.search).get('source') || 'deezer';
let artistData = null;
let formattedArtistData = null;
let currentDiscographyTab = '';
const artistPageCacheTtlMs = 2 * 60 * 60 * 1000;
const artistPreviewState = {
    trackKey: null,
    button: null,
    sourceKey: null
};
const artistSpotifyResolveCache = new Map();
const artistSpotifyResolveInFlight = new Map();
const artistDeezerPlaybackContextCache = new Map();
const artistDeezerPlaybackContextRequests = new Map();
const artistPlaybackState = window.DeezerPlaybackState;
let artistTopTracksHandlersBound = false;
let artistTopTrackPreviewWarmupTimer = 0;
const artistTopTrackQueueState = {
    queueButtons: [],
    queueIndex: -1
};

document.addEventListener('DOMContentLoaded', function() {
    if (currentArtistId) {
        loadArtist(currentArtistId);
    }
});

async function loadArtist(artistId) {
    try {
        const perfStart = performance.now();
        const cached = loadArtistPayloadFromCache(artistId, currentArtistSource);

        document.getElementById('artist-content').innerHTML = `
            <div class="loading-section">
                <div class="loading-spinner"></div>
                <p>Loading artist...</p>
            </div>
        `;
        if (cached) {
            artistData = cached;
            formattedArtistData = formatArtistData(artistData);
            displayArtist(formattedArtistData);
        }

        let response = await fetch(`/api/artist-page?id=${artistId}&source=${currentArtistSource}`);
        if (!response.ok) {
            throw new Error(`Failed to load artist: ${response.status}`);
        }
        artistData = await response.json();
        if (currentArtistSource === 'deezer' && !hasArtistExtras(artistData)) {
            response = await fetch(`/api/artist-page?id=${artistId}&source=${currentArtistSource}&refresh=1`);
            if (response.ok) {
                artistData = await response.json();
            }
        }

        artistData = mergeArtistPayload(artistData, cached);
        saveArtistPayloadToCache(artistId, currentArtistSource, artistData);
        console.log(`[artist] fetch+parse ms=${(performance.now() - perfStart).toFixed(1)}`);

        formattedArtistData = formatArtistData(artistData);
        displayArtist(formattedArtistData);
        console.log(`[artist] render ms=${(performance.now() - perfStart).toFixed(1)}`);
    } catch (error) {
        console.error('Error loading artist:', error);
        document.getElementById('artist-content').innerHTML = `
            <div class="error-section">
                <h3>Failed to Load Artist</h3>
                <p>${error.message}</p>
                <button onclick="loadArtist('${artistId}')" class="btn btn-secondary action-btn">Try Again</button>
            </div>
        `;
    }
}

function hasArtistExtras(data) {
    if (!Array.isArray(data?.playlists) || !Array.isArray(data?.related)) {
        return false;
    }

    const releases = data?.releases;
    if (!releases || typeof releases !== 'object') {
        return false;
    }

    return Object.values(releases).some(value => Array.isArray(value) && value.length > 0);
}

function formatArtistData(data) {
    const releases = {};
    const releaseDateByAlbumId = new Map();
    const releaseDateByAlbumTitle = new Map();

    if (data.releases) {
        Object.keys(data.releases).forEach(tabKey => {
            const normalizedKey = normalizeReleaseTabKey(tabKey);
            if (!normalizedKey) {
                return;
            }
            if (data.releases[tabKey] && Array.isArray(data.releases[tabKey])) {
                const formattedReleases = data.releases[tabKey].map(release => ({
                    releaseID: release.id,
                    releaseCover: resolveReleaseCover(release),
                    releaseTitle: release.title || '',
                    releaseDate: release.release_date || '',
                    releaseTracksNumber: release.nb_tracks || 0,
                    releaseLink: release.link || '',
                    releaseType: release.record_type || 'album',
                    isReleaseExplicit: release.explicit_lyrics || false,
                    releaseSource: release.source || 'deezer'
                }));

                formattedReleases.forEach((release) => {
                    const releaseDate = release.releaseDate || '';
                    if (releaseDate) {
                        if (release.releaseID) {
                            releaseDateByAlbumId.set(String(release.releaseID), releaseDate);
                        }
                        const titleKey = String(release.releaseTitle || '').trim().toLowerCase();
                        if (titleKey) {
                            releaseDateByAlbumTitle.set(titleKey, releaseDate);
                        }
                    }
                });

                if (!releases[normalizedKey]) {
                    releases[normalizedKey] = [];
                }
                releases[normalizedKey] = releases[normalizedKey].concat(formattedReleases);
            }
        });
    }

    const topTracks = (Array.isArray(data.top_tracks) ? data.top_tracks : []).map((track) => {
        const enrichedTrack = { ...track };
        let releaseDate = getTrackReleaseDate(track);

        if (!releaseDate) {
            const albumId = track?.album?.id ? String(track.album.id) : '';
            if (albumId && releaseDateByAlbumId.has(albumId)) {
                releaseDate = releaseDateByAlbumId.get(albumId) || '';
            }
        }

        if (!releaseDate) {
            const albumTitleKey = String(track?.album?.title || '').trim().toLowerCase();
            if (albumTitleKey && releaseDateByAlbumTitle.has(albumTitleKey)) {
                releaseDate = releaseDateByAlbumTitle.get(albumTitleKey) || '';
            }
        }

        if (releaseDate) {
            enrichedTrack.release_date = releaseDate;
            if (track?.album && typeof track.album === 'object') {
                enrichedTrack.album = {
                    ...track.album,
                    release_date: track.album.release_date || releaseDate
                };
            }
        }

        return enrichedTrack;
    });

    return {
        artistSource: data.source || currentArtistSource || 'deezer',
        artistName: data.name || 'Unknown Artist',
        artistPicture: data.spotify_hero || data.picture_xl || data.picture_big || data.picture_medium || '',
        artistAvatar: data.picture_medium || data.picture_small || data.picture || data.picture_xl || '',
        artistGenres: mergeGenres(data.genres, data.local_genres),
        artistFans: data.nb_fan || 0,
        artistReleases: releases,
        artistTopTracks: topTracks,
        artistRelated: Array.isArray(data.related) ? data.related : [],
        downloadLink: data.download_link || (data.id ? `https://www.deezer.com/artist/${data.id}` : '')
    };
}

function normalizeReleaseTabKey(key) {
    if (!key) return '';
    const lowered = String(key).toLowerCase().trim();
    if (lowered === 'albums' || lowered === 'album') return 'album';
    if (lowered === 'singles' || lowered === 'single') return 'single';
    if (lowered === 'singles_eps' || lowered === 'singles and eps' || lowered === 'singles & eps') return 'singles_eps';
    if (lowered === 'compilations' || lowered === 'compile') return 'compile';
    if (lowered === 'compilation') return 'compile';
    if (lowered === 'popular releases' || lowered === 'popular_releases' || lowered === 'popular') return 'popular';
    if (lowered === 'ep') return 'ep';
    return lowered;
}

function orderDiscographyTabs(tabs) {
    const order = ['popular', 'album', 'single', 'ep', 'singles_eps', 'compile', 'bundle', 'featured', 'more', 'all'];
    const scored = tabs.map(tab => {
        const idx = order.indexOf(tab);
        return {
            tab,
            idx: idx === -1 ? Number.MAX_SAFE_INTEGER : idx
        };
    });
    scored.sort((a, b) => a.idx - b.idx || a.tab.localeCompare(b.tab));
    return scored.map(item => item.tab);
}

function displayArtist(data) {
    const container = document.getElementById('artist-content');
    const availableTabs = orderDiscographyTabs(Object.keys(data.artistReleases));
    const tabsWithData = orderDiscographyTabs(availableTabs.filter(tab => (data.artistReleases[tab] || []).length > 0));
    const cachedTab = loadArtistTabFromCache(currentArtistId, currentArtistSource);

    currentDiscographyTab = tabsWithData.includes(cachedTab)
        ? cachedTab
        : tabsWithData.includes('popular')
            ? 'popular'
            : tabsWithData.includes('album')
                ? 'album'
                : (tabsWithData[0] || availableTabs[0] || 'album');

    const heroStyle = data.artistPicture ? `--hero-image: url('${data.artistPicture}')` : '';
    const genreChips = data.artistGenres.length
        ? data.artistGenres.map(genre => `<span class="artist-hero__genre">${escapeHtml(genre)}</span>`).join('')
        : '';
    const fansText = data.artistFans ? `${formatNumber(data.artistFans)} fans` : 'Fans unavailable';

    const topTracksHtml = renderTopTracks(data.artistTopTracks);
    const discographyTabs = tabsWithData.length ? tabsWithData : availableTabs;

    const artistHtml = `
        <section class="artist-hero" style="${heroStyle}">
            <div class="artist-hero__content">
                <div class="artist-hero__avatar">
                    ${data.artistAvatar ? `<img src="${data.artistAvatar}" alt="${escapeHtml(data.artistName)}">` : ''}
                </div>
                <div class="artist-hero__meta">
                    <div class="artist-hero__kicker">Artist</div>
                    <h1 class="artist-hero__title">${escapeHtml(data.artistName)}</h1>
                    <div class="artist-hero__stats">
                        <span>${fansText}</span>
                    </div>
                    ${genreChips ? `<div class="artist-hero__genres">${genreChips}</div>` : ''}
                    <div class="artist-hero__actions">
                        <button class="btn btn-secondary action-btn action-btn--wide" onclick="downloadArtist('${data.downloadLink}/discography')" ${!data.downloadLink ? 'style="display:none"' : ''}>Download Discography</button>
                        <button id="watchlistToggle" class="btn btn-primary action-btn" type="button">Monitor Artist</button>
                        <select id="downloadDestinationArtist" class="form-select download-destination-select"></select>
                    </div>
                </div>
            </div>
        </section>

        <section class="section-card top-tracks-panel">
            <h2 class="section-title">
                <a id="topSongsTracklistLink" class="top-songs-tracklist-link is-disabled" href="#" aria-disabled="true">Top Songs</a>
            </h2>
            <div class="neo-track-list" id="artistTopTracksList">
                ${topTracksHtml}
            </div>
        </section>

        <section class="section-card">
            <h2 class="section-title">Discography</h2>
            ${renderDiscographyTabs(discographyTabs)}
            <div id="discography-grid" class="discography-grid">
                ${renderDiscography(data.artistReleases[currentDiscographyTab] || [])}
            </div>
        </section>

        <section class="section-card">
            <h2 class="section-title">Similar artists</h2>
            ${renderRelatedArtists(data.artistRelated)}
        </section>
    `;

    container.innerHTML = artistHtml;

    restoreArtistPreviewState();
    updateTopSongsTracklistLink();
    bindArtistTopTracksHandlers();
    scheduleArtistTopTrackPreviewWarmup();
    initArtistWatchlistToggle(data);

    if (window.DeezSpoTagDownload?.ensureDestinationSelects) {
        window.DeezSpoTagDownload.ensureDestinationSelects();
    }

    document.title = `${data.artistName} - DeezSpoTag`;
}

async function primeArtistTopTrackPreviews(options = {}) {
    const list = document.getElementById('artistTopTracksList');
    if (!list) {
        return;
    }

    const limit = Number(options?.limit || 0);
    const visibleFirst = options?.visibleFirst !== false;
    const visibleFirstOnly = options?.visibleFirstOnly === true;
    const requestedConcurrency = Number(options?.concurrency || 4);
    const concurrency = Number.isFinite(requestedConcurrency)
        ? Math.max(1, Math.min(8, Math.trunc(requestedConcurrency)))
        : 4;
    const buttons = Array.from(list.querySelectorAll('button.track-play[data-spotify-url]'));
    if (!buttons.length) {
        return;
    }

    const queue = buttons
        .map((button) => ({
            button,
            url: normalizeArtistSpotifyTrackSourceUrl(String(button.dataset.spotifyUrl || '').trim()),
            isVisible: isArtistTopTrackButtonVisible(button)
        }))
        .filter((entry) => entry.url && !entry.button.dataset.deezerId);
    if (!queue.length) {
        return;
    }

    if (visibleFirst) {
        queue.sort((left, right) => Number(right.isVisible) - Number(left.isVisible));
    }

    let pending = queue;
    if (visibleFirstOnly) {
        pending = pending.filter((entry) => entry.isVisible);
    }
    if (limit > 0) {
        pending = pending.slice(0, limit);
    }
    if (!pending.length) {
        return;
    }

    let cursor = 0;
    const workers = Array.from({ length: Math.min(concurrency, pending.length) }, async () => {
        while (cursor < pending.length) {
            const current = pending[cursor++];
            try {
                current.button.dataset.mappingState = 'mapping';
                const resolved = await resolveSpotifyUrlToDeezer(
                    buildSpotifyTrackResolveRequestFromArtistButton(current.button)
                );
                if (resolved?.type !== 'track' || !resolved?.deezerId) {
                    current.button.dataset.mappingState = 'unmapped';
                    continue;
                }

                const deezerId = String(resolved.deezerId);
                current.button.dataset.deezerId = deezerId;
                current.button.dataset.mappingState = 'mapped';
                if (window.DeezerPlaybackContext && typeof window.DeezerPlaybackContext.fetchContext === 'function') {
                    const context = await window.DeezerPlaybackContext.fetchContext(deezerId, {
                        cache: artistDeezerPlaybackContextCache,
                        requests: artistDeezerPlaybackContextRequests
                    });
                    if (context && typeof window.DeezerPlaybackContext.applyContextToElement === 'function') {
                        window.DeezerPlaybackContext.applyContextToElement(current.button, context);
                        current.button.dataset.mappingState = 'context-ready';
                    }
                }
            } catch {
                current.button.dataset.mappingState = 'unmapped';
                // Best-effort warmup only.
            }
        }
    });

    await Promise.all(workers);
}

function scheduleArtistTopTrackPreviewWarmup() {
    if (artistTopTrackPreviewWarmupTimer) {
        clearTimeout(artistTopTrackPreviewWarmupTimer);
    }

    void primeArtistTopTrackPreviews({ visibleFirst: true, visibleFirstOnly: true, concurrency: 8, limit: 16 });
    artistTopTrackPreviewWarmupTimer = setTimeout(() => {
        artistTopTrackPreviewWarmupTimer = 0;
        void primeArtistTopTrackPreviews({ visibleFirst: true, concurrency: 6 });
    }, 120);
}

function renderTopTracks(tracks) {
    if (!tracks || tracks.length === 0) {
        return '<div class="empty-state">No top tracks available.</div>';
    }

    const rows = tracks.slice(0, 9).map((track) => {
        const source = (track.source || track.artist?.source || track.album?.source || currentArtistSource || 'deezer').toString().toLowerCase();
        const albumTitle = track.album?.title || '';
        const albumType = (track.album?.type || (source === 'spotify' ? 'track' : 'album')).toString().toLowerCase();
        const releaseYear = getTrackYear(track);
        const trackSubtitle = buildTrackSubtitle(track, albumTitle, albumType, releaseYear);
        const albumId = track.album?.id || track.id || '';
        const trackLink = track.link || '';
        const albumLink = albumId ? `/Tracklist?id=${encodeURIComponent(albumId)}&type=${encodeURIComponent(albumType)}&source=${encodeURIComponent(source)}` : trackLink;
        const coverUrl = resolveTrackCover(track);
        const safeTitle = escapeHtml(track.title || '');
        const coverMarkup = coverUrl
            ? `<img src="${coverUrl}" alt="${safeTitle}" loading="lazy" decoding="async">`
            : '<div class="top-song-item__placeholder"></div>';
        const trackActionLabel = safeTitle ? `Open ${safeTitle}` : 'Open track';
        const spotifyUrl = source === 'spotify'
            ? normalizeArtistSpotifyTrackSourceUrl(String(trackLink || ''))
            : '';
        const spotifyArtist = String(
            track.artist?.name
            || (Array.isArray(track.contributors) ? track.contributors.map((contributor) => contributor?.name).filter(Boolean).join(', ') : '')
            || ''
        ).trim();
        const trackIsrc = String(track.isrc || '').trim();
        const trackDurationMs = Number(track.duration || 0) > 0 ? Math.trunc(Number(track.duration) * 1000) : 0;
        const deezerId = source === 'deezer' ? String(track.id || track.deezer_id || '').trim() : '';
        const deezerPlaybackContext = deezerId
            ? normalizeArtistDeezerPlaybackContext({
                streamTrackId: track.stream_track_id || track.streamTrackId || '',
                trackToken: track.track_token || track.trackToken || '',
                md5origin: track.md5_origin || track.md5Origin || track.md5origin || '',
                mv: track.media_version || track.mediaVersion || track.mv || ''
            })
            : null;
        const previewUrl = deezerId && deezerPlaybackContext
            ? buildArtistDeezerStreamUrl(deezerId, deezerPlaybackContext)
            : String(track.preview || '');
        const safeSpotifyUrl = spotifyUrl ? escapeHtml(spotifyUrl) : '';
        const safePreviewUrl = previewUrl ? escapeHtml(previewUrl) : '';
        const explicitBadge = track.explicit_lyrics ? '<span class="top-song-item__explicit" aria-label="Explicit">E</span>' : '';
        const dataAttrs = [];
        if (safeSpotifyUrl) {
            dataAttrs.push(`data-spotify-url="${safeSpotifyUrl}"`);
            if (safeTitle) {
                dataAttrs.push(`data-spotify-title="${safeTitle}"`);
            }
        }
        const playAttrs = [];
        if (safeSpotifyUrl) {
            playAttrs.push(`data-spotify-url="${safeSpotifyUrl}"`);
            if (safeTitle) {
                playAttrs.push(`data-track-title="${safeTitle}"`);
            }
            if (spotifyArtist) {
                playAttrs.push(`data-track-artist="${escapeHtml(spotifyArtist)}"`);
            }
            if (albumTitle) {
                playAttrs.push(`data-track-album="${escapeHtml(albumTitle)}"`);
            }
            if (trackIsrc) {
                playAttrs.push(`data-track-isrc="${escapeHtml(trackIsrc)}"`);
            }
            if (trackDurationMs > 0) {
                playAttrs.push(`data-track-duration-ms="${trackDurationMs}"`);
            }
        }
        if (deezerId) {
            playAttrs.push(`data-deezer-id="${deezerId}"`);
            if (deezerPlaybackContext) {
                playAttrs.push(
                    `data-stream-track-id="${escapeHtml(deezerPlaybackContext.streamTrackId)}"`,
                    `data-track-token="${escapeHtml(deezerPlaybackContext.trackToken)}"`
                );
                if (deezerPlaybackContext.md5origin) {
                    playAttrs.push(`data-md5-origin="${escapeHtml(deezerPlaybackContext.md5origin)}"`);
                }
                if (deezerPlaybackContext.mv) {
                    playAttrs.push(`data-media-version="${escapeHtml(deezerPlaybackContext.mv)}"`);
                }
            }
        }
        if (safePreviewUrl) {
            playAttrs.push(`data-preview-url="${safePreviewUrl}"`);
        }
        const sourceKey = String(spotifyUrl || previewUrl || deezerId || track.id || '');
        if (sourceKey) {
            playAttrs.push(`data-source-key="${escapeHtml(sourceKey)}"`);
        }
        const thumbOpen = spotifyUrl
            ? '<div class="top-song-item__thumb">'
            : `<a class="top-song-item__thumb" href="${albumLink}" aria-label="${trackActionLabel}">`;
        const thumbClose = spotifyUrl ? '</div>' : '</a>';
        const titleMarkup = spotifyUrl
            ? `<div class="top-song-item__title-row"><div class="top-song-item__title">${safeTitle}</div>${explicitBadge}</div>`
            : `<div class="top-song-item__title-row"><a class="top-song-item__title" href="${albumLink}">${safeTitle}</a>${explicitBadge}</div>`;

        return `
            <div class="top-song-item" ${dataAttrs.join(' ')}>
                ${thumbOpen}
                    ${coverMarkup}
                    <button class="top-song-item__play track-action track-play" type="button" ${playAttrs.join(' ')} aria-label="Play ${safeTitle || 'track'} preview">
                        <span class="playback-glyph" aria-hidden="true">
                            <svg class="playback-icon playback-icon--play" viewBox="0 0 24 24" focusable="false">
                                <path d="M8 5v14l11-7z"></path>
                            </svg>
                            <svg class="playback-icon playback-icon--pause" viewBox="0 0 24 24" focusable="false">
                                <path d="M7 5h4v14H7zM13 5h4v14h-4z"></path>
                            </svg>
                        </span>
                    </button>
                ${thumbClose}
                <div class="top-song-item__info">
                    ${titleMarkup}
                    ${trackSubtitle ? `<div class="top-song-item__album">${escapeHtml(trackSubtitle)}</div>` : ''}
                </div>
            </div>
        `;
    }).join('');

    return `
        <div class="top-songs-grid">
            ${rows}
        </div>
    `;
}

function bindArtistTopTracksHandlers() {
    if (artistTopTracksHandlersBound) {
        return;
    }
    artistTopTracksHandlersBound = true;

    document.addEventListener('click', (event) => {
        const list = document.getElementById('artistTopTracksList');
        if (!list) {
            return;
        }

        const playButton = event.target.closest('.top-song-item__play');
        if (playButton && list.contains(playButton)) {
            event.preventDefault();
            event.stopPropagation();
            event.stopImmediatePropagation();
            playArtistTrackInApp(playButton);
            return;
        }

        const spotifyTarget = event.target.closest('[data-spotify-url]');
        if (spotifyTarget && list.contains(spotifyTarget)) {
            const url = spotifyTarget.dataset.spotifyUrl;
            if (!url) {
                return;
            }
            event.preventDefault();
            event.stopPropagation();
            handleSpotifyRedirect(url);
        }
    });
}

function updateTopSongsTracklistLink() {
    const link = document.getElementById('topSongsTracklistLink');
    if (!link) {
        return;
    }
    if (!currentArtistId) {
        link.setAttribute('href', '#');
        link.setAttribute('aria-disabled', 'true');
        link.classList.add('is-disabled');
        return;
    }

    const qs = new URLSearchParams();
    qs.set('id', currentArtistId);
    qs.set('type', 'artist');
    qs.set('source', currentArtistSource || 'deezer');
    link.setAttribute('href', `/Tracklist?${qs.toString()}`);
    link.setAttribute('aria-disabled', 'false');
    link.classList.remove('is-disabled');
}

function setArtistPreviewButtonState(button, isPlaying) {
    if (!button) {
        return;
    }
    if (isPlaying) {
        const list = document.getElementById('artistTopTracksList');
        if (list) {
            list.querySelectorAll('.top-song-item__play').forEach((activeButton) => {
                if (activeButton === button) {
                    return;
                }
                activeButton.classList.remove('is-playing');
                activeButton.classList.remove('is-starting');
                delete activeButton.dataset.playbackState;
                const activeRow = activeButton.closest('.top-song-item');
                if (activeRow) {
                    activeRow.classList.remove('is-playing');
                }
            });
        }
    }
    button.classList.toggle('is-playing', isPlaying);
    const row = button.closest('.top-song-item');
    if (row) {
        row.classList.toggle('is-playing', isPlaying);
    }
}

function setArtistPlaybackState(button, state) {
    const normalizedState = String(state || '').toLowerCase();
    if (artistPlaybackState && typeof artistPlaybackState.transitionButtonState === 'function') {
        artistPlaybackState.transitionButtonState(button, state, {
            setPlaying: setArtistPreviewButtonState,
            onTransition: (targetButton, nextState) => {
                if (nextState === 'requested') {
                    setArtistPreviewButtonState(targetButton, true);
                }
            }
        });
        return;
    }

    const isPlaying = normalizedState === 'requested' || normalizedState === 'playing';
    setArtistPreviewButtonState(button, isPlaying);
}

function restoreArtistPreviewState() {
    const session = window.DeezerUnifiedPlayback && typeof window.DeezerUnifiedPlayback.getSession === 'function'
        ? window.DeezerUnifiedPlayback.getSession()
        : null;
    if (!session || session.paused || !artistPreviewState.sourceKey) {
        if (artistPreviewState.button) {
            setArtistPreviewButtonState(artistPreviewState.button, false);
        }
        artistPreviewState.button = null;
        return;
    }

    const list = document.getElementById('artistTopTracksList');
    if (!list) {
        return;
    }

    const selector = `.top-song-item__play[data-source-key="${CSS.escape(artistPreviewState.sourceKey)}"]`;
    const nextButton = list.querySelector(selector);
    if (!nextButton) {
        artistPreviewState.button = null;
        return;
    }

    artistPreviewState.button = nextButton;
    setArtistPreviewButtonState(nextButton, true);
}

function getArtistPlaybackFacade() {
    const facade = window.DeezerPlaybackFacade;
    if (!facade || typeof facade !== 'object') {
        return null;
    }
    if (typeof facade.resolveTrackBySpotifyUrl !== 'function'
        && typeof facade.resolveTrackBySpotifyRequest !== 'function') {
        return null;
    }
    if (typeof facade.resolvePlayableStreamUrl !== 'function') {
        return null;
    }
    if (typeof facade.resolvePlayablePreviewUrl !== 'function') {
        return null;
    }
    return facade;
}

function normalizeArtistDeezerPlaybackContext(payload) {
    if (!window.DeezerPlaybackContext || typeof window.DeezerPlaybackContext.normalize !== 'function') {
        return null;
    }
    return window.DeezerPlaybackContext.normalize(payload);
}

function buildArtistDeezerStreamUrl(deezerId, context) {
    if (!window.DeezerPlaybackContext || typeof window.DeezerPlaybackContext.buildStreamUrl !== 'function') {
        return '';
    }
    return window.DeezerPlaybackContext.buildStreamUrl(deezerId, { context: context });
}

function buildArtistPlaybackRequest(button, getNextTopTrackButton) {
    if (!button) {
        return null;
    }

    const deezerId = String(button.dataset.deezerId || '').trim();
    const spotifyUrl = normalizeArtistSpotifyTrackSourceUrl(String(button.dataset.spotifyUrl || '').trim());
    const previewUrl = String(button.dataset.previewUrl || '').trim();
    const spotifyMetadata = buildSpotifyTrackResolveRequestFromArtistButton(button);

    return {
        page: 'artist',
        button,
        deezerId,
        spotifyUrl,
        previewUrl,
        spotifyMetadata,
        sourceKey: button.dataset.sourceKey || previewUrl || deezerId || spotifyUrl || '',
        cache: artistDeezerPlaybackContextCache,
        requests: artistDeezerPlaybackContextRequests,
        unavailableMessage: previewUrl ? 'Preview unavailable.' : 'Track not available for streaming.',
        startFailedMessage: 'Unable to start playback.',
        interruptedMessage: 'Playback interrupted.',
        onStateChange: (state, context) => {
            setArtistPlaybackState(button, state);
            if (state === 'requested' || state === 'playing') {
                artistPreviewState.button = button;
                artistPreviewState.trackKey = context?.session?.key || null;
                artistPreviewState.sourceKey = button.dataset.sourceKey || previewUrl || deezerId || spotifyUrl || '';
                return;
            }
            if (artistPreviewState.button === button) {
                artistPreviewState.button = null;
            }
            if (artistPreviewState.trackKey === (context?.session?.key || artistPreviewState.trackKey)) {
                artistPreviewState.trackKey = null;
            }
            if (state === 'idle' || state === 'error' || state === 'ended') {
                artistPreviewState.sourceKey = null;
            }
        },
        getNextRequest: () => {
            const nextButton = getNextTopTrackButton(button);
            return nextButton ? buildArtistPlaybackRequest(nextButton, getNextTopTrackButton) : null;
        }
    };
}

function buildArtistTopTrackPlaybackQueue() {
    const list = document.getElementById('artistTopTracksList');
    if (!list) {
        return [];
    }
    return Array.from(list.querySelectorAll('.top-song-item__play.track-play'))
        .filter((button) => {
            if (!(button instanceof HTMLElement) || !button.isConnected) {
                return false;
            }
            const deezerId = String(button.dataset?.deezerId || '').trim();
            const spotifyUrl = String(button.dataset?.spotifyUrl || '').trim();
            const previewUrl = String(button.dataset?.previewUrl || '').trim();
            return Boolean(deezerId || spotifyUrl || previewUrl);
        });
}

function resetArtistTopTrackQueue() {
    artistTopTrackQueueState.queueButtons = [];
    artistTopTrackQueueState.queueIndex = -1;
}

function seedArtistTopTrackQueue(startButton) {
    const queue = buildArtistTopTrackPlaybackQueue();
    if (!queue.length) {
        resetArtistTopTrackQueue();
        return;
    }
    artistTopTrackQueueState.queueButtons = queue;
    const index = queue.indexOf(startButton);
    artistTopTrackQueueState.queueIndex = Math.max(index, 0);
}

function getNextArtistTopTrackQueueButton() {
    const queue = artistTopTrackQueueState.queueButtons;
    if (!Array.isArray(queue) || queue.length === 0) {
        return null;
    }

    for (let index = artistTopTrackQueueState.queueIndex + 1; index < queue.length; index++) {
        const candidate = queue[index];
        if (candidate?.isConnected) {
            artistTopTrackQueueState.queueIndex = index;
            return candidate;
        }
    }

    resetArtistTopTrackQueue();
    return null;
}

async function playArtistTrackInApp(button) {
    if (!button) {
        return;
    }
    if (typeof button.blur === 'function') {
        button.blur();
    }
    seedArtistTopTrackQueue(button);

    const player = window.DeezerUnifiedPlayback;
    if (!player || typeof player.play !== 'function') {
        return;
    }

    const getNextTopTrackButton = () => {
        const nextButton = getNextArtistTopTrackQueueButton();
        if (!nextButton) {
            resetArtistTopTrackQueue();
            return null;
        }
        return nextButton;
    };

    const request = buildArtistPlaybackRequest(button, getNextTopTrackButton);
    if (!request) {
        resetArtistTopTrackQueue();
        return;
    }

    await player.play(request);
}

async function resolveSpotifyUrlToDeezer(url) {
    const request = typeof url === 'string' ? { link: url } : url;
    const link = normalizeArtistSpotifyTrackSourceUrl(String(request?.link || '').trim());
    if (!link) {
        return null;
    }

    const metadataKey = JSON.stringify([
        link,
        String(request?.title || '').trim(),
        String(request?.artist || '').trim(),
        String(request?.album || '').trim(),
        String(request?.isrc || '').trim(),
        Number.isFinite(Number(request?.durationMs)) ? Number(request.durationMs) : 0
    ]);

    if (artistSpotifyResolveCache.has(metadataKey)) {
        return artistSpotifyResolveCache.get(metadataKey);
    }
    if (artistSpotifyResolveInFlight.has(metadataKey)) {
        return await artistSpotifyResolveInFlight.get(metadataKey);
    }

    const resolvePromise = (async () => {
        const facade = getArtistPlaybackFacade();
        if (facade && typeof facade.resolveTrackBySpotifyRequest === 'function') {
            try {
                const resolved = await facade.resolveTrackBySpotifyRequest({
                    link,
                    title: String(request?.title || '').trim(),
                    artist: String(request?.artist || '').trim(),
                    album: String(request?.album || '').trim(),
                    isrc: String(request?.isrc || '').trim(),
                    durationMs: Number.isFinite(Number(request?.durationMs)) ? Number(request.durationMs) : 0
                });
                if (resolved?.type === 'track' && resolved?.deezerId) {
                    artistSpotifyResolveCache.set(metadataKey, resolved);
                    return resolved;
                }
            } catch {
                // Fall through to API resolver.
            }
        }

        try {
            const resolved = await fetchJsonOptional(`/api/spotify/resolve-deezer?url=${encodeURIComponent(link)}`);
            const normalized = resolved?.type === 'track' && resolved?.deezerId ? resolved : null;
            artistSpotifyResolveCache.set(metadataKey, normalized);
            return normalized;
        } catch {
            artistSpotifyResolveCache.set(metadataKey, null);
            return null;
        }
    })();

    artistSpotifyResolveInFlight.set(metadataKey, resolvePromise);
    try {
        return await resolvePromise;
    } finally {
        artistSpotifyResolveInFlight.delete(metadataKey);
    }
}

function buildArtistSpotifyWebUrl(uri) {
    if (!uri) {
        return '';
    }
    const value = String(uri).trim();
    if (!value) {
        return '';
    }
    if (value.startsWith('http://') || value.startsWith('https://')) {
        return value;
    }
    if (value.startsWith('spotify:')) {
        const parts = value.split(':');
        if (parts.length >= 3 && parts[1] && parts[2]) {
            return `https://open.spotify.com/${parts[1]}/${parts[2]}`;
        }
    }
    return '';
}

function normalizeArtistSpotifyTrackSourceUrl(url, fallbackTrackId = '') {
    const initial = buildArtistSpotifyWebUrl(url);
    const fallbackId = String(fallbackTrackId || '').trim();
    if (!initial) {
        return fallbackId ? `https://open.spotify.com/track/${encodeURIComponent(fallbackId)}` : '';
    }

    const normalized = String(initial)
        .replace(/open\.spotify\.com\/intl-[^/]+\//i, 'open.spotify.com/')
        .trim();

    if (normalized) {
        return normalized;
    }

    return fallbackId ? `https://open.spotify.com/track/${encodeURIComponent(fallbackId)}` : '';
}

function isArtistTopTrackButtonVisible(button) {
    if (!(button instanceof HTMLElement)) {
        return false;
    }
    const rect = button.getBoundingClientRect();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
    return rect.bottom >= -120 && rect.top <= viewportHeight + 200;
}

function buildSpotifyTrackResolveRequestFromArtistButton(button) {
    if (!button?.dataset) {
        return null;
    }
    const link = normalizeArtistSpotifyTrackSourceUrl(String(button.dataset.spotifyUrl || '').trim());
    if (!link) {
        return null;
    }
    const durationRaw = Number.parseInt(String(button.dataset.trackDurationMs || '0'), 10);
    return {
        link,
        title: String(button.dataset.trackTitle || '').trim(),
        artist: String(button.dataset.trackArtist || '').trim(),
        album: String(button.dataset.trackAlbum || '').trim(),
        isrc: String(button.dataset.trackIsrc || '').trim(),
        durationMs: Number.isFinite(durationRaw) && durationRaw > 0 ? durationRaw : 0
    };
}

async function fetchJsonOptional(url) {
    const response = await fetch(url);
    if (response.status === 404) {
        return null;
    }
    if (!response.ok) {
        return null;
    }
    const raw = await response.text();
    const trimmed = raw.trim();
    if (!trimmed || trimmed === 'undefined') {
        return null;
    }
    try {
        return JSON.parse(raw);
    } catch {
        return null;
    }
}

function parseSpotifyUrl(url) {
    if (!url) {
        return null;
    }
    const trimmed = String(url).trim();
    if (trimmed.startsWith('spotify:')) {
        const uriParts = trimmed.split(':');
        if (uriParts.length >= 3 && uriParts[1] && uriParts[2]) {
            return { type: uriParts[1].toLowerCase(), id: uriParts[2] };
        }
    }

    const directMatch = /open\.spotify\.com\/(?:intl-[a-z]+\/)?(album|playlist|track|show|episode|artist|station)\/([a-z0-9]+)/i.exec(trimmed);
    if (directMatch) {
        return { type: directMatch[1].toLowerCase(), id: directMatch[2] };
    }

    try {
        const parsed = new URL(trimmed);
        const segments = parsed.pathname.split('/').filter(Boolean);
        const kindIndex = segments.findIndex(seg => /^(album|playlist|track|show|episode|artist|station)$/i.test(seg));
        if (kindIndex >= 0 && segments[kindIndex + 1]) {
            return { type: segments[kindIndex].toLowerCase(), id: segments[kindIndex + 1] };
        }
    } catch {
        return null;
    }
    return null;
}

function parseDeezerArtistUrl(url) {
    if (!url) {
        return null;
    }
    const trimmed = String(url).trim();
    const match = trimmed.match(/deezer\.com\/(?:[a-z]{2}\/)?artist\/([0-9]+)/i);
    if (!match) {
        return null;
    }
    return { id: match[1], source: 'deezer' };
}

function isLikelySpotifyArtistId(value) {
    return /^[A-Za-z0-9]{22}$/.test(String(value || '').trim());
}

function buildRelatedArtistHref(artist) {
    const fallbackSource = String(currentArtistSource || 'deezer').toLowerCase();
    const normalizedSource = String(artist?.source || fallbackSource || 'deezer').toLowerCase();
    const primaryId = String(artist?.id || '').trim();
    const spotifyId = String(artist?.spotify_id || artist?.spotifyId || '').trim();
    const deezerId = String(artist?.deezer_id || artist?.deezerId || '').trim();

    if (normalizedSource === 'spotify') {
        const resolvedSpotifyId = isLikelySpotifyArtistId(primaryId)
            ? primaryId
            : (isLikelySpotifyArtistId(spotifyId) ? spotifyId : '');
        if (resolvedSpotifyId) {
            return `/Artist?id=${encodeURIComponent(resolvedSpotifyId)}&source=spotify`;
        }
        if (isNumericId(deezerId)) {
            return `/Artist?id=${encodeURIComponent(deezerId)}&source=deezer`;
        }
    }

    if (normalizedSource === 'deezer') {
        const resolvedDeezerId = isNumericId(primaryId) ? primaryId : (isNumericId(deezerId) ? deezerId : '');
        if (resolvedDeezerId) {
            return `/Artist?id=${encodeURIComponent(resolvedDeezerId)}&source=deezer`;
        }
    }

    if (primaryId) {
        return `/Artist?id=${encodeURIComponent(primaryId)}&source=${encodeURIComponent(normalizedSource || fallbackSource)}`;
    }

    const linkCandidate = artist?.link || artist?.source_url || artist?.spotify_url || artist?.deezer_url || '';
    const spotifyParsed = parseSpotifyUrl(linkCandidate);
    if (spotifyParsed?.type === 'artist' && spotifyParsed.id) {
        return `/Artist?id=${encodeURIComponent(spotifyParsed.id)}&source=spotify`;
    }

    const deezerParsed = parseDeezerArtistUrl(linkCandidate);
    if (deezerParsed?.id) {
        return `/Artist?id=${encodeURIComponent(deezerParsed.id)}&source=deezer`;
    }

    return null;
}

function handleSpotifyRedirect(url) {
    const parsed = parseSpotifyUrl(url);
    if (!parsed?.type || !parsed.id) {
        window.open(url, '_blank', 'noopener');
        return;
    }
    if (parsed.type === 'artist') {
        window.location.href = `/Artist?id=${encodeURIComponent(parsed.id)}&source=spotify`;
        return;
    }
    window.location.href = `/Tracklist?id=${encodeURIComponent(parsed.id)}&type=${encodeURIComponent(parsed.type || 'track')}&source=spotify`;
}

function showArtistPlaybackMessage(message) {
    if (window.DeezSpoTag?.ui?.showToast) {
        DeezSpoTag.ui.showToast(message, { type: 'warning' });
        return;
    }
    if (window.DeezSpoTag?.ui?.alert) {
        DeezSpoTag.ui.alert(message, { title: 'Playback' });
