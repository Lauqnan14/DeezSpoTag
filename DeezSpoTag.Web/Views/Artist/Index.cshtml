}

async function fetchJson(url, options = {}) {
    const response = await fetch(url, options);
    if (!response.ok) {
        const message = await response.text();
        throw new Error(message || `Request failed (${response.status})`);
    }
    const raw = await response.text();
    const trimmed = raw.trim();
    if (!trimmed || trimmed === 'undefined') {
        return null;
    }
    try {
        return JSON.parse(raw);
    } catch {
        return null;
    }
}

function isNumericId(value) {
    return /^[0-9]+$/.test(String(value || '').trim());
}

async function refreshArtistWatchlistToggle(button, artistIdValue) {
    let watching = false;
    try {
        const status = await fetchJson(`/api/library/watchlist/${artistIdValue}`);
        watching = status?.watching === true;
    } catch {
        // Allow toggling even if status lookup fails.
    }
    applyArtistWatchlistToggleState(button, watching, false);
}

async function refreshArtistWatchlistToggleBySpotify(button, spotifyId) {
    let watching = false;
    try {
        const status = await fetchJson(`/api/library/watchlist/spotify/${encodeURIComponent(spotifyId)}`);
        watching = status?.watching === true;
    } catch {
        // Allow toggling even if status lookup fails.
    }
    applyArtistWatchlistToggleState(button, watching, false);
}

function applyArtistWatchlistToggleState(button, watching, pending) {
    if (!button) {
        return;
    }

    button.textContent = watching ? 'Monitoring Artist' : 'Monitor Artist';
    button.classList.toggle('btn-secondary', watching);
    button.classList.toggle('btn-primary', !watching);
    button.dataset.watching = watching ? 'true' : 'false';
    button.classList.toggle('is-busy', pending === true);
    button.disabled = pending === true;
}

async function initArtistWatchlistToggle(data) {
    const button = document.getElementById('watchlistToggle');
    if (!button) {
        return;
    }
    const artistIdValue = (currentArtistId || '').trim();
    if (!artistIdValue) {
        button.disabled = true;
        button.title = 'Artist ID unavailable.';
        return;
    }

    const artistName = (data?.artistName || document.querySelector('.artist-hero__title')?.textContent || 'Unknown Artist').trim();
    const isSpotifySource = String(currentArtistSource || '').toLowerCase() === 'spotify';
    let resolvedDeezerId = null;
    let mutationInFlight = false;

    button.disabled = false;
    button.addEventListener('click', async () => {
        if (mutationInFlight) {
            return;
        }
        mutationInFlight = true;
        const currentlyWatching = button.dataset.watching === 'true';
        const nextWatching = !currentlyWatching;
        applyArtistWatchlistToggleState(button, nextWatching, true);
        try {
            if (isSpotifySource) {
                if (currentlyWatching) {
                    await fetchJson(`/api/library/watchlist/spotify/${encodeURIComponent(artistIdValue)}`, { method: 'DELETE' });
                    showArtistToast('Artist removed from watchlist.');
                } else {
                    if (!resolvedDeezerId) {
                        const resolved = await resolveSpotifyUrlToDeezer(`https://open.spotify.com/artist/${artistIdValue}`);
                        if (resolved?.available && resolved.type === 'artist' && resolved.deezerId) {
                            resolvedDeezerId = resolved.deezerId;
                        }
                    }
                    await fetchJson('/api/library/watchlist/spotify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            spotifyId: artistIdValue,
                            artistName,
                            deezerId: resolvedDeezerId
                        })
                    });
                    showArtistToast('Artist added to watchlist.');
                }
                applyArtistWatchlistToggleState(button, nextWatching, false);
            } else {
                if (currentlyWatching) {
                    await fetchJson(`/api/library/watchlist/${artistIdValue}`, { method: 'DELETE' });
                    showArtistToast('Artist removed from watchlist.');
                } else {
                    if (!isNumericId(artistIdValue)) {
                        throw new Error('Artist ID must be numeric.');
                    }
                    await fetchJson('/api/library/watchlist', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ artistId: Number(artistIdValue), artistName })
                    });
                    showArtistToast('Artist added to watchlist.');
                }
                applyArtistWatchlistToggleState(button, nextWatching, false);
            }
        } catch (error) {
            applyArtistWatchlistToggleState(button, currentlyWatching, false);
            showArtistToast(`Watchlist update failed: ${error.message}`, true);
        } finally {
            mutationInFlight = false;
        }
    });

    if (isSpotifySource) {
        await refreshArtistWatchlistToggleBySpotify(button, artistIdValue);
    } else {
        await refreshArtistWatchlistToggle(button, artistIdValue);
    }
}

function resolveTrackCover(track) {
    const album = track?.album || {};
    const directCover = album.cover_medium || album.cover_small || album.cover_big || album.cover_xl || album.cover || '';
    if (directCover) {
        return directCover;
    }

    const images = Array.isArray(album.images)
        ? album.images
        : Array.isArray(track?.images)
            ? track.images
            : [];
    if (images.length > 0) {
        const image = images.find(img => img?.url) || images[0];
        if (typeof image === 'string') {
            return image;
        }
        if (image?.url) {
            return image.url;
        }
    }

    return track?.picture_medium || track?.picture || '';
}

function renderDiscographyTabs(tabs) {
    if (!tabs || tabs.length === 0) {
        return '';
    }

    return `
        <div class="artist-tabs">
            ${tabs.map(tabKey => `
                <button class="artist-tab ${tabKey === currentDiscographyTab ? 'active' : ''}" onclick="switchDiscographyTab('${tabKey}')">
                    ${getTabDisplayName(tabKey)}
                </button>
            `).join('')}
        </div>
    `;
}

function renderDiscography(releases) {
    if (!releases || releases.length === 0) {
        return '<div class="empty-state">No releases available.</div>';
    }

    return releases.map(release => {
        const year = release.releaseDate ? String(release.releaseDate).slice(0, 4) : '';
        const link = `/Tracklist?id=${release.releaseID}&type=album${release.releaseSource && release.releaseSource !== 'deezer' ? `&source=${release.releaseSource}` : ''}`;
        const coverMarkup = release.releaseCover
            ? `<img src="${release.releaseCover}" alt="${escapeHtml(release.releaseTitle)}" loading="lazy" decoding="async" onerror="handleDiscographyCoverError(this)">`
            : '<div class="discography-cover-placeholder">No Art</div>';
        return `
            <a class="discography-card" href="${link}">
                ${coverMarkup}
                <div class="discography-title">${escapeHtml(release.releaseTitle)}</div>
                <div class="discography-meta">${year}${release.releaseType ? ` • ${escapeHtml(release.releaseType)}` : ''}</div>
            </a>
        `;
    }).join('');
}

function resolveReleaseCover(release) {
    const candidates = [
        release?.cover_medium,
        release?.cover_big,
        release?.cover_xl,
        release?.cover_small,
        release?.cover
    ];

    for (const candidate of candidates) {
        if (typeof candidate === 'string' && candidate.trim().length > 0) {
            return candidate.trim();
        }
    }

    return '';
}

function handleDiscographyCoverError(imageElement) {
    if (!imageElement) {
        return;
    }

    if (imageElement.dataset.fallbackApplied === '1') {
        imageElement.replaceWith(createDiscographyCoverPlaceholder());
        return;
    }

    imageElement.dataset.fallbackApplied = '1';
    imageElement.src = '/images/logo.svg';
}

function createDiscographyCoverPlaceholder() {
    const placeholder = document.createElement('div');
    placeholder.className = 'discography-cover-placeholder';
    placeholder.textContent = 'No Art';
    return placeholder;
}

function renderRelatedArtists(artists) {
    if (!artists || artists.length === 0) {
        return '<div class="empty-state">No similar artists available.</div>';
    }

    return `
        <div class="similar-grid">
            ${artists.map(artist => {
                const href = buildRelatedArtistHref(artist);
                if (!href) {
                    return `
                    <div class="similar-card" title="Artist route unavailable">
                        <img src="${artist.picture_medium || artist.picture || ''}" alt="${escapeHtml(artist.name || '')}">
                        <div class="similar-name">${escapeHtml(artist.name || '')}</div>
                    </div>
                `;
                }
                return `
                <a class="similar-card" href="${href}">
                    <img src="${artist.picture_medium || artist.picture || ''}" alt="${escapeHtml(artist.name || '')}">
                    <div class="similar-name">${escapeHtml(artist.name || '')}</div>
                </a>
            `;
            }).join('')}
        </div>
    `;
}

function switchDiscographyTab(tabKey) {
    currentDiscographyTab = tabKey;
    saveArtistTabToCache(currentArtistId, currentArtistSource, tabKey);

    document.querySelectorAll('.artist-tab').forEach(tab => {
        tab.classList.remove('active');
    });
    const activeTab = document.querySelector(`[onclick="switchDiscographyTab('${tabKey}')"]`);
    if (activeTab) {
        activeTab.classList.add('active');
    }

    const grid = document.getElementById('discography-grid');
    if (grid && formattedArtistData) {
        grid.innerHTML = renderDiscography(formattedArtistData.artistReleases[currentDiscographyTab] || []);
    }
}

function mergeGenres(primaryGenres, localGenres) {
    const merged = new Set();
    if (Array.isArray(primaryGenres)) {
        primaryGenres.forEach((g) => {
            if (g && typeof g === 'string') merged.add(g);
            if (g && typeof g === 'object' && g.name) merged.add(g.name);
        });
    }
    if (Array.isArray(localGenres)) {
        localGenres.forEach((g) => {
            if (g && typeof g === 'string') merged.add(g);
            if (g && typeof g === 'object' && g.name) merged.add(g.name);
        });
    }
    return Array.from(merged);
}

function formatNumber(value) {
    try {
        return new Intl.NumberFormat().format(value);
    } catch (error) {
        return String(value);
    }
}

function getTabDisplayName(tabKey) {
    const tabNames = {
        'all': 'All',
        'popular': 'Popular releases',
        'album': 'Albums',
        'single': 'Singles',
        'ep': 'EPs',
        'singles_eps': 'Singles and EPs',
        'compile': 'Compilations',
        'bundle': 'Bundles',
        'more': 'More Albums',
        'featured': 'Featured In'
    };
    return tabNames[tabKey] || capitalizeFirst(tabKey);
}

function getTrackReleaseDate(track) {
    return track?.release_date
        || track?.releaseDate
        || track?.album?.release_date
        || track?.album?.releaseDate
        || '';
}

function getTrackYear(track) {
    const releaseDate = String(getTrackReleaseDate(track) || '');
    const match = releaseDate.match(/\b(19|20)\d{2}\b/);
    return match ? match[0] : '';
}

function buildTrackSubtitle(track, albumTitle, albumType, releaseYear) {
    const parts = [];
    if (albumTitle) {
        parts.push(albumTitle);
    }

    const normalizedType = String(albumType || '').toLowerCase();
    const typeLabel = normalizedType === 'single'
        ? 'Single'
        : normalizedType === 'ep'
            ? 'EP'
            : normalizedType === 'compile' || normalizedType === 'compilation'
                ? 'Compilation'
                : normalizedType === 'bundle'
                    ? 'Bundle'
                    : normalizedType === 'album'
                        ? 'Album'
                        : '';
    if (typeLabel) {
        parts.push(typeLabel);
    }

    if (releaseYear) {
        parts.push(releaseYear);
    }

    return parts.join(' • ');
}

function getArtistPayloadCacheKey(artistId, source) {
    if (!artistId) {
        return '';
    }
    return `artist-page:${String(source || 'deezer').toLowerCase()}:${artistId}`;
}

function getArtistTabCacheKey(artistId, source) {
    if (!artistId) {
        return '';
    }
    return `artist-page-tab:${String(source || 'deezer').toLowerCase()}:${artistId}`;
}

function isTabPreferenceEnabled() {
    try {
        const stored = localStorage.getItem('tabs-preference-enabled');
        if (stored === null || stored === '') {
            return true;
        }

        return stored === 'true';
    } catch {
        return true;
    }
}

function loadArtistPayloadFromCache(artistId, source) {
    const key = getArtistPayloadCacheKey(artistId, source);
    if (!key) {
        return null;
    }

    try {
        const raw = localStorage.getItem(key);
        if (!raw) {
            return null;
        }

        const parsed = JSON.parse(raw);
        if (!parsed?.savedAtUtc || !parsed?.payload) {
            return null;
        }

        const ageMs = Date.now() - Number(parsed.savedAtUtc);
        if (!Number.isFinite(ageMs) || ageMs < 0 || ageMs > artistPageCacheTtlMs) {
            localStorage.removeItem(key);
            return null;
        }

        return parsed.payload;
    } catch {
        return null;
    }
}

function saveArtistPayloadToCache(artistId, source, payload) {
    const key = getArtistPayloadCacheKey(artistId, source);
    if (!key || !payload || typeof payload !== 'object') {
        return;
    }

    try {
        localStorage.setItem(key, JSON.stringify({
            savedAtUtc: Date.now(),
            payload
        }));
    } catch {
    }
}

function loadArtistTabFromCache(artistId, source) {
    if (!isTabPreferenceEnabled()) {
        return '';
    }

    const key = getArtistTabCacheKey(artistId, source);
    if (!key) {
        return '';
    }
    try {
        return localStorage.getItem(key) || '';
    } catch {
        return '';
    }
}

function saveArtistTabToCache(artistId, source, tab) {
    const key = getArtistTabCacheKey(artistId, source);
    if (!key) {
        return;
    }

    if (!isTabPreferenceEnabled()) {
        try {
            localStorage.removeItem(key);
        } catch {
        }
        if (window.UserPrefs?.setTabSelection) {
            window.UserPrefs.setTabSelection(key, '');
        }
        return;
    }

    if (!tab) {
        return;
    }

    try {
        localStorage.setItem(key, tab);
    } catch {
    }

    if (window.UserPrefs?.setTabSelection) {
        window.UserPrefs.setTabSelection(key, tab);
    }
}

function getReleaseCount(payload) {
    const releases = payload?.releases;
    if (!releases || typeof releases !== 'object') {
        return 0;
    }

    return Object.values(releases).reduce((count, value) => {
        return count + (Array.isArray(value) ? value.length : 0);
    }, 0);
}

function mergeArtistPayload(primary, fallback) {
    if (!primary || typeof primary !== 'object') {
        return fallback || primary;
    }
    if (!fallback || typeof fallback !== 'object') {
        return primary;
    }

    const merged = { ...primary };
    if (getReleaseCount(primary) === 0 && getReleaseCount(fallback) > 0) {
        merged.releases = fallback.releases;
    }

    const primaryTopTracks = Array.isArray(primary.top_tracks) ? primary.top_tracks : [];
    const fallbackTopTracks = Array.isArray(fallback.top_tracks) ? fallback.top_tracks : [];
    if (primaryTopTracks.length === 0 && fallbackTopTracks.length > 0) {
        merged.top_tracks = fallbackTopTracks;
    }

    const primaryRelated = Array.isArray(primary.related) ? primary.related : [];
    const fallbackRelated = Array.isArray(fallback.related) ? fallback.related : [];
    if (primaryRelated.length === 0 && fallbackRelated.length > 0) {
        merged.related = fallbackRelated;
    }

    if (!merged.picture_xl && fallback.picture_xl) {
        merged.picture_xl = fallback.picture_xl;
    }
    if (!merged.picture_big && fallback.picture_big) {
        merged.picture_big = fallback.picture_big;
    }
    if (!merged.picture_medium && fallback.picture_medium) {
        merged.picture_medium = fallback.picture_medium;
    }

    return merged;
}

function capitalizeFirst(str) {
    return str.charAt(0).toUpperCase() + str.slice(1);
}

function downloadArtist(link, metadata = null) {
    if (window.DeezSpoTagDownload) {
        window.DeezSpoTagDownload.addToQueue(link, 0, null, metadata ? { metadata } : undefined);
    } else {
        downloadUsingApi(link, metadata);
    }
}

async function downloadUsingApi(url, metadata = null) {
    try {
        const destinationFolderId = window.DeezSpoTagDownload?.getDestinationFolderId(true);
        if (document.querySelector('.download-destination-select') && !destinationFolderId) {
            return;
        }

        const lower = String(url || '').toLowerCase();
        let endpoint = '';
        let payload = {};
        const intentFromMetadata = (sourceService, sourceUrl, extras = {}) => ({
            sourceService,
            sourceUrl,
            title: metadata?.title || undefined,
            artist: metadata?.artist || undefined,
            album: metadata?.album || undefined,
            albumArtist: metadata?.albumArtist || undefined,
            isrc: metadata?.isrc || undefined,
            cover: metadata?.cover || undefined,
            durationMs: Number(metadata?.durationMs || 0) || undefined,
            position: Number(metadata?.position || 0) || undefined,
            ...extras
        });

        if (lower.startsWith('isrc:')) {
            endpoint = '/api/download/intent';
            payload = {
                destinationFolderId: destinationFolderId,
                resolveImmediately: true,
                intents: [
                    intentFromMetadata('qobuz', undefined, { isrc: url.replace(/^isrc:/i, '') })
                ]
            };
        } else if (lower.includes('music.apple.com') || lower.includes('itunes.apple.com')) {
            const hasAtmos = metadata?.hasAtmos === true || metadata?.hasAtmos === 'true';
            endpoint = isAppleMusicVideoUrl(lower) || metadata?.isVideo === true
                ? '/api/apple/videos/download'
                : '/api/apple/download';
            payload = {
                destinationFolderId: destinationFolderId,
                tracks: [{
                    appleUrl: url,
                    metadata: metadata ? { ...metadata, hasAtmos: Boolean(hasAtmos) } : undefined
                }],
                    quality: hasAtmos ? 'atmos' : null
            };
        } else if (lower.includes('tidal.com')) {
            endpoint = '/api/download/intent';
            payload = {
                destinationFolderId: destinationFolderId,
                resolveImmediately: true,
                intents: [
                    intentFromMetadata('tidal', url)
                ]
            };
        } else if (lower.includes('music.amazon') || lower.includes('amazon.com/music') || lower.includes('amazon.co')) {
            endpoint = '/api/download/intent';
            payload = {
                destinationFolderId: destinationFolderId,
                resolveImmediately: true,
                intents: [
                    intentFromMetadata('amazon', url)
                ]
            };
        } else if (lower.includes('qobuz.com')) {
            endpoint = '/api/download/intent';
            payload = {
                destinationFolderId: destinationFolderId,
                resolveImmediately: true,
                intents: [
                    intentFromMetadata('qobuz', url)
                ]
            };
        } else if (lower.includes('spotify.com') || lower.startsWith('spotify:')) {
            endpoint = '/api/download/intent';
            payload = {
                destinationFolderId: destinationFolderId,
                resolveImmediately: true,
                intents: [{
                    ...intentFromMetadata('spotify', url),
                    spotifyId: (url.match(/(?:spotify:track:|open\.spotify\.com\/track\/)([A-Za-z0-9]+)/i) || [])[1] || '',
                    deezerId: metadata?.deezerId || undefined
                }]
            };
        } else {
            DeezSpoTag.ui.alert('Download engine removed for this source.', { title: 'Download Queue' });
            return;
        }

        const response = await fetch(endpoint, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(payload)
        });

        if (response.ok) {
            const result = await response.json();
            const queued = result?.queued?.length || 0;
            const deferred = result?.deferredCount || 0;
            const message = queued > 0
                ? `Queued ${queued} item(s).${deferred > 0 ? ` (${deferred} deferred)` : ''}`
                : deferred > 0
                    ? `Queued ${deferred} item(s) for background intent resolution.`
                    : (result?.message || 'Nothing queued.');
            DeezSpoTag.ui.alert(message, { title: 'Download Queue' });
        } else {
            const error = await response.json();
            DeezSpoTag.ui.alert(`Failed to add to queue: ${error.message || 'Unknown error'}`, { title: 'Download Queue' });
        }
    } catch (error) {
        console.error('Download error:', error);
        DeezSpoTag.ui.alert(`Error: ${error.message}`, { title: 'Download Queue' });
    }
}

function isAppleMusicVideoUrl(url) {
    const lower = String(url || '').toLowerCase();
    return lower.includes('/music-video/')
        || lower.includes('/music-videos/')
        || lower.includes('/video/');
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}
</script>
}
