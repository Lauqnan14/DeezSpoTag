    margin-bottom: 4px;
}

.media-operations-tab .analysis-feature-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
}

.media-operations-tab .analysis-summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
}

.media-operations-tab .analysis-summary-grid.analysis-summary-grid-vibe {
