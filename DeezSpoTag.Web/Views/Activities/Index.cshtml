<div class="container-fluid activities-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="welcome-title mb-2">Activities</h1>
            <p class="text-muted">Track downloads, AutoTag progress, and upcoming activity reports.</p>
        </div>
    </div>

    <ul class="nav nav-tabs nav-fill mb-4 ds-mobile-tabs" id="activitiesTabs">
        <li class="nav-item">
            <button class="nav-link active" id="activities-downloads-tab" data-bs-toggle="tab" data-bs-target="#downloads-content" type="button" role="tab">
                <i class="fas fa-download me-2"></i>Downloads
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="activities-autotag-tab" data-bs-toggle="tab" data-bs-target="#autotag-status-content" type="button" role="tab">
                <i class="fas fa-tags me-2"></i>AutoTag Status
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="activities-history-tab" data-bs-toggle="tab" data-bs-target="#history-content" type="button" role="tab">
                <i class="fas fa-history me-2"></i>History
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="activities-media-operations-tab" data-bs-toggle="tab" data-bs-target="#media-operations-content" type="button" role="tab">
                <i class="fas fa-toolbox me-2"></i>Media Operations
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="activities-logs-tab" data-bs-toggle="tab" data-bs-target="#logs-content" type="button" role="tab">
                <i class="fas fa-file-alt me-2"></i>Logs
            </button>
        </li>
    </ul>

    <div class="tab-content" id="activitiesTabsContent">
        <div class="tab-pane fade show active" id="downloads-content" role="tabpanel">
            <div class="downloads-tab">
                <div class="downloads-layout">
                    <div class="downloads-actions">
                        <button class="action-btn action-btn-amber action-btn-sm" id="pauseBtn" onclick="pauseQueue()">
                            <svg class="action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M8 5h3v14H8zm5 0h3v14h-3z"/></svg>
                            Pause
                        </button>
                        <button class="action-btn action-btn-sm" id="resumeBtn" onclick="resumeQueue()">
                            <svg class="action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M8 5v14l11-7z"/></svg>
                            Resume
                        </button>
                        <button class="btn-danger action-btn action-btn-sm" id="cancelAllBtn" onclick="cancelAllTasks()">
                            <svg class="action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm3.59 13.17-1.42 1.42L12 13.41l-2.17 2.18-1.42-1.42L10.59 12 8.41 9.83l1.42-1.42L12 10.59l2.17-2.18 1.42 1.42L13.41 12l2.18 2.17z"/></svg>
                            Cancel
                        </button>
                        <button class="action-btn action-btn-sm" id="clearAllBtn" onclick="clearAllTasks()">
                            <svg class="action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M16 9v10H8V9h8zm-1.5-6h-5l-1 1H5v2h14V4h-3.5l-1-1z"/></svg>
                            Clear
                        </button>
                        <button class="action-btn action-btn-sm" id="clearCompletedBtn" onclick="clearCompletedTasks()">
                            <svg class="action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M18 7L9.97 15.03l-3.5-3.5-1.41 1.41 4.91 4.91L19.41 8.41zM13.41 8.41 12 7l-5.59 5.59L7.83 14z"/></svg>
                            Clear Completed
                        </button>
                        <button class="action-btn action-btn-sm" id="clearCanceledBtn" onclick="clearCanceledTasks()">
                            <svg class="action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13H7v-2h10v2z"/></svg>
                            Clear Canceled
                        </button>
                    </div>

                    <div class="tasks-container">
                        <div id="tasksList"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="autotag-status-content" role="tabpanel">
            <div class="card bg-darker border-secondary">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-tags me-2"></i>AutoTag Status
                    </h5>
                </div>
                <div class="card-body">
                    <div class="autotag-status-grid">
                        @foreach (var card in autoTagSummaryCards)
                        {
                            <div class="autotag-status-card">
                                <span>@card.Label</span>
                                <strong id="@card.Id">@card.Value</strong>
                            </div>
                        }
                    </div>
                    <div class="autotag-metadata">
                        @foreach (var card in autoTagMetadataCards)
                        {
                            <div class="autotag-status-card">
                                <span>@card.Label</span>
                                <strong id="@card.Id">@card.Value</strong>
                            </div>
                        }
                    </div>
                    <div class="autotag-progress">
                        <div class="progress">
                            <div id="autotag-progress-bar" class="progress-bar" style="width: 0%"></div>
                        </div>
                    </div>
                    <div class="autotag-last-log" id="autotag-last-log">No recent log lines.</div>
                    <div class="form-label text-muted">Latest Log</div>
                    <pre id="autotag-log" class="autotag-log">No AutoTag job started yet.</pre>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="media-operations-content" role="tabpanel">
            <div class="media-operations-tab">
                <div class="media-ops-layout">
                    <div class="ops-primary">
                        <div class="tool-card" id="analysis-card">
                            <div class="tool-card-header">
                                <div class="tool-card-heading">
                                    <h4 class="tool-card-title mb-0">Vibe Analysis</h4>
                                    <span class="status-pill" id="analysisStatusPill">Inactive</span>
                                </div>
                                <button class="tool-help-button" type="button" data-tool="vibe-analysis">
                                    ?
                                    <span class="tool-help-tooltip">Learn more about this tool</span>
                                </button>
                            </div>
                            <p class="tool-card-info mb-0">Analyze tracks in enabled folders to generate vibe metrics.</p>
                            <div class="section-divider"></div>
                            <div class="section-label">Recent files</div>
                            <ul id="analysisRecentList" class="analysis-recent-list">
                                <li class="analysis-recent-item">
                                    <div class="analysis-recent-meta">
                                        <span class="analysis-recent-title">No recent analyses yet</span>
                                    </div>
                                </li>
                            </ul>
                            <div class="section-divider"></div>
                            <div class="tool-card-body">
                                <div class="analysis-summary-grid analysis-summary-grid-vibe meloday-summary-grid">
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Progress</span>
                                        <span class="analysis-summary-value" id="analysisStatus">Loading analysis status...</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Pending</span>
                                        <span class="analysis-summary-value" id="analysisPending">0</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Last run</span>
                                        <span class="analysis-summary-value" id="analysisLastRun">Never</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Latest track</span>
                                        <span class="analysis-summary-value" id="analysisLatestTrack">Unknown</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Analysis mode</span>
                                        <span class="analysis-summary-value" id="analysisLatestMode">Unknown</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Analyzed at</span>
                                        <span class="analysis-summary-value" id="analysisLatestAt">Unknown</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Status</span>
                                        <span class="analysis-summary-value" id="analysisLatestStatus">Unknown</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Mood tags</span>
                                        <span class="analysis-summary-value" id="analysisMoodTags">None</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Essentia genres</span>
                                        <span class="analysis-summary-value" id="analysisEssentiaGenres">None</span>
                                    </div>
                                    <div class="analysis-summary-card">
                                        <span class="analysis-summary-label">Last.fm tags</span>
                                        <span class="analysis-summary-value" id="analysisLastfmTags">None</span>
                                    </div>
                                </div>
                                <div class="section-divider"></div>
                                <div class="section-label">Processing</div>
                                <div class="tool-card-controls vibe-analysis-settings">
                                    <div class="settings-grid">
                                        <div class="field-group">
                                            <label class="field-label" for="analysis-batch-size">Batch size</label>
                                            <div class="field-input">
                                                <input id="analysis-batch-size" class="form-control" type="number" min="10" max="500" />
                                                <span class="field-unit">tracks</span>
                                            </div>
                                        </div>
                                        <div class="field-group">
                                            <label class="field-label" for="analysis-interval-minutes">Interval</label>
                                            <div class="field-input">
                                                <input id="analysis-interval-minutes" class="form-control" type="number" min="5" max="240" />
                                                <span class="field-unit">minutes</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="section-divider"></div>
                                </div>
                                <div class="section-label">Audio features</div>
                                <div class="analysis-features-grid analysis-features-grid-main">
                                    <div class="analysis-feature">
                                        <span class="analysis-feature-label">BPM</span>
                                        <span class="analysis-feature-value" id="analysisFeatureBpm">--</span>
                                    </div>
                                    <div class="analysis-feature">
                                        <span class="analysis-feature-label">Beats</span>
                                        <span class="analysis-feature-value" id="analysisFeatureBeats">--</span>
                                    </div>
