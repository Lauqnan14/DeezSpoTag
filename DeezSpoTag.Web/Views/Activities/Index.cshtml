.media-operations-tab .analysis-summary-grid.analysis-summary-grid-main {
    grid-template-columns: repeat(3, minmax(0, 1fr));
}

.media-operations-tab .analysis-summary-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 12px;
    padding: 10px 12px;
