    color: var(--text-secondary);
}

.media-operations-tab .ops-secondary .progress-phase-label {
    color: var(--text-primary);
    font-weight: 700;
}

.media-operations-tab .ops-secondary .progress-details-label {
    font-size: 14px;
}

.media-operations-tab .analysis-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin-top: 12px;
}

.media-operations-tab .analysis-features-grid.analysis-features-grid-main {
    grid-template-columns: repeat(7, minmax(0, 1fr));
}

.media-operations-tab .analysis-feature {
    background: var(--bg-secondary);
