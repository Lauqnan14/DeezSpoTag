    }

    .media-operations-tab .field-input {
        flex-direction: column;
        flex-wrap: wrap;
        align-items: stretch;
    }

    .media-operations-tab #meloday-card .meloday-summary-grid,
    .media-operations-tab #meloday-card .meloday-history-grid,
    .media-operations-tab #meloday-card .meloday-similarity-grid {
        grid-template-columns: 1fr;
    }

    .media-operations-tab .field-unit {
        min-width: 0;
        text-align: left;
    }

    .media-operations-tab .tool-card-actions {
        flex-direction: column;
        align-items: stretch;
        gap: 8px;
    }

    .media-operations-tab .tool-card-actions .btn {
        width: 100%;
    }

    .media-operations-tab .analysis-summary-grid,
    .media-operations-tab .analysis-features-grid,
    .media-operations-tab .analysis-summary-grid.analysis-summary-grid-vibe,
