}

.download-log-level.info { color: #7aa3ff; }
.download-log-level.success { color: #6ee7b7; }
.download-log-level.warning { color: #fbbf24; }
.download-log-level.error { color: #f87171; }
.download-log-level.debug { color: #a3a3a3; }

.downloads-tab .error-message {
