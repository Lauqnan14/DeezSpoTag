    intervalMinutes: 30
};

const analysisRecent = [];
let analysisProcessing = null;
let lastAnalysisLogKey = null;

function formatTimestamp(value) {
    if (!value) {
        return 'Never';
    }
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) {
        return 'Unknown';
    }
    return parsed.toLocaleString();
}

function updateAnalysisStatusPill() {
    const statusPill = document.getElementById('analysisStatusPill');
    if (!statusPill) {
        return;
    }
    const active = Boolean(analysisSettingsState.enabled);
    statusPill.textContent = active ? 'Active' : 'Inactive';
    statusPill.classList.toggle('is-active', active);
}

async function fetchJson(url, options) {
    const response = await activityFetch(url, options);
    if (!response.ok) {
        const message = await response.text();
        throw new Error(message || `Request failed (${response.status})`);
    }
    const raw = await response.text();
    const trimmed = raw.trim();
    if (!trimmed || trimmed === 'undefined') {
        throw new Error(`Invalid JSON response from ${url}: ${trimmed || '<empty>'}`);
    }
    try {
        return JSON.parse(raw);
    } catch {
        throw new Error(`Invalid JSON response from ${url}: ${trimmed.slice(0, 200)}`);
    }
}

function formatNumber(value, digits = 2) {
    if (value === null || value === undefined || Number.isNaN(value)) {
        return '--';
    }
    return Number(value).toFixed(digits);
}

function formatList(values) {
    if (!values || !values.length) {
        return 'None';
    }
    return values.join(', ');
}

async function loadAnalysisActivity() {
    try {
        await fetchJson('/api/library/analysis/current');
        analysisState.running = true;
