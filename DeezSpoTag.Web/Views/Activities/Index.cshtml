function stopLibraryLogsAutoRefresh() {
    if (!libraryLogsRefreshTimer) {
        return;
    }
    clearInterval(libraryLogsRefreshTimer);
    libraryLogsRefreshTimer = null;
}

async function loadLibraryLogs() {
	    const logger = window.DeezSpoTag?.DownloadLogger;
	    if (!logger) {
	        return;
	    }

	    try {
            const logsTabPane = document.getElementById('logs-content');
            if (!logsTabPane?.classList.contains('active')) {
                return;
            }

	        if (libraryLogsInFlight) {
	            return;
	        }
	        libraryLogsInFlight = true;

	        libraryLogsAbortController?.abort();
	        libraryLogsAbortController = new AbortController();

	        const response = await activityFetch(`/api/library/scan/logs?limit=${LIBRARY_LOGS_LIMIT}`, {
	            signal: libraryLogsAbortController.signal
	        });
	        if (!response.ok) {
	            throw new Error(await response.text());
	        }
	        const logs = await response.json();
	        if (!Array.isArray(logs) || logs.length === 0) {
	            return;
	        }

            logs
                .slice()
                .sort((left, right) => new Date(left.timestampUtc || 0).getTime() - new Date(right.timestampUtc || 0).getTime())
                .forEach(entry => {
	            const key = buildLibraryLogKey(entry);
	            if (libraryLogKeys.has(key)) {
	                return;
	            }
	            if (libraryLogKeys.size >= LIBRARY_LOG_KEYS_MAX) {
	                libraryLogKeys.clear();
	            }
	            libraryLogKeys.add(key);
	            const level = String(entry.level || 'info').toLowerCase();
	            const message = entry.message ?? '';
	            const method = level === 'warn' ? 'warning' : level;
	            const engineMatch = /engine=([a-z0-9_-]+)/i.exec(message);
	            const engine = engineMatch ? engineMatch[1].toLowerCase() : 'library';
	            logger[method]?.(message, { engine, timestamp: entry.timestampUtc });
	        });
	    } catch (error) {
	        if (error?.name !== 'AbortError') {
	            logger?.warning?.(`library logs refresh failed: ${error?.message || error}`, { engine: 'library' });
	        }
	    } finally {
	        libraryLogsInFlight = false;
	    }
	    }

