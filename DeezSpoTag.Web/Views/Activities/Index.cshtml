    text-transform: uppercase;
}

.media-operations-tab .analysis-summary-value {
    font-size: 14px;
    color: var(--text-primary);
}

.media-operations-tab .analysis-recent-list {
    list-style: none;
    padding: 0;
    margin: 10px 0 0;
    display: grid;
    gap: 10px;
}

.media-operations-tab .analysis-recent-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid var(--border-secondary);
    border-radius: 10px;
    background: var(--bg-secondary);
    font-size: 14px;
}

.media-operations-tab .analysis-recent-meta {
    display: grid;
    gap: 2px;
    color: var(--text-secondary);
}

.media-operations-tab .analysis-recent-title {
    color: var(--text-primary);
    font-weight: 700;
}

.media-operations-tab .analysis-recent-status {
    color: var(--text-muted);
    font-size: 13px;
}

.media-operations-tab .analysis-recent-time {
    color: var(--text-muted);
    font-size: 12px;
    white-space: nowrap;
}

@@media (max-width: 1100px) {
