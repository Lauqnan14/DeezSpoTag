@section Scripts {
<script>
let queueState = 'paused';
let tasks = [];
let queuePollTimeoutId = null;
let queuePollInFlight = false;
let queueLoadRequestSequence = 0;
let queueVisibilityHandlerAttached = false;
const queueProgressCache = {};
const queueProgressTextAnimationByTask = {};
const queueProgressAnimationDurationMs = 350;
const queuePollDelayMs = 3000;
const queueActivityByTask = {};
const queuePrefetchByTask = {};
let queueRealtimeAttached = false;
let queueRealtimeAttachTimer = null;
let queueRealtimeLifecycleAttached = false;
let queueActionInFlight = false;
let queueHydrationRefreshTimer = null;
let lastQueueHydrationRefreshAt = 0;
const activityCsrfUnsafeMethods = new Set(['POST', 'PUT', 'PATCH', 'DELETE']);
const activityNativeFetch = globalThis.fetch.bind(globalThis);

function readActivityCsrfRequestToken() {
    const tokenMeta = document.querySelector('meta[name="deezspotag-csrf-token"]');
    const token = tokenMeta?.getAttribute('content');
    return typeof token === 'string' ? token.trim() : '';
}

function buildActivityFetchOptions(options) {
    const requestOptions = options ? { ...options } : {};
    const method = String(requestOptions.method || 'GET').toUpperCase();
    if (!activityCsrfUnsafeMethods.has(method)) {
        return requestOptions;
    }

    const headers = new Headers(requestOptions.headers || {});
    if (!headers.has('X-CSRF-TOKEN')) {
        const csrfToken = readActivityCsrfRequestToken();
        if (csrfToken) {
            headers.set('X-CSRF-TOKEN', csrfToken);
        }
    }

    requestOptions.headers = headers;
    if (!requestOptions.credentials) {
        requestOptions.credentials = 'same-origin';
    }
    return requestOptions;
}

function activityFetch(resource, options) {
    return activityNativeFetch(resource, buildActivityFetchOptions(options));
}

let analysisPollTimeoutId = null;
let analysisPollInFlight = false;
const analysisPollDelayMs = 15000;
let lastAutoScrollTaskId = null;
const queueScrollState = {
    animationId: null,
    startTime: 0,
    startTop: 0,
    targetTop: 0,
    duration: 320
};

function stopQueueAutoScrollAnimation() {
    if (queueScrollState.animationId != null) {
        cancelAnimationFrame(queueScrollState.animationId);
        queueScrollState.animationId = null;
    }
}

function animateQueueScroll(targetTop) {
    const container = document.querySelector('.tasks-container');
    if (!container) {
        return;
    }

    stopQueueAutoScrollAnimation();
    queueScrollState.startTime = performance.now();
    queueScrollState.startTop = container.scrollTop;
    queueScrollState.targetTop = Math.max(0, targetTop);

    const step = (now) => {
        const elapsed = now - queueScrollState.startTime;
        const t = Math.min(1, elapsed / queueScrollState.duration);
        const eased = 0.5 - Math.cos(Math.PI * t) / 2;
        container.scrollTop = queueScrollState.startTop
            + (queueScrollState.targetTop - queueScrollState.startTop) * eased;
        if (t < 1) {
            queueScrollState.animationId = requestAnimationFrame(step);
        } else {
            queueScrollState.animationId = null;
        }
    };

    queueScrollState.animationId = requestAnimationFrame(step);
}

function scrollQueueCardIntoViewAtTop(card) {
    const container = document.querySelector('.tasks-container');
    if (!container || !card) {
        return;
    }
    const containerRect = container.getBoundingClientRect();
    const cardRect = card.getBoundingClientRect();
    const targetTop = container.scrollTop + (cardRect.top - containerRect.top);
    animateQueueScroll(targetTop);
}

function isQueueTailVisible() {
    const container = document.querySelector('.tasks-container');
    if (!container) {
        return false;
    }
    return (container.scrollTop + container.clientHeight) >= (container.scrollHeight - 12);
}

function resolveAutoScrollTask(taskList) {
    if (!Array.isArray(taskList) || taskList.length === 0) {
        return null;
    }

    return taskList.find(task => task.status === 'running')
        || taskList.find(task => task.status === 'queued' || task.status === 'retrying' || task.status === 'paused')
        || taskList[0];
}

function updateQueueButtons() {
