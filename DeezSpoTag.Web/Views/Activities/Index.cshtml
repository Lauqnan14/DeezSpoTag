                       <span class="rack-line l1"></span>
                       <span class="rack-line l2"></span>
                       <span class="rack-line l3"></span>
                   </span>
               </span>`
            : '';
        const lyricsBadges = Array.isArray(task.lyricsBadges) ? task.lyricsBadges : [];
        const videoBadges = Array.isArray(task.videoBadges) ? task.videoBadges : [];

		        const displayIndex = index + 1;
		        return `
		            <div class="task-card" data-task-id="${safeTaskIdAttr}" data-status="${safeStatus}">
	                <div class="task-header">
	                    <div class="task-index">${displayIndex}</div>
	                    <div class="task-icon ${task.cover ? 'cover' : ''} ${statusForUi === 'running' ? 'running' : ''}" ${coverStyle}><span class="task-icon-fallback">${getStatusIcon(statusForUi)}</span>${runningOverlayHtml}</div>
	                    <div class="task-info">
	                        <div class="task-title">${safeTitle}</div>
