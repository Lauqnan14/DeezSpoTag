function initLibraryMaintenance() {
    const cleanupButton = document.getElementById('library-cleanup-button');
    const clearButton = document.getElementById('library-clear-button');
    const phaseLabel = document.getElementById('library-maintenance-phase');
    const detailsLabel = document.getElementById('library-maintenance-details');

    if (!cleanupButton && !clearButton) {
        return;
    }

    cleanupButton?.addEventListener('click', async () => {
        const confirmed = await confirmAction('Remove entries for files that no longer exist on disk?', 'Cleanup Missing');
        if (!confirmed) {
            return;
        }
        try {
            phaseLabel && (phaseLabel.textContent = 'Cleanup running');
            detailsLabel && (detailsLabel.textContent = 'Checking library files...');
            const response = await activityFetch('/api/library/maintenance/cleanup-missing', { method: 'POST' });
            if (!response.ok) {
                throw new Error(await response.text());
            }
            const payload = await response.json();
            if (payload?.ok === false) {
                phaseLabel && (phaseLabel.textContent = 'Cleanup skipped');
                detailsLabel && (detailsLabel.textContent = payload?.reason || 'Library DB not configured');
                notifyActivity('Library cleanup skipped.', 'warning');
                return;
            }
            const removed = payload?.removed ?? 0;
            phaseLabel && (phaseLabel.textContent = 'Cleanup completed');
            detailsLabel && (detailsLabel.textContent = `Removed ${removed} missing files`);
            notifyActivity(`Library cleanup completed (${removed} removed).`);
        } catch (error) {
            phaseLabel && (phaseLabel.textContent = 'Cleanup failed');
            detailsLabel && (detailsLabel.textContent = 'Unable to clean missing files');
            notifyActivity(`Library cleanup failed: ${error?.message || error}`, 'error');
        }
    });

    clearButton?.addEventListener('click', async () => {
        const confirmed = await confirmAction('Clear all library metadata? Your music files will not be deleted.', 'Clear Library');
        if (!confirmed) {
            return;
        }
        try {
            phaseLabel && (phaseLabel.textContent = 'Clearing library');
            detailsLabel && (detailsLabel.textContent = 'Removing library metadata...');
            const response = await activityFetch('/api/library/maintenance/clear', { method: 'POST' });
            if (!response.ok) {
                throw new Error(await response.text());
            }
            const payload = await response.json();
            if (payload?.ok === false) {
                phaseLabel && (phaseLabel.textContent = 'Clear skipped');
                detailsLabel && (detailsLabel.textContent = payload?.reason || 'Library DB not configured');
                notifyActivity('Library clear skipped.', 'warning');
                return;
            }
            phaseLabel && (phaseLabel.textContent = 'Library cleared');
            detailsLabel && (detailsLabel.textContent = 'Metadata cleared');
            notifyActivity('Library cleared.');
        } catch (error) {
            phaseLabel && (phaseLabel.textContent = 'Clear failed');
            detailsLabel && (detailsLabel.textContent = 'Unable to clear library');
            notifyActivity(`Library clear failed: ${error?.message || error}`, 'error');
        }
    });
}

