	                    <div class="task-badges">
	                        <span class="badge ${getStatusBadgeClass(statusForUi)}">${safeStatus}</span>
	                        <span class="badge badge-quality">${safeQuality}</span>
	                        ${videoBadges.map(videoBadge => `<span class="badge ${videoBadge.className}">${videoBadge.label}</span>`).join('')}
	                        <span class="badge badge-engine">${safeEngine}</span>
	                        ${renderFallbackPlanBadges(task)}
                        ${lyricsBadges.length
                            ? lyricsBadges.map(label => {
                                const kind = label.toLowerCase();
                                const cls = kind === 'time-synced'
                                    ? 'badge-lyrics-timesynced'
