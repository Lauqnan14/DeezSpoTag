@{
    ViewData["Title"] = "Activities - DeezSpoTag";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var autoTagSummaryCards = new (string Label, string Id, string Value)[]
    {
        ("Job", "autotag-job", "Idle"),
        ("Status", "autotag-state", "waiting"),
        ("Last Updated", "autotag-updated", "--:--")
    };
    var autoTagMetadataCards = new (string Label, string Id, string Value)[]
    {
        ("Runtime", "autotag-runtime", "00:00"),
        ("Log Lines", "autotag-log-count", "0"),
        ("Exit Code", "autotag-exit-code", "--"),
        ("Platform", "autotag-platform", "--"),
        ("Last Track", "autotag-last-track", "--"),
        ("Last Result", "autotag-last-result", "--"),
        ("Accuracy", "autotag-last-accuracy", "--"),
        ("Tagged", "autotag-ok-count", "0"),
        ("Errors", "autotag-error-count", "0"),
        ("Skipped", "autotag-skipped-count", "0")
    };
}

@section Styles {
<style>
/* Activities page layout - works within main content area */
.activities-container {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 40px);
    color: var(--text-primary);
}

.activities-container .tab-pane {
    color: var(--text-primary);
}

.activities-container .nav-tabs .nav-link {
    color: var(--text-muted);
}

.activities-container .nav-tabs .nav-link:hover {
    color: var(--text-primary);
}

.activities-container .nav-tabs .nav-link.active {
    color: var(--primary-color);
}

.activities-container .card,
.activities-container .card-header,
.activities-container .card-body,
.activities-container .card-header h5,
.activities-container .card-body p,
.activities-container .card-body span,
.activities-container .card-body label {
    color: var(--text-primary);
}

.activities-container .card-body .text-muted {
    color: var(--text-muted);
}

#activitiesTabsContent {
    background: transparent;
}

/* Downloads tab */
.downloads-tab {
    --accent-blue: #00d4ff;
    --accent-purple: #b744ff;
    --accent-pink: #ff3d9a;
    --success: #00ff88;
    --warning: #ffb800;
    --error: #ff3366;
    min-height: 70vh;
    overflow-x: hidden;
    position: relative;
    border-radius: 16px;
}

.downloads-tab * {
    box-sizing: border-box;
}

.downloads-tab .downloads-layout {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: clamp(12px, 1.8vw, 28px);
    position: relative;
    z-index: 1;
}

.downloads-tab .downloads-sticky {
    position: sticky;
    top: 12px;
    z-index: 3;
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 14px;
    padding: 16px;
    margin-bottom: 24px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    isolation: isolate;
    overflow: hidden;
}

.downloads-tab .downloads-sticky::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--bg-secondary);
    z-index: -1;
    border-radius: 14px;
}

.autotag-diff-panel {
    display: grid;
    gap: 12px;
    max-height: min(70vh, 700px);
    overflow: auto;
    padding-right: 4px;
    color: var(--text-primary);
}

.autotag-diff-path {
    font-size: 12px;
    color: var(--text-muted);
    word-break: break-all;
}

.autotag-diff-table-wrap {
    border: 1px solid var(--border-secondary);
    border-radius: 10px;
    overflow: auto;
    background: color-mix(in srgb, var(--bg-secondary) 86%, transparent);
}

.autotag-diff-table td,
.autotag-diff-table th {
    font-size: 12px;
    vertical-align: top;
    padding: 10px 12px;
    border: 1px solid var(--border-secondary);
    color: var(--text-primary);
}

.autotag-diff-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
}

.autotag-diff-table thead th {
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--accent-color) 18%, var(--bg-tertiary));
    font-weight: 600;
}

.autotag-diff-table td:nth-child(2),
.autotag-diff-table td:nth-child(3),
.autotag-diff-table td:nth-child(4) {
    white-space: pre-wrap;
    word-break: break-word;
}

.autotag-diff-empty {
    color: var(--text-muted);
    font-size: 13px;
}

.autotag-history-table .autotag-diff-btn {
    min-width: 72px;
    padding: 4px 10px;
    font-size: 12px;
}

.autotag-history-layout {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(250px, 300px) minmax(0, 1fr);
    min-width: 0;
}

.autotag-history-sidebar,
.autotag-history-main {
    display: grid;
    gap: 16px;
    align-content: start;
    min-width: 0;
}

.autotag-calendar-card,
.autotag-run-list-card,
.autotag-run-detail-card {
    background: color-mix(in srgb, var(--bg-secondary) 92%, transparent);
    border: 1px solid var(--border-secondary);
    border-radius: 14px;
    padding: 16px;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
}

.autotag-calendar-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
}

.autotag-calendar-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
}

.autotag-calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 8px;
    width: 100%;
    max-width: 100%;
    min-width: 0;
}

.autotag-calendar-weekday,
.autotag-calendar-day {
    min-height: 56px;
    border-radius: 12px;
}

.autotag-calendar-weekday {
    min-height: auto;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
}

.autotag-calendar-day {
    border: 1px solid var(--border-secondary);
    background: color-mix(in srgb, var(--bg-tertiary) 88%, transparent);
    color: var(--text-primary);
    display: grid;
    align-content: space-between;
    justify-items: start;
    padding: 8px;
    cursor: pointer;
    overflow: hidden;
}

.autotag-calendar-day.is-empty {
    cursor: default;
    opacity: 0.35;
}

.autotag-calendar-day.is-selected {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent-color) 70%, transparent);
}

.autotag-calendar-day.is-today {
    background: color-mix(in srgb, var(--accent-color) 14%, var(--bg-tertiary));
}

.autotag-calendar-day-number {
    font-size: 12px;
    font-weight: 700;
}

.autotag-calendar-day-count {
    font-size: 10px;
    color: var(--accent-color);
    white-space: nowrap;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
}

.autotag-calendar-day-count:empty {
    display: none;
}

.autotag-run-list {
    display: grid;
    gap: 10px;
}

.autotag-run-item {
    width: 100%;
    border: 1px solid var(--border-secondary);
    background: color-mix(in srgb, var(--bg-tertiary) 88%, transparent);
    border-radius: 12px;
    color: var(--text-primary);
    padding: 12px;
    text-align: left;
    display: grid;
    gap: 6px;
}

.autotag-run-item.is-selected {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent-color) 70%, transparent);
}

.autotag-run-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
    color: var(--text-muted);
}

.autotag-run-item-path {
    font-size: 12px;
    color: var(--text-secondary);
    word-break: break-word;
}

.autotag-run-log,
.autotag-history-main .autotag-log {
    min-height: 220px;
    max-height: 420px;
    overflow: auto;
    border: 1px solid var(--border-secondary);
    border-radius: 12px;
    padding: 14px;
    background: rgba(0, 0, 0, 0.28);
    color: var(--text-secondary);
    white-space: pre-wrap;
}

.autotag-run-empty {
    color: var(--text-muted);
    font-size: 13px;
}

@@media (max-width: 991.98px) {
    .autotag-history-layout {
        grid-template-columns: 1fr;
    }
}

@@media (max-width: 768px) {
    .tab-pane#history-content .card-body {
        overflow-x: hidden;
    }

    .autotag-calendar-card {
        padding: 12px;
    }

    .autotag-calendar-toolbar {
        gap: 8px;
        margin-bottom: 10px;
    }

    .autotag-calendar-toolbar .btn {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 32px;
    }

    .autotag-calendar-title {
        font-size: 14px;
        text-align: center;
        flex: 1 1 auto;
        min-width: 0;
    }

    .autotag-calendar-grid {
        gap: 6px;
    }

    .autotag-calendar-weekday {
        font-size: 10px;
        letter-spacing: 0.05em;
    }

    .autotag-calendar-day {
        min-height: 50px;
        padding: 6px;
        border-radius: 10px;
    }

    .autotag-calendar-day-number {
        font-size: 12px;
    }

    .autotag-calendar-day-count {
        font-size: 9px;
    }
}

@@media (max-width: 480px) {
    .autotag-calendar-card,
    .autotag-run-list-card,
    .autotag-run-detail-card {
        padding: 10px;
    }

    .autotag-calendar-grid {
        gap: 4px;
    }

    .autotag-calendar-weekday,
    .autotag-calendar-day {
        border-radius: 8px;
    }

    .autotag-calendar-weekday {
        font-size: 8px;
        letter-spacing: 0.03em;
    }

    .autotag-calendar-day {
        min-height: 44px;
        padding: 5px 4px;
    }

    .autotag-calendar-day-count {
        font-size: 8px;
    }
}


.downloads-tab .downloads-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
    align-items: center;
}

.downloads-tab .action-btn-amber {
    background-color: color-mix(in srgb, var(--warning-color) 25%, var(--bg-tertiary)) !important;
    border-color: var(--warning-color) !important;
    color: var(--text-secondary) !important;
}

.downloads-tab .action-btn-amber .material-icons,
.downloads-tab .action-btn-amber .btn-icon,
.downloads-tab .action-btn-amber .action-icon {
    color: var(--warning-color) !important;
}

.downloads-tab .action-btn .action-icon,
.logs-panel .action-btn .action-icon,
.logs-title .action-icon {
    width: 18px;
    height: 18px;
    display: inline-block;
    fill: currentColor;
    flex: 0 0 auto;
}

.logs-title .action-icon {
    width: 20px;
    height: 20px;
}

.downloads-tab .task-actions {
    display: flex;
    gap: 10px;
    margin-top: 12px;
}

.downloads-tab .completed-group {
    border: 1px solid var(--border-secondary);
    border-radius: 12px;
    padding: 12px;
    margin-bottom: 16px;
    background: var(--bg-secondary);
}

.downloads-tab .completed-group.collapsed {
    max-height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    border: 0;
}

.downloads-tab .completed-title {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 10px;
}

.downloads-tab .tasks-container {
    animation: fadeIn 0.6s ease-out 0.4s backwards;
    max-height: 60vh;
    overflow-y: auto;
    padding-right: 6px;
    scrollbar-color: var(--border-accent) var(--bg-tertiary);
    scrollbar-width: thin;
}

.downloads-tab .tasks-container::-webkit-scrollbar {
    width: 8px;
}

.downloads-tab .tasks-container::-webkit-scrollbar-track {
    background: var(--bg-tertiary);
}

.downloads-tab .tasks-container::-webkit-scrollbar-thumb {
    background: var(--border-accent);
    border-radius: 999px;
}

.downloads-tab .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.downloads-tab .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
}

.downloads-tab .task-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 12px;
    transition: border-color 0.2s ease, transform 0.2s ease;
}

.downloads-tab .task-card:hover {
    border-color: var(--primary-color);
    transform: translateX(4px);
}

.downloads-tab .task-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
}

.downloads-tab .task-index {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--bg-quaternary);
    border: 1px solid var(--border-secondary);
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.downloads-tab .task-icon {
    width: var(--art-thumb-size);
    height: var(--art-thumb-size);
    border-radius: 10px;
    background: var(--bg-quaternary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    font-size: 20px;
    color: var(--text-primary);
    overflow: hidden;
    isolation: isolate;
}

.downloads-tab .task-icon.cover {
    background-image: var(--task-cover-url);
    background-size: cover;
    background-position: center;
    color: transparent;
}

.downloads-tab .task-icon.cover::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 10px;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.15);
    z-index: 1;
}

.downloads-tab .task-icon.running {
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.25), 0 0 20px rgba(0, 212, 255, 0.2);
}

.downloads-tab .task-icon.running.cover .task-icon-fallback {
    display: none;
}

.downloads-tab .task-icon.running .download-flow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 4;
}

.downloads-tab .task-icon.running .download-flow::before {
    content: '';
    position: absolute;
    left: 50%;
    top: -10px;
    width: 2px;
    height: calc(100% - 16px);
    transform: translateX(-50%);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(0, 212, 255, 0.9), rgba(0, 212, 255, 0));
    opacity: 0.85;
}

.downloads-tab .task-icon.running .flow-packet {
    position: absolute;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: #9af4ff;
    box-shadow: 0 0 8px rgba(154, 244, 255, 0.95);
    animation: download-packet-drop 1.15s linear infinite;
}

.downloads-tab .task-icon.running .flow-packet.p2 {
    animation-delay: 0.36s;
}

.downloads-tab .task-icon.running .flow-packet.p3 {
    animation-delay: 0.72s;
}

.downloads-tab .task-icon.running .server-rack {
    position: absolute;
    left: 4px;
    right: 4px;
    bottom: 4px;
    height: 14px;
    border-radius: 5px;
    padding: 3px 4px;
    display: grid;
    gap: 2px;
    background: rgba(6, 19, 47, 0.75);
    border: 1px solid rgba(135, 205, 255, 0.6);
    backdrop-filter: blur(1px);
}

.downloads-tab .task-icon.running .rack-line {
    position: relative;
    border-radius: 4px;
    background: rgba(117, 193, 255, 0.22);
    overflow: hidden;
}

.downloads-tab .task-icon.running .rack-line::after {
    content: '';
    position: absolute;
    inset: 0;
    width: 35%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(52, 228, 255, 0.85), rgba(90, 148, 255, 0.95));
    box-shadow: 0 0 8px rgba(52, 228, 255, 0.8);
    animation: server-fill-cycle 1.5s ease-in-out infinite;
}

.downloads-tab .task-icon.running .rack-line.l2::after {
    animation-delay: 0.55s;
}

.downloads-tab .task-icon.running .rack-line.l3::after {
    animation-delay: 0.95s;
}

@@keyframes download-packet-drop {
    0% {
        top: -8px;
        opacity: 0;
    }
    20% {
        opacity: 1;
    }
    80% {
        opacity: 1;
    }
    100% {
        top: calc(100% - 20px);
        opacity: 0;
    }
}

@@keyframes server-fill-cycle {
    0%, 100% {
        width: 20%;
    }
    45% {
        width: 95%;
    }
    70% {
        width: 58%;
    }
}

@@media (prefers-reduced-motion: reduce) {
    .downloads-tab .task-icon.running .flow-packet,
    .downloads-tab .task-icon.running .rack-line::after {
        animation: none !important;
    }
}

.downloads-tab .task-icon.running:not(.cover) {
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.75);
}

.downloads-tab .task-icon-fallback {
    position: relative;
    z-index: 4;
}

.downloads-tab .task-info {
    flex: 1;
    min-width: 0;
}

.downloads-tab .task-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--text-primary);
}

.downloads-tab .task-artist {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.downloads-tab .task-activity {
    margin-top: 0.35rem;
    color: var(--accent-blue);
    font-size: 0.82rem;
    line-height: 1.3;
    min-height: 1.05rem;
}

.downloads-tab .task-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
}

.downloads-tab .badge {
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.downloads-tab .badge-status {
    background: rgba(0, 212, 255, 0.2);
    color: var(--accent-blue);
    border: 1px solid var(--accent-blue);
}

.downloads-tab .badge-complete {
    background: rgba(0, 255, 136, 0.2);
    color: var(--success);
    border: 1px solid var(--success);
}

.downloads-tab .badge-failed {
    background: rgba(255, 51, 102, 0.2);
    color: var(--error);
    border: 1px solid var(--error);
}

.downloads-tab .badge-skipped {
    background: rgba(255, 184, 0, 0.2);
    color: var(--warning);
    border: 1px solid var(--warning);
}

.downloads-tab .badge-quality {
    background: rgba(183, 68, 255, 0.2);
    color: var(--accent-purple);
    border: 1px solid var(--accent-purple);
}

.downloads-tab .badge-video-resolution {
    background: rgba(34, 197, 94, 0.2);
    color: #4ade80;
    border: 1px solid #4ade80;
}

.downloads-tab .badge-video-hdr {
    background: rgba(245, 158, 11, 0.2);
    color: #fbbf24;
    border: 1px solid #fbbf24;
}

.downloads-tab .badge-video-audio-atmos {
    background: rgba(56, 189, 248, 0.2);
    color: #38bdf8;
    border: 1px solid #38bdf8;
}

.downloads-tab .badge-video-audio-stereo {
    background: rgba(147, 197, 253, 0.2);
    color: #93c5fd;
    border: 1px solid #93c5fd;
}

.downloads-tab .badge-engine {
    background: rgba(255, 184, 0, 0.2);
    color: var(--warning);
    border: 1px solid var(--warning);
}

.downloads-tab .badge-fallback-step {
    background: rgba(148, 163, 184, 0.16);
    color: var(--text-primary);
    border: 1px solid rgba(148, 163, 184, 0.45);
    text-transform: none;
}

.downloads-tab .badge-fallback-step.is-active {
    background: rgba(0, 212, 255, 0.22);
    color: var(--accent-blue);
    border-color: var(--accent-blue);
}

.downloads-tab .badge-lyrics-synced {
    background: rgba(16, 185, 129, 0.2);
    color: #10b981;
    border: 1px solid #10b981;
}

.downloads-tab .badge-lyrics-timesynced {
    background: rgba(34, 211, 238, 0.2);
    color: #22d3ee;
    border: 1px solid #22d3ee;
}

.downloads-tab .badge-lyrics-unsynced {
    background: rgba(249, 115, 22, 0.2);
    color: #f97316;
    border: 1px solid #f97316;
}

.downloads-tab .progress-bar {
    width: 100%;
    height: 6px;
    background: var(--bg-quaternary);
    border-radius: 4px;
    overflow: hidden;
    margin: 1rem 0;
    position: relative;
}

.downloads-tab .progress-fill {
    height: 100%;
    background: var(--primary-color);
    border-radius: 4px;
    transition: width 2.8s linear;
    will-change: width;
    position: relative;
    overflow: hidden;
}

.downloads-tab .progress-text {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}

.logs-panel {
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.logs-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
}

.logs-title {
