function showDownloadActionError(message, fallbackMessage = 'Request failed.') {
    const notifier = window.DeezSpoTag?.Download?.showNotification
        || window.DeezSpoTag?.showNotification;
    if (notifier) {
        notifier(message || fallbackMessage, 'error');
    }
}

function getTaskById(taskId) {
    return tasks.find(task => task.taskId === taskId) || null;
}

function beginTaskAction(taskId) {
    const target = getTaskById(taskId);
    if (!target || target._actionInFlight || target._retryInFlight) {
        return null;
    }

    target._actionInFlight = true;
    scheduleRenderTasks();
    return target;
}

function endTaskAction(target) {
    if (!target || !target._actionInFlight) {
        return;
    }

    target._actionInFlight = false;
    scheduleRenderTasks();
}

