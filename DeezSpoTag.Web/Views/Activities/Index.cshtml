function applyLatestAnalysis(latest) {
    if (!latest) {
        return;
    }
    const track = latest.track;
    const analysis = latest.analysis;
    const trackLabel = track
        ? `${track.title} · ${track.artistName}`
        : 'Unknown';

    const modeLabel = analysis?.analysisMode || 'standard';
    const statusLabel = analysis?.status || 'unknown';

    const trackEl = document.getElementById('analysisLatestTrack');
    const modeEl = document.getElementById('analysisLatestMode');
    const atEl = document.getElementById('analysisLatestAt');
    const statusEl = document.getElementById('analysisLatestStatus');
    if (trackEl) trackEl.textContent = trackLabel;
    if (modeEl) modeEl.textContent = modeLabel;
    if (atEl) atEl.textContent = formatTimestamp(analysis?.analyzedAtUtc);
    if (statusEl) statusEl.textContent = statusLabel;

    const moodTagsEl = document.getElementById('analysisMoodTags');
    const essentiaEl = document.getElementById('analysisEssentiaGenres');
    const lastfmEl = document.getElementById('analysisLastfmTags');
    if (moodTagsEl) moodTagsEl.textContent = formatList(analysis?.moodTags);
    if (essentiaEl) essentiaEl.textContent = formatList(analysis?.essentiaGenres);
    if (lastfmEl) lastfmEl.textContent = formatList(analysis?.lastfmTags);

    const keyText = analysis?.key
        ? `${analysis.key}${analysis.keyScale ? ` ${analysis.keyScale}` : ''}`
        : '--';

    const setValue = (id, value) => {
        const el = document.getElementById(id);
        if (el) {
            el.textContent = value;
        }
    };

    setValue('analysisFeatureBpm', analysis?.bpm ?? '--');
    setValue('analysisFeatureBeats', analysis?.beatsCount ?? '--');
    setValue('analysisFeatureKey', keyText);
    setValue('analysisFeatureKeyStrength', formatNumber(analysis?.keyStrength));
    setValue('analysisFeatureEnergy', formatNumber(analysis?.energy));
    setValue('analysisFeatureLoudness', formatNumber(analysis?.loudness));
    setValue('analysisFeatureDynamicRange', formatNumber(analysis?.dynamicRange));
    setValue('analysisFeatureDanceability', formatNumber(analysis?.danceability));
    setValue('analysisFeatureDanceabilityMl', formatNumber(analysis?.danceabilityMl));
    setValue('analysisFeatureInstrumentalness', formatNumber(analysis?.instrumentalness));
    setValue('analysisFeatureAcousticness', formatNumber(analysis?.acousticness));
    setValue('analysisFeatureSpeechiness', formatNumber(analysis?.speechiness));
    setValue('analysisFeatureValence', formatNumber(analysis?.valence));
    setValue('analysisFeatureArousal', formatNumber(analysis?.arousal));

    setValue('analysisMoodHappy', formatNumber(analysis?.moodHappy));
    setValue('analysisMoodSad', formatNumber(analysis?.moodSad));
    setValue('analysisMoodRelaxed', formatNumber(analysis?.moodRelaxed));
    setValue('analysisMoodAggressive', formatNumber(analysis?.moodAggressive));
    setValue('analysisMoodParty', formatNumber(analysis?.moodParty));
    setValue('analysisMoodAcoustic', formatNumber(analysis?.moodAcoustic));
    setValue('analysisMoodElectronic', formatNumber(analysis?.moodElectronic));

    const analyzedAt = analysis?.analyzedAtUtc || new Date().toISOString();
    const key = `${track?.trackId ?? track?.id ?? 'unknown'}-${analyzedAt}`;
    if (!analysisRecent.find(item => item.key === key)) {
        analysisRecent.unshift({
            key,
            title: trackLabel,
            status: statusLabel,
            at: analyzedAt
        });
        if (analysisRecent.length > 10) {
            analysisRecent.pop();
        }
    }
    renderAnalysisRecent();

    if (key !== lastAnalysisLogKey) {
        const logger = window.DeezSpoTag?.DownloadLogger;
        const message = `Vibe analysis: ${trackLabel} (${statusLabel})`;
        logger?.info?.(message, { engine: 'analysis', timestamp: analyzedAt });
        lastAnalysisLogKey = key;
    }
}

async function loadLatestAnalysis() {
    try {
        const latest = await fetchJson('/api/library/analysis/latest');
        applyLatestAnalysis(latest);
    } catch (error) {
