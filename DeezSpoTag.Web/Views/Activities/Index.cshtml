async function loadAnalysisSettings() {
    const enabledEl = document.getElementById('analysis-enabled');
    if (!enabledEl) {
        return;
    }
    try {
        const response = await activityFetch('/api/library/analysis/settings');
        if (!response.ok) {
            throw new Error(await response.text());
        }
        const settings = await response.json();
        enabledEl.checked = settings.enabled ?? true;
        analysisSettingsState.enabled = enabledEl.checked;
        analysisSettingsState.batchSize = settings.batchSize ?? 50;
        analysisSettingsState.intervalMinutes = settings.intervalMinutes ?? 30;
        const batchSize = document.getElementById('analysis-batch-size');
        const intervalMinutes = document.getElementById('analysis-interval-minutes');
        if (batchSize) batchSize.value = settings.batchSize ?? 50;
        if (intervalMinutes) intervalMinutes.value = settings.intervalMinutes ?? 30;
        updateAnalysisStatusPill();
    } catch (error) {
        console.warn('Analysis settings failed to load.', error);
    }
}

function buildAnalysisPayload(useStateValues = false, enabledOverride) {
    if (useStateValues) {
        return {
            enabled: enabledOverride ?? analysisSettingsState.enabled,
            batchSize: analysisSettingsState.batchSize ?? 50,
            intervalMinutes: analysisSettingsState.intervalMinutes ?? 30
        };
    }

    return {
        enabled: enabledOverride ?? (document.getElementById('analysis-enabled')?.checked ?? analysisSettingsState.enabled),
        batchSize: Number(document.getElementById('analysis-batch-size')?.value || analysisSettingsState.batchSize || 50),
        intervalMinutes: Number(document.getElementById('analysis-interval-minutes')?.value || analysisSettingsState.intervalMinutes || 30)
    };
}

async function saveAnalysisEnabled(enabled) {
    const enabledEl = document.getElementById('analysis-enabled');
    const previous = enabledEl?.checked;
    if (enabledEl) {
        enabledEl.checked = enabled;
    }
    const payload = buildAnalysisPayload(true, enabled);
    try {
        const response = await activityFetch('/api/library/analysis/settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        if (!response.ok) {
            throw new Error(await response.text());
        }
        analysisSettingsState.enabled = payload.enabled;
        analysisSettingsState.batchSize = payload.batchSize;
        analysisSettingsState.intervalMinutes = payload.intervalMinutes;
        updateAnalysisStatusPill();
        notifyActivity(`Vibe analysis ${payload.enabled ? 'enabled' : 'disabled'}.`);
        return true;
    } catch (error) {
        if (enabledEl) {
            enabledEl.checked = previous ?? analysisSettingsState.enabled;
        }
        notifyActivity(`Failed to update analysis toggle: ${error?.message || error}`, 'error');
        return false;
    }
}

async function saveAnalysisSettings(silentSuccess) {
    const enabledEl = document.getElementById('analysis-enabled');
    if (!enabledEl) {
        return false;
    }
    const payload = buildAnalysisPayload(false);
    try {
        const response = await activityFetch('/api/library/analysis/settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        if (!response.ok) {
            throw new Error(await response.text());
        }
        analysisSettingsState.enabled = payload.enabled;
        analysisSettingsState.batchSize = payload.batchSize;
        analysisSettingsState.intervalMinutes = payload.intervalMinutes;
        if (!silentSuccess) {
            notifyActivity(`Vibe analysis ${payload.enabled ? 'enabled' : 'disabled'}.`);
        }
        return true;
    } catch (error) {
        notifyActivity(`Failed to save analysis settings: ${error?.message || error}`, 'error');
        return false;
    }
}

	let libraryLogsRefreshTimer = null;
	const libraryLogKeys = new Set();
	let libraryLogsInFlight = false;
	let libraryLogsAbortController = null;
	const LIBRARY_LOGS_POLL_MS = 10000;
	const LIBRARY_LOGS_LIMIT = 500;
	const LIBRARY_LOG_KEYS_MAX = 5000;

    function buildLibraryLogKey(entry) {
        const timestamp = entry?.timestampUtc ?? '';
        const level = String(entry?.level ?? '').toLowerCase();
        const message = String(entry?.message ?? '').toLowerCase();
        return `${timestamp}|${level}|${message}`;
    }

	function startLibraryLogsAutoRefresh() {
	    if (libraryLogsRefreshTimer) {
	        return;
	    }
	    libraryLogsRefreshTimer = setInterval(() => {
	        if (document.hidden) {
	            return;
	        }
	        loadLibraryLogs();
	    }, LIBRARY_LOGS_POLL_MS);
	}

function renderAnalysisRecent() {
    const list = document.getElementById('analysisRecentList');
    if (!list) return;
    if (!analysisRecent.length) {
        list.innerHTML = `
            <li class="analysis-recent-item">
                <div class="analysis-recent-meta">
                    <span class="analysis-recent-title">No recent analyses yet</span>
                </div>
            </li>`;
        return;
    }
    const items = [];
    if (analysisProcessing) {
        items.push({
            title: analysisProcessing.title,
            status: analysisProcessing.status || 'processing',
            at: analysisProcessing.at
        });
    }
    items.push(...analysisRecent);

    list.innerHTML = items
        .filter(item => (item.status || '').toLowerCase() !== 'completed')
        .map(item => {
            const time = formatTimestamp(item.at);
            return `
                <li class="analysis-recent-item">
                    <div class="analysis-recent-meta">
                        <span class="analysis-recent-title">${escapeHtml(item.title)}</span>
                        <span class="analysis-recent-status">${escapeHtml(item.status)}</span>
