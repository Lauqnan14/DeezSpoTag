}

function smoothQueueProgressBars() {
    const fills = document.querySelectorAll('.downloads-tab .progress-fill[data-progress-target]');
    if (!fills.length) {
        return;
    }
    requestAnimationFrame(() => {
        fills.forEach((fill) => {
            const target = clampQueueProgressPercent(fill.dataset.progressTarget);
            const start = clampQueueProgressPercent(fill.dataset.progressStart);
            if (Number.isFinite(target)) {
                fill.style.width = `${target}%`;
            }
            const taskCard = fill.closest('.task-card');
            const taskId = taskCard?.dataset.taskId || '';
            const valueEl = taskCard?.querySelector('.progress-value');
            if (!valueEl || !taskId) {
                return;
            }
            animateQueueProgress(taskId, fill, valueEl, start, target);
        });
    });
}

function clampQueueProgressPercent(value) {
    const numeric = Number(value);
    if (!Number.isFinite(numeric)) {
        return 0;
    }
    const normalized = (numeric > 0 && numeric < 1) ? numeric * 100 : numeric;
    return Math.max(0, Math.min(100, normalized));
}

function normalizeQueueProgressPercent(value) {
    return clampQueueProgressPercent(value);
}

function formatQueueProgressPercent(value) {
    return Math.round(clampQueueProgressPercent(value));
}

function animateQueueProgress(taskId, fillEl, valueEl, start, target) {
    const startValue = clampQueueProgressPercent(start);
    const targetValue = clampQueueProgressPercent(target);
    if (queueProgressTextAnimationByTask[taskId] != null) {
        cancelAnimationFrame(queueProgressTextAnimationByTask[taskId]);
        delete queueProgressTextAnimationByTask[taskId];
    }

    if (startValue === targetValue) {
        fillEl.style.width = `${targetValue}%`;
        valueEl.textContent = `${formatQueueProgressPercent(targetValue)}%`;
        queueProgressCache[taskId] = targetValue;
        return;
    }

    const startTime = performance.now();
    const delta = targetValue - startValue;
    const step = (now) => {
        if (!document.body.contains(valueEl) || !document.body.contains(fillEl)) {
            delete queueProgressTextAnimationByTask[taskId];
            return;
        }

        const t = Math.min(1, (now - startTime) / queueProgressAnimationDurationMs);
        const current = clampQueueProgressPercent(startValue + (delta * t));
        queueProgressCache[taskId] = current;
        fillEl.style.width = `${current}%`;
        valueEl.textContent = `${formatQueueProgressPercent(current)}%`;

        if (t < 1) {
            queueProgressTextAnimationByTask[taskId] = requestAnimationFrame(step);
        } else {
            queueProgressCache[taskId] = targetValue;
            delete queueProgressTextAnimationByTask[taskId];
        }
    };

    queueProgressTextAnimationByTask[taskId] = requestAnimationFrame(step);
}

function updateQueueProgressDom(taskId, progress) {
    const selectorTaskId = escapeCssSelectorValue(taskId);
    if (!selectorTaskId) {
        return false;
    }

    const taskCard = document.querySelector(`.task-card[data-task-id="${selectorTaskId}"]`);
    if (!taskCard) {
        return false;
    }

    const fillEl = taskCard.querySelector('.progress-fill[data-progress-target]');
    const valueEl = taskCard.querySelector('.progress-value');
    if (!fillEl || !valueEl) {
        return false;
    }

    const targetValue = clampQueueProgressPercent(progress);
    const startValue = Number.isFinite(queueProgressCache[taskId])
        ? clampQueueProgressPercent(queueProgressCache[taskId])
        : targetValue;
    fillEl.dataset.progressTarget = String(targetValue);
    fillEl.dataset.progressStart = String(startValue);
    valueEl.dataset.progressTarget = String(targetValue);
    valueEl.dataset.progressStart = String(startValue);
    animateQueueProgress(taskId, fillEl, valueEl, startValue, targetValue);
    return true;
}

function orderTasksForAutoScroll(taskList, options) {
    const list = Array.isArray(taskList) ? [...taskList] : [];
    const isTerminal = (status) => status === 'complete' || status === 'failed' || status === 'canceled';
    const terminal = list.filter(task => isTerminal(task.status));
    const activeAndQueued = list.filter(task => !isTerminal(task.status));

    if (options?.pinActive === false) {
        return [...terminal, ...activeAndQueued];
    }

    const running = activeAndQueued.filter(task => task.status === 'running');
    if (running.length === 0) {
        return [...terminal, ...activeAndQueued];
    }

    const runningIds = new Set(running.map(task => task.taskId));
    const rest = activeAndQueued.filter(task => !runningIds.has(task.taskId));
    return [...terminal, ...running, ...rest];
}

function updateStats() {
    const counts = tasks.reduce((acc, task) => {
        const bucket = (task.status === 'paused' || task.status === 'retrying') ? 'queued' : task.status;
        acc[bucket] = (acc[bucket] || 0) + 1;
        return acc;
    }, {});

    const queued = document.getElementById('stat-queued');
    const running = document.getElementById('stat-running');
    const complete = document.getElementById('stat-complete');
    const failed = document.getElementById('stat-failed');
    const canceled = document.getElementById('stat-canceled');

    if (queued) queued.textContent = counts.queued || 0;
    if (running) running.textContent = counts.running || 0;
    if (complete) complete.textContent = counts.complete || 0;
    if (failed) failed.textContent = counts.failed || 0;
    if (canceled) canceled.textContent = counts.canceled || 0;
}

function toggleQueue() {
    const nextState = queueState === 'running' ? 'paused' : 'running';
    if (nextState === 'paused') {
        pauseQueue();
    } else {
        resumeQueue();
    }
    updateToggleQueueUi(nextState);
}

function updateToggleQueueUi(state) {
    const btn = document.getElementById('toggleBtn');
    const icon = document.getElementById('btnIcon');
    const text = document.getElementById('btnText');
    const badge = document.getElementById('statusBadge');

    if (!btn || !icon || !text || !badge) return;

    if (state === 'running') {
        btn.classList.add('btn-pause');
        icon.textContent = '⏸';
        text.textContent = 'Pause Queue';
        badge.className = 'status-badge status-active';
        badge.textContent = '● Active';
    } else {
        btn.classList.remove('btn-pause');
        icon.textContent = '▶';
        text.textContent = 'Start Queue';
        badge.className = 'status-badge status-paused';
        badge.textContent = '○ Paused';
    }
}

function retryTask(taskId) {
    const target = tasks.find(task => task.taskId === taskId);
    if (target) {
        if (target._retryInFlight || target._actionInFlight) {
            return;
        }
        target._retryPreviousStatus = target.status;
        target._retryPreviousError = target.error;
        target._retryInFlight = true;
        target._actionInFlight = true;
        target.status = 'retrying';
        target.error = null;
        scheduleRenderTasks();
        updateStats();
    }

    activityFetch('/Activities/RetryFailed', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ uuid: taskId })
    })
        .then(async response => {
            const contentType = response.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json');
            const data = isJson ? await response.json() : await response.text();
            if (!response.ok || (data && typeof data === 'object' && data.success === false)) {
                const message = (data && typeof data === 'object' ? (data.error || data.message) : data) || 'Retry failed';
                throw new Error(message);
            }
            return data;
        })
        .then((data) => {
            const target = tasks.find(task => task.taskId === taskId);
            const updatedId = data?.newUuid || taskId;
            if (target) {
                target.taskId = updatedId;
                target.status = 'queued';
                target.progress = 0;
                target.failed = 0;
                target.error = null;
                target._retryInFlight = false;
                target._actionInFlight = false;
                delete target._retryPreviousError;
                delete target._retryPreviousStatus;
                if (data?.engine) {
                    target.engine = data.engine;
                }
            }
            scheduleRenderTasks();
            updateStats();
            loadQueueFromServer({ force: true });
        })
        .catch(error => {
            if (target) {
                target.status = target._retryPreviousStatus || 'failed';
                target.error = target._retryPreviousError || target.error || null;
                target._retryInFlight = false;
                target._actionInFlight = false;
                delete target._retryPreviousError;
                delete target._retryPreviousStatus;
                scheduleRenderTasks();
                updateStats();
            }
            const notifier = window.DeezSpoTag?.Download?.showNotification
                || window.DeezSpoTag?.showNotification;
            if (notifier) {
                notifier(error.message || 'Retry failed', 'warning');
            }
            console.error(`Failed to retry task ${taskId}:`, error);
        });
}

async function deleteFailedTask(taskId) {
    const target = beginTaskAction(taskId);
    if (!target) {
        return;
    }

    const confirmed = await confirmAction('Remove this item from the queue? This cannot be undone.', 'Delete Download');
    if (!confirmed) {
        endTaskAction(target);
        return;
    }

    try {
        await ensureJsonActionSuccess('/Activities/DeleteFailed', { uuid: taskId });
        await loadQueueFromServer({ force: true });
    } catch (error) {
        console.error(`Failed to delete task ${taskId}:`, error);
        showDownloadActionError(error?.message, 'Failed to delete download.');
    } finally {
        endTaskAction(target);
    }
}

