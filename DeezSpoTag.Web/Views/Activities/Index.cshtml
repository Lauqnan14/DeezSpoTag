function notifyActivity(message, type = 'info') {
    if (window.DeezSpoTag?.showNotification) {
        window.DeezSpoTag.showNotification(message, type);
    }
}

function applyLibraryScanProgress(status, phaseLabel, progressLabel, progressBar, label) {
    if (!status) {
        return;
    }
    const progress = status.progress || {};
    const processed = progress.processedFiles ?? 0;
    const total = progress.totalFiles ?? 0;
    const running = Boolean(status.running);
    const percent = total > 0 ? Math.min(100, Math.max(0, (processed / total) * 100)) : (running ? 5 : 0);
    const rawFile = progress.currentFile || '';
    const currentFile = rawFile ? rawFile.split(/[\\/]/).pop() : '';
    if (phaseLabel) {
        if (running) {
            phaseLabel.textContent = currentFile ? `${label} · ${currentFile}` : `${label} running`;
        }
    }
    if (progressLabel) {
        if (running) {
            const suffix = total > 0 ? `${processed} / ${total} files (${percent.toFixed(1)}%)` : `${processed} files scanned`;
            progressLabel.textContent = suffix;
        }
    }
    if (progressBar) {
        progressBar.style.width = `${percent}%`;
    }
}

function applyMetadataUpdaterStatus(status, phaseLabel, progressLabel, progressBar) {
    if (!status) {
        return;
    }

    const total = Number(status.totalArtists || 0);
    const processed = Number(status.processedArtists || 0);
    const running = Boolean(status.running);
    const succeeded = Number(status.successfulArtists || 0);
    const failed = Number(status.failedArtists || 0);
    const skipped = Number(status.skippedArtists || 0);
    const currentArtist = status.currentArtist || '';
    const phase = status.phase || (running ? 'Metadata update running' : 'Metadata updater idle');
    const message = status.message || '';

    if (phaseLabel) {
        if (running && currentArtist) {
            phaseLabel.textContent = `${phase} · ${currentArtist}`;
        } else {
            phaseLabel.textContent = phase;
        }
    }

    if (progressLabel) {
        if (total > 0) {
            progressLabel.textContent = `${processed} / ${total} artists (${succeeded} success, ${failed} failed, ${skipped} skipped)`;
        } else if (message) {
            progressLabel.textContent = message;
        } else {
            progressLabel.textContent = '0 / 0 artists';
        }
    }

    if (progressBar) {
        const percent = total > 0 ? Math.min(100, Math.max(0, (processed / total) * 100)) : (running ? 8 : 0);
        progressBar.style.width = `${percent}%`;
    }
}

function initMetadataUpdater() {
    const updateButton = document.getElementById('metadata-update-button');
    const refreshCacheButton = document.getElementById('metadata-refresh-cache-button');
    const cancelButton = document.getElementById('metadata-cancel-button');
    const sourceSelect = document.getElementById('metadata-source-platform');
    const intervalSelect = document.getElementById('metadata-refresh-interval');
    const targetSelect = document.getElementById('metadata-target-server');
    const phaseLabel = document.getElementById('metadata-phase-label');
    const progressLabel = document.getElementById('metadata-progress-label');
    const progressBar = document.getElementById('metadata-progress-bar');

    if (!updateButton && !refreshCacheButton) {
        return;
    }

    const targetKey = 'deezspotag-metadata-updater-target';
    const sourceKey = 'deezspotag-metadata-updater-source';

    const runMetadataUpdater = async () => {
        const source = sourceSelect?.value || 'auto';
        const intervalDays = Number(intervalSelect?.value || 30);
        const target = targetSelect?.value || 'plex';
        const payload = {
            source,
            intervalDays,
            target,
            includeAllArtists: true,
            force: intervalDays === 0
        };

        try {
            const response = await activityFetch('/api/library/spotify-cache/metadata-updater/run', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
                keepalive: true
            });
            if (!response.ok) {
                throw new Error(await response.text());
            }
            const result = await response.json().catch(() => null);
            if (result?.queued) {
                notifyActivity('Metadata updater started.');
            } else {
                notifyActivity('Metadata updater is already running.', 'warning');
            }
            if (result?.status) {
                applyMetadataUpdaterStatus(result.status, phaseLabel, progressLabel, progressBar);
            }
        } catch (error) {
            notifyActivity(`Metadata updater failed: ${error?.message || error}`, 'error');
        }
    };

    if (refreshCacheButton) {
        refreshCacheButton.addEventListener('click', async () => {
            try {
                const response = await activityFetch('/api/library/spotify-cache/refresh', { method: 'POST', keepalive: true });
                if (!response.ok) {
                    throw new Error(await response.text());
                }
                notifyActivity('Metadata cache refresh started.');
            } catch (error) {
                notifyActivity(`Metadata cache refresh failed: ${error?.message || error}`, 'error');
            }
        });
    }
    if (cancelButton) {
        cancelButton.addEventListener('click', () => {
            notifyActivity('Metadata updater cancellation is not available yet.', 'warning');
        });
        cancelButton.disabled = true;
    }

    if (targetSelect) {
        const savedTarget = localStorage.getItem(targetKey) || 'plex';
        if (savedTarget) {
            targetSelect.value = savedTarget;
        }
        targetSelect.addEventListener('change', () => {
            localStorage.setItem(targetKey, targetSelect.value);
            if (window.UserPrefs) window.UserPrefs.set('metadataUpdaterTarget', targetSelect.value);
        });
    }

    if (sourceSelect) {
        const savedSource = localStorage.getItem(sourceKey) || 'auto';
        if (savedSource) {
            sourceSelect.value = savedSource;
        }
        sourceSelect.addEventListener('change', () => {
            localStorage.setItem(sourceKey, sourceSelect.value);
            if (window.UserPrefs) window.UserPrefs.set('metadataUpdaterSource', sourceSelect.value);
        });
    }

    updateButton?.addEventListener('click', async () => {
        phaseLabel && (phaseLabel.textContent = 'Metadata update started');
        progressLabel && (progressLabel.textContent = 'Preparing run...');
        progressBar && (progressBar.style.width = '5%');
        await runMetadataUpdater(false);
    });
}

async function loadDatabaseUpdaterFolders() {
    const folderSelect = document.getElementById('db-library-folder');
    if (!folderSelect) {
        return;
    }

    const previousValue = folderSelect.value;
    try {
        const response = await activityFetch('/api/library/folders');
        if (!response.ok) {
            throw new Error(await response.text());
        }
        const folders = await response.json();
        folderSelect.innerHTML = '<option value="">All libraries</option>';
        if (Array.isArray(folders)) {
            folders.forEach(folder => {
                const option = document.createElement('option');
                option.value = String(folder.id);
                option.textContent = folder.displayName || folder.libraryName || folder.rootPath || `Folder ${folder.id}`;
                folderSelect.appendChild(option);
            });
        }
        if (previousValue) {
            folderSelect.value = previousValue;
        }
    } catch (error) {
        console.error('Failed to load library folders for database updater:', error);
    }
}

async function loadDatabaseUpdaterStatus() {
    try {
        const response = await activityFetch('/api/library/scan/status');
        if (!response.ok) {
            throw new Error(await response.text());
        }
        const status = await response.json();
        const lastRunUtc = status?.lastRunUtc;
        const counts = status?.lastCounts;
        const lastRefresh = document.getElementById('db-last-refresh');
        const artistStat = document.getElementById('db-stat-artists');
        const albumStat = document.getElementById('db-stat-albums');
        const trackStat = document.getElementById('db-stat-tracks');

        if (lastRefresh) {
            lastRefresh.textContent = lastRunUtc ? new Date(lastRunUtc).toLocaleString() : 'Never';
        }
        if (artistStat) {
            artistStat.textContent = `${counts?.artists ?? 0}`;
        }
        if (albumStat) {
            albumStat.textContent = `${counts?.albums ?? 0}`;
        }
        if (trackStat) {
            trackStat.textContent = `${counts?.tracks ?? 0}`;
        }
    } catch (error) {
        console.error('Failed to load database updater status:', error);
    }
}

async function waitForDatabaseUpdate(startedAtMs) {
    const phaseLabel = document.getElementById('db-phase-label');
    const progressLabel = document.getElementById('db-progress-label');
    const progressBar = document.getElementById('db-progress-bar');
    const deadline = startedAtMs + (15 * 60 * 1000);

    while (Date.now() < deadline) {
        try {
            const response = await activityFetch('/api/library/scan/status');
            if (!response.ok) {
                throw new Error(await response.text());
            }
            const status = await response.json();
            applyLibraryScanProgress(status, phaseLabel, progressLabel, progressBar, 'Database update');
            const lastRunUtc = status?.lastRunUtc;
            if (lastRunUtc) {
                const lastRunMs = Date.parse(lastRunUtc);
                if (!Number.isNaN(lastRunMs) && lastRunMs >= startedAtMs) {
                    phaseLabel && (phaseLabel.textContent = 'Database update completed');
                    progressLabel && (progressLabel.textContent = 'Update completed');
                    progressBar && (progressBar.style.width = '100%');
                    await loadDatabaseUpdaterStatus();
                    notifyActivity('Database update completed.');
                    return;
                }
            }
            if (!status?.running && Date.now() - startedAtMs > 15000) {
                phaseLabel && (phaseLabel.textContent = 'Database update stopped');
                notifyActivity('Database update stopped.', 'warning');
                return;
            }
        } catch {
            // Ignore polling errors; try again.
        }
        await new Promise(resolve => setTimeout(resolve, 3000));
    }

    phaseLabel && (phaseLabel.textContent = 'Database update running');
    notifyActivity('Database update still running.', 'info');
}

function initDatabaseUpdater() {
    const updateButton = document.getElementById('db-update-button');
    const cancelButton = document.getElementById('db-cancel-button');
    const refreshSelect = document.getElementById('db-refresh-type');
    const folderSelect = document.getElementById('db-library-folder');
    const phaseLabel = document.getElementById('db-phase-label');
    const progressLabel = document.getElementById('db-progress-label');
    const progressBar = document.getElementById('db-progress-bar');

    if (!updateButton) {
        return;
    }

    updateButton.addEventListener('click', async () => {
        try {
            const params = new URLSearchParams();
            const refreshType = refreshSelect?.value || 'incremental';
            params.set('reset', refreshType === 'full' ? 'true' : 'false');
            const folderId = folderSelect?.value;
            if (folderId) {
                params.set('folderId', folderId);
            }
            const url = `/api/library/scan?${params.toString()}`;

            phaseLabel && (phaseLabel.textContent = 'Database update started');
            progressLabel && (progressLabel.textContent = 'Starting...');
            progressBar && (progressBar.style.width = '5%');
            const response = await activityFetch(url, { method: 'POST', keepalive: true });
            if (!response.ok) {
                throw new Error(await response.text());
            }
            notifyActivity('Database update started.');
            await waitForDatabaseUpdate(Date.now());
        } catch (error) {
            phaseLabel && (phaseLabel.textContent = 'Database update failed');
            notifyActivity(`Database update failed: ${error?.message || error}`, 'error');
        }
    });

    if (cancelButton) {
        cancelButton.addEventListener('click', async () => {
            try {
                const response = await activityFetch('/api/library/scan/cancel', { method: 'POST' });
                if (response.ok) {
                    const payload = await response.json();
                    notifyActivity(payload?.cancelled ? 'Library scan cancelled.' : 'No scan running.', payload?.cancelled ? 'info' : 'warning');
                }
            } catch (error) {
                notifyActivity(`Cancel failed: ${error?.message || error}`, 'error');
            }
        });
    }

    void loadDatabaseUpdaterFolders();
    void loadDatabaseUpdaterStatus();
}

let libraryScanPollId = null;
function isMediaOperationsTabActive() {
    const pane = document.getElementById('media-operations-content');
    return !!pane?.classList.contains('active');
}

function startLibraryScanStatusPolling() {
    if (libraryScanPollId) {
        return;
    }
    const dbPhase = document.getElementById('db-phase-label');
    const dbProgressLabel = document.getElementById('db-progress-label');
    const dbProgressBar = document.getElementById('db-progress-bar');
    const dbCancel = document.getElementById('db-cancel-button');
    const dbUpdate = document.getElementById('db-update-button');
    const metadataPhase = document.getElementById('metadata-phase-label');
    const metadataProgressLabel = document.getElementById('metadata-progress-label');
    const metadataProgressBar = document.getElementById('metadata-progress-bar');
    const metadataUpdate = document.getElementById('metadata-update-button');

    libraryScanPollId = setInterval(async () => {
        if (document.hidden || !isMediaOperationsTabActive()) {
            return;
        }

        try {
            const response = await activityFetch('/api/library/scan/status');
            if (!response.ok) {
                return;
            }
            const status = await response.json();
            const running = Boolean(status?.running);
            if (dbCancel) dbCancel.disabled = !running;
            if (dbUpdate) dbUpdate.disabled = running;

            if (running) {
                applyLibraryScanProgress(status, dbPhase, dbProgressLabel, dbProgressBar, 'Database update');
            }
        } catch {
            // ignore polling errors
        }

        try {
            const metadataResponse = await activityFetch('/api/library/spotify-cache/metadata-updater/status');
            if (!metadataResponse.ok) {
                return;
            }
            const metadataStatus = await metadataResponse.json();
            applyMetadataUpdaterStatus(metadataStatus, metadataPhase, metadataProgressLabel, metadataProgressBar);
            if (metadataUpdate) {
                metadataUpdate.disabled = Boolean(metadataStatus?.running);
            }
        } catch {
            // ignore polling errors
        }
    }, 5000);
}

function initMediaServerScan() {
    const scanButton = document.getElementById('media-scan-button');
    const statusLabel = document.getElementById('media-scan-status');
    const lastScanLabel = document.getElementById('media-scan-last-time');
    const phaseLabel = document.getElementById('media-scan-phase');
    const progressLabel = document.getElementById('media-scan-progress-label');
    const progressBar = document.getElementById('media-scan-progress-bar');

    if (!scanButton) {
        return;
    }

    scanButton.addEventListener('click', async () => {
        try {
            statusLabel && (statusLabel.textContent = 'Scanning');
            phaseLabel && (phaseLabel.textContent = 'Scan started');
            progressLabel && (progressLabel.textContent = 'Scanning libraries...');
            progressBar && (progressBar.style.width = '10%');
            notifyActivity('Media server scan started.');

            const response = await activityFetch('/api/media-server/scan', { method: 'POST', keepalive: true });
            if (!response.ok) {
                throw new Error(await response.text());
            }
            const payload = await response.json().catch(() => null);
            if (payload && payload.success === false) {
                phaseLabel && (phaseLabel.textContent = payload.message || 'Scan skipped');
                progressLabel && (progressLabel.textContent = payload.message || 'No libraries refreshed');
                progressBar && (progressBar.style.width = '0%');
                statusLabel && (statusLabel.textContent = 'Idle');
                notifyActivity(payload.message || 'Media server scan skipped.', 'warning');
                return;
            }

            lastScanLabel && (lastScanLabel.textContent = new Date().toLocaleString());
            phaseLabel && (phaseLabel.textContent = 'Scan completed');
            progressLabel && (progressLabel.textContent = `${payload?.refreshed ?? 0} libraries refreshed`);
            progressBar && (progressBar.style.width = '100%');
            statusLabel && (statusLabel.textContent = 'Idle');
            notifyActivity('Media server scan completed.');
        } catch (error) {
            statusLabel && (statusLabel.textContent = 'Error');
            phaseLabel && (phaseLabel.textContent = 'Scan failed');
            progressLabel && (progressLabel.textContent = 'Unable to refresh media server');
            progressBar && (progressBar.style.width = '0%');
            notifyActivity(`Media server scan failed: ${error?.message || error}`, 'error');
        }
    });
}

