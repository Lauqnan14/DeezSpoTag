        await loadAnalysisStatus();
        await loadLatestAnalysis();
    } catch (error) {
        notifyActivity(`Reset failed: ${error?.message || error}`, 'error');
    } finally {
        if (button) button.disabled = false;
    }
}

function stopAnalysisPolling() {
    if (analysisPollTimeoutId) {
        clearTimeout(analysisPollTimeoutId);
        analysisPollTimeoutId = null;
    }
}

function startAnalysisPolling() {
    if (analysisPollTimeoutId) {
        return;
    }
    analysisPollTimeoutId = setTimeout(async () => {
        analysisPollTimeoutId = null;
        if (document.hidden) {
            startAnalysisPolling();
            return;
        }
        if (!isMediaOperationsTabActive()) {
            startAnalysisPolling();
            return;
        }
        if (analysisPollInFlight) {
            startAnalysisPolling();
            return;
        }
        analysisPollInFlight = true;
        try {
            await loadAnalysisActivity();
            await loadAnalysisStatus();
            await loadLatestAnalysis();
            await loadProcessingAnalysis();
        } finally {
            analysisPollInFlight = false;
        }
        startAnalysisPolling();
    }, analysisPollDelayMs);
}

