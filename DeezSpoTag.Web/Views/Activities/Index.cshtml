    border: 1px solid color-mix(in srgb, var(--primary-color) 20%, var(--border-secondary));
    border-radius: 14px;
    padding: 12px 14px;
    box-shadow: 0 4px 14px color-mix(in srgb, #000 25%, transparent);
}

.media-operations-tab .progress-bar-container {
    position: relative;
    height: 12px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary-color) 8%, var(--bg-secondary));
    overflow: hidden;
    box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--text-secondary) 8%, transparent),
        0 0 0 1px color-mix(in srgb, var(--primary-color) 18%, var(--border-secondary));
}

.media-operations-tab .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg,
        color-mix(in srgb, var(--primary-color) 85%, #00c8ff),
        color-mix(in srgb, var(--accent-color) 70%, #00c8ff));
    width: 0;
    transition: width 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 0 12px color-mix(in srgb, var(--primary-color) 55%, transparent);
    border-radius: inherit;
}

.media-operations-tab .progress-phase-label,
.media-operations-tab .progress-details-label,
.media-operations-tab .analysis-meta,
.media-operations-tab .analysis-status {
