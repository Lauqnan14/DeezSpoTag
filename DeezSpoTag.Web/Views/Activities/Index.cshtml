        if (trackEl) trackEl.textContent = 'No analyzed tracks yet';
    }
}

async function loadAnalysisStatus() {
    const statusEl = document.getElementById('analysisStatus');
    const pendingEl = document.getElementById('analysisPending');
    const lastRunEl = document.getElementById('analysisLastRun');
    const statusPill = document.getElementById('analysisStatusPill');
    if (!statusEl) {
        return;
    }
    try {
        const status = await fetchJson('/api/library/analysis/status');
        const pending = status?.pendingTracks ?? 0;
        const analyzed = status?.analyzedTracks ?? 0;
        const total = status?.totalTracks ?? 0;
        analysisState.pendingTracks = pending;
        analysisState.lastRunUtc = status?.lastRunUtc || analysisState.lastRunUtc;
        statusEl.textContent = `${analyzed.toLocaleString()}/${total.toLocaleString()} analyzed`;
        if (pendingEl) {
            pendingEl.textContent = pending.toLocaleString();
        }
        if (analysisState.running) {
            statusEl.textContent += ' • Running';
        }
        updateAnalysisStatusPill();
        const lastRunValue = analysisState.lastRunUtc || status?.lastRunUtc;
        if (lastRunEl) {
            lastRunEl.textContent = formatTimestamp(lastRunValue);
        }
    } catch (error) {
        statusEl.textContent = `Status unavailable${error?.message ? `: ${error.message}` : ''}`;
        if (pendingEl) {
            pendingEl.textContent = 'Unknown';
        }
        updateAnalysisStatusPill();
        if (lastRunEl) {
            lastRunEl.textContent = 'Unknown';
        }
        console.warn('Analysis status failed.', error);
    }
}

async function runAnalysis() {
    const button = document.getElementById('runAnalysis');
    if (!button) {
        return;
    }
    button.disabled = true;
    try {
        const saved = await saveAnalysisSettings(true);
        if (!saved) {
            return;
        }
        const batchSize = document.getElementById('analysis-batch-size')?.value;
        const params = new URLSearchParams();
        if (batchSize) {
            params.set('batchSize', batchSize);
        }
        const url = params.toString() ? `/api/library/analysis/run?${params.toString()}` : '/api/library/analysis/run';
        const response = await activityFetch(url, { method: 'POST' });
        if (!response.ok) {
            throw new Error(await response.text());
        }
        notifyActivity('Vibe analysis started.');
        await loadAnalysisActivity();
        await loadAnalysisStatus();
        await loadLatestAnalysis();
    } catch (error) {
        notifyActivity(`Vibe analysis failed: ${error?.message || error}`, 'error');
    } finally {
        button.disabled = false;
    }
}

async function resetAnalysis() {
