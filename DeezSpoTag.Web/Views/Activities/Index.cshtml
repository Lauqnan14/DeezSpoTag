let activitiesTabRefreshBound = false;
function bindActivitiesTabSwitchRefresh() {
    if (activitiesTabRefreshBound) {
        return;
    }
    activitiesTabRefreshBound = true;

    const activitiesTabs = document.getElementById('activitiesTabs');
    const keepActivitiesTabVisible = (tab) => {
        if (!(tab instanceof HTMLElement) || typeof tab.scrollIntoView !== 'function') {
            return;
        }
        if (typeof globalThis.matchMedia === 'function' && !globalThis.matchMedia('(max-width: 992px)').matches) {
            return;
        }
        tab.scrollIntoView({
            behavior: 'smooth',
            block: 'nearest',
            inline: 'center'
        });
    };

	    const refreshByTarget = (targetSelector) => {
	        if (targetSelector !== '#downloads-content') {
	            stopQueuePolling();
	        }
	        switch (targetSelector) {
	            case '#downloads-content':
	                void loadQueueFromServer({ force: true });
	                startQueuePolling();
	                scheduleRenderTasks({ immediate: true });
	                break;
	            case '#media-operations-content':
	                initMediaOperationsSection();
	                break;
	            case '#autotag-status-content':
	                void globalThis.DeezSpoTagAutoTagStatus?.refresh?.();
	                break;
            case '#history-content':
                void globalThis.DeezSpoTagAutoTagStatus?.refresh?.({ loadCalendar: true, resetLiveFollow: true });
                void globalThis.DeezSpoTagWatchlistHistory?.refresh?.();
                break;
            case '#logs-content':
                void loadLibraryLogs();
                break;
            default:
                break;
        }
    };

    activitiesTabs?.addEventListener('shown.bs.tab', (event) => {
        const trigger = event.target?.closest?.('[data-bs-toggle="tab"]');
        if (!trigger) {
            return;
        }
        const targetSelector = trigger.dataset?.bsTarget;
        if (targetSelector) {
            refreshByTarget(targetSelector);
        }
        keepActivitiesTabVisible(trigger);
    });

    const activeTabTrigger = activitiesTabs?.querySelector('[data-bs-toggle="tab"].active');
    const activeTarget = activeTabTrigger?.dataset?.bsTarget;
    if (activeTarget) {
        refreshByTarget(activeTarget);
        keepActivitiesTabVisible(activeTabTrigger);
    }
}

</script>
<script src="~/js/autotag-status.js" asp-append-version="true"></script>
<script src="~/js/watchlist-history.js" asp-append-version="true"></script>
<script src="~/js/meloday.js" asp-append-version="true"></script>
<script>
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
        bindActivitiesTabSwitchRefresh();
        initDownloadLogs();
        initLibraryLogs();
    });
} else {
    bindActivitiesTabSwitchRefresh();
    initDownloadLogs();
    initLibraryLogs();
}
</script>
}
