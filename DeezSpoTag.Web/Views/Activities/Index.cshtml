    padding: 12px;
    color: var(--error-color);
    font-size: 0.85rem;
    margin-top: 12px;
}


@@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}


