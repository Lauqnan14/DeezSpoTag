    border-radius: 4px;
    font-family: "Courier New", monospace;
    font-size: 13px;
    color: var(--primary-color);
}

.tool-help-content strong {
    color: var(--text-primary);
}

.media-operations-tab .tool-help-button:hover .tool-help-tooltip,
.media-operations-tab .tool-help-button:focus-visible .tool-help-tooltip {
    opacity: 1;
