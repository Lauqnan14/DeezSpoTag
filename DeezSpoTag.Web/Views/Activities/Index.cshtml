    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0;
    white-space: pre-wrap;
}

.download-logs-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 260px;
    max-height: 50vh;
    overflow: auto;
    padding: 4px 0;
