async function loadQueueFromServer(options) {
    const force = options?.force === true;
    if (queuePollInFlight && !force) {
        return;
    }
    const requestSequence = ++queueLoadRequestSequence;
    queuePollInFlight = true;
    try {
        const cacheBuster = Date.now();
        const response = await activityFetch(`/Activities/GetDownloadQueue?_=${cacheBuster}`, {
            cache: 'no-store',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        if (!response.ok) {
            throw new Error(await response.text());
        }
        const payload = await response.json();
        if (!payload.success) {
            throw new Error(payload.error || 'Queue load failed');
        }

        const queue = payload.data?.queue || {};
        const queueOrder = payload.data?.queueOrder || [];
        const ordered = [];
        const existingById = new Map(tasks.map(task => [task.taskId, task]));

        if (requestSequence !== queueLoadRequestSequence) {
            return;
        }

        queueOrder.forEach(uuid => {
            if (queue[uuid]) {
                ordered.push(mergeQueueTask(existingById.get(uuid), mapQueueItem(queue[uuid])));
            }
        });

        Object.values(queue).forEach(item => {
            if (!ordered.some(task => task.taskId === item.uuid)) {
                ordered.push(mergeQueueTask(existingById.get(item.uuid), mapQueueItem(item)));
            }
        });

        if (requestSequence === queueLoadRequestSequence) {
            tasks = ordered;
            clearMissingQueueActivity(tasks);
            scheduleRenderTasks();
            updateStats();
            queueState = deriveQueueState(tasks);
            updateQueueButtons();
            updateToggleQueueUi(queueState);
        }
    } catch (error) {
        console.error('Failed to load queue:', error);
    } finally {
        queuePollInFlight = false;
    }
}

function stopQueuePolling() {
    if (queuePollTimeoutId) {
        clearTimeout(queuePollTimeoutId);
        queuePollTimeoutId = null;
    }
}

function startQueuePolling() {
    stopQueuePolling();
    if (document.hidden) {
        return;
    }
    const downloadsPane = document.getElementById('downloads-content');
    if (!downloadsPane?.classList.contains('active')) {
        return;
    }
    queuePollTimeoutId = setTimeout(async () => {
        await loadQueueFromServer();
        startQueuePolling();
    }, queuePollDelayMs);
}

function mapQueueItem(item) {
    const resolvedEngine = resolveQueueDisplayEngine(item);
    const rawQuality = resolveQueueRawQuality(item, resolvedEngine);
    const contentType = String(item.contentType || item.ContentType || '').toLowerCase();
    const isVideo = contentType === 'video' || String(rawQuality).toLowerCase().startsWith('video-');
    const displayQuality = isVideo
        ? 'Video'
        : mapBitrate(rawQuality);
    return {
        taskId: item.uuid,
        title: resolveQueueItemTitle(item) || 'Unknown',
        artist: resolveQueueItemArtist(item) || 'Unknown',
        rawQuality: String(rawQuality || '').trim(),
        quality: displayQuality,
        videoBadges: isVideo ? resolveVideoBadges(item, rawQuality) : [],
        status: mapStatus(item.status),
        progress: normalizeQueueProgressPercent(item.progress),
        downloaded: normalizeQueueCounter(item.downloaded || item.Downloaded),
        failed: normalizeQueueCounter(item.failed || item.Failed),
        engine: normalizeEngine(resolvedEngine || 'deezer'),
        error: item.error || null,
        lyricsBadges: getLyricsBadges(item),
        cover: getCoverFromPayload(item)
    };
}

function normalizeQueueCounter(value) {
    const numeric = Number(value);
    if (!Number.isFinite(numeric)) {
        return 0;
    }

    return Math.max(0, Math.round(numeric));
}

function isQueueTerminalStatus(status) {
    return status === 'complete' || status === 'failed' || status === 'canceled';
}

function isQueueResetStatus(status) {
    return status === 'queued' || status === 'retrying';
}

function resolveQueueTaskText(currentValue, incomingValue) {
    const incoming = String(incomingValue || '').trim();
    if (incoming && incoming.toLowerCase() !== 'unknown') {
        return incoming;
    }

    const current = String(currentValue || '').trim();
    if (current) {
        return current;
    }

    return incoming;
}

function resolveMergedQueueProgress(currentProgress, incomingProgress, currentStatus, incomingStatus) {
    const current = clampQueueProgressPercent(currentProgress);
    const incoming = clampQueueProgressPercent(incomingProgress);
    const normalizedCurrentStatus = mapStatus(currentStatus);
    const normalizedIncomingStatus = mapStatus(incomingStatus || currentStatus);

    if (normalizedIncomingStatus === 'complete') {
        return 100;
    }

    if (isQueueResetStatus(normalizedIncomingStatus) && incoming <= 0) {
        return 0;
    }

    if (normalizedCurrentStatus === 'complete') {
        return 100;
    }

    if (isQueueTerminalStatus(normalizedIncomingStatus)) {
        return Math.max(current, incoming);
    }

    return Math.max(current, incoming);
}

function resolveMergedQueueStatus(currentStatus, incomingStatus, mergedProgress) {
    const current = mapStatus(currentStatus);
    const incoming = mapStatus(incomingStatus);

    if (!incoming) {
        return current || 'queued';
    }

    if (incoming === 'complete') {
        return 'complete';
    }

    if (incoming === 'queued' && current === 'running' && mergedProgress > 0) {
        return 'running';
    }

    return incoming;
}

function mergeQueueTask(existing, incoming) {
    if (!existing) {
        return incoming;
    }

    const mergedProgress = resolveMergedQueueProgress(
        existing.progress,
        incoming.progress,
        existing.status,
        incoming.status);
    const mergedStatus = resolveMergedQueueStatus(existing.status, incoming.status, mergedProgress);

    return {
        ...existing,
        ...incoming,
        title: resolveQueueTaskText(existing.title, incoming.title),
        artist: resolveQueueTaskText(existing.artist, incoming.artist),
        rawQuality: String(incoming.rawQuality || '').trim() || existing.rawQuality,
        quality: String(incoming.quality || '').trim() || existing.quality,
        videoBadges: Array.isArray(incoming.videoBadges) && incoming.videoBadges.length > 0
            ? incoming.videoBadges
            : existing.videoBadges,
        status: mergedStatus,
        progress: normalizeQueueProgressPercent(mergedProgress),
        downloaded: normalizeQueueCounter(incoming.downloaded ?? existing.downloaded),
        failed: normalizeQueueCounter(incoming.failed ?? existing.failed),
        engine: incoming.engine || existing.engine,
        error: incoming.error !== null && incoming.error !== undefined
            ? incoming.error
            : (mergedStatus === 'running' || mergedStatus === 'queued' ? null : existing.error),
        lyricsBadges: Array.isArray(incoming.lyricsBadges) && incoming.lyricsBadges.length > 0
            ? incoming.lyricsBadges
            : existing.lyricsBadges,
        cover: String(incoming.cover || '').trim() || existing.cover
    };
}

function readQueueItemText(item, candidates) {
    if (!item || typeof item !== 'object' || !Array.isArray(candidates)) {
        return '';
    }

    for (const candidate of candidates) {
        const value = String(item[candidate] ?? '').trim();
        if (value) {
            return value;
        }
    }

    return '';
}

function resolveQueueRawQuality(item, engineHint) {
    const normalizedEngine = normalizeEngine(engineHint || resolveQueueDisplayEngine(item) || item?.engine || item?.Engine || '');
    if (normalizedEngine === 'qobuz') {
        const resolvedQobuzQuality = readQueueItemText(item, ['qobuzResolvedQuality', 'QobuzResolvedQuality']);
        if (resolvedQobuzQuality) {
            return resolvedQobuzQuality;
        }

        const requestedQobuzQuality = readQueueItemText(item, ['qobuzRequestedQuality', 'QobuzRequestedQuality']);
        if (requestedQobuzQuality) {
            return requestedQobuzQuality;
        }
    }

    return readQueueItemText(item, ['quality', 'Quality', 'bitrate', 'Bitrate']);
}

function resolveQueueItemTitle(item) {
    return readQueueItemText(item, ['title', 'Title', 'trackTitle', 'TrackTitle']);
}

function resolveQueueItemArtist(item) {
    return readQueueItemText(item, ['artist', 'Artist', 'artistName', 'ArtistName']);
}

function taskNeedsMetadataHydration(task) {
    if (!task || typeof task !== 'object') {
        return false;
    }

    const title = String(task.title || '').trim().toLowerCase();
    const artist = String(task.artist || '').trim().toLowerCase();
    const cover = String(task.cover || '').trim();
    return !title
        || !artist
        || title === 'unknown'
        || artist === 'unknown'
        || !cover
        || cover === '/images/default-cover.png';
}

function scheduleQueueHydrationRefresh() {
    if (queueHydrationRefreshTimer != null) {
        return;
    }

    const now = Date.now();
    const delay = Math.max(0, 1000 - (now - lastQueueHydrationRefreshAt));
    queueHydrationRefreshTimer = setTimeout(async () => {
        queueHydrationRefreshTimer = null;
        lastQueueHydrationRefreshAt = Date.now();
        await loadQueueFromServer({ force: true });
    }, delay);
}

function resolveQueueDisplayEngine(item) {
    if (!item || typeof item !== 'object') {
        return '';
    }

    // The queue engine is the resolved downloader currently assigned to the item.
    // sourceService can be the originating link source and may legitimately differ.
    return item.engine
        || item.Engine
        || item.sourceService
        || item.source_service
        || '';
}

function resolveVideoBadges(item, rawQuality) {
    const badges = [];
    const qualityText = String(rawQuality || '').trim();
    const qualityLower = qualityText.toLowerCase();

    const explicitResolution = String(
        item.videoResolution
        || item.VideoResolution
        || item.videoResolutionTier
        || item.VideoResolutionTier
        || ''
    ).trim();
    const resolutionBadge = normalizeVideoResolutionBadge(explicitResolution || extractVideoResolutionFromQuality(qualityText));
    if (resolutionBadge) {
        badges.push({ label: resolutionBadge, className: 'badge-video-resolution' });
    }

    const hdrEnabled = parseBooleanValue(item.videoHdr ?? item.VideoHdr)
        || qualityLower.includes('-hdr-')
        || qualityLower.endsWith('-hdr')
        || qualityLower.includes('video-range=pq')
        || qualityLower.includes('video-range=hlg');
    if (hdrEnabled) {
        badges.push({ label: 'HDR', className: 'badge-video-hdr' });
    }

    const audioProfileRaw = String(item.videoAudioProfile || item.VideoAudioProfile || '').trim().toLowerCase();
    let audioBadge = '';
    if (audioProfileRaw.includes('atmos') || qualityLower.includes('atmos')) {
        audioBadge = 'Atmos';
    } else if (audioProfileRaw.includes('stereo') || qualityLower.includes('stereo') || qualityLower.includes('audio-aac')) {
        audioBadge = 'Stereo';
    }

    if (audioBadge === 'Atmos') {
        badges.push({ label: audioBadge, className: 'badge-video-audio-atmos' });
    } else if (audioBadge === 'Stereo') {
        badges.push({ label: audioBadge, className: 'badge-video-audio-stereo' });
    }

    return badges;
}

function normalizeVideoResolutionBadge(value) {
    const raw = String(value || '').trim();
    if (!raw) {
        return '';
    }

    const normalized = raw.toUpperCase();
    if (normalized === '4K' || normalized === 'FHD' || normalized === 'HD') {
        return normalized;
    }

    const height = extractVideoHeight(raw);
    if (height >= 2160) {
        return '4K';
    }
    if (height >= 1080) {
        return 'FHD';
    }
    if (height >= 720) {
        return 'HD';
    }

    return '';
}

function extractVideoResolutionFromQuality(value) {
    const normalized = String(value || '').trim();
    if (!normalized) {
        return '';
    }

    const match = normalized.match(/video-([0-9]{3,4}x[0-9]{3,4}|[0-9]{3,4}p?)/i);
    return match ? match[1] : '';
}

function extractVideoHeight(value) {
    const raw = String(value || '').trim().toLowerCase();
    if (!raw) {
        return 0;
    }

    if (raw.includes('x')) {
        const parts = raw.split('x');
        const height = Number.parseInt(parts[1], 10);
        return Number.isFinite(height) ? height : 0;
    }

    const digits = Number.parseInt(raw.replace(/[^0-9]/g, ''), 10);
    return Number.isFinite(digits) ? digits : 0;
}

function parseBooleanValue(value) {
    if (value === true || value === false) {
        return value;
    }
    if (typeof value === 'number') {
        return value !== 0;
    }
    if (typeof value === 'string') {
        const normalized = value.trim().toLowerCase();
        return normalized === 'true' || normalized === '1' || normalized === 'yes';
    }
    return false;
}

function mapStatus(status) {
    const normalized = String(status || '').trim().toLowerCase();
    if (!normalized) {
        return 'queued';
    }

	    const map = {
	        inqueue: 'queued',
	        queued: 'queued',
	        downloading: 'running',
        running: 'running',
        completed: 'complete',
        complete: 'complete',
        finished: 'complete',
        'download finished': 'complete',
        done: 'complete',
        success: 'complete',
        failed: 'failed',
        error: 'failed',
        cancelled: 'canceled',
        canceled: 'canceled',
        skipped: 'complete',
	        paused: 'paused',
	        retrying: 'retrying'
	    };
	    return map[normalized] || 'queued';
	}

function escapeCssUrl(value) {
    const raw = String(value ?? '').trim();
    if (!raw) {
        return '';
    }

    return raw
        .replace(/\\/g, '\\\\')
        .replace(/'/g, '%27')
        .replace(/"/g, '%22')
        .replace(/\(/g, '%28')
        .replace(/\)/g, '%29');
}

function escapeHtml(value) {
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function escapeJsString(value) {
    return String(value ?? '')
        .replace(/\\/g, '\\\\')
        .replace(/'/g, "\\'")
        .replace(/"/g, '\\"')
        .replace(/\r/g, '\\r')
        .replace(/\n/g, '\\n');
}

function escapeCssSelectorValue(value) {
    const raw = String(value ?? '');
    if (!raw) {
        return '';
    }

    if (globalThis.CSS && typeof globalThis.CSS.escape === 'function') {
        return globalThis.CSS.escape(raw);
    }

    return raw.replace(/["\\]/g, '\\$&');
}

function getTaskActivityText(task) {
    if (task.status !== 'running') {
        return '';
    }

    const prefetchText = getPrefetchActivityText(task.taskId);
    if (prefetchText) {
        return prefetchText;
    }

    const progress = normalizeQueueProgressPercent(task.progress);
    if (progress < 100) {
        return '';
    }

    const realtime = queueActivityByTask[task.taskId];
    if (typeof realtime === 'string' && realtime.trim()) {
        return realtime.trim();
    }

    return 'Finalizing items...';
}

function setTaskActivity(taskId, message) {
    if (!taskId) {
        return;
    }
    const next = String(message || '').trim();
    if (!next) {
        return;
    }
    if (queueActivityByTask[taskId] === next) {
        return;
    }
    queueActivityByTask[taskId] = next;
    scheduleRenderTasks();
}

function clearTaskActivity(taskId) {
    if (!taskId) {
        return;
    }
    if (queueActivityByTask[taskId] === undefined) {
        return;
    }
    delete queueActivityByTask[taskId];
    scheduleRenderTasks();
}

function clearMissingQueueActivity(taskList) {
    const activeTaskIds = new Set((taskList || []).map(task => task.taskId));
    Object.keys(queueActivityByTask).forEach(taskId => {
        if (!activeTaskIds.has(taskId)) {
            delete queueActivityByTask[taskId];
        }
    });
    Object.keys(queuePrefetchByTask).forEach(taskId => {
        if (!activeTaskIds.has(taskId)) {
            delete queuePrefetchByTask[taskId];
        }
    });
    Object.keys(queueProgressCache).forEach(taskId => {
        if (!activeTaskIds.has(taskId)) {
            delete queueProgressCache[taskId];
        }
    });
    Object.keys(queueProgressTextAnimationByTask).forEach(taskId => {
        if (!activeTaskIds.has(taskId) && queueProgressTextAnimationByTask[taskId] != null) {
            cancelAnimationFrame(queueProgressTextAnimationByTask[taskId]);
            delete queueProgressTextAnimationByTask[taskId];
        }
    });
}

function normalizePrefetchStatus(value) {
    const normalized = String(value || '').trim().toLowerCase();
    if (!normalized) {
        return '';
    }
    if (normalized === 'fetching' || normalized === 'completed' || normalized === 'failed' || normalized === 'skipped' || normalized === 'no-lyrics') {
        return normalized;
    }
    return '';
}

function normalizePrefetchLyricsType(value) {
    const tokens = String(value || '')
        .trim()
        .toLowerCase()
        .split(/[^a-z0-9-]+/)
        .filter(Boolean);
    if (tokens.length === 0) {
        return '';
    }

    const kinds = [];
    const addKind = (kind) => {
        if (!kinds.includes(kind)) {
            kinds.push(kind);
        }
    };

    tokens.forEach(token => {
        if (token === 'time-synced'
            || token === 'time-synced-lyrics'
            || token === 'timesynced'
            || token === 'time'
            || token === 'ttml'
            || token === 'syllable-lyrics') {
            addKind('time-synced');
            return;
        }
        if (token === 'unsynced'
            || token === 'unsynced-lyrics'
            || token === 'unsynchronized-lyrics'
            || token === 'unsynchronised-lyrics'
            || token === 'unsyncedlyrics'
            || token === 'plain'
            || token === 'text'
            || token === 'txt') {
            addKind('unsynced');
            return;
        }
        if (token === 'synced'
            || token === 'synced-lyrics'
            || token === 'lyrics'
            || token === 'lrc') {
            addKind('synced');
        }
    });

    return kinds.join(',');
}

function formatPrefetchLyricsType(value) {
    const normalized = normalizePrefetchLyricsType(value);
    if (!normalized) {
        return '';
    }
    const labels = normalized.split(',').map(kind => {
        if (kind === 'time-synced') {
            return 'Time-Synced';
        }
        if (kind === 'synced') {
            return 'Synced';
        }
        if (kind === 'unsynced') {
            return 'Unsynced';
        }
        return '';
    }).filter(Boolean);
    return labels.join(' + ');
}

function updateTaskPrefetchStatus(taskId, artworkStatus, lyricsStatus, lyricsType) {
    if (!taskId) {
        return false;
    }

    const hasArtwork = artworkStatus !== undefined && artworkStatus !== null;
    const hasLyrics = lyricsStatus !== undefined && lyricsStatus !== null;
    const hasLyricsType = lyricsType !== undefined && lyricsType !== null;
    if (!hasArtwork && !hasLyrics && !hasLyricsType) {
        return false;
    }

    const current = queuePrefetchByTask[taskId] || { artwork: '', lyrics: '', lyricsType: '' };
    const next = {
        artwork: hasArtwork ? normalizePrefetchStatus(artworkStatus) : current.artwork,
        lyrics: hasLyrics ? normalizePrefetchStatus(lyricsStatus) : current.lyrics,
        lyricsType: hasLyricsType ? normalizePrefetchLyricsType(lyricsType) : current.lyricsType
    };

    const hasVisibleStatus = [next.artwork, next.lyrics].some(status => status && status !== 'skipped');
    if (!hasVisibleStatus) {
        if (queuePrefetchByTask[taskId]) {
            delete queuePrefetchByTask[taskId];
            return true;
        }
        return false;
    }

    if (current.artwork === next.artwork
        && current.lyrics === next.lyrics
        && current.lyricsType === next.lyricsType) {
        return false;
    }

    queuePrefetchByTask[taskId] = next;
    return true;
}

function clearTaskPrefetchStatus(taskId) {
    if (!taskId) {
        return;
    }
    if (queuePrefetchByTask[taskId] !== undefined) {
        delete queuePrefetchByTask[taskId];
    }
}

function hasActivePrefetchStatus(taskId) {
    const state = queuePrefetchByTask[taskId];
    if (!state) {
        return false;
    }
    return state.artwork === 'fetching' || state.lyrics === 'fetching';
}

function formatPrefetchPart(label, status, details) {
    if (!status || status === 'skipped') {
        return '';
    }
    const suffix = details ? ` (${details})` : '';
    if (status === 'fetching') {
        return `${label}: fetching${suffix}`;
    }
    if (status === 'completed') {
        return `${label}: ready${suffix}`;
    }
    if (status === 'failed') {
        return `${label}: failed${suffix}`;
    }
    if (status === 'no-lyrics' && label === 'Lyrics') {
        return 'Lyrics: No lyrics!!!!';
    }
    return '';
}

function getPrefetchActivityText(taskId) {
    const state = queuePrefetchByTask[taskId];
    if (!state) {
        return '';
    }

    const parts = [
        formatPrefetchPart('Artwork', state.artwork),
        formatPrefetchPart('Lyrics', state.lyrics, formatPrefetchLyricsType(state.lyricsType))
    ].filter(Boolean);

    return parts.join(' • ');
}

function normalizeQueueEventUuid(payload) {
    if (!payload) {
        return '';
    }
    if (typeof payload === 'string') {
        return payload;
    }
    if (typeof payload === 'object') {
        return String(payload.uuid || payload.id || payload?.updateData?.uuid || '').trim();
    }
    return '';
}

function extractQueueEventMessage(value) {
    if (!value) {
        return '';
    }
    if (typeof value === 'string') {
        return value.trim();
    }
    if (typeof value !== 'object') {
        return '';
    }

    const messageKeys = ['message', 'error', 'reason', 'details'];
    for (const key of messageKeys) {
        if (typeof value[key] === 'string' && value[key].trim()) {
            return value[key].trim();
        }
    }

    if (typeof value.position === 'string' && value.position.trim()) {
        return `Post-processing: ${value.position.trim()}`;
    }
    if (value.itemData && typeof value.itemData === 'object') {
        return extractQueueEventMessage(value.itemData);
    }
    return '';
}

function describeQueueEventState(state) {
    const normalized = String(state || '').trim().toLowerCase();
    return normalized === 'post' ? 'Finalizing items...' : '';
}

function parseQueueRealtimeProgressValue(value) {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : null;
}

function applyQueueRealtimeProgress(payload) {
    const taskId = normalizeQueueEventUuid(payload);
    if (!taskId) {
        return;
    }
    const progress = normalizeQueueProgressPercent(payload?.progress ?? payload?.progressNext);
    const task = tasks.find(entry => entry.taskId === taskId);
    if (!task) {
        scheduleQueueHydrationRefresh();
        return;
    }

    const previousStatus = task.status;
    let changed = false;
    const mergedProgress = normalizeQueueProgressPercent(resolveMergedQueueProgress(
        task.progress,
        progress,
        task.status,
        'running'));
    if (task.progress !== mergedProgress) {
        task.progress = mergedProgress;
        changed = true;
    }
    if (progress > 0 && task.status === 'queued') {
        task.status = 'running';
        changed = true;
    }
    if (progress >= 100) {
        setTaskActivity(taskId, 'Finalizing items...');
    } else {
        if (hasActivePrefetchStatus(taskId)) {
            if (changed) {
                if (task.status !== previousStatus) {
                    updateStats();
                }
                scheduleRenderTasks();
            }
            return;
        }
        clearTaskActivity(taskId);
    }
    if (taskNeedsMetadataHydration(task)) {
        scheduleQueueHydrationRefresh();
    }
    if (changed) {
        const statusChanged = task.status !== previousStatus;
        if (statusChanged) {
            updateStats();
            scheduleRenderTasks();
            return;
        }

        if (!updateQueueProgressDom(taskId, task.progress)) {
            scheduleRenderTasks();
        }
    }
}

function applyQueueRealtimeUpdate(payload) {
    const taskId = normalizeQueueEventUuid(payload);
    if (!taskId) {
        return;
    }

    const update = (payload && typeof payload.updateData === 'object')
        ? payload.updateData
        : payload;

    const prefetchChanged = updateTaskPrefetchStatus(
        taskId,
        update?.prefetchArtworkStatus,
        update?.prefetchLyricsStatus,
        update?.prefetchLyricsType);
    if (prefetchChanged) {
        scheduleRenderTasks();
    }

    const rawStatus = update?.status;
    const status = (rawStatus === undefined || rawStatus === null || rawStatus === '')
        ? ''
        : mapStatus(rawStatus);
    const task = tasks.find(entry => entry.taskId === taskId);
    if (!task) {
        scheduleQueueHydrationRefresh();
        return;
    }

    const rawNextProgress = parseQueueRealtimeProgressValue(
        update?.progress !== undefined && update?.progress !== null
            ? update.progress
            : update?.progressNext);
    const nextProgress = rawNextProgress === null
        ? null
        : normalizeQueueProgressPercent(rawNextProgress);
    let taskChanged = false;

    const mergedStatus = resolveMergedQueueStatus(task.status, status, task.progress);
    if (status && task.status !== mergedStatus) {
        task.status = mergedStatus;
        taskChanged = true;
    }
    const nextTitle = resolveQueueItemTitle(update);
    if (nextTitle && task.title !== nextTitle) {
        task.title = nextTitle;
        taskChanged = true;
    }
    const nextArtist = resolveQueueItemArtist(update);
    if (nextArtist && task.artist !== nextArtist) {
        task.artist = nextArtist;
        taskChanged = true;
    }
    const nextCover = getCoverFromPayload(update);
    if (nextCover && task.cover !== nextCover) {
        task.cover = nextCover;
        taskChanged = true;
    }
    const nextEngineRaw = resolveQueueDisplayEngine(update);
    const nextEngine = nextEngineRaw ? normalizeEngine(nextEngineRaw) : '';
    if (nextEngine && task.engine !== nextEngine) {
        task.engine = nextEngine;
        taskChanged = true;
    }
    const nextRawQuality = resolveQueueRawQuality(update, nextEngine || task.engine);
    if (nextRawQuality) {
        const nextContentType = String(update?.contentType || update?.ContentType || '').toLowerCase();
        const nextIsVideo = nextContentType === 'video' || String(nextRawQuality).toLowerCase().startsWith('video-');
        const nextDisplayQuality = nextIsVideo ? 'Video' : mapBitrate(nextRawQuality);
        const nextVideoBadges = nextIsVideo ? resolveVideoBadges(update, nextRawQuality) : [];
        if (task.rawQuality !== nextRawQuality) {
            task.rawQuality = nextRawQuality;
            taskChanged = true;
        }
        if (nextDisplayQuality && task.quality !== nextDisplayQuality) {
            task.quality = nextDisplayQuality;
            taskChanged = true;
        }
        if (!areSameBadgeSet(task.videoBadges, nextVideoBadges)) {
            task.videoBadges = nextVideoBadges;
            taskChanged = true;
        }
    }
    if (nextProgress !== null) {
        const mergedProgress = normalizeQueueProgressPercent(resolveMergedQueueProgress(
            task.progress,
            nextProgress,
            task.status,
            status || task.status));
        if (task.progress !== mergedProgress) {
            task.progress = mergedProgress;
            taskChanged = true;
        }
    }
    if (update?.downloaded !== undefined || update?.Downloaded !== undefined) {
        const nextDownloaded = normalizeQueueCounter(update?.downloaded ?? update?.Downloaded);
        if (task.downloaded !== nextDownloaded) {
            task.downloaded = nextDownloaded;
            taskChanged = true;
        }
    }
    if (update?.failed !== undefined || update?.Failed !== undefined) {
        const nextFailed = normalizeQueueCounter(update?.failed ?? update?.Failed);
        if (task.failed !== nextFailed) {
            task.failed = nextFailed;
            taskChanged = true;
        }
    }
    if (update?.error !== undefined && update?.error !== null) {
        const nextError = String(update.error).trim();
        if (task.error !== nextError) {
            task.error = nextError;
            taskChanged = true;
        }
    } else if ((status === 'running' || status === 'queued') && task.error) {
        task.error = null;
        taskChanged = true;
    }
    const nextLyricsBadges = getLyricsBadgesFromRealtimeUpdate(update, taskId);
    if (nextLyricsBadges && !areSameBadgeSet(task.lyricsBadges, nextLyricsBadges)) {
        task.lyricsBadges = nextLyricsBadges;
        taskChanged = true;
    }
    if (status === 'complete' && task.progress !== 100) {
        task.progress = 100;
        taskChanged = true;
    }
    if (taskNeedsMetadataHydration(task)) {
        scheduleQueueHydrationRefresh();
    }
    if (taskChanged) {
        updateStats();
        scheduleRenderTasks();
    }

    if (status === 'running') {
        applyQueueRealtimeProgress(update);
        return;
    }
    if (status) {
        clearTaskActivity(taskId);
        clearTaskPrefetchStatus(taskId);
        return;
    }

    if (update?.postFailed === true) {
        clearTaskActivity(taskId);
        clearTaskPrefetchStatus(taskId);
        return;
    }

    const trailingProgress = parseQueueRealtimeProgressValue(
        update?.progress !== undefined && update?.progress !== null
            ? update.progress
            : update?.progressNext);
    if (trailingProgress !== null) {
        applyQueueRealtimeProgress(update);
    }
}

function resolveQueueRealtimeConnection() {
    return window.DeezSpoTag?.Download?.connection
        || window.DeezSpoTagDownload?.connection
        || null;
}

function initQueueRealtimeEvents() {
    if (queueRealtimeAttached) {
        return;
    }

    const connection = resolveQueueRealtimeConnection();
    if (!connection || typeof connection.on !== 'function') {
        if (queueRealtimeAttachTimer == null) {
            queueRealtimeAttachTimer = setTimeout(() => {
                queueRealtimeAttachTimer = null;
                initQueueRealtimeEvents();
            }, 500);
        }
        return;
    }

    queueRealtimeAttached = true;
    connection.on('updateQueue', (payload) => {
        applyQueueRealtimeUpdate(payload);
    });
    connection.on('downloadProgress', (payload) => {
        applyQueueRealtimeProgress(payload);
    });
    connection.on('downloadInfo', (payload) => {
        const taskId = normalizeQueueEventUuid(payload);
        if (!taskId) {
            return;
        }
        const state = String(payload?.state || '').trim().toLowerCase();
        if (state !== 'post') {
            return;
        }
        const message = extractQueueEventMessage(payload?.data) || describeQueueEventState(payload?.state);
        if (message) {
            setTaskActivity(taskId, message);
        }
    });

    if (!queueRealtimeLifecycleAttached) {
        queueRealtimeLifecycleAttached = true;
        if (typeof connection.onreconnected === 'function') {
            connection.onreconnected(() => {
                loadQueueFromServer({ force: true });
            });
        }
        if (typeof connection.onclose === 'function') {
            connection.onclose(() => {
                startQueuePolling();
            });
        }
    }
}

async function ensureActionSuccess(url) {
    const response = await activityFetch(url, {
        method: 'POST',
        cache: 'no-store',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    });

    let payload = null;
    const contentType = response.headers.get('content-type') || '';
    if (contentType.includes('application/json')) {
        payload = await response.json();
    }

    if (!response.ok) {
        const errorMessage = payload?.error || payload?.message || `Request failed (${response.status})`;
        throw new Error(errorMessage);
    }

    if (payload && payload.success === false) {
        throw new Error(payload.error || payload.message || 'Request failed.');
    }

    return payload;
}

async function ensureJsonActionSuccess(url, body) {
    const response = await activityFetch(url, {
        method: 'POST',
        cache: 'no-store',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json',
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(body ?? {})
    });

    let payload = null;
    const contentType = response.headers.get('content-type') || '';
    if (contentType.includes('application/json')) {
        payload = await response.json();
    } else if (!response.ok) {
        const text = await response.text();
        throw new Error(text || `Request failed (${response.status})`);
    }

    if (!response.ok) {
        const errorMessage = payload?.error || payload?.message || `Request failed (${response.status})`;
        throw new Error(errorMessage);
    }

    if (payload && payload.success === false) {
        throw new Error(payload.error || payload.message || 'Request failed.');
    }
}

function deriveQueueState(taskList) {
    if (!Array.isArray(taskList) || taskList.length === 0) {
        return 'paused';
    }
    const hasActive = taskList.some(task => task.status === 'queued' || task.status === 'running' || task.status === 'retrying');
    return hasActive ? 'running' : 'paused';
}

function mapBitrate(bitrate) {
    const numeric = typeof bitrate === 'number'
        ? bitrate
        : (typeof bitrate === 'string' && /^\d+$/.test(bitrate) ? Number(bitrate) : null);

    if (numeric !== null) {
        const numericMap = {
            1: 'MP3 128',
            3: 'MP3 320',
            6: 'FLAC 16-bit',
            7: 'FLAC 24-bit',
            9: 'FLAC',
            27: 'Hi-Res 24-bit'
        };
        return numericMap[numeric] || '';
    }

    if (typeof bitrate === 'string') {
        return bitrate.replace(/_/g, ' ');
    }

    return '';
}

function normalizeEngine(engine) {
    const raw = String(engine || '').toLowerCase();
    if (raw.includes('deezer')) return 'deezer';
    if (raw.includes('tidal')) return 'tidal';
    if (raw.includes('amazon')) return 'amazon';
    if (raw.includes('qobuz')) return 'qobuz';
    if (raw.includes('multisource')) return 'deezer';
    return raw || 'deezer';
}

function getCoverFromPayload(item) {
    if (item.cover) {
        return item.cover;
    }
    if (item.Cover) {
        return item.Cover;
    }
    if (item.metadata?.cover) {
        return item.metadata.cover;
    }
    if (item.metadata?.image) {
        return item.metadata.image;
    }
    if (item.artwork) {
        return item.artwork;
    }
    if (item.artworkUrl) {
        return item.artworkUrl;
    }
    if (item.image) {
        return item.image;
    }
    if (item.thumbnail) {
        return item.thumbnail;
    }
    if (item.single?.metadata?.cover) {
        return item.single.metadata.cover;
    }
    if (item.single?.metadata?.image) {
        return item.single.metadata.image;
    }
    const singleAlbum = item.single?.albumAPI;
    if (singleAlbum?.cover) {
        return singleAlbum.cover;
    }
    if (singleAlbum?.cover_small) {
        return singleAlbum.cover_small;
    }
    const singleTrackAlbum = item.single?.trackAPI?.album;
    if (singleTrackAlbum?.cover) {
        return singleTrackAlbum.cover;
    }
    const collectionAlbum = item.collection?.albumAPI;
    if (collectionAlbum?.cover) {
        return collectionAlbum.cover;
    }
    if (collectionAlbum?.cover_small) {
        return collectionAlbum.cover_small;
    }
    const collectionPlaylist = item.collection?.playlistAPI;
    if (collectionPlaylist?.picture_small) {
        return collectionPlaylist.picture_small;
    }
    return '';
}

function getLyricsBadges(item) {
    const fileBadges = getLyricsBadgesFromFiles(item);
    if (fileBadges.length) {
        return fileBadges;
    }

    const tracks = [];
    if (item.single && item.single.trackAPI) {
        tracks.push(item.single.trackAPI);
    }
    if (item.collection && Array.isArray(item.collection.tracks)) {
        tracks.push(...item.collection.tracks);
    }

    const badges = [];
    if (tracks.some(track => track && track.lyrics_sync)) {
        badges.push('synced');
    }
    if (tracks.some(track => track && track.lyrics_unsync)) {
        badges.push('unsynced');
    }
    if (badges.length === 0) {
        const statusBadges = getLyricsBadgesFromStatus(item.lyricsStatus || item.lyrics_status || '');
        if (statusBadges.length) {
            badges.push(...statusBadges);
        }
    }
    return badges;
}

function getLyricsBadgesFromRealtimeUpdate(update, taskId) {
    if (!update || typeof update !== 'object') {
        return null;
    }

    const fileBadges = getLyricsBadgesFromFiles(update);
    if (fileBadges.length) {
        return fileBadges;
    }

    const statusBadges = getLyricsBadgesFromStatus(update.lyricsStatus || update.lyrics_status || '');
    if (statusBadges.length) {
        return statusBadges;
    }

    const typeBadges = getLyricsBadgesFromStatus(update.prefetchLyricsType || '');
    if (typeBadges.length) {
        return typeBadges;
    }

    const prefetchState = queuePrefetchByTask[taskId];
    if (prefetchState && prefetchState.lyricsType) {
        const prefetchBadges = getLyricsBadgesFromStatus(prefetchState.lyricsType);
        if (prefetchBadges.length) {
            return prefetchBadges;
        }
    }

    return null;
}

function getLyricsBadgesFromStatus(rawStatus) {
    if (typeof rawStatus !== 'string' || !rawStatus.trim()) {
        return [];
    }

    const status = rawStatus.trim().toLowerCase();
    if (!status || status === 'no-lyrics' || status === 'fetching' || status === 'failed' || status === 'skipped') {
        return [];
    }

    const tokens = status
        .split(/[^a-z0-9-]+/)
        .filter(Boolean);
    const badges = [];
    const addBadge = (badge) => {
        if (!badges.includes(badge)) {
            badges.push(badge);
        }
    };

    tokens.forEach(token => {
        if (token === 'both') {
            addBadge('synced');
            addBadge('unsynced');
            return;
        }

        if (token === 'time-synced'
            || token === 'time-synced-lyrics'
            || token === 'timesynced'
            || token === 'ttml'
            || token === 'syllable-lyrics') {
            addBadge('time-synced');
            return;
        }

        if (token === 'unsynced'
            || token === 'unsynced-lyrics'
            || token === 'unsynchronized-lyrics'
            || token === 'unsynchronised-lyrics'
            || token === 'unsyncedlyrics'
            || token === 'plain'
            || token === 'text'
            || token === 'txt') {
            addBadge('unsynced');
            return;
        }

        if (token === 'synced'
            || token === 'synced-lyrics'
            || token === 'lyrics'
            || token === 'lrc') {
            addBadge('synced');
        }
    });

    return badges;
}

function areSameBadgeSet(left, right) {
    const leftBadges = Array.isArray(left) ? left.map(value => String(value).toLowerCase()).sort() : [];
    const rightBadges = Array.isArray(right) ? right.map(value => String(value).toLowerCase()).sort() : [];
    if (leftBadges.length !== rightBadges.length) {
        return false;
    }

    for (let i = 0; i < leftBadges.length; i += 1) {
        if (leftBadges[i] !== rightBadges[i]) {
            return false;
        }
    }

    return true;
}

function getLyricsBadgesFromFiles(item) {
    const files = Array.isArray(item.files) ? item.files : (Array.isArray(item.Files) ? item.Files : null);
    if (!Array.isArray(files)) {
        return [];
    }
    const filenames = files
        .map(file => {
            if (!file) {
                return '';
            }
            if (typeof file === 'string') {
                return file;
            }
            return (
                file.filename ||
                file.Filename ||
                file.path ||
                file.Path ||
                file.name ||
                file.Name ||
                ''
            );
        })
        .filter(Boolean)
        .map(name => name.toLowerCase());

    const badges = [];
    if (filenames.some(name => name.endsWith('.ttml'))) {
        badges.push('time-synced');
    }
    if (filenames.some(name => name.endsWith('.lrc'))) {
        badges.push('synced');
    }
    if (filenames.some(name => name.endsWith('.txt'))) {
        badges.push('unsynced');
    }
    return badges;
}

function initDownloadPlaceholder() {
    initQueueRealtimeEvents();
    loadQueueFromServer({ force: true });
    stopQueuePolling();
    const downloadsPane = document.getElementById('downloads-content');
    if (downloadsPane?.classList.contains('active')) {
        startQueuePolling();
    }
    if (!queueVisibilityHandlerAttached) {
        queueVisibilityHandlerAttached = true;
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                stopQueuePolling();
            } else {
                startQueuePolling();
            }
        });
    }
    updateQueueButtons();
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDownloadPlaceholder);
} else {
    initDownloadPlaceholder();
}

	function formatDownloadLogTime(date) {
	    const pad = (value) => String(value).padStart(2, '0');
	    return `${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`;
	}

	const downloadLogsMaxEntries = 300;
	let downloadLogsRenderScheduled = false;
	function scheduleRenderDownloadLogs() {
	    if (downloadLogsRenderScheduled) return;
	    downloadLogsRenderScheduled = true;
	    requestAnimationFrame(() => {
	        downloadLogsRenderScheduled = false;
	        renderDownloadLogs();
	    });
	}

		function renderDownloadLogs() {
	    const logPane = document.getElementById('download-logs');
	    const status = document.getElementById('download-logs-status');
	    const logger = window.DeezSpoTag?.DownloadLogger;
	    if (!logPane || !status || !logger) {
	        return;
	    }

	    const logs = logger.getLogs();
	    if (!logs.length) {
	        status.textContent = 'No logs yet.';
	        logPane.innerHTML = '<div class="logs-summary">No download activity logged yet.</div>';
	        return;
	    }

	    const totalCount = logs.length;
	    const visibleLogs = logs.length > downloadLogsMaxEntries
	        ? logs.slice(-downloadLogsMaxEntries)
	        : logs;

	    const previousScrollTop = logPane.scrollTop;
	    const previousScrollHeight = logPane.scrollHeight;
	    const isNearBottom = (previousScrollTop + logPane.clientHeight) >= (previousScrollHeight - 24);

	    status.textContent = totalCount > visibleLogs.length
	        ? `Showing last ${visibleLogs.length} of ${totalCount} entries.`
	        : `Showing ${totalCount} entries.`;

	    logPane.innerHTML = visibleLogs
	        .map((entry) => {
	            const time = formatDownloadLogTime(entry.timestamp);
	            const level = entry.level || 'info';
	            const engine = entry.engine ? `[${normalizeEngine(entry.engine)}]` : '';
	            return `
	                <div class="download-log-entry">
	                    <span>[${time}]</span>
                    <span class="download-log-level ${escapeHtml(level)}">[${escapeHtml(level)}]</span>
                    <span>${escapeHtml(`${engine} ${entry.message ?? ''}`.trim())}</span>
                </div>
            `;
        })
        .join('');

	    if (isNearBottom) {
	        logPane.scrollTop = logPane.scrollHeight;
	    }
	}

		function initDownloadLogs() {
    if (window.__deezspTagDownloadLogsInitDone) {
        return;
    }
    window.__deezspTagDownloadLogsInitDone = true;

    function tryLegacyClipboardCopy(text) {
        const value = String(text || '');
        if (!value) {
            return false;
        }

        const textArea = document.createElement('textarea');
        textArea.value = value;
        textArea.setAttribute('readonly', '');
        textArea.style.position = 'fixed';
        textArea.style.left = '-9999px';
        textArea.style.top = '0';
        textArea.style.opacity = '0';
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();

        let copied = false;
        try {
            copied = document.execCommand('copy');
        } catch {
            copied = false;
        } finally {
            textArea.remove();
        }

        return copied;
    }

    const copyButton = document.getElementById('download-logs-copy');
    if (copyButton) {
        copyButton.addEventListener('click', async () => {
            const logger = window.DeezSpoTag?.DownloadLogger;
            const status = document.getElementById('download-logs-status');
            if (!logger || !status) return;

            const content = logger.getLogs()
                .map((entry) => {
                    const time = formatDownloadLogTime(entry.timestamp);
                    const engine = entry.engine ? `[${normalizeEngine(entry.engine)}]` : '';
                    return `[${time}] [${entry.level}] ${engine} ${entry.message}`.trim();
                })
                .join('\n');

            if (!content.trim()) {
                status.textContent = 'No logs to copy.';
                return;
            }

            try {
                if (!document.hasFocus()) {
                    window.focus();
                    await new Promise((resolve) => window.requestAnimationFrame(resolve));
                }

                if (window.isSecureContext
                    && navigator.clipboard
                    && typeof navigator.clipboard.writeText === 'function') {
                    await navigator.clipboard.writeText(content);
                    status.textContent = 'Logs copied to clipboard.';
                    return;
                }

                if (tryLegacyClipboardCopy(content)) {
                    status.textContent = 'Logs copied to clipboard.';
                    return;
                }

                status.textContent = 'Failed to copy logs.';
            } catch (error) {
                const message = error && typeof error.message === 'string'
                    ? error.message
                    : 'Browser denied clipboard access.';
                if (tryLegacyClipboardCopy(content)) {
                    status.textContent = 'Logs copied to clipboard.';
                    return;
                }

                status.textContent = `Failed to copy logs: ${message}`;
            }
        });
    }

    const clearButton = document.getElementById('download-logs-clear');
    if (clearButton) {
        clearButton.addEventListener('click', async () => {
            const logger = window.DeezSpoTag?.DownloadLogger;
            const status = document.getElementById('download-logs-status');
            if (!logger || !status) return;
            const confirmed = await DeezSpoTag.ui.confirm('Clear all logs? This cannot be undone.', {
                title: 'Clear Logs'
            });
            if (!confirmed) {
                return;
            }

            clearButton.disabled = true;
            try {
                const response = await activityFetch('/api/library/scan/logs/clear', { method: 'POST' });
                if (!response.ok) {
                    throw new Error(await response.text());
                }

                libraryLogKeys.clear();
                logger.clear();
                status.textContent = 'Logs cleared.';
            } catch (error) {
                const message = error && typeof error.message === 'string'
                    ? error.message
                    : 'Failed to clear logs.';
                status.textContent = `Failed to clear logs: ${message}`;
            } finally {
                clearButton.disabled = false;
            }
        });
    }

	    const logger = window.DeezSpoTag?.DownloadLogger;
	    if (logger) {
	        logger.subscribe(scheduleRenderDownloadLogs);
	    }
	    scheduleRenderDownloadLogs();
	}

async function initLibraryLogs() {
    if (window.__deezspTagLibraryLogsInitDone) {
        return;
    }
    window.__deezspTagLibraryLogsInitDone = true;

    const logger = window.DeezSpoTag?.DownloadLogger;
    if (logger) {
        const existingLogs = logger.getLogs();
        existingLogs.forEach((entry) => {
            const key = buildLibraryLogKey({
                timestampUtc: entry.timestamp instanceof Date ? entry.timestamp.toISOString() : entry.timestamp,
                level: entry.level,
                message: entry.message
            });
            libraryLogKeys.add(key);
        });
    }

    const logsTab = document.getElementById('activities-logs-tab');
    if (logsTab) {
        logsTab.addEventListener('shown.bs.tab', () => {
            loadLibraryLogs();
            startLibraryLogsAutoRefresh();
        });
        logsTab.addEventListener('hidden.bs.tab', () => {
            stopLibraryLogsAutoRefresh();
        });
    }

    const logsTabPane = document.getElementById('logs-content');
    if (logsTabPane?.classList.contains('active')) {
        await loadLibraryLogs();
        startLibraryLogsAutoRefresh();
    }

    document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
            stopLibraryLogsAutoRefresh();
            return;
        }
        const pane = document.getElementById('logs-content');
        if (pane?.classList.contains('active')) {
            loadLibraryLogs();
            startLibraryLogsAutoRefresh();
        }
    });
}

