		            : '';

		        const cancelButton = (statusForUi === 'queued' || statusForUi === 'running' || statusForUi === 'paused')
		            ? `<button class="btn-danger action-btn action-btn-sm"${taskActionAttrs} onclick="cancelTask('${safeTaskIdArg}')">${activityActionIconSvg('cancel')}<span>Cancel</span></button>`
		            : '';

        const taskActions = (pauseButton || resumeButton || retryButton || deleteFailedButton || deleteCanceledButton || cancelButton)
            ? `<div class="task-actions">${pauseButton}${resumeButton}${retryButton}${deleteFailedButton}${deleteCanceledButton}${cancelButton}</div>`
            : '';

        const displayQuality = task.quality ? task.quality.replace(/_/g, ' ') : '';
        const safeTitle = escapeHtml(task.title || 'Unknown');
        const safeArtist = escapeHtml(task.artist || 'Unknown');
        const safeQuality = escapeHtml(displayQuality);
	        const safeEngine = escapeHtml(task.engine || '');
	        const coverStyle = task.cover
	            ? `style="--task-cover-url: url('${escapeCssUrl(task.cover)}')"`
	            : '';
	        const runningOverlayHtml = statusForUi === 'running'
	            ? `<span class="download-flow" aria-hidden="true">
	                   <span class="flow-packet p1"></span>
	                   <span class="flow-packet p2"></span>
