@{
    ViewData["Title"] = "AutoTag Flow - DeezSpoTag";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<link rel="stylesheet" href="~/css/autotag.css" asp-append-version="true" />
<style>
/* Stage Header */
.stage-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border-secondary);
}

.stage-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--primary-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
}

.stage-title {
    flex: 1;
}

.stage-title h5 {
    margin: 0;
    font-size: 16px;
}

.stage-title p {
    margin: 4px 0 0 0;
    font-size: 12px;
    color: var(--text-muted);
}

/* Maintenance Stats */
.maintenance-stats {
    display: flex;
    gap: 16px;
    padding: 16px;
    background: var(--bg-tertiary);
    border-radius: 8px;
    margin-top: 20px;
}

.maintenance-stat {
    flex: 1;
    text-align: center;
}

.maintenance-stat-label {
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 4px;
}

.maintenance-stat-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
}

/* Responsive */
/* Enrichment Source Items */
.enrichment-source-item {
    padding: 16px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: 10px;
}

.enrichment-source-item .source-header {
    display: flex;
    align-items: center;
}

.enrichment-source-item .source-header i {
    font-size: 18px;
}

.enrichment-source-item .source-options {
    padding: 16px;
    background: var(--bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--border-secondary);
}

.manual-tagging-run-actions {
    width: 100%;
    justify-content: flex-end;
}

.enrichment-source-item .form-row-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px 16px;
}

.uniformity-report-list {
    display: grid;
    gap: 16px;
    margin-top: 16px;
}

.uniformity-report-card {
    padding: 16px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: 10px;
}

.uniformity-report-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
}

.uniformity-report-title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
}

.uniformity-report-subtitle {
    color: var(--text-muted);
    font-size: 12px;
}

.uniformity-report-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    margin-bottom: 12px;
}

.uniformity-report-stat {
    padding: 10px 12px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 8px;
}

.uniformity-report-stat-label {
    display: block;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 4px;
}

.uniformity-report-stat-value {
    font-size: 14px;
    font-weight: 600;
}

.uniformity-report-details {
    margin-top: 8px;
}

.uniformity-report-details summary {
    cursor: pointer;
    color: var(--primary-color);
    font-weight: 600;
}

.uniformity-report-entries {
    margin: 10px 0 0;
    padding: 12px;
    max-height: 240px;
    overflow: auto;
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 8px;
    white-space: pre-wrap;
    font-family: var(--font-family-monospace, monospace);
    font-size: 12px;
    line-height: 1.5;
}

.uniformity-live-log {
    margin-top: 12px;
    padding: 12px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: 10px;
}

.uniformity-live-log-title {
    margin-bottom: 8px;
    font-size: 12px;
    color: var(--text-muted);
}

.uniformity-live-log .uniformity-report-entries {
    margin-top: 0;
}

/* Prevent hard-refresh flash of hidden tabs before shared CSS loads */
#autotagTabsContent > .tab-pane {
    display: none;
}

#autotagTabsContent > .tab-pane.active {
    display: block;
}

/* Keep icon glyph names hidden until Material Icons font is ready */
.autotag-page.material-icons-pending .material-icons {
    visibility: hidden;
}

@@media (max-width: 768px) {
    .enrichment-source-item .form-row-3 {
        grid-template-columns: repeat(2, 1fr);
    }

    .uniformity-report-header {
        flex-direction: column;
    }

    .uniformity-report-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}
</style>
}

<div class="container-fluid autotag-page material-icons-pending">
    <div class="autotag-sticky-shell" id="autotagStickyShell">
        <div class="autotag-hero">
            <div class="autotag-hero-copy">
                <h1 class="welcome-title mb-2">AutoTag Flow</h1>
                <p class="text-muted mb-0">Configure the three-stage enrichment pipeline for your music files.</p>
            </div>
            <div class="autotag-actions autotag-hero-actions">
                <button type="button" class="action-btn action-btn-sm" id="autotag-save">Save Preferences</button>
                <a class="action-btn action-btn-sm" id="autotag-view-status" href="/Activities?tab=autotag-status-content">View Status</a>
                <a class="action-btn action-btn-sm" id="autotag-tag-editor" href="/AutoTag/QuickTag">Tag Editor</a>
                <button type="button" class="action-btn action-btn-sm" id="autotag-reset">Reset</button>
                <button type="button" class="action-btn action-btn-sm" id="autotag-stop">Stop AutoTag</button>
            </div>
        </div>

        <!-- Tabs Navigation -->
        <ul class="nav nav-tabs nav-fill mb-4 ds-mobile-tabs" id="autotagTabs">
            <li class="nav-item">
                <button class="nav-link active" id="autotag-profiles-tab" data-bs-toggle="tab" data-bs-target="#autotag-profiles-panel" type="button" role="tab">
                    <i class="fas fa-layer-group me-2"></i>Profiles
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="autotag-folders-tab" data-bs-toggle="tab" data-bs-target="#autotag-folders-panel" type="button" role="tab">
                    <i class="fas fa-folder-tree me-2"></i>Folders
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="autotag-platforms-tab" data-bs-toggle="tab" data-bs-target="#autotag-platforms-panel" type="button" role="tab">
                    <i class="fas fa-globe me-2"></i>Platforms
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="autotag-stage1-tab" data-bs-toggle="tab" data-bs-target="#autotag-stage1-panel" type="button" role="tab">
                    <i class="fas fa-download me-2"></i>Download
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="autotag-stage2-tab" data-bs-toggle="tab" data-bs-target="#autotag-stage2-panel" type="button" role="tab">
                    <i class="fas fa-magic me-2"></i>Enrichment
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="autotag-stage3-tab" data-bs-toggle="tab" data-bs-target="#autotag-stage3-panel" type="button" role="tab">
                    <i class="fas fa-book me-2"></i>Enhancement
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="autotag-technical-tab" data-bs-toggle="tab" data-bs-target="#autotag-technical-panel" type="button" role="tab">
                    <i class="fas fa-cog me-2"></i>Technical
                </button>
            </li>
        </ul>
    </div>

    <div class="tab-content" id="autotagTabsContent">
        <!-- ==================== TAB 1: PROFILES ==================== -->
        <div class="tab-pane fade show active" id="autotag-profiles-panel" role="tabpanel">
            <div class="stage-header">
                <div class="stage-number"><i class="fas fa-layer-group"></i></div>
                <div class="stage-title">
                    <h5>Profiles</h5>
                    <p>Save and load configuration presets for all AutoTag stages</p>
                </div>
            </div>

            <div class="card bg-darker border-secondary mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-layer-group me-2"></i>Profile Manager
                    </h5>
                </div>
                <div class="card-body autotag-card-body">
                    <div class="download-section">
                        <div class="download-section-title">Profiles</div>
                        <div class="download-grid download-grid-2">
                            <div class="form-group">
                                <label for="autotag-profile-select">Saved profiles</label>
                                <select id="autotag-profile-select"></select>
                            </div>
                            <div class="form-group">
                                <label for="autotag-profile-name">Profile name</label>
                                <input type="text" id="autotag-profile-name" placeholder="My Tagging Profile" />
                            </div>
                        </div>
                        <span class="helper">Profiles store tag sources, platform settings, and advanced options for all three stages.</span>
                        <span class="helper" id="autotag-profile-summary">No active profile loaded.</span>
                    </div>
                    <div class="download-section">
                        <div class="download-section-title">Actions</div>
                        <div class="autotag-actions">
                            <button type="button" class="action-btn action-btn-sm" id="autotag-profile-load">Load</button>
                            <button type="button" class="action-btn action-btn-sm" id="autotag-profile-save">Save</button>
                            <button type="button" class="action-btn action-btn-sm" id="autotag-profile-copy">Copy</button>
                            <button type="button" class="btn-danger action-btn action-btn-sm" id="autotag-profile-delete">Delete</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== TAB 2: FOLDERS ==================== -->
        <div class="tab-pane fade" id="autotag-folders-panel" role="tabpanel">
            <script>
                window.LibraryFolderQualityOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    DeezSpoTag.Services.Download.QualityCatalog.GetLibraryFolderQualityOptions()
                        .Select(option => new { value = option.Value, label = option.Label })
                        .ToList()));
            </script>

            <div class="stage-header">
                <div class="stage-number"><i class="fas fa-folder-open"></i></div>
                <div class="stage-title">
                    <h5>Folders</h5>
                    <p>Configure library folders and organize file structure for downloads</p>
                </div>
            </div>

            <!-- Library Folders -->
            <div class="card bg-darker border-secondary mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-folder-open me-2"></i>Library Folders
                    </h5>
                    <button type="button" class="action-btn action-btn-sm" id="addFolderBtn">
                        <i class="fas fa-plus me-1"></i>Add Folder
                    </button>
                </div>
                <div class="card-body autotag-card-body">
                    <div class="download-section">
                        <div class="download-section-title">Folders</div>
                        <!-- Folder List -->
                        <div class="folder-table-scroll">
                            <div class="folder-table-header">
                                <span>Folder</span>
                                <span>Path</span>
                                <span>Quality</span>
                                <span>Profile</span>
                                <span>Enhancement</span>
                                <span>Status</span>
                                <span>Actions</span>
                            </div>
                            <div class="folders-list" id="foldersContainer">
                                <!-- Folders will be rendered here by JS -->
                            </div>
                        </div>

                        <!-- Empty State -->
                        <div class="folders-empty-state" id="foldersEmptyState">
                            <i class="fas fa-folder-plus"></i>
                            <p>No library folders configured</p>
                            <span class="helper">Click "Add Folder" to create your first library folder</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Add/Edit Folder Modal -->
            <div class="folder-modal app-modal hidden" id="folderModal" aria-hidden="true">
                <div class="folder-modal-backdrop app-modal-backdrop"></div>
                <dialog class="folder-modal-content app-modal-dialog playlist-settings-modal" aria-modal="true" aria-labelledby="folderModalTitle">
                    <div class="folder-modal-header app-modal-header">
                        <h5 class="app-modal-title" id="folderModalTitle">Add Library Folder</h5>
                        <button type="button" class="folder-modal-close app-modal-close" id="folderModalClose" aria-label="Close folder modal">
                            <i class="fas fa-times" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="folder-modal-body app-modal-body">
                        <div class="app-modal-content playlist-settings-panel watchlist-playlist-settings folder-settings-panel">
                            <input type="hidden" id="folderEditId" value="" />

                            <div class="playlist-settings-intro">Set folder path, quality behavior, and optional role overrides for AutoTag and Library.</div>

                            <section class="playlist-settings-section">
                                <div class="playlist-settings-section-title">Folder Details</div>
                                <div class="form-group">
                                    <label for="folderPath">Folder Path</label>
                                    <div class="path-picker-input">
                                        <input id="folderPath" type="text" placeholder="/music/collection" />
                                        <button type="button" id="browseLibraryFolderPath" class="path-picker-btn" title="Browse server folders">
                                            <i class="fas fa-folder-open"></i>
                                            <span class="visually-hidden">Browse server folders</span>
                                        </button>
                                    </div>
                                    <span class="helper">Full path to the library folder.</span>
                                </div>
                                <div class="form-group">
                                    <label for="folderName">Display Name</label>
                                    <input id="folderName" type="text" placeholder="Main Library" />
                                    <span class="helper">A friendly name used across Library and AutoTag.</span>
                                </div>
                            </section>

                            <section class="playlist-settings-section">
                                <div class="playlist-settings-section-title">Library Behavior</div>
                                <div class="form-group">
                                    <div class="checkbox-group">
                                        <input type="checkbox" id="folderEnabled" checked />
                                        <label for="folderEnabled">Show this folder in Library and scans</label>
                                    </div>
                                    <span class="helper">Disable only if you want to keep the folder configured but excluded from indexing and Library views.</span>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="folderQuality">Preferred Quality</label>
                                        <select id="folderQuality">
@foreach (var option in DeezSpoTag.Services.Download.QualityCatalog.GetLibraryFolderQualityOptions())
{
                                            <option value="@option.Value" selected="@(option.Value == "27")">@option.Label</option>
}
                                        </select>
                                    </div>
                                </div>
                            </section>

                            <section class="playlist-settings-section">
                                <div class="playlist-settings-section-title">Conversion Override</div>
                                <div class="form-group">
                                    <div class="checkbox-group">
                                        <input type="checkbox" id="folderConvertEnabled" />
                                        <label for="folderConvertEnabled">Enable conversion override</label>
                                    </div>
                                    <span class="helper">Optional folder-level conversion rule. If format is blank, global conversion format is used.</span>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="folderConvertFormat">Convert format (optional)</label>
                                        <select id="folderConvertFormat">
                                            <option value="">Use global/default</option>
                                            <option value="mp3">MP3</option>
                                            <option value="aac">AAC (M4A)</option>
                                            <option value="alac">ALAC (M4A)</option>
                                            <option value="ogg">OGG</option>
                                            <option value="opus">OPUS</option>
                                            <option value="flac">FLAC</option>
                                            <option value="wav">WAV</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="folderConvertBitrate">Convert bitrate (optional)</label>
                                        <select id="folderConvertBitrate">
                                            <option value="">Use global/default</option>
                                            <option value="AUTO">Auto</option>
                                            <option value="64">64 kbps</option>
                                            <option value="96">96 kbps</option>
                                            <option value="128">128 kbps</option>
                                            <option value="160">160 kbps</option>
                                            <option value="192">192 kbps</option>
                                            <option value="256">256 kbps</option>
                                            <option value="320">320 kbps</option>
                                        </select>
                                    </div>
                                </div>
                            </section>

                            <section class="playlist-settings-section">
                                <div class="playlist-settings-section-title">Folder Roles</div>
                                <div class="checkbox-group folder-role-options">
                                    <label>
                                        <input type="checkbox" id="folderAtmosDestination" />
                                        Set as default Atmos destination
                                    </label>
                                    <label>
                                        <input type="checkbox" id="folderVideoDestination" />
                                        Set as Video downloads folder
                                    </label>
                                    <label>
                                        <input type="checkbox" id="folderPodcastDestination" />
                                        Set as Podcast downloads folder
                                    </label>
                                </div>
                                <span class="playlist-settings-help">These update Atmos secondary destination plus global Video/Podcast download locations.</span>
                            </section>
                        </div>
                    </div>
                    <div class="folder-modal-footer app-modal-footer">
                        <button type="button" class="app-modal-action" id="folderModalCancel">Cancel</button>
                        <button type="button" class="app-modal-action primary" id="saveFolder">
                            <i class="fas fa-floppy-disk" aria-hidden="true"></i>
                            Save Folder
                        </button>
                    </div>
                </dialog>
            </div>

            <!-- Folder Structure -->
            <div class="card bg-darker border-secondary mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-sitemap me-2"></i>Folder Structure
                    </h5>
                </div>
                <div class="card-body autotag-card-body">
                    <div class="download-section">
                        <div class="download-section-title">Structure</div>
                        <!-- Structure Options Grid -->
                        <div class="folder-structure-grid">
                            <!-- Artist Folder -->
                            <div class="folder-structure-item">
                                <div class="folder-structure-toggle">
                                    <div class="checkbox-group">
                                        <input type="checkbox" id="createArtistFolder" />
                                        <label for="createArtistFolder">
                                            <i class="fas fa-user me-2"></i>Artist Folder
                                        </label>
                                    </div>
                                </div>
                                <div class="folder-structure-template" id="artistNameGroup">
                                    <input type="text" id="artistNameTemplate" placeholder="%artist%" />
                                </div>
                            </div>

                            <!-- Album Folder -->
                            <div class="folder-structure-item">
                                <div class="folder-structure-toggle">
                                    <div class="checkbox-group">
                                        <input type="checkbox" id="createAlbumFolder" />
                                        <label for="createAlbumFolder">
                                            <i class="fas fa-compact-disc me-2"></i>Album Folder
                                        </label>
                                    </div>
                                </div>
                                <div class="folder-structure-template" id="albumNameGroup">
                                    <input type="text" id="albumNameTemplate" placeholder="%album%" />
                                </div>
                            </div>

                            <!-- Playlist Folder -->
                            <div class="folder-structure-item">
                                <div class="folder-structure-toggle">
                                    <div class="checkbox-group">
                                        <input type="checkbox" id="createPlaylistFolder" />
                                        <label for="createPlaylistFolder">
                                            <i class="fas fa-list me-2"></i>Playlist Folder
                                        </label>
                                    </div>
                                </div>
                                <div class="folder-structure-template" id="playlistNameGroup">
                                    <input type="text" id="playlistNameTemplate" placeholder="%playlist%" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Extras</div>
                        <!-- Additional Options -->
                        <div class="folder-structure-extras">
                            <div class="checkbox-group">
                                <input type="checkbox" id="createCDFolder" />
                                <label for="createCDFolder">Create CD/Disc subfolder for multi-disc albums</label>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" id="createStructurePlaylist" />
                                <label for="createStructurePlaylist">Apply folder structure to playlists</label>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" id="createSingleFolder" />
                                <label for="createSingleFolder">Create separate folder for singles</label>
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Character Replacement</div>
                        <!-- Character Replacement -->
                        <div class="folder-structure-char">
                            <div class="form-group">
                                <label for="illegalCharacterReplacer">
                                    <i class="fas fa-exclamation-triangle me-2"></i>Illegal Character Replacement
                                </label>
                                <input type="text" id="illegalCharacterReplacer" value="_" style="max-width: 120px;" />
                                <span class="helper">Characters like \ / : * ? " &lt; &gt; | will be replaced with this</span>
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Preview</div>
                        <!-- Preview -->
                        <div class="folder-structure-preview">
                            <div class="form-label"><i class="fas fa-eye me-2"></i>Preview</div>
                            <div class="folder-preview-tree" id="folderPreviewTree">
                                <div class="folder-preview-line"><i class="fas fa-folder text-warning"></i> <span>Library</span></div>
                                <div class="folder-preview-line indent-1"><i class="fas fa-folder text-warning"></i> <span id="previewArtist">Artist Name</span></div>
                                <div class="folder-preview-line indent-2"><i class="fas fa-folder text-warning"></i> <span id="previewAlbum">Album Name</span></div>
                                <div class="folder-preview-line indent-3"><i class="fas fa-file-audio text-info"></i> <span>01 - Track.flac</span></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Multi-Artist Handling -->
            <div class="card bg-darker border-secondary mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-users me-2"></i>Multi-Artist Handling
                    </h5>
                </div>
                <div class="card-body autotag-card-body">
                    <div class="download-section">
                        <div class="download-section-title">Primary Rule</div>
                        <div class="checkbox-group">
                            <input type="checkbox" id="singleAlbumArtist" checked />
                            <label for="singleAlbumArtist">
                                Single Album Artist (use main artist)
                                <span class="autotag-tooltip-icon ms-1"
                                      title="Enabled: Album Artist stays single (main artist), and folders use the main artist. Disable this to allow multi-artist handling."
                                      aria-label="Enabled: Album Artist stays single (main artist), and folders use the main artist. Disable this to allow multi-artist handling.">
                                    <i class="fas fa-question-circle"></i>
                                </span>
                            </label>
                        </div>
                    </div>
                    <div class="download-section" id="autotag-multi-artist-dependent">
                        <div class="download-section-title">Other Handling</div>
                        <div class="download-grid download-grid-4">
                            <div class="form-group">
                                <label for="multiArtistSeparator">Multi Artist Separator</label>
                                <select id="multiArtistSeparator">
                                    <option value="default">Default</option>
                                    <option value=", ">, (comma)</option>
                                    <option value=" / ">/ (slash)</option>
                                    <option value=" & ">& (ampersand)</option>
                                </select>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" id="albumVariousArtists" checked />
                                <label for="albumVariousArtists">Album Various Artists</label>
