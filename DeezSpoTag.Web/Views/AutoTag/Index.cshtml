                                <label for="autotag-sep-mp4">MP4 Separator</label>
                                <input type="text" id="autotag-sep-mp4" value=", " placeholder="MP4 separator" />
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Language</div>
                        <div class="form-group">
                            <label for="autotag-id3-lang">ID3 COMM language (3 letters)</label>
                            <input type="text" id="autotag-id3-lang" placeholder="eng" maxlength="3" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Text Processing -->
            <div class="card bg-darker border-secondary mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-font me-2"></i>Text Processing
                    </h5>
                </div>
                <div class="card-body autotag-card-body">
                    <div class="download-section">
                        <div class="download-section-title">Casing</div>
                        <div class="download-grid download-grid-2">
                            <div class="form-group">
                                <label for="titleCasing">Title Casing</label>
                                <select id="titleCasing">
                                    <option value="nothing">Nothing</option>
                                    <option value="capitalize">Capitalize</option>
                                    <option value="uppercase">UPPERCASE</option>
                                    <option value="lowercase">lowercase</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="artistCasing">Artist Casing</label>
                                <select id="artistCasing">
                                    <option value="nothing">Nothing</option>
                                    <option value="capitalize">Capitalize</option>
                                    <option value="uppercase">UPPERCASE</option>
                                    <option value="lowercase">lowercase</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Formatting</div>
                        <div class="download-grid download-grid-2">
                            <div class="form-group">
                                <label for="dateFormat">Date Format</label>
                                <select id="dateFormat">
                                    <option value="Y-M-D">Year-Month-Day</option>
                                    <option value="D-M-Y">Day-Month-Year</option>
                                    <option value="M-D-Y">Month-Day-Year</option>
                                    <option value="Y">Year only</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="featuredToTitle">Featured To Title</label>
                                <select id="featuredToTitle">
                                    <option value="0">No</option>
                                    <option value="1">Move to title</option>
                                    <option value="2">Copy to title</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Options</div>
                        <div class="download-grid download-grid-3">
                            <div class="checkbox-group">
                                <input type="checkbox" id="removeAlbumVersion" />
                                <label for="removeAlbumVersion">Remove Album Version</label>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" id="autotag-short-title" />
                                <label for="autotag-short-title">Use short title (Beatport/Traxsource)</label>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" id="autotag-capitalize-genres" />
                                <label for="autotag-capitalize-genres">Capitalize genres</label>
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Cleanup</div>
                        <div class="form-group">
                            <label for="autotag-title-regex">Title cleanup regex</label>
                            <input type="text" id="autotag-title-regex" placeholder="e.g. \s*\(.*?\)\s*$" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Style/Genre Handling -->
            <div class="card bg-darker border-secondary mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-music me-2"></i>Style/Genre Handling
                    </h5>
                </div>
                <div class="card-body autotag-card-body">
                    <div class="download-section">
                        <div class="download-section-title">Handling</div>
                        <div class="form-group">
                            <label for="autotag-styles-options">Style/Genre handling</label>
                            <select id="autotag-styles-options">
                                <option value="default">Default (all)</option>
                                <option value="onlyGenres">Only genres</option>
                                <option value="onlyStyles">Only styles</option>
                                <option value="mergeToGenres">Merge to Genre</option>
                                <option value="mergeToStyles">Merge to Style</option>
                                <option value="stylesToGenre">Write Style to Genre</option>
                                <option value="genresToStyle">Write Genre to Style</option>
                                <option value="customTag">Write Style to Custom tag</option>
                            </select>
                        </div>

                        <div class="form-group" id="autotag-styles-custom-group" style="display: none;">
                            <div class="form-label">Custom tag (style)</div>
                            <div class="download-grid download-grid-3">
                                <input type="text" id="autotag-styles-id3" placeholder="ID3" />
                                <input type="text" id="autotag-styles-vorbis" placeholder="Vorbis" />
                                <input type="text" id="autotag-styles-mp4" placeholder="MP4" />
                            </div>
                        </div>
                    </div>

                    <div class="download-section">
                        <div class="download-section-title">Options</div>
                        <div class="download-grid download-grid-2">
                            <div class="checkbox-group">
                                <input type="checkbox" id="autotag-merge-genres" />
                                <label
                                    for="autotag-merge-genres"
                                    title="Merge genres/styles applies only when Genre overwrite is enabled in Tag Overwrite Settings.">
                                    Merge genres/styles instead of overwrite
                                </label>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" id="autotag-camelot" />
                                <label for="autotag-camelot">Use Camelot key notation</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tag Overwrite Settings -->
            <div class="card bg-darker border-secondary mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-edit me-2"></i>Tag Overwrite Settings
                    </h5>
                </div>
                <div class="card-body autotag-card-body">
                    <div class="download-section">
                        <div class="download-section-title">Overwrite</div>
                        <div class="checkbox-group">
                            <input type="checkbox" id="autotag-overwrite" />
                            <label for="autotag-overwrite">Overwrite existing tags</label>
                        </div>
                    </div>
                    <div class="download-section">
                        <div class="download-section-title">Tags</div>
                        <div class="form-group" id="autotag-overwrite-tags-group">
                            <div class="form-label">Overwrite only these tags</div>
                            <div class="tags-grid gap-fill-tags-grid" id="autotag-overwrite-tags"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
(function ensureAutoTagMaterialIconsReveal() {
    const selector = '.autotag-page.material-icons-pending';
    const invokeReveal = () => {
        if (typeof window.DeezSpoTagRevealMaterialIconsWhenReady === 'function') {
            window.DeezSpoTagRevealMaterialIconsWhenReady(selector);
            return true;
        }
        return false;
    };

    if (invokeReveal()) {
        return;
    }

    window.addEventListener('load', () => {
        if (!invokeReveal()) {
            document.querySelector(selector)?.classList.remove('material-icons-pending');
        }
    }, { once: true });
})();

// Pipeline tab activation helper
function activatePipelineTab(tabId) {
    const tab = document.getElementById(tabId);
    if (tab) {
        const bsTab = new bootstrap.Tab(tab);
        bsTab.show();
    }
}

// Update pipeline visual when tabs change
document.addEventListener('DOMContentLoaded', function() {
    // Toggle visibility helpers
    document.getElementById('autotag-move-failed')?.addEventListener('change', function() {
        document.getElementById('autotag-move-failed-group').style.display = this.checked ? 'block' : 'none';
    });

    // Enrichment timing radio buttons
    document.querySelectorAll('input[name="enrichmentTiming"]').forEach(radio => {
        radio.addEventListener('change', function() {
            document.getElementById('enrichmentScheduleGroup').style.display =
                this.value === 'scheduled' ? 'block' : 'none';
        });
    });

    // Download source toggles

});
</script>

@section Scripts {
<script src="~/js/library.js" asp-append-version="true"></script>
<script src="~/js/autotag.js" asp-append-version="true"></script>
}
