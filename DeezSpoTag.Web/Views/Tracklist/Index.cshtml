async function loadTracklistRecommendations() {
    const container = document.getElementById('spotify-recommendations');
    if (!container) {
        return;
    }

    const source = (tracklistSource || requestSource || '').toLowerCase();
    if (source === 'spotify') {
        await loadSpotifyRecommendations(container);
        return;
    }

    if (source === 'boomplay') {
        await loadBoomplayRecommendations(container);
        return;
    }

    container.classList.add('is-hidden');
    container.innerHTML = '';
}

async function loadSpotifyRecommendations(container) {
    if (tracklistType !== 'playlist' && tracklistType !== 'album') {
        container.classList.add('is-hidden');
        container.innerHTML = '';
        return;
    }
    if (tracklistType === 'playlist' && isSpotifyHomeTrendingTracklistView()) {
        container.classList.add('is-hidden');
        container.innerHTML = '';
        return;
    }

    const spotifyUrl = buildSpotifyTracklistUrl();
    if (!spotifyUrl) {
        container.classList.add('is-hidden');
        container.innerHTML = '';
        return;
    }

    if (spotifyRecommendationState?.url === spotifyUrl && spotifyRecommendationState?.sections?.length) {
        renderSpotifyRecommendationSections(spotifyRecommendationState.sections);
        return;
    }

    spotifyRecommendationState = { url: spotifyUrl, loaded: false };

    try {
        const response = await fetch(`/api/spotify/tracklist/recommendations?url=${encodeURIComponent(spotifyUrl)}&limit=12`);
        if (!response.ok) {
            throw new Error(`Recommendations failed: ${response.status}`);
        }
        const payload = await response.json();
        if (!payload?.available || !Array.isArray(payload.sections) || payload.sections.length === 0) {
            container.classList.add('is-hidden');
            container.innerHTML = '';
            spotifyRecommendationState.loaded = true;
            return;
        }
        spotifyRecommendationState.sections = payload.sections;
        renderSpotifyRecommendationSections(payload.sections);
        spotifyRecommendationState.loaded = true;
    } catch (error) {
        console.warn('Spotify recommendations unavailable:', error);
        container.classList.add('is-hidden');
        container.innerHTML = '';
    }
}

async function loadBoomplayRecommendations(container) {
    if (tracklistType !== 'playlist' && tracklistType !== 'trending') {
        container.classList.add('is-hidden');
        container.innerHTML = '';
        return;
    }

    const recommendationType = tracklistType === 'trending' ? 'trending' : 'playlist';
    const cacheKey = `${recommendationType}:${tracklistId || ''}`;
    if (boomplayRecommendationState?.key === cacheKey && boomplayRecommendationState?.sections?.length) {
        renderSpotifyRecommendationSections(boomplayRecommendationState.sections);
        return;
    }

    boomplayRecommendationState = { key: cacheKey, loaded: false };

    try {
        const qs = new URLSearchParams();
        qs.set('type', recommendationType);
        qs.set('id', tracklistId || '');
        qs.set('limit', '12');

        const response = await fetch(`/api/boomplay/playlist/recommendations?${qs.toString()}`);
        if (!response.ok) {
            throw new Error(`Recommendations failed: ${response.status}`);
        }

        const payload = await response.json();
        if (!payload?.available || !Array.isArray(payload.sections) || payload.sections.length === 0) {
            container.classList.add('is-hidden');
            container.innerHTML = '';
            boomplayRecommendationState.loaded = true;
            return;
        }

        boomplayRecommendationState.sections = payload.sections;
        renderSpotifyRecommendationSections(payload.sections);
        boomplayRecommendationState.loaded = true;
    } catch (error) {
        console.warn('Boomplay recommendations unavailable:', error);
        container.classList.add('is-hidden');
        container.innerHTML = '';
    }
}

function buildSpotifyTracklistUrl() {
    if (!tracklistId || !tracklistType) {
        return '';
    }
    if (tracklistId.startsWith('spotify:')) {
        return tracklistId;
    }
    if (tracklistId.includes('open.spotify.com/')) {
        return tracklistId;
    }
    return `https://open.spotify.com/${tracklistType}/${tracklistId}`;
}

function renderSpotifyRecommendationSections(sections) {
    const container = document.getElementById('spotify-recommendations');
    if (!container) {
        return;
    }

    const html = sections.map(section => {
        const title = escapeHtml(section.title || 'Recommended');
        const items = Array.isArray(section.items) ? section.items : [];
        const cards = items.map(renderSpotifyRecommendationItem).join('');
        return `
            <div class="home-section">
                <div class="home-section-title">${title}</div>
                <div class="spotify-home-row">${cards}</div>
            </div>
        `;
    }).join('');

    if (!html.trim()) {
        container.classList.add('is-hidden');
        container.innerHTML = '';
        return;
    }

    container.innerHTML = html;
    container.classList.remove('is-hidden');
}

function renderSpotifyRecommendationItem(item) {
    if (!item) {
        return '';
    }
    const source = (item.source || 'spotify').toString().toLowerCase();
    const sourceType = (item.type || 'playlist').toString().toLowerCase();
    const sourceId = (item.id || '').toString();
    const sourceUrl = (item.url || item.sourceUrl || '').toString();
    const title = escapeHtml(item.name || '');
    const rawSubtitle = (item.artists || item.description || '').toString().trim();
    const subtitleIsGeneric = ['spotify', 'playlist'].includes(rawSubtitle.toLowerCase());
    const subtitle = subtitleIsGeneric ? '' : escapeHtml(rawSubtitle);
    const cover = item.coverUrl || item.imageUrl || item.image_url || '';
    const type = escapeHtml(item.type || '');
    const hideGenericPlaylistMeta = source === 'spotify' && sourceType === 'playlist';
    const meta = hideGenericPlaylistMeta ? '' : (type ? `${type}` : '');
    const artStyle = cover ? `style="background-image: url('${cover}');"` : '';
    return `
        <div class="spotify-card"
             data-source="${escapeHtml(source)}"
             data-source-type="${escapeHtml(sourceType)}"
             data-source-id="${escapeHtml(sourceId)}"
             data-source-url="${escapeHtml(sourceUrl)}"
             data-spotify-uri="${escapeHtml(item.uri || '')}">
            <div class="spotify-card-art" ${artStyle}>${cover ? '' : '🎵'}</div>
            <div class="spotify-card-title">${title}</div>
            ${subtitle ? `<div class="spotify-card-subtitle">${subtitle}</div>` : ''}
            ${meta ? `<div class="spotify-card-meta"><span>${meta}</span></div>` : ''}
        </div>
    `;
}

function parseSpotifyUri(uri) {
    if (!uri) return null;
    const trimmed = uri.trim();
    if (trimmed.startsWith('spotify:')) {
        const parts = trimmed.split(':').filter(Boolean);
        if (parts.length >= 3) {
            return { type: parts[1], id: parts[2] };
        }
    }
    const match = trimmed.match(/open\.spotify\.com\/(album|playlist|track|artist|show|episode)\/([A-Za-z0-9]+)/i);
    if (match) {
        return { type: match[1], id: match[2] };
    }
    return null;
}

function showTracklistNotice(message) {
    const notice = document.getElementById('tracklist-notice');
    if (!notice) {
        return;
    }
    if (!message) {
        notice.classList.add('is-hidden');
        notice.textContent = '';
        return;
    }
    notice.textContent = message;
    notice.classList.remove('is-hidden');
}

function updateSpotifyNotice() {
    const parts = [];
    if (spotifyLazyState && (spotifyLazyState.isLoading || spotifyLazyState.hasMore)) {
        const total = spotifyLazyState.total || 0;
        const loaded = spotifyLazyState.loaded || 0;
        const progress = total > 0
            ? `${loaded.toLocaleString()} / ${total.toLocaleString()}`
            : `${loaded.toLocaleString()}`;
        parts.push(`Loading tracks… ${progress}`);
    }

    if (boomplayLazyState && (boomplayLazyState.isLoading || boomplayLazyState.hasMore)) {
        const total = boomplayLazyState.total || 0;
        const loaded = boomplayLazyState.loaded || 0;
        const progress = total > 0
            ? `${loaded.toLocaleString()} / ${total.toLocaleString()}`
            : `${loaded.toLocaleString()}`;
        parts.push(`Loading Boomplay tracks… ${progress}`);
    }

    if (spotifyMatchState) {
        const remaining = typeof spotifyMatchState.pending === 'number' ? spotifyMatchState.pending : null;
        const matched = typeof spotifyMatchState.matched === 'number' ? spotifyMatchState.matched : null;
        const failed = typeof spotifyMatchState.failed === 'number' ? spotifyMatchState.failed : null;
        const rechecking = typeof spotifyMatchState.rechecking === 'number' ? spotifyMatchState.rechecking : null;
        if (remaining !== null) {
            if (matched !== null && failed !== null) {
                const recheckPart = rechecking !== null && rechecking > 0
                    ? `, ${rechecking} rechecking`
                    : '';
                parts.push(`Matching Deezer tracks… ${remaining} remaining (${matched} matched, ${failed} failed${recheckPart}).`);
            } else {
                parts.push(`Matching Deezer tracks… ${remaining} remaining.`);
            }
        }
    } else if (spotifyMatchCompletion) {
        parts.push(spotifyMatchCompletion);
    }

    if (externalMatchState) {
        const remaining = externalMatchState.pending || 0;
        const matched = externalMatchState.matched || 0;
        const failed = externalMatchState.failed || 0;
        const source = externalMatchState.source || 'External';
        if (remaining > 0) {
            parts.push(`Matching Deezer tracks… ${remaining} remaining (${matched} matched, ${failed} failed).`);
        } else if (externalMatchState.done) {
            parts.push(`Matching complete: ${matched} matched, ${failed} failed.`);
        }
    }

    if (parts.length === 0) {
        showTracklistNotice('');
        return;
    }

    showTracklistNotice(parts.join(' • '));
}

function setTracksEmptyMessage(message) {
    const tableBody = document.getElementById('tracks-table-body');
    if (!tableBody) {
        return;
    }
    const isPlaylistLike = tracklistLayoutIsPlaylistLike;
    const monitorSource = (requestSource || tracklistSource || 'deezer').toLowerCase();
    const isLocalSource = monitorSource === 'plex' || monitorSource === 'mix' || monitorSource === 'radio';
    const columnCount = getTracklistColumnCount(isPlaylistLike, isLocalSource);
    tableBody.innerHTML = `<tr class="tracks-empty"><td colspan="${columnCount}">${escapeHtml(message)}</td></tr>`;
}

function appendSpotifyTrackRows(tracks) {
    if (!tracks || tracks.length === 0) {
        return;
    }
    const tableBody = document.getElementById('tracks-table-body');
    if (!tableBody) {
        return;
    }
    tableBody.querySelectorAll('.tracks-loading, .tracks-empty').forEach(row => row.remove());

    const monitorSource = (requestSource || tracklistSource || 'deezer').toLowerCase();
    const isLocalSource = monitorSource === 'plex' || monitorSource === 'mix' || monitorSource === 'radio';
    const isPlaylistLike = tracklistLayoutIsPlaylistLike;
    const base = spotifyLazyState?.offset ?? 0;
    const filtered = tracks.filter((track, index) => {
        const trackIndex = typeof track.index === 'number' ? track.index : base + index;
        return !tableBody.querySelector(`tr[data-track-index="${trackIndex}"]`);
    });
    if (filtered.length === 0) {
        return;
    }
    const rows = renderTrackRows(filtered, isPlaylistLike, isLocalSource);
    if (!rows) {
        return;
    }
    tableBody.insertAdjacentHTML('beforeend', rows);
    applyIgnoredTrackState();
    bindIgnoreButtons();
    scheduleAvailabilityChecks(filtered, isLocalSource);
    preloadDeezerPlaybackContextsForVisibleRows(32);

    const indices = filtered.map((track, index) => {
        if (typeof track.index === 'number') {
            return track.index;
        }
        return base + index;
    });
    applySpotifyMatchesToRows(indices);
}

function appendBoomplayTrackRows(tracks) {
    if (!tracks || tracks.length === 0) {
        return [];
    }
    const tableBody = document.getElementById('tracks-table-body');
    if (!tableBody) {
        return [];
    }
    tableBody.querySelectorAll('.tracks-loading, .tracks-empty').forEach(row => row.remove());

    const monitorSource = (requestSource || tracklistSource || 'deezer').toLowerCase();
    const isLocalSource = monitorSource === 'plex' || monitorSource === 'mix' || monitorSource === 'radio';
    const isPlaylistLike = tracklistLayoutIsPlaylistLike;
    const base = boomplayLazyState?.offset ?? 0;
    const filtered = tracks.filter((track, index) => {
        const trackIndex = typeof track.index === 'number' ? track.index : base + index;
        return !tableBody.querySelector(`tr[data-track-index="${trackIndex}"]`);
    });
    if (filtered.length === 0) {
        return [];
    }
    const rows = renderTrackRows(filtered, isPlaylistLike, isLocalSource);
    if (!rows) {
        return [];
    }
    tableBody.insertAdjacentHTML('beforeend', rows);
    applyIgnoredTrackState();
    bindIgnoreButtons();
    scheduleAvailabilityChecks(filtered, isLocalSource);
    preloadDeezerPlaybackContextsForVisibleRows(32);
    return filtered;
}

function reconcileExternalMatchesFromCache() {
    const tableBody = document.getElementById('tracks-table-body');
    if (!tableBody) {
        return 0;
    }

    let applied = 0;
    tableBody.querySelectorAll('tr[data-track-index]').forEach((row) => {
        const checkbox = row.querySelector('.track-checkbox');
        if (!checkbox) {
            return;
        }

        const existing = String(checkbox.getAttribute('data-track-id') || '').trim();
        if (existing) {
            return;
        }

        const link = String(row.dataset.availabilityUrl || checkbox.getAttribute('data-track-link') || '').trim();
        if (!link || !externalDeezerMatchCache.has(link)) {
            return;
        }

        const deezerId = String(externalDeezerMatchCache.get(link) || '').trim();
        if (!/^\d+$/.test(deezerId)) {
            return;
        }

        applyExternalMatchToRow(row, deezerId);
        applied += 1;
    });

    return applied;
}

async function hydrateLibrespotTrackDetails(tracks) {
    if (!tracks || tracks.length === 0) {
        return;
    }

    const ids = [];
    tracks.forEach(track => {
        const id = getSpotifyTrackId(track);
        if (!id || librespotHydratedIds.has(id)) {
            return;
        }
        ids.push(id);
    });

    if (ids.length === 0) {
        return;
    }

    try {
        const response = await fetch(`/api/spotify/tracklist/librespot/tracks?ids=${encodeURIComponent(ids.join(','))}`);
        if (!response.ok) {
            throw new Error(`Failed to hydrate librespot tracks (HTTP ${response.status})`);
        }
        const payload = await response.json();
        if (!payload.available || !Array.isArray(payload.tracks)) {
            return;
        }

        const hydratedNow = new Set();
        payload.tracks.forEach(track => {
            if (!track || !track.id) {
                return;
            }
            const hasUsefulData = Boolean(
                (track.name && track.name.trim()) ||
                (track.artists && track.artists.trim()) ||
                (track.album && track.album.trim()) ||
                (track.durationMs && Number(track.durationMs) > 0)
            );
            if (!hasUsefulData) {
                return;
            }

            const mapped = {
                title: track.name || 'Unknown',
                artist: { name: track.artists || 'Unknown', id: '' },
                album: { title: track.album || 'Unknown', cover_medium: normalizeCoverUrl(track.imageUrl || '') },
                duration: track.durationMs ? Math.round(track.durationMs / 1000) : 0,
                isrc: track.isrc || '',
                link: track.sourceUrl || `https://open.spotify.com/track/${track.id}`
            };
            const row = document.querySelector(`tr[data-spotify-id="${track.id}"]`);
            if (row) {
                applyLibrespotTrackDetailsToRow(row, mapped);
            }
            hydratedNow.add(track.id);
        });

        hydratedNow.forEach((id) => librespotHydratedIds.add(id));
    } catch (error) {
        console.warn('Librespot track hydration failed', error);
    }
}

function applyLibrespotTrackDetailsToRow(row, track) {
    if (!row || !track) {
        return;
    }
    const hasUsefulData = Boolean(
        (track.title && track.title.trim()) ||
        (track.artist?.name && track.artist.name.trim()) ||
        (track.album?.title && track.album.title.trim())
    );
    if (!hasUsefulData) {
        return;
    }

    const titleCell = row.querySelector('.track-title');
    if (titleCell) {
        titleCell.innerHTML = renderTrackTitleHtml(track);
    }

    const artistCell = row.querySelector('.track-artist');
    if (artistCell) {
        artistCell.textContent = track.artist?.name || 'Unknown';
    }

    const albumCell = row.querySelector('.track-album');
    if (albumCell) {
        albumCell.textContent = track.album?.title || 'Unknown';
    }

    const durationCell = row.querySelector('.track-duration');
    if (durationCell) {
        durationCell.textContent = formatDuration(track.duration || 0);
    }

    const checkbox = row.querySelector('.track-checkbox');
    if (checkbox) {
        checkbox.setAttribute('data-track-link', track.link || track.sourceUrl || track.appleUrl || '');
        checkbox.setAttribute('data-track-title', escapeHtml(track.title || ''));
        checkbox.setAttribute('data-track-artist', escapeHtml(track.artist?.name || ''));
        checkbox.setAttribute('data-track-album', escapeHtml(track.album?.title || ''));
        checkbox.setAttribute('data-track-cover', escapeHtml(normalizeCoverUrl(track.album?.cover_medium || '')));
        checkbox.setAttribute('data-track-isrc', escapeHtml(track.isrc || ''));
        checkbox.setAttribute('data-track-duration-ms', track.duration ? track.duration * 1000 : 0);
    }

    const ignoreButton = row.querySelector('.track-ignore-btn');
    if (ignoreButton) {
        ignoreButton.setAttribute('data-ignore-track-isrc', escapeHtml(track.isrc || ''));
    }

    const availabilityKey = buildAvailabilityKeyFromTrack(track, getSpotifyTrackId(track));
    if (availabilityKey) {
        row.dataset.availabilityKey = availabilityKey;
        row.dataset.availabilityUrl = track.link || '';
        row.dataset.availabilityIsrc = track.isrc || '';
        row.dataset.availabilitySpotifyId = getSpotifyTrackId(track) || '';
        row.dataset.availabilityDeezerId = track.id || '';
        row.dataset.availabilityTitle = track.title || '';
        row.dataset.availabilityArtist = (track.artist && track.artist.name) || track.artists || track.artist_name || '';
        row.dataset.availabilityDuration = track.duration ? String(Math.round(track.duration * 1000)) : '';
        scheduleAvailabilityChecks([track], false);
    }
}

async function startSpotifyMatchPolling(token, pendingCount) {
    if (spotifyMatchTimer) {
        clearInterval(spotifyMatchTimer);
    }

    let remaining = pendingCount;
    spotifyMatchCompletion = null;
    spotifyMatchState = { pending: remaining, matched: null, failed: null, rechecking: null };
    updateSpotifyNotice();
    const pollMatches = async () => {
        try {
            const response = await fetch(`/api/spotify/tracklist/matches?token=${encodeURIComponent(token)}`);
            if (!response.ok) {
                return;
            }
            const payload = await response.json();
            if (!payload.available) {
                return;
            }
            if (Array.isArray(payload.matches)) {
                applySpotifyMatches(payload.matches);
            }
            if (typeof payload.pending === 'number') {
                remaining = payload.pending;
            }
            const matched = typeof payload.matched === 'number' ? payload.matched : null;
            const failed = typeof payload.failed === 'number' ? payload.failed : null;
            const rechecking = typeof payload.rechecking === 'number' ? payload.rechecking : null;

            if (remaining <= 0) {
                clearInterval(spotifyMatchTimer);
                spotifyMatchTimer = null;
                spotifyMatchState = null;
                if (matched !== null && failed !== null) {
                    spotifyMatchCompletion = `Matching complete: ${matched} matched, ${failed} failed.`;
                    if (failed > 0
                        && isSpotifyPlaylistDeezerMatchContext()
                        && !spotifyMatchFailureToastShown
                        && window.DeezSpoTag?.ui?.showToast) {
                        spotifyMatchFailureToastShown = true;
                        DeezSpoTag.ui.showToast(`Deezer matching failed for ${failed} playlist track(s).`, { type: 'warning' });
                    }
                } else {
                    spotifyMatchCompletion = 'All Deezer matches are ready.';
                }
                updateSpotifyNotice();
                setTimeout(() => {
                    spotifyMatchCompletion = null;
                    updateSpotifyNotice();
                }, 3000);
            } else {
                spotifyMatchState = { pending: remaining, matched, failed, rechecking };
                updateSpotifyNotice();
            }
        } catch (error) {
            console.warn('Spotify match polling failed', error);
        }
    };

    await pollMatches();
    spotifyMatchTimer = setInterval(pollMatches, 1000);
}

function applySpotifyMatchesToRows(indices) {
    if (!Array.isArray(indices) || indices.length === 0) {
        return;
    }
    indices.forEach(index => {
        if (!spotifyMatchCache.has(index)) {
            return;
        }
        const row = document.querySelector(`tr[data-track-index="${index}"]`);
        if (!row) {
            return;
        }
            applyExternalMatchToRow(row, spotifyMatchCache.get(index) || '');
    });
}

function applySpotifyMatches(matches) {
    matches.forEach(match => {
        if (!match) {
            return;
        }
        const status = String(match.status || '').toLowerCase();
        const spotifyId = match.spotifyId || match.spotifyID || '';
        const byIndex = (match.index !== undefined && match.index !== null)
            ? document.querySelector(`tr[data-track-index="${match.index}"]`)
            : null;
        const bySpotifyId = !byIndex && spotifyId
            ? document.querySelector(`tr[data-spotify-id="${spotifyId}"]`)
            : null;
        const row = byIndex || bySpotifyId;
        const rawDeezerId = String(match.deezerId || match.deezerID || '').trim();
        const deezerId = /^\d+$/.test(rawDeezerId) ? rawDeezerId : '';
        if (match.index !== undefined && match.index !== null && deezerId) {
            spotifyMatchCache.set(match.index, deezerId || '');
        }
        if (row && (deezerId || status === 'matched')) {
            applyExternalMatchToRow(row, deezerId);
        }
    });
}

function getRowTrackSource(row) {
    if (!row) {
        return '';
    }
    const rowSource = String(row.dataset.trackSource || '').trim().toLowerCase();
    if (rowSource) {
        return rowSource;
    }
    const checkbox = row.querySelector('.track-checkbox');
    return String(checkbox?.dataset.trackSource || '').trim().toLowerCase();
}

function isDeezerMatchedExternalSource(source) {
    const normalizedSource = String(source || '').trim().toLowerCase();
    return deezerMatchedExternalSources.has(normalizedSource);
}

function shouldHydrateDeezerMetadata(source) {
    const normalizedSource = String(source || '').trim().toLowerCase();
    return deezerMatchedExternalSources.has(normalizedSource);
}

function buildExternalMatchRequestFromTrack(track, source, fallbackIndex) {
    if (!track) {
        return null;
    }

    let link = track.link || track.sourceUrl || track.appleUrl || '';
    if (!link && source === 'spotify') {
        const spotifyId = getSpotifyTrackId(track);
        if (spotifyId) {
            link = `https://open.spotify.com/track/${spotifyId}`;
        }
    }
    if (!link) {
        return null;
    }

    return {
        link,
        index: track.index ?? fallbackIndex,
        title: track.title || '',
        artist: resolveArtistName(track) || '',
        album: track.album?.title || '',
        isrc: track.isrc || '',
        durationMs: track.duration ? Math.round(track.duration * 1000) : 0
    };
}

function buildExternalMatchRequestFromRow(row) {
    if (!row) {
        return null;
    }

    const checkbox = row.querySelector('.track-checkbox');
    const sourceLink = String(row.dataset.availabilityUrl || checkbox?.dataset.trackLink || '').trim();
    const source = getRowTrackSource(row);
    let link = sourceLink;
    if (!link && source === 'spotify') {
        const spotifyId = String(row.dataset.spotifyId || checkbox?.dataset.spotifyId || '').trim();
        if (spotifyId) {
            link = `https://open.spotify.com/track/${spotifyId}`;
        }
    }
    if (!link) {
        return null;
    }

    const durationMsRaw = Number(row.dataset.availabilityDuration || checkbox?.dataset.trackDurationMs || 0);
    return {
        link,
        index: parseInt(row.dataset.trackIndex || '-1', 10),
        title: row.dataset.availabilityTitle || checkbox?.dataset.trackTitle || '',
        artist: row.dataset.availabilityArtist || checkbox?.dataset.trackArtist || '',
        album: checkbox?.dataset.trackAlbum || '',
        isrc: row.dataset.availabilityIsrc || checkbox?.dataset.trackIsrc || '',
        durationMs: Number.isFinite(durationMsRaw) && durationMsRaw > 0 ? Math.round(durationMsRaw) : 0
    };
}

async function resolveExternalRequestToDeezer(current, source, row, options = {}) {
    if (!current || !current.link) {
        return '';
    }

    const cacheKey = String(current.link || '').trim();
    if (!cacheKey) {
        return '';
    }

    const priority = options?.priority === 'high' ? 'high' : 'low';
    let inFlightEntry = externalDeezerMatchInFlight.get(cacheKey);
    const shouldPromotePriority = priority === 'high'
        && inFlightEntry
        && inFlightEntry.priority !== 'high';

    if (!inFlightEntry || shouldPromotePriority) {
        const inFlightPromise = runExternalResolverTask(async () => {
            let deezerId = '';
            let resolvePayload = null;

            if (source === 'spotify') {
                const data = await fetchJsonWithRetry(`/api/spotify/resolve-deezer?url=${encodeURIComponent(current.link)}`, 3);
                deezerId = data?.deezerId || '';
            }

            if (!deezerId) {
                const qs = new URLSearchParams();
                qs.set('url', current.link);
                if (current.title) {
                    qs.set('title', current.title);
                }
                if (current.artist) {
                    qs.set('artist', current.artist);
                }
                if (current.album) {
                    qs.set('album', current.album);
                }
                if (current.isrc) {
                    qs.set('isrc', current.isrc);
                }
                if (current.durationMs && Number.isFinite(current.durationMs) && current.durationMs > 0) {
                    qs.set('durationMs', String(current.durationMs));
                }
                if (shouldHydrateDeezerMetadata(source)) {
                    qs.set('includeMeta', 'true');
                }

                const data = await fetchJsonWithRetry(`/api/resolve/deezer?${qs.toString()}`, 3);
                resolvePayload = data;
                deezerId = data?.deezerId || '';
            }

            externalDeezerMatchCache.set(cacheKey, deezerId);
            return { deezerId, resolvePayload };
        }, priority);

        inFlightEntry = {
            promise: inFlightPromise,
            priority
        };
        externalDeezerMatchInFlight.set(cacheKey, inFlightEntry);
    }

    try {
        const result = await inFlightEntry.promise;
        const deezerId = String(result?.deezerId || '').trim();
        if (deezerId && row) {
            if (result?.resolvePayload) {
                applyDeezerMetadataToRow(row, result.resolvePayload);
            }
            applyExternalMatchToRow(row, deezerId);
        }
        return deezerId;
    } finally {
        if (externalDeezerMatchInFlight.get(cacheKey) === inFlightEntry) {
            externalDeezerMatchInFlight.delete(cacheKey);
        }
    }
}

async function ensureRowPreviewForPlayback(row, control) {
    if (!row || !control) {
        return '';
    }

    const source = getRowTrackSource(row);
    if (!isDeezerMatchedExternalSource(source)) {
        return '';
    }

    const existingDeezerId = String(row.querySelector('.track-checkbox')?.dataset.trackId || row.dataset.availabilityDeezerId || '').trim();
    if (/^\d+$/.test(existingDeezerId)) {
        const context = getDeezerPlaybackContextForRow(row, existingDeezerId);
        const previewUrl = buildDeezerStreamUrl(existingDeezerId, {
            type: getRowPlaybackTypeHint(row),
            context
        });
        control.setAttribute('data-preview', previewUrl);
        control.classList.remove('is-disabled');
        return previewUrl;
    }

    const request = buildExternalMatchRequestFromRow(row);
    if (!request) {
        return '';
    }

    const originalIcon = control.textContent;
    control.classList.add('is-resolving');
    control.classList.remove('is-disabled');
    control.classList.add('is-pending');
    control.textContent = 'hourglass_top';

    try {
        let deezerId = externalDeezerMatchCache.get(request.link) || '';
        if (!deezerId) {
            deezerId = await resolveExternalRequestToDeezer(request, source, row, { priority: 'high' });
        }
        if (!/^\d+$/.test(deezerId)) {
            return '';
        }

        const context = getDeezerPlaybackContextForRow(row, deezerId);
        const previewUrl = buildDeezerStreamUrl(deezerId, {
            type: getRowPlaybackTypeHint(row),
            context
        });
        control.setAttribute('data-preview', previewUrl);
        control.classList.remove('is-disabled');
        control.classList.remove('is-pending');
        if (!context) {
            void ensureDeezerPlaybackContextForRow(row, deezerId);
        }
        return previewUrl;
    } finally {
        control.classList.remove('is-resolving');
        if (!control.hasAttribute('playing')) {
            control.textContent = originalIcon || 'play_arrow';
        }
    }
}

function applyExternalMatchToRow(row, deezerId) {
    const source = getRowTrackSource(row);
    if (source === 'boomplay') {
        applyBoomplayMatchToRow(row, deezerId);
        return;
    }
    applySpotifyMatchToRow(row, deezerId);
}

function applySpotifyMatchToRow(row, deezerId) {
    applyMatchedRowState(row, deezerId);
}

function applyBoomplayMatchToRow(row, deezerId) {
    applyMatchedRowState(row, deezerId);
}

function applyMatchedRowState(row, deezerId) {
    const preview = deezerId
        ? buildDeezerStreamUrl(deezerId, {
            type: getRowPlaybackTypeHint(row),
            context: getDeezerPlaybackContextForRow(row, deezerId)
        })
        : '';
    updateMatchedRowCheckbox(row, deezerId);
    const source = getRowTrackSource(row);
    const canRetryMatch = !deezerId
        && isDeezerMatchedExternalSource(source)
        && !!buildExternalMatchRequestFromRow(row);
    row.dataset.availabilityDeezerId = deezerId;
    row.classList.toggle('track-row-dead', !deezerId && !canRetryMatch);
    const previewControl = row.querySelector('.preview-controls');
    if (previewControl) {
        if (deezerId) {
            previewControl.setAttribute('data-preview', preview);
            previewControl.classList.remove('is-disabled');
            previewControl.classList.remove('is-pending');
            previewControl.setAttribute('title', 'Play Track');
        } else {
            previewControl.setAttribute('data-preview', '');
            previewControl.classList.toggle('is-disabled', !canRetryMatch);
            previewControl.classList.toggle('is-pending', canRetryMatch);
            previewControl.setAttribute('title', canRetryMatch ? 'Match and play track' : 'No Deezer match');
        }
    }

    if (deezerId) {
        const availabilityTrack = buildAvailabilityTrackFromRow(row, deezerId);
        if (availabilityTrack) {
            scheduleAvailabilityChecks([availabilityTrack], false);
        }
        void ensureDeezerPlaybackContextForRow(row, deezerId);
    }
}

function updateMatchedRowCheckbox(row, deezerId) {
    const checkbox = row.querySelector('.track-checkbox');
    if (!checkbox) {
        return;
    }

    checkbox.setAttribute('data-track-id', deezerId);
    if (deezerId) {
        checkbox.disabled = false;
        checkbox.removeAttribute('aria-disabled');
        checkbox.setAttribute('title', 'Select track');
        return;
    }

    checkbox.checked = false;
    checkbox.disabled = true;
    checkbox.setAttribute('aria-disabled', 'true');
    checkbox.setAttribute('title', 'Waiting for Deezer match');
}

function applyDeezerMetadataToRow(row, metadata) {
    if (!row || !metadata) {
        return;
    }
    const durationMs = Number(metadata.durationMs || metadata.duration || 0);
    if (durationMs > 0) {
        const durationSeconds = Math.round(durationMs / 1000);
        const durationCell = row.querySelector('.track-duration');
        if (durationCell) {
            durationCell.textContent = formatDuration(durationSeconds);
        }
        row.dataset.availabilityDuration = String(durationMs);
        const checkbox = row.querySelector('.track-checkbox');
        if (checkbox) {
            checkbox.setAttribute('data-track-duration-ms', String(durationMs));
        }
    }

    if (metadata.title) {
        const titleCell = row.querySelector('.track-title-text');
        const displayTitle = isBoomplayTracklistSource()
            ? normalizeBoomplayLabelForDisplay(metadata.title, { artist: metadata.artist || row.dataset.availabilityArtist || '' })
            : metadata.title;
        if (titleCell) {
            titleCell.textContent = displayTitle;
        }
        row.dataset.availabilityTitle = metadata.title;
        const checkbox = row.querySelector('.track-checkbox');
        if (checkbox) {
            checkbox.setAttribute('data-track-title', escapeHtml(metadata.title));
        }
    }

    if (metadata.artist) {
        const artistCell = row.querySelector('.track-artist .track-cell-text');
        const displayArtist = isBoomplayTracklistSource()
            ? normalizeBoomplayLabelForDisplay(metadata.artist, { isArtist: true })
            : metadata.artist;
        if (artistCell) {
            artistCell.textContent = displayArtist;
        }
        row.dataset.availabilityArtist = metadata.artist;
        const checkbox = row.querySelector('.track-checkbox');
        if (checkbox) {
            checkbox.setAttribute('data-track-artist', escapeHtml(metadata.artist));
        }
    }

    if (metadata.album) {
        const albumCell = row.querySelector('.track-album .track-cell-text');
        if (albumCell) {
            albumCell.textContent = metadata.album;
        }
        const checkbox = row.querySelector('.track-checkbox');
        if (checkbox) {
            checkbox.setAttribute('data-track-album', escapeHtml(metadata.album));
        }
    }

    if (metadata.coverMedium) {
        const cover = normalizeCoverUrl(metadata.coverMedium);
        if (!cover) {
            return;
        }
        const coverImg = row.querySelector('.track-album-art');
        if (coverImg) {
            coverImg.src = cover;
        } else {
            const titleContent = row.querySelector('.track-title-content');
            if (titleContent) {
                const img = document.createElement('img');
                img.className = 'track-album-art';
                img.src = cover;
                img.alt = '';
                img.loading = 'lazy';
                titleContent.insertBefore(img, titleContent.firstChild);
            }
        }
        const checkbox = row.querySelector('.track-checkbox');
        if (checkbox) {
            checkbox.setAttribute('data-track-cover', escapeHtml(cover));
        }
    }
}

function buildAvailabilityTrackFromRow(row, deezerId) {
    if (!row || !deezerId) {
        return null;
    }
    return {
        id: deezerId,
        link: row.dataset.availabilityUrl || '',
        isrc: row.dataset.availabilityIsrc || '',
        spotifyId: row.dataset.availabilitySpotifyId || '',
        title: row.dataset.availabilityTitle || '',
        artist: row.dataset.availabilityArtist || '',
        durationMs: row.dataset.availabilityDuration ? Number(row.dataset.availabilityDuration) : 0
    };
}

async function fetchJsonWithRetry(url, attempts = 3) {
    let lastError = null;
    for (let attempt = 1; attempt <= attempts; attempt++) {
        try {
            const response = await fetch(url);
            if (response.ok) {
                return await response.json();
            }

            // Retry only transient response codes.
            if (response.status === 429 || response.status >= 500) {
                if (attempt < attempts) {
                    await new Promise(resolve => setTimeout(resolve, Math.min(2000, attempt * 350)));
                    continue;
                }
                return null;
            }

            // Non-transient response (4xx except 429) - do not retry.
            return null;
        } catch (error) {
            lastError = error;
            if (attempt < attempts) {
                await new Promise(resolve => setTimeout(resolve, Math.min(2000, attempt * 350)));
                continue;
            }
            throw lastError;
        }
    }

    return null;
}

function drainExternalResolverQueue() {
    while ((externalResolverScheduler.activeHigh + externalResolverScheduler.activeLow) < externalMatchMaxConcurrent) {
        let priority = '';
        let task = null;

        if (externalResolverScheduler.queueHigh.length > 0) {
            priority = 'high';
            task = externalResolverScheduler.queueHigh.shift();
        } else if (externalResolverScheduler.queueLow.length > 0
            && externalResolverScheduler.activeLow < externalMatchLowConcurrencyCap) {
            priority = 'low';
            task = externalResolverScheduler.queueLow.shift();
        } else {
            return;
        }

        if (!task) {
            continue;
        }

        if (priority === 'high') {
            externalResolverScheduler.activeHigh += 1;
        } else {
            externalResolverScheduler.activeLow += 1;
        }

        Promise.resolve()
            .then(task.work)
            .then(task.resolve, task.reject)
            .finally(() => {
                if (priority === 'high') {
                    externalResolverScheduler.activeHigh = Math.max(0, externalResolverScheduler.activeHigh - 1);
                } else {
                    externalResolverScheduler.activeLow = Math.max(0, externalResolverScheduler.activeLow - 1);
                }
                drainExternalResolverQueue();
            });
    }
}

function runExternalResolverTask(work, priority = 'low') {
    return new Promise((resolve, reject) => {
        const task = { work, resolve, reject };
        if (priority === 'high' && externalResolverScheduler.activeHigh < externalMatchHighConcurrencyCap) {
            externalResolverScheduler.activeHigh += 1;
            Promise.resolve()
                .then(task.work)
                .then(task.resolve, task.reject)
                .finally(() => {
                    externalResolverScheduler.activeHigh = Math.max(0, externalResolverScheduler.activeHigh - 1);
                    drainExternalResolverQueue();
                });
            return;
        }

        if (priority === 'high') {
            externalResolverScheduler.queueHigh.push(task);
        } else {
            externalResolverScheduler.queueLow.push(task);
        }
        drainExternalResolverQueue();
    });
}

async function resolveExternalTracklistMatches(tracks, source, options = {}) {
    if (!Array.isArray(tracks) || tracks.length === 0) {
        return;
    }
    const normalizedSource = String(source || '').trim().toLowerCase();
    const isAppleAudioTracklist = normalizedSource === 'apple'
        && tracks.some(track => track?.isVideo !== true);
    if (isAppleAudioTracklist) {
        return;
    }
    const incremental = options?.incremental === true;
    const finalize = options?.finalize !== false;

    const queue = [];
    tracks.forEach((track, index) => {
        const request = buildExternalMatchRequestFromTrack(track, normalizedSource, index);
        if (!request) {
            return;
        }
        const deezerHint = String(track.deezerId || track.deezer_id || '').trim();
        const trackIdHint = String(track.id || '').trim();
        const hasResolvedDeezerId = /^\d+$/.test(deezerHint)
            || (normalizedSource === 'spotify' && /^\d+$/.test(trackIdHint));
        if (hasResolvedDeezerId) {
            return;
        }
        const cacheKey = request.link;
        if (externalDeezerMatchCache.has(cacheKey)) {
            const cached = externalDeezerMatchCache.get(cacheKey) || '';
            const row = document.querySelector(`tr[data-track-index="${request.index}"]`);
            if (cached) {
                if (row) {
                    applyExternalMatchToRow(row, cached);
                }
                return;
            }

            // Empty-cache entries are transient misses; allow a fresh re-resolve.
            externalDeezerMatchCache.delete(cacheKey);
        }
        queue.push(request);
    });

    if (queue.length === 0) {
        return;
    }

    const showProgress = normalizedSource === 'boomplay'
        || normalizedSource === 'apple'
        || normalizedSource === 'tidal'
        || normalizedSource === 'amazon'
        || normalizedSource === 'youtube'
        || normalizedSource === 'soundcloud'
        || normalizedSource === 'qobuz'
        || normalizedSource === 'bandcamp'
        || normalizedSource === 'pandora';
    if (showProgress) {
        if (incremental && externalMatchState && externalMatchState.source === source) {
            externalMatchState.pending = (externalMatchState.pending || 0) + queue.length;
            externalMatchState.done = false;
        } else {
            externalMatchState = { source, pending: queue.length, matched: 0, failed: 0, done: false };
        }
        updateSpotifyNotice();
    }

    const concurrency = 4;
    let cursor = 0;
    const workers = Array.from({ length: Math.min(concurrency, queue.length) }, async () => {
        while (cursor < queue.length) {
            const current = queue[cursor++];
            const row = document.querySelector(`tr[data-track-index="${current.index}"]`);
            if (!row) {
                if (showProgress) {
                    externalMatchState.pending = Math.max(0, externalMatchState.pending - 1);
                    externalMatchState.failed++;
                    updateSpotifyNotice();
                }
                continue;
            }
            try {
                const deezerId = await resolveExternalRequestToDeezer(current, normalizedSource, row, { priority: 'low' });
                if (showProgress) {
                    externalMatchState.pending = Math.max(0, externalMatchState.pending - 1);
                    if (deezerId) {
                        externalMatchState.matched++;
                    } else {
                        externalMatchState.failed++;
                    }
                    updateSpotifyNotice();
                }
            } catch (error) {
                console.warn('External Deezer match failed', error);
                if (showProgress) {
                    externalMatchState.pending = Math.max(0, externalMatchState.pending - 1);
                    externalMatchState.failed++;
                    updateSpotifyNotice();
                }
            }
        }
    });

    await Promise.all(workers);
    if (source === 'boomplay') {
        reconcileExternalMatchesFromCache();
    }

    if (showProgress) {
        if (externalMatchState) {
            externalMatchState.pending = Math.max(0, externalMatchState.pending || 0);
            const canFinalizeNow = finalize
                || (source === 'boomplay' && boomplayLazyState && boomplayLazyState.hasMore === false);
            externalMatchState.done = canFinalizeNow && externalMatchState.pending === 0;
        }
        updateSpotifyNotice();
        if (finalize && externalMatchState?.done) {
            setTimeout(() => {
                externalMatchState = null;
                updateSpotifyNotice();
            }, 3000);
        }
    }
}

async function updateMonitorButtonState() {
    const isMonitorable = tracklistType === 'playlist'
        || tracklistType === 'trending'
        || tracklistType === 'smarttracklist'
        || tracklistType === 'recommendation'
        || tracklistType === 'show'
        || isSpotifyArtistTopTracksView();
    const isPodcastShow = String(tracklistType || '').toLowerCase() === 'show';
    const monitorDefaultLabel = isSpotifyArtistTopTracksView()
        ? 'Monitor Top Songs'
        : (isSpotifyHomeTrendingTracklistView()
            ? 'Monitor Trending Songs'
            : (String(tracklistType || '').toLowerCase() === 'recommendation'
                ? 'Monitor Recommendations'
                : (isPodcastShow ? 'Monitor Podcast' : 'Monitor Playlist')));
    const headerActions = document.getElementById('tracklist-header-actions');
    const hideMonitorAndHeaderActions = () => {
        if (monitorMenu) {
            monitorMenu.style.display = 'none';
            closeMonitorMenu();
        }
        if (headerActions) {
            headerActions.style.display = 'none';
            closeTracklistHeaderActionsMenu();
        }
    };
    const applyDefaultMonitorState = (disabled) => {
        if (monitorLabel) {
            monitorLabel.textContent = monitorDefaultLabel;
        }
        monitorButton.disabled = disabled;
        hideMonitorAndHeaderActions();
        setIgnoreVisibility(false);
    };

    if (!monitorButton || !currentTracklistMeta) {
        if (monitorButton) {
            if (monitorLabel) {
                monitorLabel.textContent = monitorDefaultLabel;
            }
            monitorButton.disabled = true;
        }
        hideMonitorAndHeaderActions();
        setIgnoreVisibility(false);
        return;
    }

    if (!isMonitorable) {
        applyDefaultMonitorState(true);
        return;
    }

    try {
        const status = await fetchJson(`/api/library/playlists/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}`);
        if (status?.watching) {
            if (monitorLabel) {
                monitorLabel.textContent = 'Monitored';
            }
            monitorButton.disabled = true;
            if (monitorMenu) {
                monitorMenu.style.display = '';
            }
            if (headerActions) {
                headerActions.style.display = '';
            }
            setIgnoreVisibility(true);
        } else {
            applyDefaultMonitorState(false);
        }
    } catch {
        applyDefaultMonitorState(false);
    }
}

function setIgnoreVisibility(enabled) {
    watchlistIgnoreEnabled = Boolean(enabled);
    document.querySelectorAll('.track-ignore-btn, .track-ignore-toggle').forEach(element => {
        element.classList.toggle('is-hidden', !watchlistIgnoreEnabled);
    });
}

function closeMonitorMenu() {
    if (monitorMenuDropdown) {
        monitorMenuDropdown.hidden = true;
    }
    if (monitorMenuToggle) {
        monitorMenuToggle.setAttribute('aria-expanded', 'false');
    }
}

function closeTracklistHeaderActionsMenu() {
    const dropdown = document.getElementById('tracklist-header-actions-dropdown');
    const toggle = document.getElementById('tracklist-header-actions-toggle');
    if (dropdown) {
        dropdown.hidden = true;
    }
    if (toggle) {
        toggle.setAttribute('aria-expanded', 'false');
    }
}

function applyTracklistArtworkSelection(url) {
    if (!url) {
        return;
    }

    const normalizedUrl = String(url).trim();
    const coverImage = document.querySelector('.tracklist-header .tracklist-cover img');
    if (coverImage) {
        coverImage.src = normalizedUrl;
    }

    const header = document.querySelector('.tracklist-header');
    if (header) {
        const backgroundUrl = `/api/playlist/cover/background?url=${encodeURIComponent(normalizedUrl)}`;
        header.style.backgroundImage = `url('${backgroundUrl}')`;
    }

    if (currentTracklistMeta) {
        currentTracklistMeta.imageUrl = normalizedUrl;
    }
}

async function openPlaylistArtworkHistoryModal() {
    if (!currentTracklistMeta?.source || !currentTracklistMeta?.sourceId) {
        return;
    }

    let visuals = [];
    try {
        const response = await fetchJson(`/api/library/playlists/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}/visuals`);
        visuals = Array.isArray(response) ? response : [];
    } catch (error) {
        DeezSpoTag.ui.alert(`Failed to load artwork history: ${error.message}`, { title: 'Playlist Artwork' });
        return;
    }

    if (visuals.length === 0) {
        DeezSpoTag.ui.alert('No saved artwork history is available for this playlist yet.', { title: 'Playlist Artwork' });
        return;
    }

    const panel = document.createElement('div');
    panel.className = 'playlist-settings-panel';
    const section = document.createElement('div');
    section.className = 'playlist-settings-section';
    section.innerHTML = '<div class="playlist-settings-section-title">Saved artwork history</div>';
    const grid = document.createElement('div');
    grid.className = 'dropdown-visuals-grid';
    grid.innerHTML = visuals.map(item => `
        <div class="visual-tile" title="Saved artwork">
            <img src="${String(item.url || '').replaceAll('"', '&quot;')}" alt="Saved playlist artwork" loading="lazy" decoding="async" />
            <div class="visual-tile__actions">
                <button class="action-btn action-btn-sm ${item.isActive ? 'btn-secondary' : ''}" type="button"
                    data-playlist-visual-select="${String(item.fileName || '').replaceAll('"', '&quot;')}"
                    data-playlist-visual-url="${String(item.url || '').replaceAll('"', '&quot;')}">
                    ${item.isActive ? 'Active' : 'Use this art'}
                </button>
            </div>
        </div>
    `).join('');
    section.appendChild(grid);
    panel.appendChild(section);

    grid.querySelectorAll('[data-playlist-visual-select]').forEach(button => {
        button.addEventListener('click', async () => {
            const fileName = button.getAttribute('data-playlist-visual-select');
            const url = button.getAttribute('data-playlist-visual-url') || '';
            if (!fileName) {
                return;
            }

            try {
                await fetchJson(`/api/library/playlists/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}/visuals/select`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fileName })
                });
                applyTracklistArtworkSelection(url);
                DeezSpoTag.ui.showToast('Playlist artwork updated.');
            } catch (error) {
                DeezSpoTag.ui.alert(`Failed to apply artwork: ${error.message}`, { title: 'Playlist Artwork' });
            }
        });
    });

    await DeezSpoTag.ui.showModal({
        title: `Artwork — ${currentTracklistMeta.name || 'Playlist'}`,
        contentElement: panel,
        buttons: [
            { label: 'Close', value: 'close', primary: true }
        ]
    });
}

function bindTracklistHeaderActions() {
    const actions = document.getElementById('tracklist-header-actions');
    const toggle = document.getElementById('tracklist-header-actions-toggle');
    const dropdown = document.getElementById('tracklist-header-actions-dropdown');
    if (!actions || !toggle || !dropdown) {
        return;
    }

    toggle.addEventListener('click', (event) => {
        event.stopPropagation();
        const shouldOpen = dropdown.hidden;
        closeTracklistHeaderActionsMenu();
        dropdown.hidden = !shouldOpen;
        toggle.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
    });

    dropdown.querySelectorAll('[data-tracklist-monitor-action]').forEach(button => {
        button.addEventListener('click', async () => {
            const action = button.getAttribute('data-tracklist-monitor-action');
            closeTracklistHeaderActionsMenu();
            if (action === 'manage-settings') {
                await openPlaylistManagementPage();
                return;
            }

            if (!currentTracklistMeta?.source || !currentTracklistMeta?.sourceId) {
                return;
            }

            try {
                if (action === 'sync') {
                    const result = await fetchJson(`/api/library/playlists/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}/sync`, { method: 'POST' });
                    DeezSpoTag.ui.showToast(result?.message || 'Playlist sync scheduled.');
                    return;
                }

                if (action === 'refresh-artwork') {
                    await fetchJson(`/api/library/playlists/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}/refresh-artwork`, { method: 'POST' });
                    DeezSpoTag.ui.showToast('Playlist artwork refresh started.');
                    return;
                }

                if (action === 'artwork-history') {
                    await openPlaylistArtworkHistoryModal();
                    return;
                }

                if (action === 'remove') {
                    await fetchJson(`/api/library/playlists/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}`, { method: 'DELETE' });
                    await updateMonitorButtonState();
                    DeezSpoTag.ui.showToast('Playlist removed from monitoring.');
                }
            } catch (error) {
                DeezSpoTag.ui.alert(`${String(action || 'Action')} failed: ${error.message}`, { title: 'Playlist Actions' });
            }
        });
    });

    document.addEventListener('click', (event) => {
        if (!actions.contains(event.target)) {
            closeTracklistHeaderActionsMenu();
        }
    });
}

async function openPlaylistManagementPage() {
    if (!currentTracklistMeta?.source || !currentTracklistMeta?.sourceId) {
        return;
    }

    let folders = [];
    let preference = null;
    try {
        const [folderResponse, preferenceResponse] = await Promise.all([
            fetchJson('/api/library/folders'),
            fetchJson(`/api/library/playlists/preferences/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}`)
        ]);
        folders = Array.isArray(folderResponse)
            ? folderResponse.filter(folder => folder && folder.enabled)
            : [];
        preference = preferenceResponse && typeof preferenceResponse === 'object'
            ? preferenceResponse
            : null;
