function getTracklistColumnCount(isPlaylistLike, isLocalSource) {
    // Base columns: number, title, artist, [album if playlist], duration, actions
    let base = isPlaylistLike ? 7 : 6;
    if (!shouldShowQualityColumn()) {
        base -= 1;
    }
    return base + (shouldShowAvailabilityColumn(isLocalSource) ? 1 : 0);
}

function shouldShowAvailabilityColumn(isLocalSource) {
    const isPodcastView = String(tracklistType || '').toLowerCase() === 'show'
        || String(tracklistType || '').toLowerCase() === 'episode';
    return !isLocalSource && !tracklistIsAtmosView && !isPodcastView;
}

function shouldShowQualityColumn() {
    return tracklistIsAtmosView;
}

function renderAvailabilityCell() {
    const useSpotifyBadge = isDeezerStyleAvailabilitySource();
    const primaryClass = useSpotifyBadge ? 'availability-spotify' : 'availability-deezer';
    const primaryTitle = useSpotifyBadge ? 'Spotify' : 'Deezer';
    return `
        <div class="availability-icons">
            <span class="availability-icon ${primaryClass} is-loading" data-platform="deezer" title="${primaryTitle}"></span>
            <span class="availability-icon availability-tidal is-loading" data-platform="tidal" title="Tidal"></span>
            <span class="availability-icon availability-amazon is-loading" data-platform="amazon" title="Amazon Music"></span>
            <span class="availability-icon availability-qobuz is-loading" data-platform="qobuz" title="Qobuz"></span>
            <span class="availability-icon availability-apple is-loading" data-platform="apple" title="Apple Music"></span>
        </div>
    `;
}

const availabilityChecksEnabled = true;
const availabilityCache = new Map();
const availabilityQueue = [];
let availabilityActive = 0;
const availabilityMaxConcurrent = 4;
let apiTokenCache = null;
const availabilityDelayMs = 1200;
const availabilityMinIntervalMs = 1500;
const availabilitySuccessTtlMs = 10 * 60 * 1000;
const availabilityFailureTtlMs = 2 * 60 * 1000;
let availabilityNextAllowedAt = 0;
let availabilityDelayTimer = null;
let availabilityDeferred = [];

async function getApiToken() {
    if (apiTokenCache !== null) {
        return apiTokenCache;
    }
    try {
        const response = await fetch('/api/getSettings');
        if (!response.ok) {
            apiTokenCache = '';
            return apiTokenCache;
        }
        const payload = await response.json();
        apiTokenCache = payload?.settings?.apiToken || '';
        return apiTokenCache;
    } catch {
        apiTokenCache = '';
        return apiTokenCache;
    }
}

function buildAvailabilityKeyFromTrack(track, spotifyIdOverride) {
    const currentSource = (tracklistSource || requestSource || '').toLowerCase();
    const deezerId = currentSource === 'boomplay'
        ? String(track.deezerId || track.deezer_id || '').trim()
        : String(track.id || track.deezerId || track.deezer_id || '').trim();
    if (deezerId) {
        return `deezer:${deezerId}`;
    }
    const spotifyId = spotifyIdOverride || getSpotifyTrackId(track);
    if (spotifyId) {
        return `spotify:${spotifyId}`;
    }
    const link = String(track.link || track.sourceUrl || '').trim();
    if (link) {
        return `url:${link}`;
    }
    const isrc = String(track.isrc || '').trim();
    if (isrc) {
        return `isrc:${isrc}`;
    }
    return '';
}

function scheduleAvailabilityChecks(tracks, isLocalSource) {
    if (!availabilityChecksEnabled) {
        return;
    }
    if (!tracks || tracks.length === 0 || !shouldShowAvailabilityColumn(isLocalSource)) {
        return;
    }

    const eligibleTracks = tracks.filter(track => !!buildAvailabilityKeyFromTrack(track));
    if (eligibleTracks.length === 0) {
        return;
    }

    deferAvailabilityChecks(eligibleTracks);
}

function deferAvailabilityChecks(tracks) {
    if (!tracks || tracks.length === 0) {
        return;
    }

    availabilityDeferred = availabilityDeferred.concat(tracks);
    if (availabilityDelayTimer) {
        return;
    }

    const hasMatchedDeezerIds = isSpotifySource() && tracks.some(track =>
        (track?.id || track?.deezerId || track?.deezer_id || '').toString().trim()
    );
    const delayMs = hasMatchedDeezerIds ? 100 : availabilityDelayMs;

    availabilityDelayTimer = setTimeout(() => {
        availabilityDelayTimer = null;
        const batch = availabilityDeferred;
        availabilityDeferred = [];
        enqueueAvailabilityChecks(batch);
    }, delayMs);
}

function enqueueAvailabilityChecks(tracks) {
    tracks.forEach(track => {
        const key = buildAvailabilityKeyFromTrack(track);
        if (!key) {
            return;
        }
        const cached = getCachedAvailability(key);
        if (cached !== undefined) {
            applyAvailabilityToRows(key, cached);
            return;
        }
        if (availabilityQueue.some(entry => entry.key === key)) {
            return;
        }
        availabilityQueue.push({ key, track });
    });

    drainAvailabilityQueue();
}

function drainAvailabilityQueue() {
    if (availabilityActive >= availabilityMaxConcurrent) {
        return;
    }
    while (availabilityActive < availabilityMaxConcurrent && availabilityQueue.length > 0) {
        const now = Date.now();
        if (now < availabilityNextAllowedAt) {
            const waitMs = availabilityNextAllowedAt - now;
            setTimeout(drainAvailabilityQueue, waitMs);
            return;
        }
        const next = availabilityQueue.shift();
        if (!next) {
            break;
        }
        availabilityActive++;
        availabilityNextAllowedAt = Date.now() + availabilityMinIntervalMs;
        fetchAvailability(next.track)
            .then(result => {
                if (result !== null && result !== undefined) {
                    availabilityCache.set(next.key, { stamp: Date.now(), value: result });
                }
                applyAvailabilityToRows(next.key, result);
            })
            .catch(() => {
                availabilityCache.set(next.key, { stamp: Date.now(), value: null });
                applyAvailabilityToRows(next.key, null);
            })
            .finally(() => {
                availabilityActive--;
                drainAvailabilityQueue();
            });
    }
}

function getCachedAvailability(key) {
    if (!availabilityCache.has(key)) {
        return undefined;
    }
    const cached = availabilityCache.get(key);
    if (!cached || typeof cached !== 'object') {
        availabilityCache.delete(key);
        return undefined;
    }
    const age = Date.now() - (cached.stamp || 0);
    const ttl = cached.value === null ? availabilityFailureTtlMs : availabilitySuccessTtlMs;
    if (age > ttl) {
        availabilityCache.delete(key);
        return undefined;
    }
    return cached.value;
}

async function fetchAvailability(track) {
    const deezerId = (track.id || track.deezerId || track.deezer_id || '').trim();
    const spotifyId = getSpotifyTrackId(track);
    const link = (track.link || track.sourceUrl || '').trim();
    const isrc = (track.isrc || '').trim();
    const qs = new URLSearchParams();
    if (deezerId) {
        qs.set('deezerId', deezerId);
    } else if (spotifyId) {
        qs.set('spotifyId', spotifyId);
    } else if (link) {
        qs.set('url', link);
    } else if (isrc) {
        qs.set('isrc', isrc);
    } else {
        return null;
    }
    if (track.title) {
        qs.set('title', track.title);
    }
    const artistValue = typeof track.artist === 'object' && track.artist !== null
        ? (track.artist.name || '')
        : (track.artist || '');
    if (artistValue) {
        qs.set('artist', artistValue);
    }
    if (track.durationMs && Number.isFinite(track.durationMs)) {
        qs.set('durationMs', String(track.durationMs));
    }

    const apiToken = await getApiToken();
    const headers = apiToken ? { Authorization: `Bearer ${apiToken}` } : {};
    const endpoint = deezerId ? '/api/availability/deezer' : '/api/availability/spotify';
    const response = await fetch(`${endpoint}?${qs.toString()}`, { headers });
    if (!response.ok) {
        return null;
    }
    return await response.json();
}

function applyAvailabilityToRows(key, availability) {
    const rows = document.querySelectorAll(`tr[data-availability-key="${CSS.escape(key)}"]`);
    if (!rows.length) {
        return;
    }
    rows.forEach(row => applyAvailabilityToRow(row, availability));
}

function applyAvailabilityToRow(row, availability) {
    const container = row.querySelector('.availability-icons');
    if (!container) {
        return;
    }
    const status = availability || {};
    if (isDeezerStyleAvailabilitySource()) {
        const spotifyAvailable = !!status.spotifyId || !!status.spotifyUrl;
        updateAvailabilityTag(container, 'deezer', spotifyAvailable);
    } else {
        const preview = row.querySelector('.preview-controls')?.getAttribute('data-preview') || '';
        const deezerId = row.querySelector('.track-checkbox')?.getAttribute('data-track-id') || '';
        const deezerAvailable = !!status.deezer || !!preview || !!deezerId;
        updateAvailabilityTag(container, 'deezer', deezerAvailable);
    }
    updateAvailabilityTag(container, 'tidal', status.tidal);
    updateAvailabilityTag(container, 'amazon', status.amazon);
    updateAvailabilityTag(container, 'qobuz', status.qobuz);
    updateAvailabilityTag(container, 'apple', status.apple);
}

function isDeezerSource() {
    return (currentTracklistMeta?.source || tracklistSource || '').toLowerCase() === 'deezer';
}

function isDeezerStyleAvailabilitySource() {
    const source = (currentTracklistMeta?.source || tracklistSource || requestSource || '').toLowerCase();
    return source === 'deezer' || source === 'boomplay';
}

function isSpotifySource() {
    return (currentTracklistMeta?.source || tracklistSource || requestSource || '').toLowerCase() === 'spotify';
}

function updateAvailabilityTag(container, platform, available) {
    const tag = container.querySelector(`[data-platform="${platform}"]`);
    if (!tag) {
        return;
    }
    tag.classList.remove('is-loading', 'is-available', 'is-unavailable');
    if (available === true) {
        tag.classList.add('is-available');
    } else if (available === false) {
        tag.classList.add('is-unavailable');
    } else {
        tag.classList.add('is-loading');
    }
}

function extractSpotifyTrackId(value) {
    if (!value) {
        return '';
    }
    const trimmed = value.trim();
    if (trimmed.startsWith('spotify:track:')) {
        return trimmed.split(':')[2] || '';
    }
    const match = trimmed.match(/open\.spotify\.com\/track\/([a-zA-Z0-9]+)/);
    if (match && match[1]) {
        return match[1];
    }
    return '';
}

function getSpotifyTrackId(track) {
    if (!track) {
        return '';
    }
    if (track.spotifyId) {
        return track.spotifyId;
    }
    return extractSpotifyTrackId(track.link || track.sourceUrl || '');
}

function isBoomplayTracklistSource() {
    const source = (requestSource || tracklistSource || '').toLowerCase();
    return source === 'boomplay';
}

function normalizeBoomplayLabelForDisplay(value, options = {}) {
    if (!value) {
        return '';
    }

    let cleaned = String(value)
        .replace(/[\u0000-\u001F\u007F]/g, ' ')
        .replace(/\u00A0/g, ' ')
        .trim();

    if (!cleaned) {
        return '';
    }

    const isArtist = options?.isArtist === true;
    const artist = String(options?.artist || '').trim();

    if (!isArtist && artist) {
        const lower = cleaned.toLowerCase();
        const artistLower = artist.toLowerCase();
        if (lower.startsWith(`${artistLower} - `)) {
            cleaned = cleaned.slice(artist.length + 3).trim();
        } else if (lower.startsWith(`${artistLower} – `)) {
            cleaned = cleaned.slice(artist.length + 3).trim();
        }
    }

    cleaned = cleaned
        .replace(/([A-Za-z])_([A-Za-z])/g, '$1 $2')
        .replace(/[_]{2,}/g, ' ')
        .replace(/\s*[\(\[]\s*master\s*[\)\]]\s*$/i, '')
        .replace(/\s*-\s*master\s*$/i, '')
        .replace(/\s*[!\x40#$%^&*+=~`|<>]{2,}\s*$/g, '')
        .replace(/\s*[\.\-_,]{2,}\s*$/g, '')
        .replace(/\s+/g, ' ')
        .trim();

    return cleaned || String(value).trim();
}

function renderTrackTitleHtml(track) {
    const cover = normalizeCoverUrl(track.album?.cover_medium);
    const explicit = track.explicit_lyrics;
    const rawTitle = track.title || 'Loading…';
    const rawArtist = resolveArtistName(track);
    const titleText = isBoomplayTracklistSource()
        ? normalizeBoomplayLabelForDisplay(rawTitle, { artist: rawArtist })
        : rawTitle;
    const isMobileView = window.matchMedia && window.matchMedia('(max-width: 640px)').matches;
    const showCover = cover && (isMobileView || useUnifiedTracklistView || tracklistType === 'playlist' || tracklistIsAtmosView || isDeezerSource());
    return `
        <span class="track-title-content">
            ${showCover
                ? `<img class="track-album-art" src="${cover}" alt="" loading="lazy">`
                : ''}
            ${explicit ? '<span class="material-icons track-explicit">explicit</span>' : ''}
            <span class="track-title-text">${escapeHtml(titleText)}</span>
        </span>
    `;
}

function resolveArtistName(track) {
    if (!track) {
        return 'Unknown';
    }
    if (track.artist && typeof track.artist === 'object' && track.artist.name) {
        return track.artist.name;
    }
    if (typeof track.artist === 'string') {
        return track.artist;
    }
    if (typeof track.artists === 'string') {
        return track.artists;
    }
    if (Array.isArray(track.artists)) {
        return track.artists.filter(Boolean).join(', ');
    }
    if (track.artist_name) {
        return track.artist_name;
    }
    return 'Unknown';
}

function normalizeDeezerPlaybackContext(context) {
    if (!window.DeezerPlaybackContext || typeof window.DeezerPlaybackContext.normalize !== 'function') {
        return null;
    }
    return window.DeezerPlaybackContext.normalize(context);
}

function extractDeezerPlaybackContextFromTrack(track) {
    return normalizeDeezerPlaybackContext(track || {});
}

function getRowPlaybackTypeHint(row) {
    const contentType = String(row?.querySelector('.track-checkbox')?.dataset.trackContentType || '').trim().toLowerCase();
    if (contentType === 'podcast' || isPodcastTracklistContext()) {
        return 'episode';
    }
    return '';
}

function buildDeezerStreamUrl(deezerId, options = {}) {
    if (!window.DeezerPlaybackContext || typeof window.DeezerPlaybackContext.buildStreamUrl !== 'function') {
        return '';
    }
    return window.DeezerPlaybackContext.buildStreamUrl(deezerId, options);
}

function getDeezerPlaybackContextForRow(row, deezerId = '') {
    if (!row) {
        return null;
    }

    const inlineContext = normalizeDeezerPlaybackContext({
        streamTrackId: row.dataset.streamTrackId || '',
        trackToken: row.dataset.trackToken || '',
        md5origin: row.dataset.md5Origin || row.dataset.md5origin || '',
        mv: row.dataset.mediaVersion || ''
    });
    if (inlineContext) {
        return inlineContext;
    }

    const normalizedId = String(deezerId || row.dataset.availabilityDeezerId || row.querySelector('.track-checkbox')?.dataset.trackId || '').trim();
    if (!normalizedId) {
        return null;
    }

    const cached = deezerPlaybackContextCache.get(normalizedId) || null;
    return normalizeDeezerPlaybackContext(cached);
}

function setDeezerPlaybackContextOnRow(row, deezerId, context) {
    const normalizedContext = normalizeDeezerPlaybackContext(context);
    if (!row || !normalizedContext) {
        return;
    }

    const normalizedId = String(deezerId || row.dataset.availabilityDeezerId || row.querySelector('.track-checkbox')?.dataset.trackId || '').trim();
    if (normalizedId) {
        deezerPlaybackContextCache.set(normalizedId, normalizedContext);
    }

    row.dataset.streamTrackId = normalizedContext.streamTrackId;
    row.dataset.trackToken = normalizedContext.trackToken;
    row.dataset.md5Origin = normalizedContext.md5origin || '';
    row.dataset.mediaVersion = normalizedContext.mv || '';

    const checkbox = row.querySelector('.track-checkbox');
    if (checkbox) {
        checkbox.dataset.streamTrackId = normalizedContext.streamTrackId;
        checkbox.dataset.trackToken = normalizedContext.trackToken;
        checkbox.dataset.md5Origin = normalizedContext.md5origin || '';
        checkbox.dataset.mediaVersion = normalizedContext.mv || '';
    }

    const previewControl = row.querySelector('.preview-controls');
    if (previewControl && normalizedId) {
        previewControl.setAttribute('data-preview', buildDeezerStreamUrl(normalizedId, {
            type: getRowPlaybackTypeHint(row),
            context: normalizedContext
        }));
    }
}

async function fetchDeezerPlaybackContext(deezerId) {
    if (!window.DeezerPlaybackContext || typeof window.DeezerPlaybackContext.fetchContext !== 'function') {
        return null;
    }
    return await window.DeezerPlaybackContext.fetchContext(deezerId, {
        cache: deezerPlaybackContextCache,
        requests: deezerPlaybackContextRequests
    });
}

async function ensureDeezerPlaybackContextForRow(row, deezerId) {
    if (!row) {
        return null;
    }

    const normalizedId = String(deezerId || '').trim();
    if (!normalizedId || !/^\d+$/.test(normalizedId)) {
        return null;
    }

    const existing = getDeezerPlaybackContextForRow(row, normalizedId);
    if (existing) {
        setDeezerPlaybackContextOnRow(row, normalizedId, existing);
        return existing;
    }

    const context = await fetchDeezerPlaybackContext(normalizedId);
    if (!context) {
        return null;
    }

    setDeezerPlaybackContextOnRow(row, normalizedId, context);
    return context;
}

function preloadDeezerPlaybackContextsForVisibleRows(limit = 48) {
    const rows = Array.from(document.querySelectorAll('#tracks-table-body tr[data-track-index]'));
    if (!rows.length) {
        return;
    }

    const targets = [];
    for (const row of rows) {
        if (targets.length >= limit) {
            break;
        }
        const deezerId = String(row.querySelector('.track-checkbox')?.dataset.trackId || row.dataset.availabilityDeezerId || '').trim();
        if (!deezerId || !/^\d+$/.test(deezerId)) {
            continue;
        }
        const existing = getDeezerPlaybackContextForRow(row, deezerId);
        if (existing) {
            setDeezerPlaybackContextOnRow(row, deezerId, existing);
            continue;
        }
        targets.push({ row, deezerId });
    }

    if (!targets.length) {
        return;
    }

    const concurrency = 4;
    let cursor = 0;
    const workers = Array.from({ length: Math.min(concurrency, targets.length) }, async () => {
        while (cursor < targets.length) {
            const current = targets[cursor++];
            await ensureDeezerPlaybackContextForRow(current.row, current.deezerId);
        }
    });

    void Promise.all(workers);
}

function renderTrackRows(tracks, isPlaylistLike, isLocalSource, fallbackAlbumTitle) {
    if (!tracks || tracks.length === 0) {
        return '';
    }

    const playbackSource = (requestSource || tracklistSource || 'deezer').toLowerCase();
    const isPodcastShow = String(tracklistType || '').toLowerCase() === 'show';
    const forceFullStream = playbackSource === 'deezer' || isDeezerSource();
    const resolveExternalDeezerId = (track) => {
        if (!track) {
            return '';
        }

        if (playbackSource === 'apple') {
            const mappedAppleDeezerId = String(track.deezerId || track.deezer_id || '').trim();
            return /^\d+$/.test(mappedAppleDeezerId) ? mappedAppleDeezerId : '';
        }

        const candidate = playbackSource === 'spotify'
            ? String(track.deezerId || track.deezer_id || track.id || '').trim()
            : String(track.deezerId || track.deezer_id || '').trim();
        return /^\d+$/.test(candidate) ? candidate : '';
    };
    tracks.forEach((track) => {
        if (!track.id && !track.deezerId && !track.deezer_id) {
            return;
        }
        if (playbackSource === 'apple' && (track.hasAtmos || track.isVideo)) {
            return;
        }
        if (playbackSource !== 'apple') {
            const deezerCandidate = resolveExternalDeezerId(track);
            if (deezerCandidate) {
                const playbackContext = extractDeezerPlaybackContextFromTrack(track);
                if (playbackContext) {
                    deezerPlaybackContextCache.set(deezerCandidate, playbackContext);
                }
                track.preview = buildDeezerStreamUrl(deezerCandidate, {
                    type: isPodcastShow ? 'episode' : '',
                    context: playbackContext
                });
            }
        }
    });

    const shouldShowIgnore = isPlaylistLike && !isLocalSource && currentTracklistMeta?.source && watchlistIgnoreEnabled;
    const ignoreToggleClass = shouldShowIgnore ? '' : 'is-hidden';
    const isSpotifyExternalSource = playbackSource === 'spotify';
    const isBoomplayExternalSource = playbackSource === 'boomplay';
    const isGenericExternalSource = playbackSource === 'youtube'
        || playbackSource === 'soundcloud'
        || playbackSource === 'tidal'
        || playbackSource === 'qobuz'
        || playbackSource === 'bandcamp'
        || playbackSource === 'pandora';

    return tracks.map((track, index) => {
        const spotifyId = getSpotifyTrackId(track);
        const artistIdsRaw = track.artist_ids ?? track.artistIds;
        const artistId = track.artist?.id || (Array.isArray(artistIdsRaw) ? artistIdsRaw[0] : artistIdsRaw) || '';
        const artistName = resolveArtistName(track);
        const artistDisplayName = isBoomplayTracklistSource()
            ? normalizeBoomplayLabelForDisplay(artistName, { isArtist: true })
            : artistName;
        const albumId = track.album?.id || track.album_id || track.albumId || '';
        const availabilityKey = buildAvailabilityKeyFromTrack(track, spotifyId);
        const availabilityKeyAttr = availabilityKey ? ` data-availability-key="${availabilityKey}"` : '';
        const availabilitySpotifyAttr = spotifyId ? ` data-availability-spotify-id="${spotifyId}"` : '';
        const availabilityUrlAttr = track.link ? ` data-availability-url="${escapeHtml(track.link)}"` : '';
        const availabilityIsrcAttr = track.isrc ? ` data-availability-isrc="${escapeHtml(track.isrc)}"` : '';
        const availabilityTitleAttr = track.title ? ` data-availability-title="${escapeHtml(track.title)}"` : '';
        const availabilityArtistAttr = artistName ? ` data-availability-artist="${escapeHtml(artistName)}"` : '';
        const availabilityDurationAttr = track.duration ? ` data-availability-duration="${Math.round(track.duration * 1000)}"` : '';
        const deezerId = playbackSource === 'deezer'
            ? String(track.deezerId || track.deezer_id || track.id || '').trim()
            : resolveExternalDeezerId(track);
        const availabilityDeezerAttr = deezerId ? ` data-availability-deezer-id="${escapeHtml(deezerId)}"` : '';
        const playbackContext = extractDeezerPlaybackContextFromTrack(track);
        if (deezerId && playbackContext) {
            deezerPlaybackContextCache.set(deezerId, playbackContext);
        }
        const streamTrackIdAttr = playbackContext?.streamTrackId
            ? ` data-stream-track-id="${escapeHtml(playbackContext.streamTrackId)}"`
            : '';
        const trackTokenAttr = playbackContext?.trackToken
            ? ` data-track-token="${escapeHtml(playbackContext.trackToken)}"`
            : '';
        const md5OriginAttr = playbackContext?.md5origin
            ? ` data-md5-origin="${escapeHtml(playbackContext.md5origin)}"`
            : '';
        const mediaVersionAttr = playbackContext?.mv
            ? ` data-media-version="${escapeHtml(playbackContext.mv)}"`
            : '';
        const isDeadSpotifyRow = isSpotifyExternalSource && !deezerId;
        const isDeadBoomplayRow = isBoomplayExternalSource && !deezerId;
        const isDeadGenericExternalRow = isGenericExternalSource && !deezerId;
        const supportsOnDemandMatch = isDeezerMatchedExternalSource(playbackSource);
        const hasResolvableExternalLink = !!String(track.link || track.sourceUrl || track.appleUrl || '').trim()
            || (isSpotifyExternalSource && !!spotifyId);
        const isPendingExternalRow = (isDeadSpotifyRow || isDeadBoomplayRow || isDeadGenericExternalRow)
            && supportsOnDemandMatch
            && hasResolvableExternalLink;
        const isDeadExternalRow = (isDeadSpotifyRow || isDeadBoomplayRow || isDeadGenericExternalRow)
            && !isPendingExternalRow;
        const rowSourceAttr = escapeHtml(playbackSource);
        const rowClass = isDeadExternalRow ? ' class="track-row-dead"' : '';
        const checkboxDisabledAttr = isDeadExternalRow ? ' disabled aria-disabled="true" title="Waiting for Deezer match"' : ' title="Select track"';
        const previewUrl = playbackSource === 'apple'
            ? (String(track.preview || '').trim()
                || (deezerId
                    ? buildDeezerStreamUrl(deezerId, {
                        type: isPodcastShow ? 'episode' : '',
                        context: playbackContext
                    })
                    : ''))
            : (deezerId
                ? buildDeezerStreamUrl(deezerId, {
                    type: isPodcastShow ? 'episode' : '',
                    context: playbackContext
                })
                : (track.preview || ''));
        const hasPreview = !!previewUrl;
        const canResolveOnDemand = !hasPreview && isPendingExternalRow;
        const previewClass = hasPreview ? '' : (canResolveOnDemand ? ' is-pending' : ' is-disabled');
        const previewLabel = hasPreview
            ? (isPodcastShow ? 'Play Episode' : 'Play Track')
            : (canResolveOnDemand ? 'Match and play track' : 'No Deezer match');
        const albumTitle = escapeHtml(track.album?.title || fallbackAlbumTitle || 'Unknown');
        const collectionCell = isPlaylistLike
            ? (isPodcastShow
                ? `<td class="track-album"><span class="track-cell-text">${albumTitle}</span></td>`
                : `<td class="track-album" onclick="openAlbum('${albumId}')"><span class="track-cell-text">${albumTitle}</span></td>`)
            : '';
        return `
        <tr${rowClass} data-track-index="${track.index ?? index}" data-track-source="${rowSourceAttr}"${spotifyId ? ` data-spotify-id="${spotifyId}"` : ''}${availabilityKeyAttr}${availabilitySpotifyAttr}${availabilityUrlAttr}${availabilityIsrcAttr}${availabilityTitleAttr}${availabilityArtistAttr}${availabilityDurationAttr}${availabilityDeezerAttr}${streamTrackIdAttr}${trackTokenAttr}${md5OriginAttr}${mediaVersionAttr}>
            <td class="track-number">
                <span class="track-num">${track.track_position || index + 1}</span>
                <span class="material-icons preview-controls${previewClass}"
                      data-preview="${previewUrl}"
                      data-link-only="${track.link || ''}"
                      onclick="playPausePreview(this)"
                      title="${previewLabel}">
                    play_arrow
                </span>
            </td>
            <td class="track-title">
                ${renderTrackTitleHtml(track)}
            </td>
            <td class="track-artist" onclick="openArtist('${artistId}')"><span class="track-cell-text">${escapeHtml(artistDisplayName)}</span></td>
            ${collectionCell}
            ${shouldShowQualityColumn() ? `<td class="track-quality">${renderQualityCell(track)}</td>` : ''}
            <td class="track-duration">${formatDuration(track.duration || 0)}</td>
            ${shouldShowAvailabilityColumn(isLocalSource) ? `<td class="track-availability">${renderAvailabilityCell()}</td>` : ''}
            <td class="track-actions">
                <div class="track-actions-row">
	                   ${isLocalSource ? '' : `<input type="checkbox" class="track-checkbox"
	                           data-track-id="${deezerId}"
                               data-track-content-type="${isPodcastShow ? 'podcast' : 'track'}"
	                           data-track-source="${rowSourceAttr}"
	                           data-spotify-id="${spotifyId || ''}"
	                           data-track-link="${track.link || track.sourceUrl || track.appleUrl || ''}"
	                           data-track-title="${escapeHtml(track.title || '')}"
	                           data-track-artist="${escapeHtml(artistName || '')}"
	                           data-track-album="${escapeHtml(track.album?.title || fallbackAlbumTitle || '')}"
	                           data-track-album-id="${escapeHtml(albumId || '')}"
	                           data-track-artist-id="${escapeHtml(artistId || '')}"
			                           data-track-cover="${escapeHtml(normalizeCoverUrl(track.album?.cover_medium || ''))}"
		                           data-track-isrc="${escapeHtml(track.isrc || '')}"
                               data-stream-track-id="${escapeHtml(playbackContext?.streamTrackId || '')}"
                               data-track-token="${escapeHtml(playbackContext?.trackToken || '')}"
                               data-md5-origin="${escapeHtml(playbackContext?.md5origin || '')}"
                               data-media-version="${escapeHtml(playbackContext?.mv || '')}"
                           data-track-has-atmos="${track.hasAtmos ? 'true' : 'false'}"
                           data-track-has-apple-digital-master="${track.hasAppleDigitalMaster ? 'true' : 'false'}"
                           data-track-is-video="${track.isVideo ? 'true' : 'false'}"
                           data-track-duration-ms="${track.duration ? track.duration * 1000 : 0}"
                           data-track-position="${track.track_position || index + 1}"${checkboxDisabledAttr}>`}
                    <button class="track-ignore-btn ${ignoreToggleClass}" type="button"
                        data-ignore-track-id="${track.id}"
                        data-ignore-track-isrc="${escapeHtml(track.isrc || '')}"
                        title="${isPodcastShow ? 'Ignore episode' : 'Ignore track'}">Ignore</button>
                </div>
            </td>
        </tr>
    `;
    }).join('');
}

function renderTracksTable(tracks, isPlaylistLike, isLocalSource, fallbackAlbumTitle, options = {}) {
    const allowEmptyTracks = options?.allowEmptyTracks === true;
    const rows = renderTrackRows(tracks, isPlaylistLike, isLocalSource, fallbackAlbumTitle);
    if (!rows && !allowEmptyTracks) {
        return `<div class="error">${tracklistType === 'show' ? 'No episodes available' : 'No tracks available'}</div>`;
    }

    const columnCount = getTracklistColumnCount(isPlaylistLike, isLocalSource);
    const shouldShowIgnore = isPlaylistLike && !isLocalSource && currentTracklistMeta?.source && watchlistIgnoreEnabled;
    const ignoreToggleClass = shouldShowIgnore ? '' : 'is-hidden';
    const collectionHeaderLabel = tracklistType === 'show' ? 'Podcast' : 'Album';
    const ignoreToggleTitle = tracklistType === 'show' ? 'Ignore episode' : 'Ignore track';
    const isPodcastTable = tracklistType === 'show' || tracklistType === 'episode';
    const emptyRow = rows
        ? rows
        : `<tr class="tracks-loading"><td colspan="${columnCount}">Loading tracks…</td></tr>`;

    return `
        <div class="tracks-table-wrap">
        <table class="tracks-table${shouldShowIgnore ? ' tracks-table--with-ignore' : ''}${isPlaylistLike ? ' tracks-table--playlistlike' : ''}${isPodcastTable ? ' tracks-table--podcast' : ''}">
            <colgroup>
                <col class="col-number">
                <col class="col-title">
                <col class="col-artist">
                ${isPlaylistLike ? '<col class="col-album">' : ''}
                ${shouldShowQualityColumn() ? '<col class="col-quality">' : ''}
                <col class="col-duration">
                ${shouldShowAvailabilityColumn(isLocalSource) ? '<col class="col-availability">' : ''}
                <col class="col-actions">
            </colgroup>
            <thead>
                <tr>
                    <th class="track-number">#</th>
                    <th>Title</th>
                    <th>Artist</th>
                    ${isPlaylistLike ? `<th>${collectionHeaderLabel}</th>` : ''}
                    ${shouldShowQualityColumn() ? '<th class="track-quality">Quality</th>' : ''}
                    <th class="track-duration">
                        <span class="material-icons">timer</span>
                    </th>
                    ${shouldShowAvailabilityColumn(isLocalSource) ? '<th class="track-availability">Availability</th>' : ''}
                    <th class="track-actions">
                        <div class="track-actions-row">
                            ${isLocalSource ? '' : '<input type="checkbox" class="track-checkbox" onchange="toggleAllTracks(this)" title="Select All">'}
                            <span class="material-icons track-ignore-toggle ${ignoreToggleClass}" title="${ignoreToggleTitle}">visibility_off</span>
                        </div>
                    </th>
                </tr>
            </thead>
            <tbody id="tracks-table-body">
                ${emptyRow}
            </tbody>
        </table>
        </div>
    `;
}

function renderQualityCell(track) {
    if (!track.hasAtmos) return '';
    const depth = track.bitDepth || '24B';
    const rate = track.sampleRate || '48kHz';
    const qualityText = [depth, rate].filter(Boolean).join(' · ');
    return `
        <div class="quality-tags">
            <span class="quality-strip">
                <span class="quality-icon lossless-icon" aria-label="Lossless"></span>
                <span class="quality-text">${escapeHtml(qualityText)}</span>
                <span class="quality-icon atmos-icon" aria-label="Dolby Atmos"></span>
            </span>
        </div>`;
}

function formatDuration(seconds) {
    if (!seconds) return '--:--';
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;
    return `${minutes}:${remainingSeconds.toString().padStart(2, '0')}`;
}

function applyIgnoredTrackState() {
    if (!ignoredTrackIds || ignoredTrackIds.size === 0) {
        return;
    }
    document.querySelectorAll('.track-ignore-btn').forEach(button => {
        const trackId = button.getAttribute('data-ignore-track-id');
        if (trackId && ignoredTrackIds.has(trackId)) {
            button.classList.add('ignored');
            button.textContent = 'Ignored';
        }
    });
}

function bindIgnoreButtons() {
    const playlistSource = currentTracklistMeta?.source;
    const playlistSourceId = currentTracklistMeta?.sourceId;
    if (!playlistSource || !playlistSourceId) {
        return;
    }

    document.querySelectorAll('.track-ignore-btn').forEach(button => {
        if (button.dataset.ignoreBound === 'true') {
            return;
        }
        button.dataset.ignoreBound = 'true';
        button.addEventListener('click', async () => {
            const trackId = button.getAttribute('data-ignore-track-id');
            const isrc = button.getAttribute('data-ignore-track-isrc') || '';
            if (!trackId) {
                return;
            }

            try {
                if (button.classList.contains('ignored')) {
                    await fetchJson(`/api/library/playlists/${encodeURIComponent(playlistSource)}/${encodeURIComponent(playlistSourceId)}/ignore/${encodeURIComponent(trackId)}`, {
                        method: 'DELETE'
                    });
                    button.classList.remove('ignored');
                    button.textContent = 'Ignore';
                    ignoredTrackIds.delete(trackId);
                } else {
                    await fetchJson(`/api/library/playlists/${encodeURIComponent(playlistSource)}/${encodeURIComponent(playlistSourceId)}/ignore`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            trackSourceId: trackId,
                            isrc: isrc || null
                        })
                    });
                    button.classList.add('ignored');
                    button.textContent = 'Ignored';
                    ignoredTrackIds.add(trackId);
                }
            } catch (error) {
                DeezSpoTag.ui.alert(`Ignore failed: ${error.message}`, { title: 'Ignore Track' });
            }
        });
    });
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

const previewAudio = document.getElementById('preview-track');

let previewStopped = false;

function getPreviewVolume() {
    const stored = parseInt(localStorage.getItem('previewVolume') || '', 10);
    if (!Number.isNaN(stored)) {
        return Math.max(0, Math.min(1, stored / 100));
    }
    return 0.8;
}

function resetPreviewControls() {
    document.querySelectorAll('.preview-controls').forEach((el) => {
        el.removeAttribute('playing');
        el.textContent = 'play_arrow';
    });
    document.querySelectorAll('tr.track-row-playing').forEach((row) => {
        row.classList.remove('track-row-playing');
    });
}

async function playNextPreviewFrom(control) {
    if (!control) {
        return false;
    }
    const row = control.closest('tr');
    const body = row?.parentElement;
    if (!row || !body) {
        return false;
    }
    const rows = Array.from(body.querySelectorAll('tr'));
    const startIndex = rows.indexOf(row);
    if (startIndex === -1) {
        return false;
    }
    for (let i = startIndex + 1; i < rows.length; i += 1) {
        const nextControl = rows[i].querySelector('.preview-controls');
        if (!nextControl) {
            continue;
        }
        let nextUrl = nextControl.getAttribute('data-preview') || '';
        if (!nextUrl || nextControl.classList.contains('is-disabled')) {
            nextUrl = await ensureRowPreviewForPlayback(rows[i], nextControl);
            if (!nextUrl || nextControl.classList.contains('is-disabled')) {
                continue;
            }
        }
        await playPausePreview(nextControl);
        return true;
    }
    return false;
}

async function playPausePreview(control) {
    if (!control) {
        return;
    }
    if (!previewAudio) {
        return;
    }

    let previewUrl = control.getAttribute('data-preview') || '';
    const linkOnly = control.getAttribute('data-link-only') || '';
    const row = control.closest('tr');

    if (previewUrl && previewUrl.includes('/api/deezer/stream/')) {
        const hasContextParams = /[?&](trackToken|streamTrackId)=/i.test(previewUrl);
        if (!hasContextParams && row) {
            const playbackType = getRowPlaybackTypeHint(row);
            if (playbackType === 'episode') {
                // Podcast episode playback already resolves directly by episode id.
            } else {
                const deezerId = String(row.querySelector('.track-checkbox')?.dataset.trackId || row.dataset.availabilityDeezerId || '').trim();
                if (deezerId && /^\d+$/.test(deezerId)) {
                    const context = getDeezerPlaybackContextForRow(row, deezerId);
                    if (context) {
                        previewUrl = buildDeezerStreamUrl(deezerId, {
                            type: playbackType,
                            context
                        });
                    } else {
                        previewUrl = buildDeezerStreamUrl(deezerId, { type: playbackType });
                        void ensureDeezerPlaybackContextForRow(row, deezerId);
                    }
                    control.setAttribute('data-preview', previewUrl);
                }
            }
        }
    }

    if (!previewUrl) {
        if (row) {
            previewUrl = await ensureRowPreviewForPlayback(row, control);
        }
    }

    if (!previewUrl) {
        const source = row ? getRowTrackSource(row) : '';
        if (isDeezerMatchedExternalSource(source) && window.DeezSpoTag?.ui?.showToast) {
            DeezSpoTag.ui.showToast('No Deezer match available yet for this track.', { type: 'warning' });
            return;
        }
        if (linkOnly) {
            DeezSpoTag.ui.alert('Track not available for streaming.', { title: 'Playback' });
        }
        return;
    }

    if (control.hasAttribute('playing')) {
        if (previewAudio.paused) {
            previewAudio.play().catch(() => {});
            previewStopped = false;
            control.textContent = 'pause';
            if (row) {
                row.classList.add('track-row-playing');
            }
        } else {
            previewStopped = true;
            control.textContent = 'play_arrow';
            previewAudio.pause();
            if (row) {
                row.classList.remove('track-row-playing');
            }
        }
        return;
    }

    resetPreviewControls();
    control.setAttribute('playing', 'true');
    control.textContent = 'pause';
    previewStopped = false;
    if (row) {
        row.classList.add('track-row-playing');
    }
    previewAudio.pause();
    previewAudio.src = previewUrl;
    previewAudio.load();
    previewAudio.volume = getPreviewVolume();
    previewAudio.play().catch(() => {});
}

if (previewAudio) {
    previewAudio.addEventListener('ended', () => {
        const current = document.querySelector('.preview-controls[playing]');
        if (!current) {
            previewStopped = true;
            resetPreviewControls();
            return;
        }

        void (async () => {
            if (await playNextPreviewFrom(current)) {
                return;
            }
            previewStopped = true;
            resetPreviewControls();
        })();
    });

    previewAudio.addEventListener('error', () => {
        previewStopped = true;
        resetPreviewControls();
        if (window.DeezSpoTag?.ui?.showToast) {
            DeezSpoTag.ui.showToast('Playback failed for this track.', { type: 'warning' });
        }
    });
}

function openArtist(artistId) {
    if (artistId) {
        console.log('Opening artist:', artistId);
        // Implement artist view navigation
    }
}

function openAlbum(albumId) {
    if (albumId) {
        window.location.href = `/Tracklist?id=${albumId}&type=album`;
    }
}

function getDownloadEligibleTrackCheckboxes(checkedOnly = false) {
    const source = normalizeDownloadSource(tracklistSource);
    const scope = '#tracks-table-body ';
    if (source === 'deezer' || source === 'boomplay') {
        const selector = checkedOnly
            ? `${scope}.track-checkbox[data-track-id]:not([data-track-id=""]):not(:disabled):checked`
            : `${scope}.track-checkbox[data-track-id]:not([data-track-id=""]):not(:disabled)`;
        return Array.from(document.querySelectorAll(selector));
    }

    const selector = checkedOnly
        ? `${scope}.track-checkbox:not(:disabled):checked`
        : `${scope}.track-checkbox:not(:disabled)`;
    return Array.from(document.querySelectorAll(selector));
}

function toggleAllTracks(checkbox) {
    const trackCheckboxes = getDownloadEligibleTrackCheckboxes(false);
    trackCheckboxes.forEach(cb => cb.checked = checkbox.checked);
}

function showTracklistToast(message, type = 'info', options = {}) {
    if (window.DeezSpoTag?.showNotification) {
        window.DeezSpoTag.showNotification(message, type, options);
        return;
    }
    if (window.DeezSpoTag?.ui?.showToast) {
        window.DeezSpoTag.ui.showToast(message, { type });
        return;
    }
    const toast = document.createElement('div');
    const safeType = (type || 'info').toString().toLowerCase();
    toast.className = `toast toast-${safeType}`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}

function formatTracklistDescription(text) {
    if (!text) {
        return '';
    }
    try {
        const parser = new DOMParser();
        const doc = parser.parseFromString(text, 'text/html');
        const fragment = document.createElement('div');
        doc.body.childNodes.forEach(node => {
            if (node.nodeType === Node.TEXT_NODE) {
                fragment.appendChild(document.createTextNode(node.textContent || ''));
                return;
            }
            if (node.nodeType === Node.ELEMENT_NODE && node.nodeName === 'A') {
                const href = node.getAttribute('href') || '';
                const label = node.textContent || href;
                if (isSpotifyArtistLink(href)) {
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'tracklist-desc-link';
                    button.dataset.spotifyUrl = href;
                    button.textContent = label;
                    fragment.appendChild(button);
                    return;
                }
                if (/^https?:\/\//i.test(href)) {
                    const link = document.createElement('a');
                    link.href = href;
                    link.target = '_blank';
                    link.rel = 'noopener';
                    link.textContent = label;
                    fragment.appendChild(link);
                    return;
                }
                fragment.appendChild(document.createTextNode(label));
                return;
            }
            fragment.appendChild(document.createTextNode(node.textContent || ''));
        });
        return fragment.innerHTML;
    } catch {
        return escapeHtml(text);
    }
}

function isSpotifyArtistLink(url) {
    if (!url) {
        return false;
    }
    const trimmed = url.trim();
    return /open\.spotify\.com\/artist\/[A-Za-z0-9]+/i.test(trimmed)
        || /^spotify:artist:[A-Za-z0-9]+$/i.test(trimmed);
}

async function downloadAll() {
    console.log('Download all tracks');

    const allTracks = getDownloadEligibleTrackCheckboxes(false);
    if (allTracks.length === 0) {
        showTracklistToast(tracklistType === 'show'
            ? 'No episodes available to download'
            : 'No tracks available to download', 'warning');
        return;
    }

    if (tracklistType === 'show') {
        downloadEpisodeTracks(allTracks);
        return;
    }

    if (tracklistSource !== 'deezer') {
        await downloadTracks(allTracks);
        return;
    }

    if (window.DeezSpoTagDownload) {
        const url = tracklistType === 'album'
            ? `https://www.deezer.com/album/${tracklistId}`
            : (tracklistType === 'smarttracklist'
                ? `https://www.deezer.com/smarttracklist/${tracklistId}`
                : `https://www.deezer.com/playlist/${tracklistId}`);
        window.DeezSpoTagDownload.addToQueue(url);
        return;
    }

    await downloadTracks(allTracks);
}

async function downloadSelected() {
    const selectedTracks = getDownloadEligibleTrackCheckboxes(true);

    if (selectedTracks.length === 0) {
        showTracklistToast(tracklistType === 'show'
            ? 'Please select episodes to download'
            : 'Please select tracks to download', 'warning');
        return;
    }

    console.log('Download selected tracks:', selectedTracks.length);

    if (tracklistType === 'show') {
        downloadEpisodeTracks(selectedTracks);
        return;
    }

    if (tracklistSource !== 'deezer') {
        await downloadTracks(selectedTracks);
        return;
    }

    if (window.DeezSpoTagDownload) {
        // Use the download engine for individual tracks
        const trackIds = selectedTracks
            .map(el => el.dataset.trackId)
            .filter(id => id && id !== '0' && /^[0-9]+$/.test(id));
        if (trackIds.length === 0) {
            showTracklistToast('No Deezer tracks available to download.', 'warning');
            return;
        }
        window.DeezSpoTagDownload.downloadSelectedTracks(trackIds);
    } else {
        // Fallback to direct API calls
        await downloadTracks(selectedTracks);
    }
}

async function downloadEpisodeTracks(trackElements) {
    const downloader = window.DeezSpoTagDownload;
    const requireDestination = !!stereoDestinationSelect;
    const destinationFolderId = getStereoDestinationFolderId(requireDestination);
    if (requireDestination && destinationFolderId === null) {
        return;
    }
    const episodeRequests = trackElements
        .map((el) => {
            const episodeId = (el.dataset.trackId || '').trim();
            if (!episodeId || episodeId === '0' || !/^[0-9]+$/.test(episodeId)) {
                return null;
            }

            const deezerEpisodeUrl = `https://www.deezer.com/episode/${episodeId}`;
            const sourceUrl = deezerEpisodeUrl;
            const durationMs = Number.parseInt(el.dataset.trackDurationMs || '0', 10);
            const position = Number.parseInt(el.dataset.trackPosition || '0', 10);
            const albumId = (el.dataset.trackAlbumId || '').trim();
            const artistId = (el.dataset.trackArtistId || '').trim();

            return {
                url: sourceUrl,
                metadata: {
                    sourceService: 'deezer',
                    sourceUrl,
                    deezerId: episodeId,
                    deezerAlbumId: albumId || undefined,
                    deezerArtistId: artistId || albumId || undefined,
                    title: (el.dataset.trackTitle || '').trim() || undefined,
                    artist: (el.dataset.trackArtist || '').trim() || undefined,
                    album: (el.dataset.trackAlbum || '').trim() || undefined,
                    albumArtist: (el.dataset.trackArtist || '').trim() || undefined,
                    cover: (el.dataset.trackCover || '').trim() || undefined,
                    durationMs: Number.isFinite(durationMs) && durationMs > 0 ? durationMs : undefined,
                    position: Number.isFinite(position) && position > 0 ? position : undefined,
                    contentType: 'podcast',
                    quality: 'podcast',
                    allowQualityUpgrade: true
                }
            };
        })
        .filter(Boolean);

    if (episodeRequests.length === 0) {
        showTracklistToast('No episode IDs available for download.', 'warning');
        return;
    }
    const downloadButton = document.querySelector('.btn-download');
    const originalText = downloadButton?.innerHTML;

    try {
        if (downloadButton) {
            downloadButton.innerHTML = '<span class="material-icons">hourglass_empty</span> Adding to queue...';
            downloadButton.disabled = true;
        }

        let success = 0;
        let failed = 0;
        let alreadyQueued = 0;

        if (downloader?.addToQueue) {
            episodeRequests.forEach((request) => {
                downloader.addPendingQueueItem({
                    url: request.url,
                    bitrate: 0,
                    destinationFolderId,
                    metadata: request.metadata
                });
            });
        }

        for (const request of episodeRequests) {
            const url = request.url;
            try {
                if (downloader?.addToQueue) {
                    const result = await downloader.addToQueue(url, 0, destinationFolderId, {
                        silent: true,
                        skipPending: true,
                        metadata: request.metadata
                    });
                    if (result?.alreadyQueued) {
                        alreadyQueued++;
                        downloader.removePendingQueueItem({ url, bitrate: 0, destinationFolderId });
                    } else if (result?.success || result?.deferred) {
                        success++;
                        downloader.removePendingQueueItem({ url, bitrate: 0, destinationFolderId });
                    } else {
                        failed++;
                    }
                    continue;
                }

                const response = await fetch(
                    '/api/deezer/download/add-with-settings',
                    buildCsrfFetchOptions({
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        keepalive: true,
                        body: JSON.stringify({
                            url: url,
                            bitrate: 0,
                            userId: window.DeezSpoTagDownload?.getCurrentUserId?.() || null,
                            destinationFolderId: destinationFolderId,
                            metadata: request.metadata
                        })
                    }));

                if (!response.ok) {
                    const raw = await response.text();
                    const trimmed = String(raw || '').trim();
                    let message = trimmed;
                    if (trimmed) {
                        try {
                            const parsed = JSON.parse(trimmed);
                            message = (typeof parsed?.message === 'string' && parsed.message.trim())
                                || (typeof parsed?.error === 'string' && parsed.error.trim())
                                || trimmed;
                        } catch {
                            message = trimmed;
                        }
                    }

                    if (response.status === 400 && /already\s+queued|already\s+in\s+queue|matching\s+track\s+is\s+already\s+in\s+queue/i.test(message)) {
                        alreadyQueued++;
                        continue;
                    }
                    throw new Error(message || `HTTP error! status: ${response.status}`);
                }

                const result = await response.json();
                if (result?.alreadyQueued) {
                    alreadyQueued++;
                } else if (result?.downloadId || (Array.isArray(result?.downloadIds) && result.downloadIds.length > 0)) {
                    success++;
                } else if (result?.deferred) {
                    success++;
                } else {
                    failed++;
                }
            } catch (error) {
                failed++;
            }
        }

        if (success > 0) {
            showTracklistToast(`Queued ${success} episode(s)${alreadyQueued ? ` (${alreadyQueued} already queued)` : ''}${failed ? ` (${failed} failed)` : ''}`, failed ? 'warning' : 'success');
        } else if (alreadyQueued > 0 && failed === 0) {
            showTracklistToast(`All ${alreadyQueued} episode(s) already queued`, 'info');
        } else if (failed > 0) {
            showTracklistToast('Failed to queue episodes', 'error');
        }
    } catch (error) {
        showTracklistToast(error?.message || 'Failed to queue episodes', 'error');
    } finally {
        if (downloadButton) {
            downloadButton.innerHTML = originalText;
            downloadButton.disabled = false;
        }
    }
}

async function downloadTracks(trackElements) {
    const downloader = window.DeezSpoTagDownload;
    if (tracklistSource === 'apple') {
        try {
            if (typeof downloader?.ensureSettingsLoaded === 'function') {
                await downloader.ensureSettingsLoaded();
            }
            const multiQuality = downloader?.settings?.multiQuality || downloader?.settings?.MultiQuality || {};
            tracklistMultiQualityEnabled = (multiQuality.enabled === true || multiQuality.Enabled === true)
                && (multiQuality.secondaryEnabled === true || multiQuality.SecondaryEnabled === true);
            refreshDestinationSelectorLayoutState();
        } catch {
            // Keep existing in-memory state if settings refresh fails.
        }
    }

    const isAppleTrackVideo = (trackElement) => {
        const sourceUrl = (trackElement?.dataset?.trackLink || '').toLowerCase();
        return trackElement?.dataset?.trackIsVideo === 'true'
            || trackElement?.dataset?.trackIsVideo === '1'
            || sourceUrl.includes('/music-video/')
            || sourceUrl.includes('/music-videos/')
            || sourceUrl.includes('/video/');
    };
    const requireDestination = !!stereoDestinationSelect;
    const stereoDestinationFolderId = getStereoDestinationFolderId(requireDestination);
    if (requireDestination && stereoDestinationFolderId === null) {
        return;
    }
    const hasSelectedAtmosAudioTracks = tracklistSource === 'apple'
        && Array.isArray(trackElements)
        && trackElements.some((trackElement) => {
            const hasAtmos = trackElement?.dataset?.trackHasAtmos === 'true'
                || trackElement?.dataset?.trackHasAtmos === '1';
            return hasAtmos && !isAppleTrackVideo(trackElement);
        });
    const useDualAtmosRouting = tracklistSource === 'apple'
        && tracklistMultiQualityEnabled
        && hasSelectedAtmosAudioTracks;
    const multiQualitySettings = downloader?.settings?.multiQuality || downloader?.settings?.MultiQuality || {};
    const configuredAtmosDestinationFolderId = parseFolderId(
        multiQualitySettings.secondaryDestinationFolderId ?? multiQualitySettings.SecondaryDestinationFolderId
    );
    let atmosDestinationFolderId = stereoDestinationFolderId;
    if (useDualAtmosRouting) {
        const selectedAtmosDestinationFolderId = getAtmosDestinationFolderId(false);
        atmosDestinationFolderId = selectedAtmosDestinationFolderId ?? configuredAtmosDestinationFolderId;
        if (requireDestination && atmosDestinationFolderId === null) {
            if (atmosDestinationSelect && tracklistIsAtmosView) {
                getAtmosDestinationFolderId(true);
            } else {
                showTracklistToast('Select an Atmos destination folder before downloading.', 'warning');
            }
            return;
        }
    }
    const downloadButton = document.querySelector('.btn-download');
    const originalText = downloadButton.innerHTML;
    
    try {
        // Update button to show progress
        downloadButton.innerHTML = '<span class="material-icons">hourglass_empty</span> Adding to queue...';
        downloadButton.disabled = true;
        let successCount = 0;
        let deferredCount = 0;
        let alreadyQueuedCount = 0;
        let errorCount = 0;
        let lastMessage = '';
        const resolveReasonCodeMessage = (reasonCode) => {
            const normalized = String(reasonCode || '').trim();
            if (!normalized) {
                return '';
            }
            if (typeof downloader?.reasonCodeToMessage === 'function') {
                const mapped = downloader.reasonCodeToMessage(normalized);
                if (mapped) {
                    return mapped;
                }
            }
            return normalized.replace(/_/g, ' ');
        };
        const resolveFailureMessage = (payload, fallback = '') => {
            if (typeof payload === 'string') {
                const message = payload.trim();
                if (message) {
                    return message;
                }
            }
            if (payload && typeof payload === 'object') {
                const message = typeof payload.message === 'string' ? payload.message.trim() : '';
                if (message) {
                    return message;
                }
                const error = typeof payload.error === 'string' ? payload.error.trim() : '';
                if (error) {
                    return error;
                }
                const errorMessage = typeof payload.errorMessage === 'string' ? payload.errorMessage.trim() : '';
                if (errorMessage) {
                    return errorMessage;
                }
                if (Array.isArray(payload.reasonCodes) && payload.reasonCodes.length > 0) {
                    const mapped = resolveReasonCodeMessage(payload.reasonCodes[0]);
                    if (mapped) {
                        return mapped;
                    }
                }
            }
            return String(fallback || '').trim();
        };

        if (downloader?.addToQueue) {
            const source = normalizeDownloadSource(tracklistSource);
            const requests = [];
            let boomplayUnmatchedCount = 0;

            for (const trackElement of trackElements) {
                const sourceUrl = (trackElement.dataset.trackLink || '').trim();
                const availabilityUrl = (trackElement.closest('tr')?.dataset.availabilityUrl || '').trim();
                const deezerId = (trackElement.dataset.trackId || '').trim();
                const deezerTrackUrl = /^\d+$/.test(deezerId) ? `https://www.deezer.com/track/${deezerId}` : '';
                const resolvedSourceUrl = source === 'deezer'
                    ? (availabilityUrl || deezerTrackUrl || sourceUrl)
                    : (availabilityUrl || sourceUrl);
                const spotifyId = (trackElement.dataset.spotifyId || '').trim();
                const isrc = (trackElement.dataset.trackIsrc || '').trim();
                const durationMs = parseInt(trackElement.dataset.trackDurationMs || '0', 10);
                const position = parseInt(trackElement.dataset.trackPosition || '0', 10);
                const normalizedSource = source;
                const metadata = {
                    sourceService: normalizedSource || undefined,
                    sourceUrl: resolvedSourceUrl || undefined,
                    title: trackElement.dataset.trackTitle || '',
                    artist: trackElement.dataset.trackArtist || '',
                    album: trackElement.dataset.trackAlbum || '',
                    albumArtist: trackElement.dataset.trackArtist || '',
                    deezerId: (normalizedSource === 'deezer' || normalizedSource === 'spotify' || normalizedSource === 'boomplay')
                        ? deezerId
                        : '',
                    isrc: isrc || undefined,
                    cover: trackElement.dataset.trackCover || '',
                    durationMs: Number.isFinite(durationMs) ? durationMs : 0,
                    position: Number.isFinite(position) ? position : 0,
                    allowQualityUpgrade: true
                };

                if (source === 'spotify') {
                    const spotifyUrl = resolvedSourceUrl || (spotifyId ? `https://open.spotify.com/track/${spotifyId}` : '');
                    if (spotifyUrl) {
                        requests.push({ url: spotifyUrl, metadata, destinationFolderId: stereoDestinationFolderId });
                    } else {
                        errorCount++;
                    }
                    continue;
                }

                if (source === 'apple') {
                    const isVideo = isAppleTrackVideo(trackElement);
                    const hasAtmos = trackElement.dataset.trackHasAtmos === 'true' || trackElement.dataset.trackHasAtmos === '1';
                    const useDualRoutingForTrack = useDualAtmosRouting && hasAtmos && !isVideo;
                    const requestedContentType = isVideo
                        ? 'video'
                        : (useDualRoutingForTrack ? 'stereo' : (hasAtmos ? 'atmos' : 'stereo'));
                    if (resolvedSourceUrl) {
                        requests.push({
                            url: resolvedSourceUrl,
                            destinationFolderId: stereoDestinationFolderId,
                            secondaryDestinationFolderId: useDualRoutingForTrack ? atmosDestinationFolderId : null,
                            metadata: {
                                ...metadata,
                                contentType: requestedContentType,
                                hasAtmos: hasAtmos,
                                hasAppleDigitalMaster: trackElement.dataset.trackHasAppleDigitalMaster === 'true' || trackElement.dataset.trackHasAppleDigitalMaster === '1',
                                isVideo
                            }
                        });
                    } else {
                        errorCount++;
                    }
                    continue;
                }

                if (source === 'qobuz') {
                    if (resolvedSourceUrl) {
                        requests.push({ url: resolvedSourceUrl, destinationFolderId: stereoDestinationFolderId });
                    } else if (isrc) {
                        requests.push({ url: `isrc:${isrc}`, destinationFolderId: stereoDestinationFolderId });
                    } else {
                        errorCount++;
                    }
                    continue;
                }

                if (source === 'boomplay') {
                    const deezerId = (trackElement.dataset.trackId || '').trim();
                    if (/^\d+$/.test(deezerId)) {
                        const deezerTrackUrl = `https://www.deezer.com/track/${deezerId}`;
                        requests.push({
                            url: deezerTrackUrl,
                            destinationFolderId: stereoDestinationFolderId,
                            metadata: {
                                ...metadata,
                                sourceService: 'deezer',
                                sourceUrl: deezerTrackUrl,
                                deezerId: deezerId
                            }
                        });
                    } else {
                        boomplayUnmatchedCount++;
                        if (!lastMessage) {
                            lastMessage = 'Some Boomplay tracks were skipped because they are not matched to Deezer yet.';
                        }
                    }
                    continue;
                }

                if (source === 'tidal' || source === 'amazon' || source === 'deezer') {
                    if (resolvedSourceUrl) {
                        requests.push({
                            url: resolvedSourceUrl,
                            destinationFolderId: stereoDestinationFolderId,
                            metadata: source === 'deezer'
                                ? {
                                    ...metadata,
                                    sourceService: 'deezer',
                                    sourceUrl: resolvedSourceUrl
                                }
                                : undefined
                        });
                    } else {
                        errorCount++;
                    }
                    continue;
                }

                lastMessage = 'Download engine removed for this source.';
                errorCount++;
            }

            if (requests.length === 0) {
                showTracklistToast(lastMessage || 'No tracks available to download.', 'warning');
                return;
            }

            requests.forEach((request) => {
                const requestDestinationFolderId = request.destinationFolderId ?? stereoDestinationFolderId;
                downloader.addPendingQueueItem({
                    url: request.url,
                    bitrate: 0,
                    destinationFolderId: requestDestinationFolderId,
                    metadata: request.metadata
                });
            });

            for (const request of requests) {
                try {
                    const requestDestinationFolderId = request.destinationFolderId ?? stereoDestinationFolderId;
                    const result = await downloader.addToQueue(
                        request.url,
                        0,
                        requestDestinationFolderId,
                        {
                            silent: true,
                            skipPending: true,
                            allowQualityUpgrade: true,
                            metadata: request.metadata,
                            secondaryDestinationFolderId: request.secondaryDestinationFolderId
                        }
                    );
                    if (result?.alreadyQueued) {
                        alreadyQueuedCount++;
                        downloader.removePendingQueueItem({ url: request.url, bitrate: 0, destinationFolderId: requestDestinationFolderId });
                    } else if (result?.deferred) {
                        deferredCount++;
                        downloader.removePendingQueueItem({ url: request.url, bitrate: 0, destinationFolderId: requestDestinationFolderId });
                    } else if (result?.success) {
                        successCount++;
                        downloader.removePendingQueueItem({ url: request.url, bitrate: 0, destinationFolderId: requestDestinationFolderId });
                    } else {
                        errorCount++;
                        if (!lastMessage) {
                            lastMessage = resolveFailureMessage(result, result?.errorMessage || '');
                        }
                    }
                } catch (error) {
                    errorCount++;
                    if (!lastMessage) {
                        lastMessage = error?.message || '';
                    }
                }
            }

            if (successCount > 0) {
                const message = `Added ${successCount} track(s) to the queue.` +
                    `${deferredCount > 0 ? ` (${deferredCount} deferred)` : ''}` +
                    `${alreadyQueuedCount > 0 ? ` (${alreadyQueuedCount} already queued)` : ''}` +
                    `${boomplayUnmatchedCount > 0 ? ` (${boomplayUnmatchedCount} skipped: no Deezer match)` : ''}` +
                    `${errorCount > 0 ? ` (${errorCount} failed)` : ''}`;
                const hasWarningSignals = deferredCount > 0 || boomplayUnmatchedCount > 0 || errorCount > 0;
                showTracklistToast(message, hasWarningSignals ? 'warning' : 'success', {
                    action: { label: 'View', href: activitiesDownloadsTabHref }
                });
            } else if (deferredCount > 0) {
                const message = `Queued ${deferredCount} track(s) for background intent resolution.` +
                    `${alreadyQueuedCount > 0 ? ` (${alreadyQueuedCount} already queued)` : ''}` +
                    `${boomplayUnmatchedCount > 0 ? ` (${boomplayUnmatchedCount} skipped: no Deezer match)` : ''}` +
                    `${errorCount > 0 ? ` (${errorCount} failed)` : ''}`;
                showTracklistToast(message, boomplayUnmatchedCount > 0 || errorCount > 0 ? 'warning' : 'info', {
                    action: { label: 'View', href: activitiesDownloadsTabHref }
                });
            } else if (alreadyQueuedCount > 0 && errorCount === 0) {
                showTracklistToast(`All ${alreadyQueuedCount} track(s) were already queued.`, 'info');
            } else {
                const message = lastMessage
                    || (boomplayUnmatchedCount > 0
                        ? `${boomplayUnmatchedCount} Boomplay track(s) were skipped because they are not matched to Deezer yet.`
                        : 'Failed to add tracks to download queue. Please try again.');
                showTracklistToast(message, boomplayUnmatchedCount > 0 && errorCount === 0 ? 'warning' : 'error');
            }
            return;
        }

        // Apple fallback pipeline (used when downloader script is unavailable)
        if (tracklistSource === 'apple') {
            const tracksPayload = trackElements.map(trackElement => {
                const durationMs = parseInt(trackElement.dataset.trackDurationMs || '0', 10);
                const hasAtmos = trackElement.dataset.trackHasAtmos === 'true'
                    || trackElement.dataset.trackHasAtmos === '1';
                const hasAppleDigitalMaster = trackElement.dataset.trackHasAppleDigitalMaster === 'true'
                    || trackElement.dataset.trackHasAppleDigitalMaster === '1';
                const isVideo = trackElement.dataset.trackIsVideo === 'true'
                    || trackElement.dataset.trackIsVideo === '1'
                    || (trackElement.dataset.trackLink || '').toLowerCase().includes('/music-video/')
                    || (trackElement.dataset.trackLink || '').toLowerCase().includes('/music-videos/')
                    || (trackElement.dataset.trackLink || '').toLowerCase().includes('/video/');
                return {
                    appleUrl: trackElement.dataset.trackLink || '',
                    appleId: trackElement.dataset.trackId || '',
                    isVideo: isVideo,
                    metadata: {
                        title: trackElement.dataset.trackTitle || '',
                        artist: trackElement.dataset.trackArtist || '',
                        album: trackElement.dataset.trackAlbum || '',
                        albumArtist: trackElement.dataset.trackArtist || '',
                        isrc: trackElement.dataset.trackIsrc || '',
                        cover: trackElement.dataset.trackCover || '',
                        durationMs: durationMs,
                        position: parseInt(trackElement.dataset.trackPosition || '0', 10),
                        hasAtmos: hasAtmos,
                        hasAppleDigitalMaster: hasAppleDigitalMaster
                    }
                };
            }).filter(t => t.appleUrl || t.appleId);

            if (tracksPayload.length === 0) {
                showTracklistToast('No Apple tracks to download.', 'warning');
            } else {
                const videoTracks = tracksPayload.filter(t => t.isVideo);
                const audioTracks = tracksPayload.filter(t => !t.isVideo);

                if (audioTracks.length > 0) {
                    const intents = audioTracks
                        .map((track) => {
                            const hasAtmos = track?.metadata?.hasAtmos === true;
                            const useDualRoutingForTrack = useDualAtmosRouting && hasAtmos;
                            const requestedContentType = useDualRoutingForTrack
                                ? 'stereo'
                                : (hasAtmos ? 'atmos' : 'stereo');
                            return {
                                sourceService: 'apple',
                                sourceUrl: track.appleUrl,
                                appleId: track.appleId || undefined,
                                contentType: requestedContentType,
                                hasAtmos: Boolean(hasAtmos),
                                hasAppleDigitalMaster: track?.metadata?.hasAppleDigitalMaster === true,
                                title: track?.metadata?.title || undefined,
                                artist: track?.metadata?.artist || undefined,
                                album: track?.metadata?.album || undefined,
                                albumArtist: track?.metadata?.albumArtist || undefined,
                                isrc: track?.metadata?.isrc || undefined,
                                cover: track?.metadata?.cover || undefined,
                                durationMs: Number(track?.metadata?.durationMs || 0) || undefined,
                                position: Number(track?.metadata?.position || 0) || undefined,
                                allowQualityUpgrade: true
                            };
                        })
                        .filter(intent => intent.sourceUrl);

                    if (intents.length === 0) {
                        errorCount += audioTracks.length;
                        if (!lastMessage) {
                            lastMessage = 'No Apple audio tracks available to queue.';
                        }
                    } else {
                        const response = await fetch(
                            '/api/download/intent',
                            buildCsrfFetchOptions({
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    resolveImmediately: true,
                                    destinationFolderId: stereoDestinationFolderId,
                                    secondaryDestinationFolderId: useDualAtmosRouting ? atmosDestinationFolderId : null,
                                    intents
                                })
                            }));

                        const rawData = await response.text();
                        let data = null;
                        if (rawData && rawData.trim()) {
                            try {
                                data = JSON.parse(rawData);
                            } catch {
                                data = rawData;
                            }
                        }

                        if (!response.ok) {
                            errorCount += audioTracks.length;
                            lastMessage = resolveFailureMessage(data, rawData) || lastMessage;
                        } else {
                            const payload = (data && typeof data === 'object') ? data : {};
                            const queued = Array.isArray(payload?.queued) ? payload.queued.length : 0;
                            const deferred = Number.isFinite(payload?.deferredCount) ? payload.deferredCount : 0;
                            const skipped = Number.isFinite(payload?.skipped) ? payload.skipped : 0;
                            successCount += queued;
                            deferredCount += deferred;
                            const processedCount = queued + deferred;
                            errorCount += Math.max(0, audioTracks.length - processedCount) + skipped;
                            if (!processedCount) {
                                const maybeMessage = resolveFailureMessage(payload, '');
                                if (maybeMessage) {
                                    lastMessage = maybeMessage;
                                }
                            }
                        }
                    }
                }

                if (videoTracks.length > 0) {
                    const response = await fetch(
                        '/api/apple/videos/download',
                        buildCsrfFetchOptions({
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                destinationFolderId: stereoDestinationFolderId,
                                tracks: videoTracks
                            })
                        }));
                    const rawData = await response.text();
                    let data = null;
                    if (rawData && rawData.trim()) {
                        try {
                            data = JSON.parse(rawData);
                        } catch {
                            data = rawData;
                        }
                    }
                    if (!response.ok) {
                        errorCount += videoTracks.length;
                        lastMessage = resolveFailureMessage(data, rawData) || lastMessage;
                    } else {
                        const payload = (data && typeof data === 'object') ? data : {};
                        const queued = Array.isArray(payload?.queued) ? payload.queued.length : 0;
                        successCount += queued;
                        errorCount += Math.max(0, videoTracks.length - queued) + (Number.isFinite(payload?.skipped) ? payload.skipped : 0);
                        if (!queued) {
                            const maybeMessage = resolveFailureMessage(payload, '');
                            if (maybeMessage) {
                                lastMessage = maybeMessage;
                            }
                        }
                    }
                }
            }
        } else {
            const downloadSource = normalizeDownloadSource(tracklistSource);
            const tracksPayload = trackElements.map(trackElement => {
                const sourceUrl = (trackElement.closest('tr')?.dataset.availabilityUrl || trackElement.dataset.trackLink || '').trim();
                const durationMs = parseInt(trackElement.dataset.trackDurationMs || '0', 10);
                const durationSeconds = durationMs > 0 ? Math.round(durationMs / 1000) : 0;
                return {
                    sourceUrl: sourceUrl,
                    spotifyId: trackElement.dataset.spotifyId || '',
                    deezerId: trackElement.dataset.trackId || '',
                    isrc: trackElement.dataset.trackIsrc || '',
                    title: trackElement.dataset.trackTitle || '',
                    artist: trackElement.dataset.trackArtist || '',
                    album: trackElement.dataset.trackAlbum || '',
                    albumArtist: trackElement.dataset.trackArtist || '',
                    cover: trackElement.dataset.trackCover || '',
                    durationSeconds: durationSeconds,
                    position: parseInt(trackElement.dataset.trackPosition || '0', 10)
                };
            });

            let filtered = tracksPayload;
            const buildExternalIntent = (track, sourceService, sourceUrl, overrides = {}) => ({
                sourceService: sourceService,
                sourceUrl: sourceUrl,
                isrc: track.isrc,
                title: track.title,
                artist: track.artist,
                album: track.album,
                albumArtist: track.albumArtist,
                cover: track.cover,
                durationMs: track.durationSeconds * 1000,
                position: track.position,
                ...overrides
            });

            if (downloadSource === 'tidal') {
                filtered = tracksPayload
                    .filter(t => t.sourceUrl)
                    .map(t => buildExternalIntent(t, 'tidal', t.sourceUrl));
            } else if (downloadSource === 'amazon') {
                filtered = tracksPayload
                    .filter(t => t.sourceUrl)
                    .map(t => buildExternalIntent(t, 'amazon', t.sourceUrl));
            } else if (downloadSource === 'qobuz') {
                filtered = tracksPayload
                    .filter(t => t.sourceUrl || t.isrc)
                    .map(t => buildExternalIntent(
                        t,
                        'qobuz',
                        t.sourceUrl || undefined,
                        { isrc: t.isrc || undefined }));
            } else if (downloadSource === 'spotify') {
                filtered = tracksPayload.map(t => {
                    const spotifyId = t.spotifyId || (t.sourceUrl ? (t.sourceUrl.match(/(?:spotify:track:|open\.spotify\.com\/track\/)([A-Za-z0-9]+)/i) || [])[1] || '' : '');
                    const sourceUrl = t.sourceUrl || (spotifyId ? `https://open.spotify.com/track/${spotifyId}` : '');
                    return buildExternalIntent(
                        t,
                        'spotify',
                        sourceUrl,
                        {
                            spotifyId: spotifyId,
                            deezerId: t.deezerId || ''
                        });
                });
            } else if (downloadSource === 'deezer') {
                filtered = tracksPayload
                    .map(t => {
                        const deezerId = String(t.deezerId || '').trim();
                        const sourceUrl = t.sourceUrl || (/^\d+$/.test(deezerId) ? `https://www.deezer.com/track/${deezerId}` : '');
                        return buildExternalIntent(
                            t,
                            'deezer',
                            sourceUrl,
                            { deezerId: deezerId || '' });
                    })
                    .filter(t => t.sourceUrl);
            } else {
                showTracklistToast('Download engine removed for this source.', 'error');
                return;
            }

            if (filtered.length === 0) {
                showTracklistToast('No tracks available for download.', 'warning');
                return;
            }

            const response = await fetch(
                '/api/download/intent',
                buildCsrfFetchOptions({
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        destinationFolderId: stereoDestinationFolderId,
                        intents: filtered,
                        resolveImmediately: true
                    })
                }));
            const rawData = await response.text();
            let data = null;
            if (rawData && rawData.trim()) {
                try {
                    data = JSON.parse(rawData);
                } catch {
                    data = rawData;
                }
            }
            if (!response.ok) {
                errorCount = filtered.length;
                lastMessage = resolveFailureMessage(data, rawData) || lastMessage;
            } else {
                const payload = (data && typeof data === 'object') ? data : {};
                successCount = payload?.queued?.length || 0;
                deferredCount = payload?.deferredCount || 0;
                const processedCount = successCount + deferredCount;
                errorCount = filtered.length - processedCount + (payload?.skipped || 0);
                if (!processedCount) {
                    const maybeMessage = resolveFailureMessage(payload, '');
                    if (maybeMessage) {
                        lastMessage = maybeMessage;
                    }
                }
            }
        }

        // Show result
        if (successCount > 0) {
            const message = `Added ${successCount} track(s) to the queue.` +
                `${deferredCount > 0 ? ` (${deferredCount} deferred)` : ''}` +
                `${errorCount > 0 ? ` (${errorCount} failed)` : ''}`;
            showTracklistToast(message, errorCount > 0 || deferredCount > 0 ? 'warning' : 'success', {
                action: { label: 'View', href: activitiesDownloadsTabHref }
            });
        } else if (deferredCount > 0) {
            const message = `Queued ${deferredCount} track(s) for background intent resolution.`;
            showTracklistToast(message, 'info', {
                action: { label: 'View', href: activitiesDownloadsTabHref }
            });
        } else {
            const message = lastMessage || 'Failed to add tracks to download queue. Please try again.';
            showTracklistToast(message, 'error');
        }
        
    } catch (error) {
        console.error('Error downloading tracks:', error);
        showTracklistToast(error?.message || 'Error occurred while adding tracks to download queue', 'error');
    } finally {
        // Restore button
        downloadButton.innerHTML = originalText;
        downloadButton.disabled = false;
    }
}

function extractDeezerTrackId(trackLink) {
    if (!trackLink) return null;
    
    // Extract track ID from Deezer URL
    // Examples: 
    // https://www.deezer.com/track/123456789
    // https://deezer.com/track/123456789
    const match = trackLink.match(/\/track\/(\d+)/);
    return match ? match[1] : null;
}

document.addEventListener('click', event => {
    if (!(event.target instanceof Element)) {
        return;
    }
    const recommendationCard = event.target.closest('#spotify-recommendations .spotify-card');
    if (recommendationCard) {
        const source = (recommendationCard.dataset.source || '').toLowerCase();
        if (source === 'boomplay') {
            const id = recommendationCard.dataset.sourceId || '';
            const type = recommendationCard.dataset.sourceType || 'playlist';
            const sourceUrl = recommendationCard.dataset.sourceUrl || '';
            if (id) {
                window.location.href = `/Tracklist?id=${encodeURIComponent(id)}&type=${encodeURIComponent(type)}&source=boomplay`;
                return;
            }
            if (sourceUrl) {
                window.location.href = sourceUrl;
                return;
            }
        }
        const parsed = parseSpotifyUri(recommendationCard.dataset.spotifyUri || '');
        if (parsed?.id && parsed?.type) {
            if (parsed.type === 'artist') {
                window.location.href = `/Artist?source=spotify&id=${encodeURIComponent(parsed.id)}`;
                return;
            }
            window.location.href = `/Tracklist?id=${encodeURIComponent(parsed.id)}&type=${encodeURIComponent(parsed.type)}&source=spotify`;
            return;
        }
    }
    const descLink = event.target.closest('.tracklist-desc-link');
    if (descLink && descLink.dataset.spotifyUrl) {
        event.preventDefault();
        event.stopPropagation();
        handleTracklistArtistLink(descLink.dataset.spotifyUrl);
    }
});

async function handleTracklistArtistLink(spotifyUrl) {
    if (!spotifyUrl) {
        return;
    }
    try {
        const response = await fetch(`/api/spotify/resolve-deezer?url=${encodeURIComponent(spotifyUrl)}`);
        const payload = response.ok ? await response.json() : null;
        if (payload?.deezerId && payload.type === 'artist') {
            window.location.href = `/Artist?id=${encodeURIComponent(payload.deezerId)}&source=deezer`;
            return;
        }
        if (window.DeezSpoTag?.ui?.showToast) {
            DeezSpoTag.ui.showToast('Artist not available in the library yet.', { type: 'warning' });
        }
    } catch {
        if (window.DeezSpoTag?.ui?.showToast) {
            DeezSpoTag.ui.showToast('Unable to open artist right now.', { type: 'warning' });
        }
    }
}

// Load tracklist when page loads
document.addEventListener('DOMContentLoaded', loadTracklist);

document.addEventListener('mouseenter', (event) => {
    if (!(event.target instanceof Element)) {
        return;
    }
    const cell = event.target.closest('.track-title, .track-artist, .track-album');
    if (!cell) {
        return;
    }
    const text = cell.querySelector('.track-title-text, .track-cell-text');
    if (!text) {
        return;
    }
    const clipTarget = cell.querySelector('.track-title-content') || cell;
    const textWidth = text.scrollWidth;
    text.style.width = `${textWidth}px`;
    const distance = Math.max(0, textWidth - clipTarget.clientWidth);
    if (!distance) {
        cell.classList.remove('is-marquee');
        cell.style.removeProperty('--marquee-distance');
        text.style.removeProperty('width');
        return;
    }
    cell.style.setProperty('--marquee-distance', `${distance}px`);
    cell.classList.add('is-marquee');
}, true);

document.addEventListener('mouseleave', (event) => {
    if (!(event.target instanceof Element)) {
        return;
    }
    const cell = event.target.closest('.track-title, .track-artist, .track-album');
    if (!cell) {
        return;
    }
    const text = cell.querySelector('.track-title-text, .track-cell-text');
    if (text) {
        text.style.removeProperty('width');
    }
    cell.classList.remove('is-marquee');
    cell.style.removeProperty('--marquee-distance');
}, true);
</script>
