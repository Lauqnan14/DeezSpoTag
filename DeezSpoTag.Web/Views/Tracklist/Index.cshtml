function scheduleExternalTracklistMatches(tracks, source) {
    if (!Array.isArray(tracks) || tracks.length === 0) {
        return;
    }

    const normalizedSource = String(source || '').trim().toLowerCase();
    if (!normalizedSource || normalizedSource === 'deezer' || normalizedSource === 'apple') {
        return;
    }

    externalBatchMatchSessionId += 1;
    const sessionId = externalBatchMatchSessionId;
    if (externalBatchMatchTimer) {
        clearTimeout(externalBatchMatchTimer);
        externalBatchMatchTimer = null;
    }

    const initialCount = Math.min(externalMatchInitialBatchSize, tracks.length);
    const initialBatch = tracks.slice(0, initialCount);
    void resolveExternalTracklistMatches(initialBatch, normalizedSource, {
        incremental: false,
        finalize: tracks.length <= initialCount
    }).catch((error) => {
        console.warn('Initial external match batch failed', error);
    });

    if (tracks.length <= initialCount) {
        return;
    }

    let offset = initialCount;
    const runNextBatch = () => {
        if (sessionId !== externalBatchMatchSessionId) {
            return;
        }

        const batch = tracks.slice(offset, offset + externalMatchBackgroundBatchSize);
        if (batch.length === 0) {
            externalBatchMatchTimer = null;
            return;
        }

        offset += batch.length;
        const isLast = offset >= tracks.length;
        void resolveExternalTracklistMatches(batch, normalizedSource, {
            incremental: true,
            finalize: isLast
        }).catch((error) => {
            console.warn('External Deezer background match batch failed', error);
        }).finally(() => {
            if (sessionId !== externalBatchMatchSessionId) {
                return;
            }
            if (isLast) {
                externalBatchMatchTimer = null;
                return;
            }
            externalBatchMatchTimer = setTimeout(runNextBatch, 0);
        });
    };

    externalBatchMatchTimer = setTimeout(runNextBatch, 0);
}

