async function loadSpotifyTracklist() {
    resetSpotifyState();
    const spotifyUrl = `https://open.spotify.com/${tracklistType}/${tracklistId}`;
    const isHomeTrendingPlaylist = tracklistType === 'playlist' && isSpotifyHomeTrendingTracklistView();
    if (tracklistType === 'playlist') {
        if (isHomeTrendingPlaylist) {
            await loadSpotifyTrendingTracklist();
            return;
        }
        await loadSpotifyPlaylistTracklist(spotifyUrl);
        return;
    }
    if (tracklistType === 'trending') {
        await loadSpotifyTrendingTracklist();
        return;
    }
    const response = await fetchWithTransientRetry(
        `/api/spotify/tracklist?url=${encodeURIComponent(spotifyUrl)}`,
        {},
        { maxRetries: 3, baseDelayMs: 300 });
    if (!response.ok) {
        throw new Error(`Failed to load Spotify tracklist (HTTP ${response.status})`);
    }
    const payload = await response.json();
    if (!payload.available || !payload.tracklist) {
        throw new Error('Spotify tracklist unavailable.');
    }
    await loadIgnoredTracks();
    renderTracklist(payload.tracklist);
    if (payload.matching?.pending > 0 && payload.matching?.token) {
        startSpotifyMatchPolling(payload.matching.token, payload.matching.pending);
    } else {
        updateSpotifyNotice();
    }
}

