@{
    ViewData["Title"] = "Tracklist - DeezSpoTag";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var id = ViewData["Id"]?.ToString();
    var type = ViewData["Type"]?.ToString();
}

@section Styles {
<link rel="stylesheet" href="~/css/spotify-card-shared.css" asp-append-version="true" />
<style>
.tracklist-header {
    background-size: cover;
    background-position: center 15%;
    background-repeat: no-repeat;
    background-color: var(--bg-primary);
    padding: 60px 0;
    margin-bottom: 30px;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
}

.tracklist-header::after {
    content: '';
    position: absolute;
    top: -10%;
    left: -10%;
    right: -10%;
    bottom: -10%;
    background-image: inherit;
    background-size: cover;
    background-position: center 15%;
    filter: blur(8px);
    opacity: 0.4;
    z-index: 0;
}

.tracklist-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    /* Dark overlay for readability while still showing the background image. */
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0.45) 55%, rgba(0, 0, 0, 0.2) 100%);
    z-index: 1;
}

.tracklist-header-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    gap: 30px;
    padding: 0 30px;
}

.tracklist-header-actions {
    position: relative;
    align-self: flex-start;
}

.tracklist-header-utility {
    margin-left: auto;
    display: flex;
    align-items: flex-start;
    gap: 10px;
}

.tracklist-soundtrack-match-btn {
    min-height: 42px;
    white-space: nowrap;
}

.tracklist-header-menu-btn {
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.18);
    background: rgba(8, 15, 28, 0.72);
    color: var(--text-primary);
    display: grid;
    place-items: center;
}

.tracklist-header-menu-btn:hover {
    border-color: color-mix(in srgb, var(--primary-color) 45%, transparent);
    background: rgba(8, 15, 28, 0.92);
}

@@media (max-width: 900px) {
    .tracklist-header-utility {
        width: 100%;
        justify-content: flex-end;
    }

    .tracklist-soundtrack-match-btn {
        max-width: 100%;
    }
}

.tracklist-header-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    min-width: 220px;
    z-index: 12;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(5, 10, 20, 0.94);
    box-shadow: 0 18px 34px rgba(0,0,0,0.34);
}

.tracklist-header-dropdown .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    border: none;
    border-radius: 10px;
    background: transparent;
    color: var(--text-primary);
    padding: 10px 12px;
    text-align: left;
}

.tracklist-header-dropdown .dropdown-item:hover {
    background: color-mix(in srgb, var(--primary-color) 18%, transparent);
}

.tracklist-header-dropdown .dropdown-item.danger:hover {
    background: color-mix(in srgb, var(--error-color) 24%, transparent);
    color: #fff;
}

.dropdown-visuals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
}

.visual-tile {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 10px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--bg-secondary) 84%, transparent);
    border: 1px solid var(--border-secondary);
}

.visual-tile img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 10px;
}

.visual-tile__actions {
    display: flex;
    justify-content: center;
}

.tracklist-cover {
    width: var(--art-card-size);
    border-radius: 12px;
    background: var(--bg-tertiary);
    font-size: 64px;
    color: var(--text-secondary);
    flex-shrink: 0;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
}

.tracklist-cover img {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 12px;
    object-fit: contain; /* keep full cover visible */
    background: var(--bg-tertiary);
}

.tracklist-info h1 {
    font-size: 48px;
    font-weight: 700;
    margin: 0 0 10px 0;
    color: var(--text-primary);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
}

.tracklist-info .metadata {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 5px;
    line-height: 1.5;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
}

.tracklist-info .metadata.tracklist-meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.tracklist-meta-separator {
    color: var(--text-muted);
}

.tracklist-info .metadata a {
    color: var(--text-primary);
    text-decoration: none;
}

.tracklist-info .metadata .tracklist-desc-link {
    color: var(--text-primary);
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
}

.tracklist-owner {
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.tracklist-owner-avatar {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border-secondary);
}

.tracklist-info .release-date {
    font-size: 14px;
    color: var(--text-muted);
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
}

.tracklist-content {
    padding-bottom: 120px; /* Add space for fixed footer */
}

.tracklist-notice {
    margin: 0 0 20px 0;
    padding: 12px 16px;
    border-radius: 10px;
    background: rgba(255, 205, 100, 0.12);
    border: 1px solid rgba(255, 205, 100, 0.35);
    color: var(--text-secondary);
    font-size: 14px;
}

.tracklist-notice.is-hidden {
    display: none;
}

.tracklist-actions {
    position: fixed;
    bottom: 0;
    left: 250px;
    width: calc(100% - 250px);
    z-index: 1000;
    background: var(--bg-primary);
    backdrop-filter: blur(10px);
    border-top: 1px solid var(--border-secondary);
    padding: 15px 20px;
    display: flex;
    gap: 15px;
    align-items: flex-end;
    justify-content: center;
    box-shadow: 0 -2px 20px rgba(0, 0, 0, 0.2);
}

.main-content.sidebar-collapsed .tracklist-actions {
    left: 70px;
    width: calc(100% - 70px);
}

.tracklist-actions.has-atmos-destinations {
    flex-wrap: wrap;
}

.download-destination {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 220px;
}

.download-destination-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
}

.download-destination-select {
    margin-bottom: 0;
}

.btn-download {
    border: 1px solid var(--border-secondary);
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
    min-width: 160px;
    justify-content: center;
}

.btn-download:hover {
    border-color: var(--primary-color);
    transform: translateY(-1px);
}

.tracklist-monitor-menu {
    position: relative;
}

.tracklist-monitor-menu-dropdown {
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    min-width: 200px;
    z-index: 1005;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px;
    border-radius: 12px;
    border: 1px solid var(--border-secondary);
    background: color-mix(in srgb, var(--bg-secondary) 92%, black 8%);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
}

.tracklist-monitor-menu-dropdown .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-primary);
    padding: 10px 12px;
    text-align: left;
}

.tracklist-monitor-menu-dropdown .dropdown-item:hover {
    background: color-mix(in srgb, var(--primary-color) 16%, transparent);
}

.tracklist-monitor-menu-dropdown .dropdown-item.danger:hover {
    background: color-mix(in srgb, var(--error-color) 24%, transparent);
    color: #fff;
}

.tracks-table-wrap {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
}

.tracks-table {
    width: 100%;
    background: var(--bg-tertiary);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 30px;
    table-layout: fixed;
    min-width: 1060px;
}

.tracks-table col.col-number { width: 60px; }
.tracks-table col.col-quality { width: 170px; }
.tracks-table col.col-duration { width: 72px; }
.tracks-table col.col-availability { width: 208px; }
.tracks-table col.col-actions { width: 72px; }
.tracks-table.tracks-table--playlistlike col.col-title { width: 28%; }
.tracks-table.tracks-table--playlistlike col.col-artist { width: 21%; }
.tracks-table.tracks-table--playlistlike col.col-album { width: 21%; }
.tracks-table.tracks-table--podcast {
    min-width: 980px;
}
.tracks-table.tracks-table--podcast col.col-number { width: 38px; }
.tracks-table.tracks-table--podcast col.col-duration { width: 68px; }
.tracks-table.tracks-table--podcast col.col-actions { width: 60px; }
.tracks-table.tracks-table--playlistlike.tracks-table--podcast col.col-title { width: 44%; }
.tracks-table.tracks-table--playlistlike.tracks-table--podcast col.col-artist { width: 16%; }
.tracks-table.tracks-table--playlistlike.tracks-table--podcast col.col-album { width: 16%; }
.tracks-table.tracks-table--with-ignore {
    min-width: 1200px;
}
.tracks-table.tracks-table--with-ignore col.col-actions { width: 168px; }
.tracks-table.tracks-table--podcast.tracks-table--with-ignore col.col-actions { width: 146px; }
.tracks-table.tracks-table--podcast .track-number {
    width: 26px;
}
.tracks-table.tracks-table--podcast th.track-number,
.tracks-table.tracks-table--podcast td.track-number {
    padding-left: 6px;
    padding-right: 4px;
}
.tracks-table.tracks-table--podcast td.track-title {
    padding-left: 6px;
}
.tracks-table.tracks-table--podcast thead th:nth-child(2) {
    padding-left: 6px;
}

.tracks-table th,
.tracks-table td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border-secondary);
}

.tracks-table th.track-availability,
.tracks-table td.track-availability {
    padding-left: 10px;
    padding-right: 10px;
}

.tracks-table th.track-actions,
.tracks-table td.track-actions {
    padding-left: 8px;
    padding-right: 8px;
}

.tracks-table th {
    background: var(--bg-quaternary);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.tracks-table td {
    color: var(--text-primary);
}

.tracks-table tr:hover {
    background: var(--bg-quaternary);
}

.tracks-table tbody td {
    border-bottom: none;
}

.tracks-table tbody tr {
    border-bottom: 1px solid var(--border-secondary);
}

.tracks-table tbody tr:last-child {
    border-bottom: none;
}

.spotify-recommendations {
    margin-top: 32px;
}

.spotify-recommendations.is-hidden {
    display: none;
}

.spotify-recommendations .home-section-title {
    font-size: 18px;
    font-weight: 600;
    margin: 10px 0 16px;
}

.spotify-home-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--art-grid-min, 160px), 1fr));
    gap: 16px;
}

.spotify-card {
    width: 100%;
    background: transparent;
    border: none;
    border-radius: 14px;
    padding: 12px;
    display: grid;
    gap: 8px;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease;
}

.spotify-card:hover {
    border-color: transparent;
    transform: translateY(-2px);
}

.spotify-card-art {
    background: transparent;
}

/* Merged number/play column - shows number by default, play icon on hover */
.track-number {
    width: 50px;
    text-align: center;
    color: var(--text-muted);
    font-weight: 600;
    position: relative;
}

.track-number .track-num {
    display: block;
}

.track-number .preview-controls {
    display: none;
    font-size: 22px;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.2s ease;
}

.track-number .preview-controls:hover {
    color: var(--primary-color);
}

.track-number .preview-controls.is-disabled {
    opacity: 0.35;
    pointer-events: auto;
    cursor: not-allowed;
}

.track-number .preview-controls.is-pending {
    opacity: 0.8;
    cursor: pointer;
}

.track-number .preview-controls.is-resolving {
    color: var(--primary-color);
    animation: track-preview-resolving-pulse 0.9s ease-in-out infinite;
}

@@keyframes track-preview-resolving-pulse {
    0% { opacity: 0.45; }
    50% { opacity: 1; }
    100% { opacity: 0.45; }
}

/* Show play icon on row hover, hide number */
.tracks-table tbody tr:hover .track-number .track-num {
    display: none;
}

.tracks-table tbody tr:hover .track-number .preview-controls {
    display: block;
}

/* When track is playing, always show play/pause icon */
.tracks-table tbody tr.track-row-playing .track-number .track-num {
    display: none;
}

.tracks-table tbody tr.track-row-playing .track-number .preview-controls {
    display: block;
    color: var(--primary-color);
}

.track-title {
    font-weight: 600;
    min-width: 0;
    overflow: hidden;
}

.track-title-content {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    overflow: hidden;
}

.track-title-text {
    display: inline-block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    width: max-content;
    max-width: none;
    padding-right: 24px;
    transform: translateX(0);
    will-change: transform;
    flex: 0 0 auto;
}

.track-explicit {
    font-size: 16px;
    color: var(--text-muted);
}

.track-artist {
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.2s ease;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.track-artist:hover {
    color: var(--primary-color);
}

.track-album {
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.2s ease;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.track-cell-text {
    display: inline-block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    width: max-content;
    max-width: none;
    padding-right: 24px;
    transform: translateX(0);
    will-change: transform;
    flex: 0 0 auto;
}

.is-marquee .track-title-text,
.is-marquee .track-cell-text {
    text-overflow: clip;
    animation: track-marquee var(--marquee-duration, 8s) linear infinite;
    overflow: visible;
}

@@keyframes track-marquee {
    0% {
        transform: translateX(0);
    }
    100% {
        transform: translateX(calc(-1 * var(--marquee-distance, 0px)));
    }
}

.track-album:hover {
    color: var(--primary-color);
}

.track-duration {
    width: 80px;
    text-align: center;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
}

.track-availability {
    text-align: center;
    color: var(--text-muted);
}

.availability-icons {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    justify-content: center;
}

.availability-icon {
    width: 18px;
    height: 18px;
    display: inline-block;
    background-color: var(--text-muted);
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    mask-size: contain;
    -webkit-mask-size: contain;
    opacity: 0.9;
}

.availability-icon.is-available {
    background-color: #23d18b;
}

.availability-icon.is-unavailable {
    background-color: #ff6b6b;
}

.availability-icon.is-loading {
    background-color: #f5f7ff;
}

.availability-icon.availability-deezer {
    mask-image: url("/images/availability/deezer.svg");
    -webkit-mask-image: url("/images/availability/deezer.svg");
}
.availability-icon.availability-spotify {
    mask-image: url("/images/availability/spotify.svg");
    -webkit-mask-image: url("/images/availability/spotify.svg");
}

.availability-icon.availability-tidal {
    mask-image: url("/images/availability/tidal.svg");
    -webkit-mask-image: url("/images/availability/tidal.svg");
}

.availability-icon.availability-amazon {
    mask-image: url("/images/availability/amazon.svg");
    -webkit-mask-image: url("/images/availability/amazon.svg");
}

.availability-icon.availability-qobuz {
    mask-image: url("/images/availability/qobuz.svg");
    -webkit-mask-image: url("/images/availability/qobuz.svg");
}

.availability-icon.availability-apple {
    mask-image: url("/images/availability/apple.svg");
    -webkit-mask-image: url("/images/availability/apple.svg");
}

.track-quality { width: 170px; }
.quality-tags { display: inline-flex; align-items: center; gap: 8px; }
.quality-strip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-primary);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.15px;
}
.quality-strip .quality-icon {
    display: inline-block;
    background-color: currentColor;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    mask-size: contain;
    -webkit-mask-size: contain;
    opacity: 0.95;
}
.quality-strip .quality-icon.lossless-icon {
    width: 22px;
    height: 14px;
    mask-image: url("/images/apple/lossless.svg");
    -webkit-mask-image: url("/images/apple/lossless.svg");
}
.quality-strip .quality-icon.atmos-icon {
    width: 62px;
    height: 18px;
    mask-image: url("/images/apple/atmos.svg");
    -webkit-mask-image: url("/images/apple/atmos.svg");
}
.quality-strip .quality-text {
    color: var(--text-primary);
    white-space: nowrap;
}

.track-actions {
    width: auto;
    text-align: center;
}

.track-actions-row {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    white-space: nowrap;
}

.track-checkbox {
    cursor: pointer;
}

.tracks-table tbody tr.track-row-dead {
    opacity: 0.78;
}

.tracks-table tbody tr.track-row-dead .track-checkbox {
    cursor: not-allowed;
    opacity: 0.45;
}

.track-ignore-btn {
    background: transparent;
    border: 1px solid var(--border-secondary);
    color: var(--text-muted);
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 12px;
    margin-left: 2px;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
}

.track-ignore-btn.is-hidden,
.track-ignore-toggle.is-hidden {
    display: none;
}

.track-ignore-btn:hover {
    border-color: var(--primary-color);
    color: var(--text-primary);
}

.track-ignore-btn.ignored {
    border-color: var(--warning-color);
    color: var(--warning-color);
}

.loading {
    text-align: center;
    padding: 60px;
    color: var(--text-muted);
    font-size: 18px;
}

.error {
    text-align: center;
    padding: 60px;
    color: var(--error-color);
    font-size: 18px;
}

.back-button {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 1px solid var(--border-secondary);
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
    text-decoration: none;
    margin-bottom: 20px;
    width: fit-content;
}

.back-button .material-icons {
    width: 20px;
    height: 20px;
    font-size: 20px;
    line-height: 1;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
}

.back-button:hover {
    background: var(--bg-quaternary);
    border-color: var(--primary-color);
    color: var(--text-primary);
    text-decoration: none;
}

@@media (max-width: 1180px) {
    .tracks-table col.col-number { width: 52px; }
    .tracks-table col.col-duration { width: 68px; }
    .tracks-table col.col-quality { width: 0; }
    .tracks-table .track-quality {
        display: none;
    }
}

@@media (max-width: 900px) {
    .tracklist-header-content {
        gap: 20px;
    }

    .tracklist-info h1 {
        font-size: 34px;
    }

    .tracks-table {
        font-size: 15px;
    }

    /* Fix fixed action bar positioning when sidebar is hidden on mobile */
    .tracklist-actions {
        left: 0;
        width: 100%;
    }

    .main-content.sidebar-collapsed .tracklist-actions {
        left: 0;
        width: 100%;
    }
}

@@media (max-width: 768px) {
    .tracklist-header-content {
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 20px;
        padding: 0 16px;
    }

    .tracklist-cover {
        width: var(--art-card-size);
    }

    .tracklist-info h1 {
        font-size: 28px;
    }

    /* Hide less important columns on tablet - use class selectors only */
    .tracks-table col.col-quality { width: 0; }
    .tracks-table col.col-availability { width: 0; }
    .tracks-table .track-quality,
    .tracks-table .track-availability {
        display: none;
    }

    .tracks-table {
