}

async function loadSpotifyPlaylistTracklist(spotifyUrl) {
    const response = await fetchWithTransientRetry(
        `/api/spotify/tracklist/playlist/metadata?url=${encodeURIComponent(spotifyUrl)}`,
        {},
        { maxRetries: 3, baseDelayMs: 300 });
    if (!response.ok) {
        throw new Error(`Failed to load Spotify playlist metadata (HTTP ${response.status})`);
    }
    const payload = await response.json();
    if (!payload.available || !payload.tracklist) {
        throw new Error('Spotify playlist unavailable.');
    }

    const trackSource = ((payload.trackSource || 'pathfinder').toLowerCase() === 'spotiflac' ? 'pathfinder' : (payload.trackSource || 'pathfinder').toLowerCase());
    spotifyPageSize = trackSource === 'librespot' ? 1000 : 50;
    renderTracklist(payload.tracklist, { allowEmptyTracks: true });
    await loadIgnoredTracks();
    applyIgnoredTrackState();
    bindIgnoreButtons();

    spotifyLazyState = {
        url: spotifyUrl,
        offset: 0,
        limit: spotifyPageSize,
        total: payload.tracklist.nb_tracks || 0,
        loaded: 0,
        hasMore: true,
        isLoading: false,
        backgroundLoading: false,
        trackSource
    };
    updateSpotifyNotice();

    await loadSpotifyPlaylistTracksPage();
    void startSpotifyPlaylistMatching(spotifyUrl);
    scheduleSpotifyNextPage();
}

async function loadSpotifyPlaylistTracksPage() {
    if (!spotifyLazyState || spotifyLazyState.isLoading || !spotifyLazyState.hasMore) {
        return;
    }

    spotifyLazyState.isLoading = true;
    updateSpotifyNotice();
    try {
        const qs = new URLSearchParams();
        qs.set('url', spotifyLazyState.url);
        qs.set('offset', spotifyLazyState.offset);
        qs.set('limit', spotifyLazyState.limit);
        qs.set('hydrate', spotifyLazyState.trackSource !== 'librespot');

        const response = await fetchWithTransientRetry(
            `/api/spotify/tracklist/playlist/tracks?${qs.toString()}`,
            {},
            { maxRetries: 3, baseDelayMs: 300 });
        if (!response.ok) {
            throw new Error(`Failed to load Spotify playlist tracks (HTTP ${response.status})`);
        }
        const payload = await response.json();
        if (!payload.available) {
            throw new Error('Spotify playlist tracks unavailable.');
        }

        const tracks = Array.isArray(payload.tracks) ? payload.tracks : [];
        appendSpotifyTrackRows(tracks);
        if (spotifyLazyState.trackSource === 'librespot') {
            void hydrateLibrespotTrackDetails(tracks);
        }
        if (!spotifyMatchState && payload.matching?.token) {
            startSpotifyMatchPolling(payload.matching.token, payload.matching.pending || 0);
        }

        spotifyLazyState.offset = (payload.offset || 0) + tracks.length;
        spotifyLazyState.total = typeof payload.total === 'number' ? payload.total : spotifyLazyState.total;
        spotifyLazyState.loaded = spotifyLazyState.offset;
        spotifyLazyState.hasMore = !!payload.hasMore;

        if (!spotifyLazyState.hasMore && spotifyLazyState.loaded === 0) {
            setTracksEmptyMessage('No tracks available');
        }
    } finally {
        if (spotifyLazyState) {
            spotifyLazyState.isLoading = false;
        }
        updateSpotifyNotice();
    }
}

function scheduleSpotifyNextPage() {
    if (!spotifyLazyState || spotifyLazyState.backgroundLoading || !spotifyLazyState.hasMore) {
        return;
    }
    if (spotifyLazyTimer) {
        return;
    }

    const delayMs = 0;
    spotifyLazyTimer = setTimeout(async () => {
        spotifyLazyTimer = null;
        if (!spotifyLazyState || spotifyLazyState.isLoading || !spotifyLazyState.hasMore) {
            return;
        }

        spotifyLazyState.backgroundLoading = true;
        try {
            await loadSpotifyPlaylistTracksPage();
        } catch (error) {
            console.warn('Spotify playlist paging failed', error);
            if (spotifyLazyState) {
                spotifyLazyState.hasMore = false;
            }
        } finally {
            if (spotifyLazyState) {
                spotifyLazyState.backgroundLoading = false;
            }
            updateSpotifyNotice();
            scheduleSpotifyNextPage();
        }
    }, delayMs);
}

async function startSpotifyPlaylistMatching(spotifyUrl) {
