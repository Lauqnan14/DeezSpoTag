@section Scripts {
<script>
const tracklistId = '@Html.Raw(id)';
const tracklistAppleUrl = '@Html.Raw(ViewData["AppleUrl"] ?? "")';
const tracklistExternalUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["ExternalUrl"]?.ToString() ?? ""));
const tracklistType = '@Html.Raw(type)';
const tracklistSource = '@Html.Raw(ViewData["Source"] ?? "deezer")';
const tracklistQuery = new URLSearchParams(window.location.search);
const tracklistDiscoverAvatar = tracklistQuery.get('discoverAvatar') || '';
const tracklistDiscoverHero = tracklistQuery.get('discoverHero') || '';
const requestSource = '@Html.Raw(ViewData["Source"] ?? "")';
const spotifyHomeTrendingSourceId = 'home-trending-songs';
const deezerSimilarParam = tracklistQuery.get('deezerSimilar');
const isBoomplayCollectionTracklist = tracklistType === 'playlist' || tracklistType === 'trending';
const boomplayDeezerSimilarMode = (() => {
    const source = (tracklistSource || '').toLowerCase();
    if (source !== 'boomplay') {
        return deezerSimilarParam === '1';
    }
    if (isBoomplayCollectionTracklist) {
        return deezerSimilarParam !== '0';
    }
    return deezerSimilarParam === '1';
})();
const tracklistLibraryId = '@Html.Raw(ViewData["LibraryId"] ?? "")';
const soundtrackMatchContextType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["MatchContextType"]?.ToString() ?? ""));
const soundtrackMatchContextServerType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["MatchContextServerType"]?.ToString() ?? ""));
const soundtrackMatchContextLibraryId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["MatchContextLibraryId"]?.ToString() ?? ""));
const soundtrackMatchContextItemId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["MatchContextItemId"]?.ToString() ?? ""));
const soundtrackMatchContextTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["MatchContextTitle"]?.ToString() ?? ""));
const soundtrackMatchContextYearRaw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["MatchContextYear"]?.ToString() ?? ""));
const soundtrackMatchContextYear = Number.isFinite(Number(soundtrackMatchContextYearRaw))
    ? Number(soundtrackMatchContextYearRaw)
    : null;
const externalDeezerMatchCache = new Map();
// Map<link, { promise: Promise<{ deezerId: string, resolvePayload: any }>, priority: 'high'|'low' }>
const externalDeezerMatchInFlight = new Map();
const deezerPlaybackContextCache = new Map();
const deezerPlaybackContextRequests = new Map();
const radioType = '@Html.Raw(ViewData["RadioType"] ?? "")';
const radioValue = '@Html.Raw(ViewData["RadioValue"] ?? "")';
const recommendationType = '@Html.Raw(ViewData["RecommendationType"] ?? "")';
const recommendationValue = '@Html.Raw(ViewData["RecommendationValue"] ?? "")';
const activitiesDownloadsTabHref = '/Activities?tab=downloads-content';
const downloadActions = document.getElementById('download-actions');
const stereoDestinationSelect = document.getElementById('downloadDestinationTracklist');
const stereoDestinationLabel = document.getElementById('downloadDestinationStereoLabel');
const atmosDestinationGroup = document.getElementById('downloadDestinationAtmosGroup');
const atmosDestinationSelect = document.getElementById('downloadDestinationTracklistAtmos');
const monitorButton = document.getElementById('monitor-playlist');
const monitorLabel = monitorButton?.querySelector('.monitor-label');
const monitorMenu = document.getElementById('tracklist-monitor-menu');
const monitorMenuToggle = document.getElementById('monitor-playlist-actions');
const monitorMenuDropdown = document.getElementById('tracklist-monitor-menu-dropdown');
const monitorManageSettingsButton = document.getElementById('monitor-playlist-manage-settings');
const monitorSyncButton = document.getElementById('monitor-playlist-sync');
const monitorRefreshArtworkButton = document.getElementById('monitor-playlist-refresh-artwork');
const monitorArtworkHistoryButton = document.getElementById('monitor-playlist-artwork-history');
const monitorRemoveButton = document.getElementById('monitor-playlist-remove');
let currentTracklistMeta = null;
let ignoredTrackIds = new Set();
let watchlistIgnoreEnabled = false;
let useUnifiedTracklistView = false;
let tracklistLayoutIsPlaylistLike = tracklistType !== 'album';
let tracklistIsAtmosView = false;
let tracklistIsVideoView = false;
let tracklistMultiQualityEnabled = false;
let atmosDestinationPrefilled = false;
let spotifyPageSize = 50;
let spotifyLazyState = null;
let boomplayLazyState = null;
let spotifyMatchState = null;
let spotifyMatchCompletion = null;
let spotifyMatchFailureToastShown = false;
let externalMatchState = null;
const spotifyMatchCache = new Map();
let spotifyMatchTimer = null;
let spotifyLazyTimer = null;
let boomplayLazyTimer = null;
let boomplayTracksEventSource = null;
let spotifyRecommendationState = null;
let boomplayRecommendationState = null;
let librespotHydratedIds = new Set();
let externalBatchMatchTimer = null;
let externalBatchMatchSessionId = 0;
const externalMatchInitialBatchSize = 24;
const externalMatchBackgroundBatchSize = 96;
const externalMatchMaxConcurrent = 4;
const externalMatchLowConcurrencyCap = 2;
const externalMatchHighConcurrencyCap = 2;
const externalResolverScheduler = {
    activeHigh: 0,
    activeLow: 0,
    queueHigh: [],
    queueLow: []
};
const deezerMatchedExternalSources = new Set([
    'spotify',
    'boomplay',
    'tidal',
    'qobuz',
    'bandcamp'
]);

function isSpotifyArtistTopTracksView() {
    const source = (requestSource || tracklistSource || '').toLowerCase();
    return source === 'spotify' && tracklistType === 'artist';
}

function isSpotifyHomeTrendingSourceId(value) {
    return String(value || '').trim().toLowerCase() === spotifyHomeTrendingSourceId;
}

function isSpotifyHomeTrendingTracklistView() {
    const source = (requestSource || tracklistSource || '').toLowerCase();
    return source === 'spotify' && isSpotifyHomeTrendingSourceId(tracklistId);
}

function isSpotifyPlaylistDeezerMatchContext() {
    const source = (requestSource || tracklistSource || '').toLowerCase();
    return source === 'spotify' && tracklistType === 'playlist';
}

function isRecommendationTracklistContext() {
    return (requestSource || tracklistSource || '').toLowerCase() === 'recommendations'
        || String(tracklistType || '').toLowerCase() === 'recommendation';
}

function isPodcastTracklistContext() {
    const normalizedType = String(tracklistType || '').toLowerCase();
    return normalizedType === 'show'
        || normalizedType === 'episode'
        || normalizedType === 'podcast';
}

function hasSoundtrackMatchContext() {
    return Boolean(String(soundtrackMatchContextServerType || '').trim())
        && Boolean(String(soundtrackMatchContextLibraryId || '').trim())
        && Boolean(String(soundtrackMatchContextItemId || '').trim())
        && Boolean(String(soundtrackMatchContextTitle || '').trim());
}

function mapSoundtrackMatchCategory() {
    const contextType = String(soundtrackMatchContextType || '').trim().toLowerCase();
    return contextType === 'tv_show'
        || contextType === 'episode'
        || contextType === 'season'
        ? 'tv_show'
        : 'movie';
}

function getTracklistManualMatchTargetUrl() {
    const source = String(requestSource || tracklistSource || '').trim().toLowerCase();
    const type = String(tracklistType || '').trim().toLowerCase();
    const normalizedId = String(tracklistId || '').trim();
    const externalUrl = String(tracklistExternalUrl || tracklistAppleUrl || '').trim();

    if (externalUrl && /(?:open\.spotify\.com|deezer\.com)/i.test(externalUrl)) {
        return externalUrl;
    }

    if (!normalizedId) {
        return '';
    }

    if (source === 'spotify' && (type === 'album' || type === 'playlist' || type === 'track')) {
        return `https://open.spotify.com/${type}/${encodeURIComponent(normalizedId)}`;
    }

    if (source === 'deezer' && (type === 'album' || type === 'playlist' || type === 'track')) {
        return `https://www.deezer.com/${type}/${encodeURIComponent(normalizedId)}`;
    }

    return externalUrl;
}

function isSupportedSoundtrackMatchLink(value) {
    const input = String(value || '').trim();
    if (!input) {
        return false;
    }

    if (/^spotify:(album|playlist|track):[a-z0-9]{22}$/i.test(input)) {
        return true;
    }

    if (/open\.spotify\.com\/(album|playlist|track)\/[a-z0-9]{22}/i.test(input)) {
        return true;
    }

    if (/deezer\.com\/(?:[a-z]{2}(?:-[a-z]{2})?\/)?(album|playlist|track)\/\d+/i.test(input)) {
        return true;
    }

    return false;
}

async function matchCurrentTracklistToSoundtrackContext(button, manualQueryOverride = '') {
    if (!hasSoundtrackMatchContext()) {
        return;
    }

    const manualQuery = String(manualQueryOverride || '').trim() || getTracklistManualMatchTargetUrl();
    if (!manualQuery) {
        showTracklistToast('No Spotify/Deezer tracklist URL available to save this soundtrack match.', 'warning');
        return;
    }

    if (!isSupportedSoundtrackMatchLink(manualQuery)) {
        showTracklistToast('Only Spotify/Deezer album, playlist, or track links are supported.', 'warning');
        return;
    }

    const payload = {
        serverType: String(soundtrackMatchContextServerType || '').trim().toLowerCase(),
        libraryId: String(soundtrackMatchContextLibraryId || '').trim(),
        category: mapSoundtrackMatchCategory(),
        itemId: String(soundtrackMatchContextItemId || '').trim(),
        title: String(soundtrackMatchContextTitle || '').trim(),
        year: Number.isFinite(soundtrackMatchContextYear) ? soundtrackMatchContextYear : null,
        manualQuery
    };

    const label = button?.querySelector('[data-match-label]');
    if (button) {
        button.disabled = true;
    }
    if (label) {
        label.textContent = 'Matching...';
    }

    try {
        const result = await fetchJson('/api/media-server/soundtracks/resolve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const matchedTitle = String(result?.soundtrack?.title || soundtrackMatchContextTitle || 'item').trim();
        showTracklistToast(`Soundtrack matched for ${matchedTitle}.`, 'success');
        if (label) {
            label.textContent = 'Matched';
        }
    } catch (error) {
        showTracklistToast(`Soundtrack match failed: ${error?.message || 'Unknown error'}`, 'error');
        if (label) {
            label.textContent = 'Match';
        }
    } finally {
        if (button) {
            button.disabled = false;
        }
    }
}

async function promptAndMatchSoundtrackWithPastedLink(button) {
    const suggested = getTracklistManualMatchTargetUrl();
    const entered = globalThis.prompt(
        'Paste Spotify or Deezer album/playlist/track link (Spotify URI is also supported).',
        suggested || ''
    );
    if (entered === null) {
        return;
    }

    const trimmed = String(entered || '').trim();
    if (!trimmed) {
        showTracklistToast('Paste a Spotify/Deezer link to continue.', 'warning');
        return;
    }

    await matchCurrentTracklistToSoundtrackContext(button, trimmed);
}

function bindSoundtrackTracklistMatchButton() {
    const button = document.getElementById('tracklist-soundtrack-match-btn');
    const pasteButton = document.getElementById('tracklist-soundtrack-match-paste-btn');
    if (!button && !pasteButton) {
        return;
    }

    if (button) {
        button.addEventListener('click', async () => {
            await matchCurrentTracklistToSoundtrackContext(button);
        });
    }
    if (pasteButton) {
        pasteButton.addEventListener('click', async () => {
            await promptAndMatchSoundtrackWithPastedLink(pasteButton);
        });
    }
}

function setDestinationContentMode(select, contentMode) {
    if (!select) {
        return false;
    }

    const targetMode = String(contentMode || '').trim().toLowerCase() || 'music';
    if (String(select.dataset.destinationContentMode || '').trim().toLowerCase() === targetMode) {
        return false;
    }

    select.dataset.destinationContentMode = targetMode;
    select.dataset.destinationLoaded = 'false';
    select.dataset.destinationLoadedForMode = '';
    return true;
}

function normalizeDownloadSource(source) {
    const normalized = String(source || '').trim().toLowerCase();
    const deezerMappedSources = new Set([
        'recommendations',
        'youtube',
        'soundcloud',
        'tidal',
        'qobuz',
        'bandcamp',
        'pandora'
    ]);
    if (deezerMappedSources.has(normalized)) {
        return 'deezer';
    }
    return normalized;
}

function normalizeWatchlistSource(source, type) {
    const normalizedSource = String(source || '').trim().toLowerCase();
    const normalizedType = String(type || '').trim().toLowerCase();

    if (normalizedType === 'smarttracklist') {
        return 'smarttracklist';
    }
    if (normalizedType === 'recommendation') {
        return 'recommendations';
    }

    switch (normalizedSource) {
        case 'smarttracklist':
        case 'smarttracks':
            return 'smarttracklist';
        case 'recommendation':
        case 'recommendations':
            return 'recommendations';
        case 'itunes':
        case 'applemusic':
            return 'apple';
        default:
            return normalizedSource || 'deezer';
    }
}

function getWatchlistSourceId() {
    if (isRecommendationTracklistContext()) {
        return String(tracklistId || '').trim() || 'daily-rotation';
    }
    if (isSpotifyArtistTopTracksView()) {
        return `artist-top:${tracklistId}`;
    }
    if (isSpotifyHomeTrendingTracklistView()) {
        return spotifyHomeTrendingSourceId;
    }
    return String(tracklistId || '');
}

async function loadIgnoredTracks() {
    if (!currentTracklistMeta?.source || !currentTracklistMeta?.sourceId) {
        return;
    }
    try {
        const ignored = await fetchJson(`/api/library/playlists/${encodeURIComponent(currentTracklistMeta.source)}/${encodeURIComponent(currentTracklistMeta.sourceId)}/ignore`);
        if (Array.isArray(ignored)) {
            ignoredTrackIds = new Set(ignored);
        }
    } catch {
        ignoredTrackIds = new Set();
    }
}

const csrfUnsafeMethods = new Set(['POST', 'PUT', 'PATCH', 'DELETE']);

function readCsrfRequestToken() {
    const tokenMeta = document.querySelector('meta[name="deezspotag-csrf-token"]');
    const token = tokenMeta?.getAttribute('content');
    return typeof token === 'string' ? token.trim() : '';
}

function buildCsrfFetchOptions(options) {
    const requestOptions = options ? { ...options } : {};
    const method = String(requestOptions.method || 'GET').toUpperCase();
    if (!csrfUnsafeMethods.has(method)) {
        return requestOptions;
    }

    const headers = new Headers(requestOptions.headers || {});
    if (!headers.has('X-CSRF-TOKEN')) {
        const csrfToken = readCsrfRequestToken();
        if (csrfToken) {
            headers.set('X-CSRF-TOKEN', csrfToken);
        }
    }

    requestOptions.headers = headers;
    if (!requestOptions.credentials) {
        requestOptions.credentials = 'same-origin';
    }
    return requestOptions;
}

async function fetchJson(url, options) {
    const response = await fetch(url, buildCsrfFetchOptions(options));
    if (!response.ok) {
        const raw = await response.text();
        const trimmed = String(raw || '').trim();
        let message = trimmed;
        if (trimmed) {
            try {
                const parsed = JSON.parse(trimmed);
                const reasonCodes = Array.isArray(parsed?.reasonCodes)
                    ? parsed.reasonCodes.map((value) => String(value || '').trim()).filter(Boolean)
                    : [];
                const parsedMessage = (typeof parsed?.message === 'string' && parsed.message.trim())
                    || '';
                message = (parsedMessage && !/^nothing queued\.?$/i.test(parsedMessage) ? parsedMessage : '')
                    || (typeof parsed?.error === 'string' && parsed.error.trim())
                    || (reasonCodes.length > 0 ? reasonCodes[0].replace(/_/g, ' ') : '')
                    || trimmed;
            } catch {
                message = trimmed;
            }
        }
        throw new Error(message || `Request failed: ${response.status}`);
    }
    const raw = await response.text();
    const trimmed = String(raw || '').trim();
    if (!trimmed) {
        return null;
    }
    return JSON.parse(trimmed);
}

function delayAsync(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
}

function shouldRetryTransientResponse(status) {
    return status === 408 || status === 429 || status === 500 || status === 502 || status === 503 || status === 504;
}

async function fetchWithTransientRetry(url, options = {}, retryOptions = {}) {
    const maxRetries = Number.isFinite(retryOptions.maxRetries) ? Math.max(0, retryOptions.maxRetries) : 2;
    const baseDelayMs = Number.isFinite(retryOptions.baseDelayMs) ? Math.max(0, retryOptions.baseDelayMs) : 250;
    let attempt = 0;
    while (true) {
        try {
            const response = await fetch(url, buildCsrfFetchOptions(options));
            if (response.ok || !shouldRetryTransientResponse(response.status) || attempt >= maxRetries) {
                return response;
            }
        } catch (error) {
            if (attempt >= maxRetries) {
                throw error;
            }
        }

        attempt += 1;
        await delayAsync(baseDelayMs * attempt);
    }
}

function shouldUseUnifiedTracklistView(tracks) {
    if (tracklistType === 'show') {
        return false;
    }
    const source = (requestSource || tracklistSource || '').toLowerCase();
    if (source !== 'apple') {
        return true;
    }
    if (!Array.isArray(tracks)) {
        return true;
    }
    return !tracks.some(track => track?.hasAtmos || track?.isVideo);
}

function updateTracklistLayoutState(tracks) {
    useUnifiedTracklistView = shouldUseUnifiedTracklistView(tracks);
    tracklistLayoutIsPlaylistLike = useUnifiedTracklistView || tracklistType !== 'album';
    const source = (requestSource || tracklistSource || '').toLowerCase();
    tracklistIsAtmosView = source === 'apple' && Array.isArray(tracks) && tracks.some(track => track?.hasAtmos);
    tracklistIsVideoView = source === 'apple' && Array.isArray(tracks) && tracks.some(track => track?.isVideo);
    refreshDestinationSelectorLayoutState();
}

function refreshDestinationSelectorLayoutState() {
    const showDualSelectors = tracklistIsAtmosView && tracklistMultiQualityEnabled;
    downloadActions?.classList.toggle('has-atmos-destinations', showDualSelectors);
    if (stereoDestinationLabel) {
        stereoDestinationLabel.textContent = showDualSelectors ? 'Stereo folder' : 'Destination folder';
    }
    if (atmosDestinationGroup) {
        atmosDestinationGroup.style.display = showDualSelectors ? '' : 'none';
    }

    let stereoContentMode = 'music';
    if (isPodcastTracklistContext()) {
        stereoContentMode = 'podcast';
    } else if (tracklistIsVideoView) {
        stereoContentMode = 'video';
    } else if (tracklistIsAtmosView && !showDualSelectors) {
        stereoContentMode = 'atmos';
    }

    const stereoChanged = setDestinationContentMode(stereoDestinationSelect, stereoContentMode);
    const atmosChanged = setDestinationContentMode(atmosDestinationSelect, showDualSelectors ? 'atmos' : stereoContentMode);
    if ((stereoChanged || atmosChanged) && typeof window.DeezSpoTagDownload?.ensureDestinationSelects === 'function') {
        window.DeezSpoTagDownload
            .ensureDestinationSelects()
            .catch((error) => console.warn('Failed to reload tracklist destination folders', error));
    }
}

function parseFolderId(rawValue) {
    if (rawValue === null || rawValue === undefined) {
        return null;
    }

    const value = String(rawValue).trim();
    if (!value) {
        return null;
    }

    return /^\d+$/.test(value) ? Number(value) : value;
}

function setSelectValueIfAvailable(select, folderId) {
    if (!select || folderId === null || folderId === undefined || folderId === '') {
        return false;
    }

    const targetValue = String(folderId);
    const hasOption = Array.from(select.options || []).some((option) => String(option.value) === targetValue);
    if (!hasOption) {
        return false;
    }

    select.value = targetValue;
    const storageKey = select.dataset.destinationStorageKey || 'download-destination-folder';
    localStorage.setItem(storageKey, targetValue);
    if (window.UserPrefs) {
        if (storageKey === 'download-destination-folder-stereo') {
            window.UserPrefs.set('downloadDestinationStereoFolderId', targetValue);
        } else if (storageKey === 'download-destination-folder-atmos') {
            window.UserPrefs.set('downloadDestinationAtmosFolderId', targetValue);
        } else {
            window.UserPrefs.set('downloadDestinationFolderId', targetValue);
        }
    }
    return true;
}

function chooseStereoDefaultFolderId(atmosFolderId) {
    const candidate = parseFolderId(
        localStorage.getItem('download-destination-folder-stereo')
            || localStorage.getItem('download-destination-folder')
    );
    if (candidate !== null && String(candidate) !== String(atmosFolderId ?? '')) {
        return candidate;
    }

    if (!stereoDestinationSelect) {
        return null;
    }

    const fallbackOption = Array.from(stereoDestinationSelect.options || []).find((option) => {
        const value = String(option.value || '').trim();
        if (!value) {
            return false;
        }
        return value !== String(atmosFolderId ?? '');
    });

    return fallbackOption ? parseFolderId(fallbackOption.value) : null;
}

function getSelectedDestinationFolderId(select, requireSelection, emptyMessage) {
    if (!select) {
        return null;
    }

    const value = parseFolderId(select.value);
    if (requireSelection && value === null) {
        showTracklistToast(emptyMessage, 'warning');
        return null;
    }

    return value;
}

function getStereoDestinationFolderId(requireSelection = false) {
    return getSelectedDestinationFolderId(
        stereoDestinationSelect,
        requireSelection,
        'Select a stereo destination folder before downloading.'
    );
}

function getAtmosDestinationFolderId(requireSelection = false) {
    if (!tracklistIsAtmosView || !tracklistMultiQualityEnabled || !atmosDestinationSelect) {
        return getStereoDestinationFolderId(requireSelection);
    }

    return getSelectedDestinationFolderId(
        atmosDestinationSelect,
        requireSelection,
        'Select an Atmos destination folder before downloading.'
    );
}

async function preloadAtmosDestinationForTracklist() {
    if (!tracklistIsAtmosView || atmosDestinationPrefilled) {
        return;
    }

    const downloader = window.DeezSpoTagDownload;
    if (!downloader) {
        return;
    }

    try {
        if (typeof downloader.ensureSettingsLoaded === 'function') {
            await downloader.ensureSettingsLoaded();
        }
        if (typeof downloader.ensureDestinationSelects === 'function') {
            await downloader.ensureDestinationSelects();
        }

        const multiQuality = downloader.settings?.multiQuality || {};
        tracklistMultiQualityEnabled = (multiQuality.enabled === true || multiQuality.Enabled === true)
            && (multiQuality.secondaryEnabled === true || multiQuality.SecondaryEnabled === true);
        refreshDestinationSelectorLayoutState();

        const atmosDefault = parseFolderId(multiQuality.secondaryDestinationFolderId ?? multiQuality.SecondaryDestinationFolderId);
        if (!tracklistMultiQualityEnabled) {
            if (setSelectValueIfAvailable(stereoDestinationSelect, atmosDefault)) {
                atmosDestinationPrefilled = true;
            }
            return;
        }

        let stereoDefault = parseFolderId(multiQuality.primaryDestinationFolderId ?? multiQuality.PrimaryDestinationFolderId);
        if (stereoDefault === null || String(stereoDefault) === String(atmosDefault ?? '')) {
            stereoDefault = chooseStereoDefaultFolderId(atmosDefault);
        }
        const stereoApplied = setSelectValueIfAvailable(stereoDestinationSelect, stereoDefault);
        const atmosApplied = setSelectValueIfAvailable(atmosDestinationSelect, atmosDefault);
        if (stereoApplied || atmosApplied) {
            atmosDestinationPrefilled = true;
        }
    } catch (error) {
        console.warn('Failed to preload Atmos destination folder for tracklist', error);
    }
}

function resetSpotifyState() {
    if (spotifyMatchTimer) {
        clearInterval(spotifyMatchTimer);
    }
    if (spotifyLazyTimer) {
        clearTimeout(spotifyLazyTimer);
    }
    if (boomplayLazyTimer) {
        clearTimeout(boomplayLazyTimer);
    }
    if (boomplayTracksEventSource) {
        boomplayTracksEventSource.close();
    }
    spotifyMatchTimer = null;
    spotifyLazyTimer = null;
    boomplayLazyTimer = null;
    boomplayTracksEventSource = null;
    spotifyLazyState = null;
    boomplayLazyState = null;
    spotifyMatchState = null;
    spotifyMatchCompletion = null;
    spotifyMatchFailureToastShown = false;
    externalMatchState = null;
    spotifyMatchCache.clear();
    spotifyRecommendationState = null;
    boomplayRecommendationState = null;
    librespotHydratedIds = new Set();
    externalBatchMatchSessionId += 1;
    if (externalBatchMatchTimer) {
        clearTimeout(externalBatchMatchTimer);
    }
    externalBatchMatchTimer = null;
    externalResolverScheduler.queueHigh.length = 0;
    externalResolverScheduler.queueLow.length = 0;
    updateSpotifyNotice();
}

async function loadTracklist() {
    try {
        console.log('Loading tracklist:', tracklistType, tracklistId);

        if (tracklistSource === 'mix') {
            await loadMixTracklist();
            return;
        }

        if (tracklistSource === 'radio') {
            await loadRadioTracklist();
            return;
        }

        if (tracklistSource === 'recommendations') {
            await loadRecommendationsTracklist();
            return;
        }

        if (tracklistSource === 'plex') {
            await loadPlexTracklist();
            return;
        }

        if (requestSource === 'spotify' || tracklistSource === 'spotify') {
            await loadSpotifyTracklist();
            return;
        }

        if (tracklistSource === 'apple') {
            await loadAppleTracklist();
            return;
        }

        if (tracklistSource === 'boomplay') {
            await loadBoomplayTracklist();
            return;
        }

        if (tracklistSource === 'youtube') {
            await loadYouTubeTracklist();
            return;
        }

        if (['soundcloud', 'tidal', 'qobuz', 'bandcamp', 'pandora'].includes((tracklistSource || '').toLowerCase())) {
            await loadExternalPlaylistTracklist();
            return;
        }

        const response = await fetch(`/api/tracklist?id=${tracklistId}&type=${tracklistType}`);
        
        if (!response.ok) {
            let errorMessage = `Failed to load tracklist (HTTP ${response.status})`;
            try {
                const errorPayload = await response.json();
                if (errorPayload && errorPayload.error) {
                    errorMessage = errorPayload.error;
                }
            } catch (parseError) {
                // Keep the default message when the response isn't JSON.
            }
            throw new Error(errorMessage);
        }
        
        const data = await response.json();
        console.log('Tracklist data received:', data);
        
        await loadIgnoredTracks();
        renderTracklist(data);
    } catch (error) {
        console.error('Error loading tracklist:', error);
        const message = error && error.message ? error.message : 'Failed to load tracklist';
        document.getElementById('tracklist-container').innerHTML = `<div class="error">${message}</div>`;
    }
}

async function loadBoomplayTracklist() {
    resetSpotifyState();
    if (tracklistType === 'playlist' || tracklistType === 'trending') {
        await loadBoomplayPlaylistTracklist();
        return;
    }

    const qs = new URLSearchParams();
    qs.set('type', tracklistType);
    qs.set('id', tracklistId);
    const response = await fetch(`/api/boomplay/tracklist?${qs.toString()}`);
    if (!response.ok) {
        throw new Error(`Failed to load Boomplay tracklist (HTTP ${response.status})`);
    }
    const payload = await response.json();
    if (!payload) {
        throw new Error('Boomplay tracklist unavailable.');
    }
    await loadIgnoredTracks();
    renderTracklist(payload);
}

async function loadYouTubeTracklist() {
    resetSpotifyState();

    const qs = new URLSearchParams();
    qs.set('type', tracklistType);
    qs.set('id', tracklistId);

    const response = await fetch(`/api/youtube/tracklist?${qs.toString()}`);
    if (!response.ok) {
        throw new Error(`Failed to load YouTube tracklist (HTTP ${response.status})`);
    }

    const payload = await response.json();
    if (!payload.available || !payload.tracklist) {
        throw new Error(payload.error || 'YouTube playlist unavailable.');
    }

    await loadIgnoredTracks();
    renderTracklist(payload.tracklist, { allowEmptyTracks: true });
}

function resolveExternalPlaylistUrl() {
    const explicit = String(tracklistExternalUrl || '').trim();
    if (explicit) {
        return explicit;
    }

    const fallback = String(tracklistId || '').trim();
    if (/^https?:\/\//i.test(fallback)) {
        return fallback;
    }

    return '';
}

async function loadExternalPlaylistTracklist() {
    resetSpotifyState();
    const normalizedSource = String(tracklistSource || '').trim().toLowerCase();
    const sourceUrl = resolveExternalPlaylistUrl();
    if (!sourceUrl) {
        throw new Error(`Missing ${normalizedSource || 'external'} playlist URL.`);
    }

    const qs = new URLSearchParams();
    qs.set('source', normalizedSource);
    qs.set('url', sourceUrl);
    if (tracklistType) {
        qs.set('type', tracklistType);
    }
    if (tracklistId) {
        qs.set('id', tracklistId);
    }

    const response = await fetch(`/api/external/playlist/tracklist?${qs.toString()}`);
    if (!response.ok) {
        throw new Error(`Failed to load external playlist tracklist (HTTP ${response.status})`);
    }

    const payload = await response.json();
    if (!payload.available || !payload.tracklist) {
        throw new Error(payload.error || 'External playlist unavailable.');
    }

    await loadIgnoredTracks();
    renderTracklist(payload.tracklist, { allowEmptyTracks: true });
}

async function loadBoomplayPlaylistTracklist() {
    const qs = new URLSearchParams();
    qs.set('type', tracklistType);
    qs.set('id', tracklistId);
    const response = await fetch(`/api/boomplay/playlist/metadata?${qs.toString()}`);
    if (!response.ok) {
        throw new Error(`Failed to load Boomplay playlist metadata (HTTP ${response.status})`);
    }
    const payload = await response.json();
    if (!payload.available || !payload.tracklist) {
        throw new Error('Boomplay playlist unavailable.');
    }

    renderTracklist(payload.tracklist, { allowEmptyTracks: true });
    await loadIgnoredTracks();
    applyIgnoredTrackState();
    bindIgnoreButtons();

    boomplayLazyState = {
        type: tracklistType,
        id: tracklistId,
        offset: 0,
        limit: 25,
        total: payload.tracklist.nb_tracks || 0,
        loaded: 0,
        hasMore: true,
        isLoading: false,
        backgroundLoading: false,
        consecutivePageErrors: 0
    };
    updateSpotifyNotice();

    const streamCompleted = await loadBoomplayPlaylistTracksStream();
    if (!streamCompleted && boomplayLazyState?.hasMore) {
        await loadBoomplayPlaylistTracksPage();
        scheduleBoomplayNextPage();
    }
}

function parseBoomplayStreamEventData(event) {
    try {
        return JSON.parse(event?.data || '{}');
    } catch {
        return null;
    }
}

function finalizeBoomplayExternalMatchState() {
    if (!externalMatchState || externalMatchState.source !== 'boomplay') {
        return;
    }

    externalMatchState.pending = Math.max(0, externalMatchState.pending || 0);
    externalMatchState.done = externalMatchState.pending === 0;
    updateSpotifyNotice();
    if (externalMatchState.done) {
        setTimeout(() => {
            if (externalMatchState?.source === 'boomplay' && externalMatchState.done) {
                externalMatchState = null;
                updateSpotifyNotice();
            }
        }, 3000);
    }
}

async function loadBoomplayPlaylistTracksStream() {
    if (!boomplayLazyState || typeof EventSource === 'undefined') {
        return false;
    }

    const remaining = Math.max(0, (boomplayLazyState.total || 0) - (boomplayLazyState.offset || 0));
    if (remaining === 0) {
        boomplayLazyState.hasMore = false;
        updateSpotifyNotice();
        return true;
    }

    return await new Promise((resolve) => {
        let settled = false;
        let receivedTracks = 0;
        const qs = new URLSearchParams();
        qs.set('type', boomplayLazyState.type);
        qs.set('id', boomplayLazyState.id);
        qs.set('offset', String(boomplayLazyState.offset));
        qs.set('limit', String(remaining));
        if (boomplayDeezerSimilarMode) {
            qs.set('resolveDeezer', 'true');
        }

        const eventSource = new EventSource(`/api/boomplay/playlist/tracks/stream?${qs.toString()}`);
        boomplayTracksEventSource = eventSource;
        boomplayLazyState.isLoading = true;
        boomplayLazyState.backgroundLoading = true;
        updateSpotifyNotice();

        const closeAndResolve = (ok) => {
            if (settled) {
                return;
            }

            settled = true;
            if (boomplayTracksEventSource === eventSource) {
                boomplayTracksEventSource = null;
            }
            eventSource.close();

            if (boomplayLazyState) {
                boomplayLazyState.isLoading = false;
                boomplayLazyState.backgroundLoading = false;
            }
            updateSpotifyNotice();
            resolve(ok);
        };

        eventSource.addEventListener('track', (event) => {
            const payload = parseBoomplayStreamEventData(event);
            if (!payload || !payload.track) {
                return;
            }

            receivedTracks += 1;
            const appendedTracks = appendBoomplayTrackRows([payload.track]);
            if (appendedTracks.length > 0) {
                void resolveExternalTracklistMatches(appendedTracks, 'boomplay', {
                    incremental: true,
                    finalize: false
                }).catch((error) => console.warn('Boomplay stream match failed', error));
            }

            if (boomplayLazyState) {
                if (typeof payload.total === 'number') {
                    boomplayLazyState.total = payload.total;
                }
                if (typeof payload.nextOffset === 'number') {
                    boomplayLazyState.offset = payload.nextOffset;
                    boomplayLazyState.loaded = payload.nextOffset;
                } else if (typeof payload.loaded === 'number') {
                    boomplayLazyState.loaded = payload.loaded;
                }
                if (typeof payload.hasMore === 'boolean') {
                    boomplayLazyState.hasMore = payload.hasMore;
                }
            }

            updateSpotifyNotice();
        });

        eventSource.addEventListener('complete', (event) => {
            const payload = parseBoomplayStreamEventData(event);
            if (boomplayLazyState && payload) {
                if (typeof payload.total === 'number') {
                    boomplayLazyState.total = payload.total;
                }
                if (typeof payload.nextOffset === 'number') {
                    boomplayLazyState.offset = payload.nextOffset;
                    boomplayLazyState.loaded = payload.nextOffset;
                }
                if (typeof payload.hasMore === 'boolean') {
                    boomplayLazyState.hasMore = payload.hasMore;
                } else {
                    boomplayLazyState.hasMore = false;
                }
            }

            if (boomplayLazyState && !boomplayLazyState.hasMore && (boomplayLazyState.loaded || 0) === 0) {
                setTracksEmptyMessage('No tracks available');
            }
            finalizeBoomplayExternalMatchState();
            closeAndResolve(true);
        });

        eventSource.addEventListener('error', () => {
            if (boomplayLazyState) {
                const total = boomplayLazyState.total || 0;
                const loaded = boomplayLazyState.loaded || 0;
                boomplayLazyState.hasMore = total > 0 ? loaded < total : false;
            }

            // Fall back to paged loading if stream drops before completion.
            const shouldFallback = !!(boomplayLazyState && boomplayLazyState.hasMore);
            if (!shouldFallback) {
                finalizeBoomplayExternalMatchState();
            }
            closeAndResolve(!shouldFallback && receivedTracks > 0);
        });
    });
}

async function loadBoomplayPlaylistTracksPage() {
    if (!boomplayLazyState || boomplayLazyState.isLoading || !boomplayLazyState.hasMore) {
        return;
    }

    boomplayLazyState.isLoading = true;
    updateSpotifyNotice();
    try {
        const qs = new URLSearchParams();
        qs.set('type', boomplayLazyState.type);
        qs.set('id', boomplayLazyState.id);
        qs.set('offset', String(boomplayLazyState.offset));
        qs.set('limit', String(boomplayLazyState.limit));
        if (boomplayDeezerSimilarMode) {
            qs.set('resolveDeezer', 'true');
        }

        const response = await fetch(`/api/boomplay/playlist/tracks?${qs.toString()}`);
        if (!response.ok) {
            throw new Error(`Failed to load Boomplay playlist tracks (HTTP ${response.status})`);
        }
        const payload = await response.json();
        if (!payload.available) {
            throw new Error('Boomplay playlist tracks unavailable.');
        }

        const tracks = Array.isArray(payload.tracks) ? payload.tracks : [];
        const appendedTracks = appendBoomplayTrackRows(tracks);
        if (appendedTracks.length > 0) {
            void resolveExternalTracklistMatches(appendedTracks, 'boomplay', {
                incremental: true,
                finalize: !payload.hasMore
            }).catch((error) => console.warn('Boomplay match batch failed', error));
        }

        const nextOffset = typeof payload.nextOffset === 'number'
            ? payload.nextOffset
            : ((payload.offset || 0) + tracks.length);
        boomplayLazyState.offset = nextOffset;
        boomplayLazyState.total = typeof payload.total === 'number' ? payload.total : boomplayLazyState.total;
        boomplayLazyState.loaded = nextOffset;
        boomplayLazyState.hasMore = !!payload.hasMore;
        boomplayLazyState.consecutivePageErrors = 0;

        if (!boomplayLazyState.hasMore && boomplayLazyState.loaded === 0) {
            setTracksEmptyMessage('No tracks available');
        }
    } finally {
        if (boomplayLazyState) {
            boomplayLazyState.isLoading = false;
        }
        updateSpotifyNotice();
    }
}

function scheduleBoomplayNextPage() {
    if (!boomplayLazyState || boomplayLazyState.backgroundLoading || !boomplayLazyState.hasMore) {
        return;
    }
    if (boomplayLazyTimer) {
        return;
    }

    boomplayLazyTimer = setTimeout(async () => {
        boomplayLazyTimer = null;
        if (!boomplayLazyState || boomplayLazyState.isLoading || !boomplayLazyState.hasMore) {
            return;
        }

        boomplayLazyState.backgroundLoading = true;
        try {
            await loadBoomplayPlaylistTracksPage();
        } catch (error) {
            console.warn('Boomplay playlist paging failed', error);
            if (boomplayLazyState) {
                const message = String(error?.message || error || '').toLowerCase();
                const transient = message.includes('network') || message.includes('fetch') || message.includes('timeout');
                const count = (boomplayLazyState.consecutivePageErrors || 0) + 1;
                boomplayLazyState.consecutivePageErrors = count;
                if (!transient || count >= 5) {
                    boomplayLazyState.hasMore = false;
                }
            }
        } finally {
            if (boomplayLazyState) {
                boomplayLazyState.backgroundLoading = false;
            }
            updateSpotifyNotice();
            if (boomplayLazyState && boomplayLazyState.hasMore) {
                const delayMs = boomplayLazyState.consecutivePageErrors > 0
                    ? Math.min(8000, 500 * Math.pow(2, boomplayLazyState.consecutivePageErrors - 1))
                    : 0;
                if (delayMs > 0) {
                    boomplayLazyTimer = setTimeout(() => {
                        boomplayLazyTimer = null;
                        scheduleBoomplayNextPage();
                    }, delayMs);
                } else {
                    scheduleBoomplayNextPage();
                }
            }
        }
    }, 0);
}

async function loadMixTracklist() {
    if (!tracklistLibraryId) {
        throw new Error('Library is required for mix tracklist.');
    }
    const response = await fetch(`/api/mixes/${encodeURIComponent(tracklistId)}?libraryId=${encodeURIComponent(tracklistLibraryId)}`);
    if (!response.ok) {
        throw new Error(`Failed to load mix tracklist (HTTP ${response.status})`);
    }
    const payload = await response.json();
    if (!payload?.summary) {
        throw new Error('Mix tracklist unavailable.');
    }
    const mapped = mapMixTracklist(payload);
    await loadIgnoredTracks();
    renderTracklist(mapped);
}

function mapMixTracklist(payload) {
    const tracks = mapLibraryStyleTracks(payload.tracks);

    return {
        title: payload.summary?.name || 'Mix',
        description: payload.summary?.description || '',
        creator: { name: 'Auto Mix' },
        nb_tracks: payload.summary?.trackCount || tracks.length,
        tracks
    };
}

async function loadRadioTracklist() {
    if (!tracklistLibraryId) {
        throw new Error('Library is required for radio stations.');
    }
    if (!radioType) {
        throw new Error('Radio type is required.');
    }
    const params = new URLSearchParams({
        type: radioType,
        libraryId: tracklistLibraryId
    });
    if (radioValue) {
        params.set('value', radioValue);
    }
    const response = await fetch(`/api/library/radio?${params.toString()}`);
    if (!response.ok) {
        throw new Error(`Failed to load radio station (HTTP ${response.status})`);
    }
    const payload = await response.json();
    if (!payload?.station || !Array.isArray(payload.tracks)) {
        throw new Error('Radio station unavailable.');
    }
    const mapped = mapRadioTracklist(payload);
    await loadIgnoredTracks();
    renderTracklist(mapped);
}

function mapRadioTracklist(payload) {
    const tracks = mapLibraryStyleTracks(payload.tracks);

    return {
        title: payload.station?.name || 'Radio Station',
        description: payload.station?.description || '',
        creator: { name: 'Radio' },
        nb_tracks: tracks.length,
        tracks
    };
}

function normalizeCoverUrl(value) {
    if (typeof value !== 'string') {
        return '';
    }

    const trimmed = value.trim();
    if (!trimmed) {
        return '';
    }

    if (/^https?:\/\//i.test(trimmed) || /^data:image\//i.test(trimmed) || trimmed.startsWith('/')) {
        return trimmed;
    }

    if (trimmed.startsWith('//')) {
        return `https:${trimmed}`;
    }

    return '';
}

function mapLibraryStyleTracks(tracks) {
    return (tracks || []).map((track, index) => ({
        id: track.trackId || '',
        title: track.title || 'Unknown',
        artist: { name: track.artistName || 'Unknown', id: '' },
        album: { title: track.albumTitle || 'Unknown', cover_medium: normalizeCoverUrl(track.coverPath || '') },
        duration: track.durationMs ? Math.round(track.durationMs / 1000) : 0,
        preview: '',
        track_position: index + 1
    }));
}

