function resolvePlatformAuthBinding(url, bindings) {
    return Object.entries(bindings || {}).find(([, binding]) => url.includes(binding.matches)) || null;
}

function applyPlatformAuthState(url, data, payload, statusElementId, isConnected) {
    const bindings = {
        discogs: {
            matches: '/discogs',
            render: info => renderDiscogsInfo(info || {})
        },
        lastfm: {
            matches: '/lastfm',
            render: (info, rawPayload, connected, elementId) => {
                const hasLastFmApiKey = Boolean(info?.hasApiKey ?? connected);
                setStatus(elementId, hasLastFmApiKey);
                renderLastFmInfo(info || { username: rawPayload?.username || '', hasApiKey: hasLastFmApiKey });
                return hasLastFmApiKey;
            }
        },
        bpm: {
            matches: '/bpmsupreme',
            render: info => renderBpmInfo(info || {})
        },
        plex: {
            matches: '/plex',
            render: info => renderPlexInfo(info || {})
        },
        jellyfin: {
            matches: '/jellyfin',
            render: info => renderJellyfinInfo(info || {})
        },
        appleMusic: {
            matches: '/applemusic',
            render: info => renderAppleMusicInfo(info || {})
        }
    };

    setStatus(statusElementId, isConnected);
    const entry = resolvePlatformAuthBinding(url, bindings);
    if (!entry) {
        return;
    }

    const [platform, binding] = entry;
    const payloadForRender =
        platform === 'discogs' ? data?.discogs || payload :
        platform === 'lastfm' ? data?.lastFm :
        platform === 'bpm' ? data?.bpmSupreme || payload :
        platform === 'plex' ? data?.plex || payload :
        platform === 'jellyfin' ? data?.jellyfin || payload :
        data?.appleMusic || payload;
    const effectiveConnected = binding.render(payloadForRender, payload, isConnected, statusElementId) ?? isConnected;
    togglePlatformLoginState(platform, effectiveConnected);
}

function applyPlatformDisconnectState(url, statusElementId, bindings) {
    setStatus(statusElementId, false);
    const entry = resolvePlatformAuthBinding(url, bindings);
    if (!entry) {
        return;
    }

    const [platform, binding] = entry;
    binding.clear?.();
    binding.render?.({});
    togglePlatformLoginState(platform, false);
}

