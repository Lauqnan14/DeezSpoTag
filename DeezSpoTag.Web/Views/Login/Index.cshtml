function clearStoredLoginState() {
    localStorage.removeItem('arl');
    localStorage.removeItem('loginUser');
    showLoginForm();
}

function finalizeLoginSuccess(data, successMessage, credentialValue = null) {
    showToast(successMessage, 'success');
    if (credentialValue) {
        localStorage.setItem('arl', credentialValue);
    }

    localStorage.setItem('loginUser', JSON.stringify(data.user));
    showLoggedInInfo(data.user);
}

function handleLoginResponse(data, options = {}) {
    const {
        successMessage = 'Login successful!',
        failureMessage = 'Login failed.',
        credentialValue = null
    } = options;

    switch (data.status) {
        case 1:
        case 3:
            console.log('Login successful!');
            finalizeLoginSuccess(data, successMessage, credentialValue);
            return;
        case 2:
            console.log('Already logged in');
            finalizeLoginSuccess(data, 'Already logged in', credentialValue);
            return;
        case 0:
            console.log('Login failed');
            showToast(failureMessage, 'error');
            clearStoredLoginState();
            return;
        case -1:
            console.log('Deezer not available');
            showToast('Deezer is not available. Try again later.', 'error');
            clearStoredLoginState();
            return;
        default:
            console.log('Unknown status:', data.status);
            showToast(`Unknown login status: ${data.status}`, 'error');
            clearStoredLoginState();
            return;
    }
}

async function submitLoginRequest(url, payload, options = {}) {
    showToast('Logging in...', 'info');

    try {
        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        });

        if (!response.ok) {
            showToast(`Server error: ${response.status}`, 'error');
            return;
        }

        const data = await response.json();
        handleLoginResponse(data, options);
    } catch (error) {
        console.error('Login error:', error);
        showToast('Network error. Please check your connection.', 'error');
    }
}

