async function loadAppleMusicSettings() {
    try {
        const response = await fetch('/api/settings');
        if (!response.ok) {
            throw new Error(`status ${response.status}`);
        }
        const data = await response.json();
        appleMusicSettingsCache = data?.settings || {};
        const apple = appleMusicSettingsCache.appleMusic || {};
        setAppleMusicTokenFieldValue('appleStorefront', apple.storefront || 'us');
        setAppleMusicTokenFieldValue('appleMediaUserToken', apple.mediaUserToken || '');
    } catch (error) {
        console.warn('Failed to load Apple Music settings', error);
        setAppleMusicTokensStatus('Unable to load Apple Music tokens', 'error');
    }
}

async function saveAppleMusicSettings() {
    const saveBtn = document.getElementById('appleMusicTokensSaveBtn');
    if (saveBtn) {
        saveBtn.disabled = true;
    }
    setAppleMusicTokensStatus('Saving...', 'info');
    try {
        if (!appleMusicSettingsCache) {
            await loadAppleMusicSettings();
        }
        if (!appleMusicSettingsCache) {
            throw new Error('Settings not loaded');
        }

        const storefront = document.getElementById('appleStorefront')?.value.trim() || 'us';
        const mediaUserToken = document.getElementById('appleMediaUserToken')?.value.trim() || '';
        const payload = {
            appleMusic: {
                storefront,
                mediaUserToken
            }
        };

        const response = await fetch('/api/settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const result = await response.json();
        if (!response.ok || !result?.result) {
            throw new Error(result?.error || `status ${response.status}`);
        }

        appleMusicSettingsCache = {
            ...(appleMusicSettingsCache || {}),
            appleMusic: {
                ...(appleMusicSettingsCache?.appleMusic || {}),
                storefront,
                mediaUserToken
            }
        };
        setAppleMusicTokensStatus('Saved', 'success');
        showToast('Apple Music tokens saved', 'success');
    } catch (error) {
        console.error('Failed to save Apple Music settings', error);
        setAppleMusicTokensStatus('Save failed', 'error');
        showToast('Failed to save Apple Music tokens', 'error');
    } finally {
        if (saveBtn) {
            saveBtn.disabled = false;
        }
    }
}

