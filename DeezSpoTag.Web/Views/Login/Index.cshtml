}

function handleAppleMusicStatus(data) {
    if (!data) return;
    const rawStatus = data.status ?? '';
    const status = typeof rawStatus === 'string' ? rawStatus.toLowerCase() : String(rawStatus);
    const message = data.message || '';
    const email = data.email || '';
    const wrapperReady = Boolean(data.wrapperReady);
    const diagnostics = data.diagnostics || null;
    const diagnosticMessage = diagnostics?.message || '';
    appleMusicExternalMode = Boolean(data.externalMode);
    const wrapperAvailable = diagnostics ? Boolean(diagnostics.portsOpen) : true;
    applyAppleMusicWrapperAvailability(wrapperAvailable);
    const needs2fa = Boolean(data.needsTwoFactor) || status === 'waitingfortwofactor';
    const hasExplicitSuccess = status === 'success' || wrapperReady;
    const loginAttemptPending = appleMusicLoginRequestPending && appleMusicLoginInProgress;
    const loginFlowActive = appleMusicLoginInProgress || appleMusic2faSubmitting || loginAttemptPending;
    const inProgress = status === 'starting' || (status === 'waitingfortwofactor' && loginFlowActive) || loginAttemptPending || appleMusic2faSubmitting;
    const twoFactorRequired = needs2fa;
    const isAuthenticated = Boolean(wrapperReady) && !twoFactorRequired;
    const isSuccess = (hasExplicitSuccess || wrapperReady) && !twoFactorRequired;
    const waitingFor2fa = twoFactorRequired && !isAuthenticated && loginFlowActive;
    const backendWaitingFor2fa = twoFactorRequired && !isAuthenticated;
    const show2fa = waitingFor2fa;
    const syncSignature = `${status}|${wrapperReady ? '1' : '0'}|${needs2fa ? '1' : '0'}|${wrapperAvailable ? '1' : '0'}|${email || ''}`;
    if (syncSignature !== appleMusicLastSyncSignature) {
        appleMusicLastSyncSignature = syncSignature;
        queueConnectedPlatformsRefresh();
    }
    if (needs2fa || appleMusicLoginInProgress || appleMusic2faSubmitting) {
        togglePlatformLoginState('appleMusic', false);
    }

    let effectiveMessage = message;
    if (!wrapperAvailable) {
        if (diagnosticMessage) {
            effectiveMessage = diagnosticMessage;
        } else if (appleMusicExternalMode && !appleMusicLoginInProgress && !appleMusic2faSubmitting) {
            effectiveMessage = 'Wrapper will start on login. Enter your credentials to continue.';
        } else {
            effectiveMessage = 'Wrapper is not ready. Start the Apple Music wrapper to continue.';
        }
    } else if (waitingFor2fa) {
        const normalizedMessage = message.toLowerCase();
        const submittedHint = normalizedMessage.includes('verification code submitted')
            ? 'Verification code submitted. Waiting for wrapper confirmation.'
            : null;
        effectiveMessage = submittedHint || 'Waiting for two-factor verification code.';
    } else if (backendWaitingFor2fa && !loginFlowActive) {
        effectiveMessage = 'A previous Apple Music 2FA challenge is pending. Click Login to start a fresh session.';
    } else if (loginAttemptPending) {
        effectiveMessage = 'Submitting login request...';
    } else if (isSuccess) {
        effectiveMessage = 'Login successful.';
    } else if (status === 'failed') {
        effectiveMessage = message || 'Login failed.';
    } else if (status === 'starting') {
        effectiveMessage = 'Starting wrapper login...';
    } else if (status === 'running') {
        effectiveMessage = message || 'Wrapper is running. Enter your credentials to login.';
    } else if (!isSuccess && diagnosticMessage) {
        effectiveMessage = diagnosticMessage;
    }

    setAppleMusicLoginState(effectiveMessage);
    if (loginAttemptPending) {
        setAppleMusicConnectionText('In progress');
    } else if (isAuthenticated) {
        setAppleMusicConnectionText('Connected');
    } else if (waitingFor2fa || appleMusicLoginInProgress) {
        setAppleMusicConnectionText('In progress');
    } else if (!wrapperAvailable && !appleMusicExternalMode) {
        setAppleMusicConnectionText('Wrapper not ready');
    } else {
        setAppleMusicConnectionText('Not connected');
    }

    if (isSuccess && appleMusicLoginInProgress && !loginAttemptPending) {
        // Only switch to logged-in state during active login, not on page load status check
        appleMusicLoginInProgress = false;
        appleMusic2faSubmitting = false;
        appleMusicLoginRequestPending = false;
        stopAppleMusicStatusPolling();
        setAppleMusicCredentialsEnabled(true);
        setAppleMusicLoginEnabled(true);
        showAppleMusic2fa(false);
        setAppleMusic2faEnabled(false, 'Login successful. 2FA not required for this session.');
        setAppleMusicLoggedInStatus('Login successful.');
        setStatus('appleMusicStatus', true);
        renderAppleMusicInfo({ email: email, wrapperReady: true });
        togglePlatformLoginState('appleMusic', true);
        document.getElementById('appleMusic2fa').value = '';
        showToast('Apple Music verified', 'success');
        refreshConnectedPlatformsSidebar();
    } else if (isAuthenticated && !appleMusicLoginInProgress && !appleMusic2faSubmitting && !loginAttemptPending) {
        appleMusicLoginInProgress = false;
        appleMusic2faSubmitting = false;
        appleMusicLoginRequestPending = false;
        stopAppleMusicStatusPolling();
        setAppleMusicCredentialsEnabled(true);
        setAppleMusicLoginEnabled(true);
        showAppleMusic2fa(false);
        setAppleMusic2faEnabled(false, '');
        setAppleMusicLoggedInStatus('Login successful.');
        setStatus('appleMusicStatus', true);
        renderAppleMusicInfo({ email: email, wrapperReady: true });
        togglePlatformLoginState('appleMusic', true);
    } else if (show2fa) {
        appleMusicLoginRequestPending = false;
        showAppleMusic2fa(true);
        const normalizedMessage = (message || '').toLowerCase();
        const submittedHint = normalizedMessage.includes('verification code submitted')
            ? 'Verification code submitted. Waiting for wrapper confirmation.'
            : null;
        const hint = submittedHint || 'Enter the verification code from Apple.';
        setAppleMusicCredentialsEnabled(false);
        setAppleMusicLoginEnabled(false);
        setAppleMusic2faEnabled(!appleMusic2faSubmitting, hint);
        setAppleMusicLoggedInStatus('');
    } else if (status === 'failed') {
        setStatus('appleMusicStatus', false);
        togglePlatformLoginState('appleMusic', false);
        setAppleMusicLoggedInStatus(message || 'Login failed.');
        if (message && appleMusicLoginInProgress) {
            showToast(message, 'error');
        }
        appleMusicLoginInProgress = false;
        appleMusic2faSubmitting = false;
        appleMusicLoginRequestPending = false;
        setAppleMusicCredentialsEnabled(true);
        setAppleMusicLoginEnabled(true);
        stopAppleMusicStatusPolling();
        refreshConnectedPlatformsSidebar();
    } else if (status === 'stopped') {
        setStatus('appleMusicStatus', false);
        togglePlatformLoginState('appleMusic', false);
        setAppleMusicLoginState(message || 'Timed out. Please click Login again.');
        appleMusicLoginInProgress = false;
        appleMusic2faSubmitting = false;
        appleMusicLoginRequestPending = false;
        setAppleMusicCredentialsEnabled(true);
        setAppleMusicLoginEnabled(true);
        stopAppleMusicStatusPolling();
        refreshConnectedPlatformsSidebar();
    } else if (status === 'missing') {
        // Wrapper not running - show message but keep login form visible
        setAppleMusicCredentialsEnabled(!appleMusicExternalMode ? false : true);
        setAppleMusicLoginEnabled(!appleMusicExternalMode ? false : true);
        if (!appleMusicLoginInProgress && !appleMusic2faSubmitting) {
            hideAppleMusic2fa();
            appleMusicLoginRequestPending = false;
        }
    } else {
        // In progress or running - update state but don't switch UI unless actively logging in
        appleMusicLoginInProgress = inProgress && appleMusicLoginInProgress;
        appleMusic2faSubmitting = false;
        setAppleMusicCredentialsEnabled(!appleMusicLoginInProgress);
        setAppleMusicLoginEnabled(!appleMusicLoginInProgress);
        if (!appleMusicLoginInProgress) {
            hideAppleMusic2fa();
            setStatus('appleMusicStatus', false);
            togglePlatformLoginState('appleMusic', false);
            setAppleMusicLoggedInStatus('');
        }
        setAppleMusic2faEnabled(true, '');
        if (!inProgress && !appleMusicLoginInProgress) {
            appleMusicLoginRequestPending = false;
            stopAppleMusicStatusPolling();
        }
    }
}

