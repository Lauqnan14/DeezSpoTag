let appleMusicLoginInProgress = false;
let appleMusic2faSubmitting = false;
let appleMusicStatusPoll = null;
let appleMusicPassiveStatusPoll = null;
let appleMusicWrapperAvailable = true;
let appleMusicExternalMode = false;
let appleMusicLoginRequestPending = false;
let appleMusicStatusRequestInFlight = false;
let appleMusicLastSyncSignature = '';

function applyAppleMusicWrapperAvailability(available) {
    appleMusicWrapperAvailable = available;
    const ids = [
        'appleMusicEmail',
        'appleMusicPassword',
        'appleMusicLoginBtn',
        'appleMusic2fa',
        'appleMusicSubmit2faBtn'
    ];
    ids.forEach((id) => {
        const el = document.getElementById(id);
        if (el) {
            if (appleMusicExternalMode && (id === 'appleMusicEmail' || id === 'appleMusicPassword' || id === 'appleMusicLoginBtn')) {
                el.disabled = false;
            } else {
                el.disabled = !available;
            }
        }
    });
    if (!available) {
        showAppleMusic2fa(false);
    }
    setAppleMusicWrapperModeHint();
}

function setAppleMusicWrapperModeHint() {
    const hint = document.getElementById('appleMusicWrapperModeHint');
    if (!hint) {
        return;
    }
    hint.textContent = 'This login uses the external Apple wrapper container. It will be started automatically when you click Login.';
}

async function startAppleMusicLogin() {
    if (!appleMusicWrapperAvailable && !appleMusicExternalMode) {
        showToast('Wrapper is not ready. Start the Apple Music wrapper and try again.', 'warning');
        return;
    }
    if (!appleMusicWrapperAvailable && appleMusicExternalMode) {
        showToast('Wrapper is not ready yet. Login will start it automatically.', 'info');
    }
    const email = document.getElementById('appleMusicEmail').value.trim();
    const password = document.getElementById('appleMusicPassword').value.trim();
    if (!email || !password) {
        showToast('Email and password are required', 'warning');
        return;
    }

    appleMusicLoginInProgress = true;
    appleMusic2faSubmitting = false;
    appleMusicLoginRequestPending = true;
    togglePlatformLoginState('appleMusic', false);
    setAppleMusicLoginState('Logging in...');
    setAppleMusicCredentialsEnabled(false);
    setAppleMusicLoginEnabled(false);
    showAppleMusic2fa(false);
    setAppleMusic2faEnabled(false, '');
    document.getElementById('appleMusic2fa').value = '';
    beginAppleMusicStatusPolling();

    try {
        const response = await fetch('/api/apple-music/wrapper-ref/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        if (!response.ok) {
            const message = await response.text();
            showToast(message || 'Apple Music login failed', 'error');
            setAppleMusicLoginState(message || 'Login failed');
            appleMusicLoginInProgress = false;
            appleMusic2faSubmitting = false;
            appleMusicLoginRequestPending = false;
            setAppleMusicCredentialsEnabled(true);
            setAppleMusicLoginEnabled(true);
            stopAppleMusicStatusPolling();
            return;
        }
        const data = await response.json();
        appleMusicLoginRequestPending = false;
        handleAppleMusicStatus(data);
    } catch (error) {
        console.error('Apple Music login error:', error);
        showToast('Network error while starting Apple Music login', 'error');
        setAppleMusicLoginState('Network error');
        setAppleMusicCredentialsEnabled(true);
        setAppleMusicLoginEnabled(true);
        appleMusicLoginInProgress = false;
        appleMusicLoginRequestPending = false;
    } finally {
        document.getElementById('appleMusicPassword').value = '';
    }
}

async function submitAppleMusic2fa() {
    const code = document.getElementById('appleMusic2fa').value.trim();
    if (!code) {
        showToast('Enter the verification code', 'warning');
        return;
    }

    appleMusicLoginInProgress = true;
    appleMusic2faSubmitting = true;
    appleMusicLoginRequestPending = false;
    setAppleMusicLoginState('Verifying code...');
    setAppleMusic2faEnabled(false, 'Verifying code...');
    setAppleMusicLoginEnabled(false);
    setAppleMusicCredentialsEnabled(false);
    beginAppleMusicStatusPolling();

    try {
        const response = await fetch('/api/apple-music/wrapper-ref/2fa', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code })
        });
        if (!response.ok) {
            const message = await response.text();
            showToast(message || 'Verification failed', 'error');
            setAppleMusicLoginState(message || 'Verification failed');
            return;
        }
        const data = await response.json();
        handleAppleMusicStatus(data);
    } catch (error) {
        console.error('Apple Music 2FA error:', error);
        showToast('Network error while submitting code', 'error');
        setAppleMusicLoginState('Network error');
        setAppleMusic2faEnabled(true, 'Enter the verification code from Apple.');
        setAppleMusicCredentialsEnabled(true);
        setAppleMusicLoginEnabled(true);
    } finally {
        // Keep polling active, but allow users to retry/resubmit if wrapper remains in waiting state.
        appleMusic2faSubmitting = false;
    }
}

async function refreshAppleMusicWrapperStatus() {
    if (!appleMusicBootstrapRequested && !appleMusicLoginInProgress && !appleMusic2faSubmitting && !appleMusicLoginRequestPending) {
        return;
    }
    if (appleMusicStatusRequestInFlight) {
        return;
    }
    appleMusicStatusRequestInFlight = true;
    try {
        const response = await fetch('/api/apple-music/wrapper-ref/status', {
            cache: 'no-store',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
        });
        if (!response.ok) {
            return;
        }
        const data = await response.json();
        handleAppleMusicStatus(data);
    } catch (error) {
        console.warn('Apple Music status check failed', error);
    } finally {
        appleMusicStatusRequestInFlight = false;
    }
}

async function checkAppleMusicWrapperHelperStatus() {
    const outputEl = document.getElementById('appleMusicWrapperHelperOutput');
    if (outputEl) {
        outputEl.textContent = 'Checking wrapper helper...';
    }
    try {
        const response = await fetch('/api/apple-music/wrapper-ref/helper/status');
        if (!response.ok) {
            const message = await response.text();
            if (outputEl) {
                outputEl.textContent = message || 'Wrapper helper status failed.';
            }
            showToast(message || 'Wrapper helper status failed', 'error');
            return;
        }
        const data = await response.json();
        const lines = [];
        if (data.helperPath) {
            lines.push(`Helper: ${data.helperPath}`);
        }
        lines.push(`Exit code: ${data.exitCode}`);
        if (data.output) {
            lines.push(data.output.trim());
        }
        if (data.error) {
            lines.push(`Error: ${data.error.trim()}`);
        }
        if (outputEl) {
            outputEl.textContent = lines.filter(Boolean).join('\n');
        }
        showToast(data.success ? 'Wrapper helper responded.' : 'Wrapper helper returned an error.', data.success ? 'success' : 'error');
    } catch (error) {
        console.error('Wrapper helper status error', error);
        if (outputEl) {
            outputEl.textContent = 'Wrapper helper status failed.';
        }
        showToast('Wrapper helper status failed', 'error');
    }
}

async function checkAppleMusicWrapperHealth() {
    const outputEl = document.getElementById('appleMusicWrapperHealthOutput');
    if (outputEl) {
