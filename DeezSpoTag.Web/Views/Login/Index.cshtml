async function generateSpotifyBlob() {
    const name = document.getElementById('spotifyAccountName').value.trim();
    const region = document.getElementById('spotifyAccountRegion').value.trim();
    if (!name) {
        showToast('Account name is required', 'error');
        return;
    }

    try {
        const response = await fetch(`/api/spotify-credentials/accounts/${encodeURIComponent(name)}/generate`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
                'Content-Type': 'application/json',
                Accept: 'application/json'
            },
            body: JSON.stringify({ region })
        });

        if (isAuthRedirectResponse(response)) {
            showToast('Login required to generate Spotify credentials', 'error');
            return;
        }

        if (!response.ok) {
            const message = await getApiErrorMessage(response, 'Failed to generate Spotify credentials');
            showToast(message, 'error');
            return;
        }

        showToast('Spotify credentials generated', 'success');
        await loadSpotifyConfig();
    } catch (error) {
        console.error('Spotify credentials generation error:', error);
        showToast('Network error generating Spotify credentials', 'error');
    }
}

async function loadSpotifyConfig() {
    const loadSequence = ++spotifyConfigLoadSequence;
    try {
        const apiCredentialsTask = loadSpotifyApiCredentials();
        const accountsResponse = await fetch('/api/spotify-credentials/accounts', {
            cache: 'no-store',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
        });

        if (!accountsResponse.ok) {
            await apiCredentialsTask;
            if (loadSequence !== spotifyConfigLoadSequence) {
                return;
            }
            setStatus('spotifyStatus', false);
            localStorage.removeItem('spotifyAccount');
            toggleSpotifyLoginState(false);
            return;
        }

        const data = await accountsResponse.json();
        const accounts = Array.isArray(data.accounts) ? data.accounts : [];
        const activeAccountName = typeof data.activeAccount === 'string' ? data.activeAccount : '';
        const active = accounts.find(account => account.name && account.name.toLowerCase() === activeAccountName.toLowerCase());
        const accountHasBlob = Boolean(active?.blobPath || active?.librespotBlobPath || active?.webPlayerBlobPath);
        const provisionalConnected = Boolean(active && accountHasBlob);
        applySpotifyConnectionUiState(data, active, activeAccountName, provisionalConnected);
        queueConnectedPlatformsRefresh();

        void refreshSpotifyConnectionStatus(data, active, activeAccountName, accountHasBlob, loadSequence);
        await apiCredentialsTask;
        if (loadSequence !== spotifyConfigLoadSequence) {
            return;
        }
        queueConnectedPlatformsRefresh();
    } catch (error) {
        if (loadSequence !== spotifyConfigLoadSequence) {
            return;
        }
        console.warn('Failed to load Spotify config', error);
        setStatus('spotifyStatus', false);
        localStorage.removeItem('spotifyAccount');
        toggleSpotifyLoginState(false);
    }
}

function applySpotifyConnectionUiState(data, active, activeAccountName, isConnected) {
    const showLoggedIn = Boolean(isConnected);
    setStatus('spotifyStatus', showLoggedIn);
    if (showLoggedIn) {
        const accountName = active?.name || activeAccountName || 'Spotify';
        const region = active?.region || 'UL';
        const plan = data?.activeAccountPlan ? capitalizeSpotifyPlan(data.activeAccountPlan) : 'Unknown';
        document.getElementById('spotifyLoggedInName').textContent = accountName;
        document.getElementById('spotifyLoggedInPlanLocation').textContent = `${plan} | ${region || 'UL'}`;
        const picture = document.getElementById('spotifyLoggedInPicture');
        if (picture) {
            picture.src = getPlatformIcon('spotify');
        }
        localStorage.setItem('spotifyAccount', accountName);
    } else {
        localStorage.removeItem('spotifyAccount');
    }
    toggleSpotifyLoginState(showLoggedIn);
}

async function refreshSpotifyConnectionStatus(data, active, activeAccountName, accountHasBlob, loadSequence) {
    try {
        const response = await fetchWithTimeout('/api/spotify-credentials/status', {
            cache: 'no-store',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
        }, 4500);

        if (!response || !response.ok) {
            return;
        }

        const connectionStatus = await response.json();
        if (loadSequence !== spotifyConfigLoadSequence) {
            return;
        }

        const isConnected = Boolean(
            connectionStatus &&
            connectionStatus.ok === true &&
            active &&
            accountHasBlob
        );
        applySpotifyConnectionUiState(data, active, activeAccountName, isConnected);
        queueConnectedPlatformsRefresh();
    } catch (error) {
        console.warn('Spotify status probe timed out or failed; keeping provisional UI state', error);
    }
}

async function fetchWithTimeout(url, options = {}, timeoutMs = 5000) {
    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), timeoutMs);
    try {
        return await fetch(url, { ...options, signal: controller.signal });
    } finally {
        window.clearTimeout(timeoutId);
    }
}

async function loadSpotifyApiCredentials() {
    const statusEl = document.getElementById('spotifyApiCredentialsStatus');
    try {
        const response = await fetch('/api/spotify-credentials/web-player/status');
        if (!response.ok) {
            if (statusEl) {
                statusEl.textContent = 'Web player cookies unavailable.';
            }
            return null;
        }
        const data = await response.json();
        if (!statusEl) {
            return data;
        }
        const bits = [];
        const hasSpDc = data?.hasSpDc ?? data?.HasSpDc;
        const hasSpKey = data?.hasSpKey ?? data?.HasSpKey;
        const hasUserAgent = data?.hasUserAgent ?? data?.HasUserAgent;
        if (hasSpDc) bits.push('sp_dc saved');
        if (hasSpKey) bits.push('sp_key saved');
        if (hasUserAgent) bits.push('user agent saved');
        statusEl.textContent = bits.length ? bits.join(' • ') : 'Web player cookies not saved yet.';
        return data;
    } catch (error) {
        console.warn('Failed to load Spotify web player status', error);
        if (statusEl) {
            statusEl.textContent = 'Web player status unavailable.';
        }
        return null;
    }
}

async function saveSpotifyWebPlayerCookies() {
    const spDc = document.getElementById('spotifySpDc')?.value?.trim();
    const spKey = document.getElementById('spotifySpKey')?.value?.trim();
    const spT = document.getElementById('spotifySpT')?.value?.trim();
    const userAgentInput = document.getElementById('spotifyUserAgent')?.value?.trim();
    if (!spDc) {
        showToast('sp_dc is required', 'error');
        return;
    }
    if (!spT) {
        showToast('sp_t is required', 'error');
        return;
    }
    const userAgent = userAgentInput || navigator.userAgent;
    const cookies = [
        { name: 'sp_dc', value: spDc },
        { name: 'sp_key', value: spKey || '' },
        { name: 'sp_t', value: spT }
    ];

    try {
        const response = await fetch('/api/spotify-credentials/web-player', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
                'Content-Type': 'application/json',
                Accept: 'application/json'
            },
            body: JSON.stringify({ spDc, spKey, userAgent, cookies })
        });
        if (isAuthRedirectResponse(response)) {
            showToast('Login required to save Spotify web player cookies', 'error');
            return;
        }
        if (!response.ok) {
            const message = await getApiErrorMessage(response, 'Failed to save Spotify web player cookies');
            showToast(message, 'error');
            return;
        }
        showToast('Spotify web player cookies saved', 'success');
        const spDcInput = document.getElementById('spotifySpDc');
        const spKeyInput = document.getElementById('spotifySpKey');
        const spTInput = document.getElementById('spotifySpT');
        if (spDcInput) {
            spDcInput.value = '';
        }
        if (spKeyInput) {
            spKeyInput.value = '';
        }
        if (spTInput) {
            spTInput.value = '';
        }
    } catch (error) {
        console.error('Spotify web player cookie save error:', error);
        showToast('Network error while saving Spotify web player cookies', 'error');
    }
}

function toggleSpotifyLoginState(isConnected) {
    const loginSection = document.getElementById('spotifyLoginFormSection');
    const loggedInSection = document.getElementById('spotifyLoggedInInfo');
    if (!loginSection || !loggedInSection) {
        return;
    }
    if (isConnected) {
        loginSection.classList.add('hidden');
        loggedInSection.classList.remove('hidden');
    } else {
        loginSection.classList.remove('hidden');
        loggedInSection.classList.add('hidden');
    }
}

function getPlatformIcon(platform) {
    switch (platform) {
        case 'spotify':
            return '/images/icons/spotify.png';
        case 'discogs':
            return '/images/icons/discogs.png';
        case 'lastfm':
            return '/images/icons/last-fm.png';
        case 'bpmsupreme':
            return '/images/icons/bpmsupreme.png';
        case 'plex':
            return '/images/icons/plex.png';
        case 'jellyfin':
            return '/images/icons/jellyfin.png';
        case 'deezer':
            return '/images/icons/deezer.png';
        case 'apple-music':
            return '/images/icons/apple-music.png';
        case 'shazam':
            return '/images/icons/shazam.png';
        default:
            return '/images/icons/deezer.png';
    }
}

function capitalizeSpotifyPlan(plan) {
    if (!plan) return 'Unknown';
    const normalized = plan.trim().toLowerCase();
    if (!normalized) return 'Unknown';
    return normalized.charAt(0).toUpperCase() + normalized.slice(1);
}

