        document.getElementById('settings_picture').src = 
            `https://e-cdns-images.dzcdn.net/images/user/${user.picture}/125x125-000000-80-0-0.jpg`;
    } else {
        document.getElementById('settings_picture').src = getPlatformIcon('deezer');
    }
    
    // Update license and country
    let license = 'Free';
    if (user.can_stream_lossless) license = 'Hi-Fi';
    else if (user.can_stream_hq) license = 'Premium';
    
    document.getElementById('user_license_country').textContent = 
        `${license} | ${user.country || 'UL'}`;

    console.log('User info updated successfully');

    if (window.DeezSpoTag && typeof window.DeezSpoTag.loadConnectedPlatforms === 'function') {
        queueConnectedPlatformsRefresh();
    }
}

