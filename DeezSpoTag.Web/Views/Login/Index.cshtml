@using DeezSpoTag.Web.Models
@* ARL-only login page - ported from deezspotag *@
@{
    ViewData["Title"] = "Login";
}

<div class="fixed-footer">
    <h1 class="mb-8 text-5xl">Login</h1>

    <ul class="nav nav-tabs nav-fill mb-4" id="platformLoginTabs" data-no-global-tab-fallback="true" hidden>
        <li class="nav-item">
            <button class="nav-link" id="deezer-login-tab" data-login-target="deezer-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/deezer.png" alt="Deezer" class="platform-icon" />Deezer
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="spotify-login-tab" data-login-target="spotify-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/spotify.png" alt="Spotify" class="platform-icon" />Spotify
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="apple-music-login-tab" data-login-target="apple-music-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/apple-music.png" alt="Apple Music" class="platform-icon" />Apple Music
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="discogs-login-tab" data-login-target="discogs-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/discogs.png" alt="Discogs" class="platform-icon" />Discogs
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="lastfm-login-tab" data-login-target="lastfm-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/last-fm.png" alt="Last.fm" class="platform-icon" />Last.fm
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="bpmsupreme-login-tab" data-login-target="bpmsupreme-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/bpmsupreme.png" alt="BPM Supreme" class="platform-icon" />BPM Supreme
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="plex-login-tab" data-login-target="plex-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/plex.png" alt="Plex" class="platform-icon" />Plex
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="jellyfin-login-tab" data-login-target="jellyfin-login" type="button" role="tab" aria-selected="false">
                <img src="/images/icons/jellyfin.png" alt="Jellyfin" class="platform-icon" />Jellyfin
            </button>
        </li>
    </ul>

    <div class="tab-content" id="platformLoginTabsContent" hidden>
        <div class="tab-pane" id="deezer-login" role="tabpanel" hidden>
            <div class="settings-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">person</i>Deezer Login
                </h3>

                <div id="logged_in_info" class="platform-logged-in-wrapper" style="display: none;">
                    <div class="platform-logged-in">
                        <div class="platform-logged-in-media">
                            <img id="settings_picture" alt="Profile" class="h-32 w-32 rounded-full" />
                            <button class="btn btn-danger" id="logoutBtn">Logout</button>
                        </div>
                        <div class="platform-user-info">
                            <p>Logged in as <strong id="settings_username">not logged</strong></p>
                            <p id="user_license_country"></p>
                        </div>
                    </div>
                    <select id="family_account" style="display: none;">
                    </select>
                </div>

                <div id="login_form">
                    <!-- Credentials Login Section -->
                    <div class="base-accordion my-5 space-y-5">
                        <div class="accordion-header">
                            <span>Credentials Login</span>
                        </div>
                        <div class="accordion-content my-5 space-y-5">
                            <label class="block">
                                <span class="block mb-2">Email</span>
                                <input id="login_email" autocomplete="off" placeholder="Email" type="email" class="w-full" />
                            </label>
                            <label class="block">
                                <span class="block mb-2">Password</span>
                                <input id="login_password" autocomplete="off" placeholder="Password" type="password" class="w-full" />
                            </label>
                            <button class="btn btn-primary action-btn" id="loginEmailBtn">Login</button>
                        </div>
                    </div>

                    <!-- ARL Login Section -->
                    <div class="base-accordion my-5 space-y-5">
                        <div class="accordion-header">
                            <span>ARL Login</span>
                        </div>
                        <div class="accordion-content my-5 space-y-5">
                            <div class="flex items-center">
                                <input id="login_input_arl" autocomplete="off" placeholder="ARL" type="password" />
                                <button class="btn btn-primary action-btn btn-only-icon ml-2" id="copyArlBtn">
                                    <i class="material-icons">assignment</i>
                                </button>
                            </div>
                            <a href="/InfoArl" class="block">How do i get my own ARL?</a>
                            <button class="btn btn-primary action-btn" id="loginArlBtn">Login</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane" id="spotify-login" role="tabpanel" hidden>
            <div class="settings-group spotify-login-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">library_music</i>Spotify Login
                </h3>
                <div id="spotifyLoginFormSection" class="hidden">
                    <p class="text-muted" id="spotifyStatus">
                        Ready to connect via Spotify Connect.
                    </p>
                    <div class="settings-group mt-6" id="spotifyApiCredentialsSection">
                        <form id="spotifyApiCredentialsForm" class="space-y-5">
                            <label class="block mb-4">
                                <span class="block mb-2">sp_dc (Web Player cookie)</span>
                                <input type="text" id="spotifySpDc" placeholder="sp_dc cookie value" class="w-full" />
                            </label>
                            <label class="block mb-4">
                                <span class="block mb-2">sp_key</span>
                                <input type="text" id="spotifySpKey" placeholder="sp_key cookie value" class="w-full" />
                            </label>
                            <label class="block mb-4">
                                <span class="block mb-2">sp_t (device id cookie)</span>
                                <input type="text" id="spotifySpT" placeholder="sp_t cookie value" class="w-full" />
                            </label>
                            <label class="block mb-4">
                                <span class="block mb-2">User Agent</span>
                                <input type="text" id="spotifyUserAgent" placeholder="Leave blank to use this browser's user agent" class="w-full" />
                            </label>
                            <p class="text-muted" id="spotifyApiCredentialsStatus"></p>
                        </form>
                        <button class="btn btn-primary action-btn mt-4" type="button" id="spotifySaveWebPlayerCookiesBtn">Save Web Player Cookies</button>
                    </div>
                    <div class="settings-group mt-6" id="spotifyBlobSection">
                        <h4 class="settings-group__header">Spotify Account Credentials</h4>
                        <p class="text-muted">
                            Click Login, then open the Spotify desktop app or the Spotify Web Player and transfer playback to
                            the “DeezSpoTag” device in the Connect menu.
                        </p>
                        <form id="spotifyBlobForm" class="space-y-5">
                            <label class="block mb-4">
                                <span class="block mb-2">Account Name</span>
                                <input type="text" id="spotifyAccountName" placeholder="account name" class="w-full" />
                            </label>
                            <label class="block mb-4">
                                <span class="block mb-2">Region (optional)</span>
                                <input type="text" id="spotifyAccountRegion" placeholder="US" class="w-full" />
                            </label>
                        </form>
                        <button class="btn btn-primary action-btn mt-4" type="button" id="spotifyGenerateBlobBtn">Login</button>
                    </div>
                </div>
                <partial name="~/Views/Shared/_PlatformLoginStatusCard.cshtml" model='new PlatformLoginStatusCardModel { ContainerId = "spotifyLoggedInInfo", ImageId = "spotifyLoggedInPicture", ImageAlt = "Spotify Profile", ButtonId = "spotifyLogoutBtn", NameId = "spotifyLoggedInName", NameFallback = "Spotify account", DetailId = "spotifyLoggedInPlanLocation", DetailText = "Unknown | UL" }' />
            </div>
        </div>

        <div class="tab-pane" id="apple-music-login" role="tabpanel" hidden>
            <div class="settings-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">music_note</i>Apple Music Login
                </h3>
                <div class="settings-group mt-6" id="appleMusicTokensSection">
                    <h4 class="settings-group__header">Apple Music Tokens</h4>
                    <form id="appleMusicTokensForm" class="space-y-5">
                        <label class="block mb-4">
                            <span class="block mb-2">Storefront</span>
                            <input type="text" id="appleStorefront" placeholder="us" class="w-full" />
                            <span class="text-muted">2-letter storefront (example: us, gb, de).</span>
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">Media User Token (cookie: media-user-token)</span>
                            <input type="password" id="appleMediaUserToken" placeholder="Paste media-user-token from https://music.apple.com cookies" class="w-full" autocomplete="off" />
                            <span class="text-muted">Required for AAC LC downloads and Apple lyrics; not the same as the wrapper session.</span>
                        </label>
                    </form>
                    <button class="btn btn-primary action-btn" type="button" id="appleMusicTokensSaveBtn">Save Tokens</button>
                    <p class="text-muted" id="appleMusicTokensStatus"></p>
                </div>
                <div id="appleMusicLoginFormSection">
                    <p class="text-muted">
                        Enter your Apple Music email and password. We'll handle the wrapper login in the background and prompt for 2FA if needed.
                    </p>
                    <p class="text-muted" id="appleMusicWrapperModeHint">
                        This login uses the external Apple wrapper container. It will be started automatically when you click Login.
                    </p>
                    <form id="appleMusicLoginForm" class="space-y-5">
                        <label class="block mb-4">
                            <span class="block mb-2">Email</span>
                            <input type="text" id="appleMusicEmail" placeholder="email@example.com" class="w-full" autocomplete="username" />
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">Password</span>
                            <input type="password" id="appleMusicPassword" placeholder="Password" class="w-full" autocomplete="current-password" />
                        </label>
                        <div id="appleMusic2faSection" class="hidden">
                            <label class="block mb-4">
                                <span class="block mb-2">Verification Code</span>
                                <input type="text" id="appleMusic2fa" placeholder="123456" class="w-full" autocomplete="one-time-code" />
                            </label>
                            <button class="btn btn-primary action-btn" type="button" id="appleMusicSubmit2faBtn">Submit 2FA</button>
                            <p class="text-muted mt-2" id="appleMusic2faHint"></p>
                        </div>
                        <button class="btn btn-primary action-btn" type="button" id="appleMusicLoginBtn">Login</button>
                        <div class="mt-4 space-y-3">
                            <button class="btn btn-primary action-btn" type="button" id="appleMusicWrapperHelperBtn">Check Wrapper Helper</button>
                            <button class="btn btn-primary action-btn" type="button" id="appleMusicWrapperHealthBtn">Check Wrapper Health</button>
                            <pre class="text-muted" id="appleMusicWrapperHelperOutput" style="white-space: pre-wrap;"></pre>
                            <pre class="text-muted" id="appleMusicWrapperHealthOutput" style="white-space: pre-wrap;"></pre>
                        </div>
                        <p class="text-muted" id="appleMusicStatus"></p>
                        <p class="text-muted" id="appleMusicLoginState"></p>
                    </form>
                </div>
                <partial name="~/Views/Shared/_PlatformLoginStatusCard.cshtml" model='new PlatformLoginStatusCardModel { ContainerId = "appleMusicLoggedInInfo", ImageId = "appleMusicLoggedInPicture", ImageAlt = "Apple Music", ButtonId = "appleMusicDisconnectBtn", NameId = "appleMusicLoggedInName", NameFallback = "Apple Music account", DetailId = "appleMusicLoggedInStatus" }' />
            </div>
        </div>

        <div class="tab-pane" id="discogs-login" role="tabpanel" hidden>
            <div class="settings-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">album</i>Discogs Token
                </h3>
                <div id="discogsLoginFormSection">
                    <form id="discogsLoginForm" class="space-y-5">
                        <label class="block mb-4">
                            <span class="block mb-2">Token</span>
                            <input type="password" id="discogsToken" placeholder="Discogs Token" class="w-full" />
                        </label>
                        <button class="btn btn-primary action-btn" type="submit">Login</button>
                        <p class="text-muted" id="discogsStatus"></p>
                    </form>
                </div>
                <partial name="~/Views/Shared/_PlatformLoginStatusCard.cshtml" model='new PlatformLoginStatusCardModel { ContainerId = "discogsLoggedInInfo", ImageAlt = "Discogs", ImageSrc = "/images/icons/discogs.png", ImageCssClass = "h-20 w-20", ButtonId = "discogsDisconnectBtn", NameId = "discogsLoggedInName", NameFallback = "Discogs account" }' />
            </div>
        </div>

        <div class="tab-pane" id="lastfm-login" role="tabpanel" hidden>
            <div class="settings-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">local_fire_department</i>Last.fm API
                </h3>
                <div id="lastfmLoginFormSection">
                    <p class="text-muted">
                        Provide your Last.fm API key to enable tag enrichment.
                    </p>
                    <form id="lastfmLoginForm" class="space-y-5">
                        <label class="block mb-4">
                            <span class="block mb-2">API Key</span>
                            <input type="password" id="lastfmApiKey" placeholder="Last.fm API Key" class="w-full" />
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">Username (optional)</span>
                            <input type="text" id="lastfmUsername" placeholder="Last.fm username" class="w-full" />
                        </label>
                        <button class="btn btn-primary action-btn" type="submit">Save</button>
                        <p class="text-muted" id="lastfmStatus"></p>
                    </form>
                </div>
                <partial name="~/Views/Shared/_PlatformLoginStatusCard.cshtml" model='new PlatformLoginStatusCardModel { ContainerId = "lastfmLoggedInInfo", ImageAlt = "Last.fm", ImageSrc = "/images/icons/last-fm.png", ImageCssClass = "h-20 w-20", ButtonId = "lastfmDisconnectBtn", TextPrefix = "Configured for", NameId = "lastfmLoggedInName", NameFallback = "Last.fm" }' />
            </div>
        </div>

        <div class="tab-pane" id="bpmsupreme-login" role="tabpanel" hidden>
            <div class="settings-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">graphic_eq</i>BPM Supreme Login
                </h3>
                <div id="bpmLoginFormSection">
                    <form id="bpmLoginForm" class="space-y-5">
                        <label class="block mb-4">
                            <span class="block mb-2">Email</span>
                            <input type="text" id="bpmEmail" placeholder="Email" class="w-full" />
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">Password</span>
                            <input type="password" id="bpmPassword" placeholder="Password" class="w-full" />
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">Library</span>
                            <select id="bpmLibrary" class="w-full">
                                <option value="Supreme">Supreme</option>
                                <option value="Latino">Latino</option>
                            </select>
                        </label>
                        <button class="btn btn-primary action-btn" type="submit">Login</button>
                        <p class="text-muted" id="bpmStatus"></p>
                    </form>
                </div>
                <partial name="~/Views/Shared/_PlatformLoginStatusCard.cshtml" model='new PlatformLoginStatusCardModel { ContainerId = "bpmLoggedInInfo", ImageId = "bpmLoggedInPicture", ImageAlt = "BPM Supreme Profile", ButtonId = "bpmDisconnectBtn", NameId = "bpmLoggedInName", NameFallback = "BPM Supreme account" }' />
            </div>
        </div>

        <div class="tab-pane" id="plex-login" role="tabpanel" hidden>
            <div class="settings-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">storage</i>Plex Login
                </h3>
                <div id="plexLoginFormSection">
                    <form id="plexLoginForm" class="space-y-5">
                        <label class="block mb-4">
                            <span class="block mb-2">Server URL</span>
                            <input type="text" id="plexUrl" placeholder="http://localhost:32400" class="w-full" />
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">Token</span>
                            <input type="password" id="plexToken" placeholder="Plex Token" class="w-full" />
                        </label>
                        <button class="btn btn-primary action-btn" type="submit">Login</button>
                        <p class="text-muted" id="plexStatus"></p>
                    </form>
                </div>
                <partial name="~/Views/Shared/_PlatformLoginStatusCard.cshtml" model='new PlatformLoginStatusCardModel { ContainerId = "plexLoggedInInfo", ImageId = "plexLoggedInPicture", ImageAlt = "Plex Profile", ButtonId = "plexDisconnectBtn", NameId = "plexLoggedInName", NameFallback = "Plex account" }' />
            </div>
        </div>

        <div class="tab-pane" id="jellyfin-login" role="tabpanel" hidden>
            <div class="settings-group">
                <h3 class="settings-group__header">
                    <i class="material-icons">storage</i>Jellyfin Integration
                </h3>
                <div id="jellyfinLoginFormSection">
                    <form id="jellyfinLoginForm" class="space-y-5">
                        <label class="block mb-4">
                            <span class="block mb-2">Server URL</span>
                            <input type="text" id="jellyfinUrl" placeholder="http://localhost:8096" class="w-full" />
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">API Key</span>
                            <input type="password" id="jellyfinApiKey" placeholder="Jellyfin API Key" class="w-full" />
                        </label>
                        <label class="block mb-4">
                            <span class="block mb-2">Username (optional)</span>
                            <input type="text" id="jellyfinUsername" placeholder="Username" class="w-full" />
                        </label>
                        <button class="btn btn-primary action-btn" type="submit">Login</button>
                        <p class="text-muted" id="jellyfinStatus"></p>
                    </form>
                </div>
                <partial name="~/Views/Shared/_PlatformLoginStatusCard.cshtml" model='new PlatformLoginStatusCardModel { ContainerId = "jellyfinLoggedInInfo", ImageId = "jellyfinLoggedInPicture", ImageAlt = "Jellyfin Profile", ButtonId = "jellyfinDisconnectBtn", NameId = "jellyfinLoggedInName", NameFallback = "Jellyfin account" }' />
            </div>
        </div>
    </div>
</div>

<style>
html {
    scrollbar-gutter: stable;
}

html,
body {
    overflow-y: scroll;
}

.fixed-footer {
    padding: 20px;
    background: var(--bg-primary);
    color: var(--text-primary);
}

.fixed-footer .nav-tabs .nav-link {
    color: var(--text-muted);
}

.fixed-footer .nav-tabs .nav-link:hover {
    color: var(--text-primary);
}

.fixed-footer .nav-tabs .nav-link.active {
    color: var(--primary-color);
}

.fixed-footer .tab-pane {
    color: var(--text-primary);
}

.fixed-footer label,
.fixed-footer .form-label {
    color: var(--text-primary);
}

.settings-group {
    border-top: 1px solid var(--border-primary);
    margin-bottom: 2rem;
}

.settings-group__header {
    display: inline-flex;
    align-items: center;
    padding-top: 2rem;
    padding-bottom: 2rem;
    font-size: 1.5rem;
    color: var(--text-primary);
}

.settings-group__header i.material-icons {
    margin-right: 1rem;
    color: var(--primary-color);
}

.spotify-login-group {
    border-top: none;
    margin-top: 0;
}

.platform-icon {
    width: 18px;
    height: 18px;
    margin-right: 8px;
    object-fit: contain;
}

.platform-logged-in {
    display: grid;
    align-items: center;
    grid-template-columns: 128px 1fr;
    gap: 24px;
    min-height: 128px;
}

.platform-logged-in-media {
    display: grid;
    justify-items: center;
    row-gap: 12px;
}

.platform-logged-in .platform-user-info {
    padding-left: 24px;
}

.platform-logged-in img,
#logged_in_info img {
    width: 128px;
    height: 128px;
    object-fit: cover;
}

.platform-user-info {
    min-height: 72px;
}

@@media (max-width: 900px) {
    .fixed-footer {
        padding: 20px 16px;
    }

    .settings-group__header {
        padding-top: 1rem;
        padding-bottom: 1rem;
        font-size: 1.3rem;
    }

    .platform-logged-in {
        grid-template-columns: 1fr;
        align-items: flex-start;
    }

    .platform-logged-in .platform-user-info {
        padding-left: 0;
    }

    .platform-logged-in-media {
        grid-auto-flow: column;
        justify-content: flex-start;
        column-gap: 12px;
    }
}

@@media (max-width: 640px) {
    .fixed-footer > h1,
    .text-5xl {
        text-align: center;
    }

    .nav-tabs {
        flex-wrap: wrap;
        gap: 6px;
    }

    .nav-tabs .nav-link {
        width: 100%;
        text-align: left;
    }

    .settings-group .btn,
    .platform-logged-in .btn {
        width: 100%;
    }

    .platform-logged-in-media {
        grid-auto-flow: row;
        justify-items: flex-start;
    }
}

/* Small phone breakpoints */
@@media (max-width: 480px) {
    .fixed-footer {
        padding: 14px 12px;
    }

    .text-5xl {
        font-size: clamp(1.75rem, 8vw, 3rem);
    }

    .mb-8 {
        margin-bottom: 1.25rem;
    }

    .settings-group__header {
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
        font-size: 1.1rem;
    }

    .settings-group__header i.material-icons {
        margin-right: 0.5rem;
        font-size: 20px;
    }

    .nav-tabs .nav-link {
        padding: 10px 12px;
        font-size: 14px;
        min-height: 44px;
    }

    .platform-icon {
        width: 20px;
        height: 20px;
    }

    .platform-logged-in img,
    #logged_in_info img {
        width: 80px;
        height: 80px;
    }

    .h-32 {
        height: 5rem;
    }

    .w-32 {
        width: 5rem;
    }

    .accordion-header {
        padding: 0.875rem;
    }

    .accordion-content {
        padding: 0.875rem;
    }

    input[type="text"],
    input[type="password"],
    input[type="email"] {
        padding: 10px;
        font-size: 16px;
        min-height: 44px;
    }

    .btn,
    .action-btn {
        min-height: 44px;
        padding: 10px 14px;
    }

    .btn-only-icon {
        padding: 10px;
        min-width: 44px;
        min-height: 44px;
    }
}

@@media (max-width: 400px) {
    .fixed-footer {
        padding: 12px 10px;
    }

    .text-5xl {
        font-size: 1.5rem;
    }

    .mb-8 {
        margin-bottom: 1rem;
    }

    .settings-group__header {
        font-size: 1rem;
    }

    .nav-tabs .nav-link {
        padding: 10px;
        font-size: 13px;
    }

    .platform-icon {
        width: 18px;
        height: 18px;
        margin-right: 6px;
    }

    .platform-logged-in {
        gap: 14px;
    }

    .platform-logged-in img,
    #logged_in_info img {
        width: 64px;
        height: 64px;
    }

    .h-32, .h-20 {
        height: 4rem;
    }

    .w-32, .w-20 {
        width: 4rem;
    }

    .base-accordion {
        border-radius: 6px;
    }

    .accordion-header {
        padding: 0.75rem;
        font-size: 14px;
    }

    .accordion-content {
        padding: 0.75rem;
    }

    .my-5 {
        margin-top: 1rem;
        margin-bottom: 1rem;
    }

    .space-y-5 > * + * {
