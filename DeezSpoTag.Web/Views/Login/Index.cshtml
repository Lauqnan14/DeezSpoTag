            `Account info reachable: ${Boolean(data.accountInfoReachable)}`,
            `Tokens: dev=${Boolean(data.hasDevToken)} music=${Boolean(data.hasMusicToken)}`
        ];
        if (outputEl) {
            outputEl.textContent = lines.join('\n');
        }
        showToast(data.acceptingLoginCommands ? 'Wrapper is accepting login commands.' : 'Wrapper is not accepting login commands.', data.acceptingLoginCommands ? 'success' : 'error');
    } catch (error) {
        console.error('Wrapper health check error', error);
        if (outputEl) {
            outputEl.textContent = 'Wrapper health check failed.';
        }
        showToast('Wrapper health check failed', 'error');
    }
}

function beginAppleMusicStatusPolling() {
    if (appleMusicStatusPoll) {
        clearInterval(appleMusicStatusPoll);
    }
    // Poll every 500ms for faster 2FA detection and login completion
    appleMusicStatusPoll = setInterval(() => {
        if (!appleMusicLoginInProgress && !appleMusic2faSubmitting) {
            clearInterval(appleMusicStatusPoll);
            appleMusicStatusPoll = null;
            return;
        }
        refreshAppleMusicWrapperStatus();
    }, 500);
}

function stopAppleMusicStatusPolling() {
    if (appleMusicStatusPoll) {
        clearInterval(appleMusicStatusPoll);
        appleMusicStatusPoll = null;
    }
}

function beginAppleMusicPassiveStatusPolling() {
    if (appleMusicPassiveStatusPoll) {
        return;
    }
    appleMusicPassiveStatusPoll = setInterval(() => {
        refreshAppleMusicWrapperStatus();
    }, 15000);
}

