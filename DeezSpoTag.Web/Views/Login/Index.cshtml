@section Scripts {
<script>
console.log('=== LOGIN PAGE SCRIPT LOADED ===');

let appleMusicSettingsCache = null;
let connectedPlatformsRefreshTimer = null;
const LOGIN_TAB_STORAGE_KEY = 'deezspotag-login-active-tab';
let spotifyConfigRequested = false;
let spotifyConfigLoadSequence = 0;
let deezerStatusRequested = false;
let platformAuthStateRequested = false;
let appleMusicBootstrapRequested = false;

function isTabPreferenceEnabled() {
    try {
        const stored = localStorage.getItem('tabs-preference-enabled');
        if (stored === null || stored === '') {
            return true;
        }

        return stored === 'true';
    } catch (error) {
        console.warn('Failed to read tab preference setting', error);
        return true;
    }
}

// Toast notification system
function showToast(message, type = 'info') {
    if (window.DeezSpoTag?.showNotification) {
        window.DeezSpoTag.showNotification(message, type);
        return;
    }

    console.log('TOAST:', message, type);
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    console.log('=== DOM LOADED ===');

    const platformAuthBindings = {
        discogs: {
            matches: '/discogs',
            render: data => renderDiscogsInfo(data || {}),
            clear: () => clearDiscogsInputs()
        },
        lastfm: {
            matches: '/lastfm',
            render: (data, payload, isConnected, statusElementId) => {
                const hasLastFmApiKey = Boolean(data?.hasApiKey ?? isConnected);
                setStatus(statusElementId, hasLastFmApiKey);
                renderLastFmInfo(data || { username: payload?.username || '', hasApiKey: hasLastFmApiKey });
                return hasLastFmApiKey;
            },
            clear: () => clearLastFmInputs()
        },
        bpm: {
            matches: '/bpmsupreme',
            render: data => renderBpmInfo(data || {}),
            clear: () => clearBpmInputs()
        },
        plex: {
            matches: '/plex',
            render: data => renderPlexInfo(data || {}),
            clear: () => clearPlexInputs()
        },
        jellyfin: {
            matches: '/jellyfin',
            render: data => renderJellyfinInfo(data || {}),
            clear: () => clearJellyfinInputs()
        },
        appleMusic: {
            matches: '/applemusic',
            render: data => renderAppleMusicInfo(data || {}),
            clear: () => clearAppleMusicLoginInputs()
        }
    };

    function bindAsyncClick(elementId, handler) {
        const element = document.getElementById(elementId);
        if (!element) {
            return;
        }

        element.addEventListener('click', async function() {
            await handler();
        });
    }

    function bindPlatformDisconnect(buttonId, url, statusElementId, afterDisconnect) {
        bindAsyncClick(buttonId, async function() {
            await disconnectPlatform(url, statusElementId, platformAuthBindings);
            if (typeof afterDisconnect === 'function') {
                afterDisconnect();
            }
        });
    }

    // Render tab UI immediately, then hydrate async state in the background.
    initializeLoginTabs();
    void initializeLoginPageState();
    
    // Set up ARL login button
    const loginBtn = document.getElementById('loginArlBtn');
    if (loginBtn) {
        loginBtn.addEventListener('click', function() {
            const arl = document.getElementById('login_input_arl').value.trim();
            
            if (!arl) {
                showToast('Please enter your ARL token.', 'warning');
                return;
            }
            
            loginWithArl(arl);
        });
    }
    
    // Set up logout button
    const logoutBtn = document.getElementById('logoutBtn');
    if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
            logout();
        });
    }
    
    // Set up copy button
    const copyBtn = document.getElementById('copyArlBtn');
    if (copyBtn) {
        copyBtn.addEventListener('click', function() {
            const input = document.getElementById('login_input_arl');
            const originalType = input.type;
            
            input.type = 'text';
            input.select();
            input.setSelectionRange(0, 99999);
            
            try {
                document.execCommand('copy');
                showToast('ARL copied to clipboard!', 'success');
            } catch (err) {
                showToast('Failed to copy ARL', 'error');
            }
            
            input.type = originalType;
        });
    }

    const loginEmailBtn = document.getElementById('loginEmailBtn');
    if (loginEmailBtn) {
        loginEmailBtn.addEventListener('click', function() {
            const email = document.getElementById('login_email').value.trim();
            const password = document.getElementById('login_password').value;

            if (!email || !password) {
                showToast('Please enter your email and password.', 'warning');
                return;
            }

            loginWithEmail(email, password);
        });
    }

    bindAsyncClick('spotifyGenerateBlobBtn', generateSpotifyBlob);
    bindAsyncClick('spotifySaveWebPlayerCookiesBtn', saveSpotifyWebPlayerCookies);
    bindAsyncClick('spotifyLogoutBtn', logoutSpotify);
    bindAsyncClick('appleMusicLoginBtn', startAppleMusicLogin);
    bindAsyncClick('appleMusicTokensSaveBtn', saveAppleMusicSettings);
    bindAsyncClick('appleMusicSubmit2faBtn', submitAppleMusic2fa);
    bindAsyncClick('appleMusicWrapperHelperBtn', checkAppleMusicWrapperHelperStatus);
    bindAsyncClick('appleMusicWrapperHealthBtn', checkAppleMusicWrapperHealth);
    bindPlatformDisconnect('appleMusicDisconnectBtn', '/api/platform-auth/applemusic/disconnect', 'appleMusicStatus', function() {
        appleMusicLoginInProgress = false;
        appleMusicLoginRequestPending = false;
    });

    const discogsForm = document.getElementById('discogsLoginForm');
    if (discogsForm) {
        discogsForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const token = document.getElementById('discogsToken').value.trim();
            await savePlatformAuth('/api/platform-auth/discogs', { token }, 'discogsStatus', Boolean(token));
        });
    }

    bindPlatformDisconnect('discogsDisconnectBtn', '/api/platform-auth/discogs/disconnect', 'discogsStatus');

    const lastfmForm = document.getElementById('lastfmLoginForm');
    if (lastfmForm) {
        lastfmForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const apiKey = document.getElementById('lastfmApiKey').value.trim();
            const username = document.getElementById('lastfmUsername').value.trim();
            await savePlatformAuth('/api/platform-auth/lastfm', { apiKey, username }, 'lastfmStatus', Boolean(apiKey));
        });
    }

    bindPlatformDisconnect('lastfmDisconnectBtn', '/api/platform-auth/lastfm/disconnect', 'lastfmStatus');

    const bpmForm = document.getElementById('bpmLoginForm');
    if (bpmForm) {
        bpmForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const email = document.getElementById('bpmEmail').value.trim();
            const password = document.getElementById('bpmPassword').value.trim();
            const library = document.getElementById('bpmLibrary').value;
            await savePlatformAuth('/api/platform-auth/bpmsupreme', { email, password, library }, 'bpmStatus', Boolean(email && password));
        });
    }

    bindPlatformDisconnect('bpmDisconnectBtn', '/api/platform-auth/bpmsupreme/disconnect', 'bpmStatus');

    const plexForm = document.getElementById('plexLoginForm');
    if (plexForm) {
        plexForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const url = document.getElementById('plexUrl').value.trim();
            const token = document.getElementById('plexToken').value.trim();
            await loginPlex(url, token);
        });
    }

    bindPlatformDisconnect('plexDisconnectBtn', '/api/platform-auth/plex/disconnect', 'plexStatus');

    const jellyfinForm = document.getElementById('jellyfinLoginForm');
    if (jellyfinForm) {
        jellyfinForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const url = document.getElementById('jellyfinUrl').value.trim();
            const apiKey = document.getElementById('jellyfinApiKey').value.trim();
            const username = document.getElementById('jellyfinUsername').value.trim();
            await loginJellyfin(url, apiKey, username);
        });
    }

    bindPlatformDisconnect('jellyfinDisconnectBtn', '/api/platform-auth/jellyfin/disconnect', 'jellyfinStatus');

});

async function initializeLoginPageState() {
    const tasks = [ensurePlatformAuthStateLoaded()];
    const activeTabId = getActiveLoginTabId();
    if (activeTabId) {
        tasks.push(bootstrapLoginTab(activeTabId));
    }

    const results = await Promise.allSettled(tasks);
    results.forEach((result) => {
        if (result.status === 'rejected') {
            console.warn('Initial login state setup failed', result.reason);
        }
    });
    window.setTimeout(() => {
        queueConnectedPlatformsRefresh();
    }, 400);
}

function setLoginTabsVisible(visible) {
    const tabList = document.getElementById('platformLoginTabs');
    const tabContent = document.getElementById('platformLoginTabsContent');
    if (tabList) {
        tabList.hidden = !visible;
    }
    if (tabContent) {
        tabContent.hidden = !visible;
    }
}

function isValidLoginTabId(tabId) {
    if (!tabId) return false;
    return Boolean(document.querySelector(`#platformLoginTabsContent .tab-pane#${tabId}`));
}

function getLoginTabFromLocation() {
    const queryParams = new URLSearchParams(window.location.search || '');
    const explicitTab = (queryParams.get('tab') || queryParams.get('loginTab') || '').trim();
    if (isValidLoginTabId(explicitTab)) {
        return explicitTab;
    }

    const platformRaw = (queryParams.get('platform') || '').trim().toLowerCase();
    if (platformRaw) {
        const platformMap = {
            deezer: 'deezer-login',
            spotify: 'spotify-login',
            applemusic: 'apple-music-login',
            discogs: 'discogs-login',
            lastfm: 'lastfm-login',
            bpmsupreme: 'bpmsupreme-login',
            plex: 'plex-login',
            jellyfin: 'jellyfin-login'
        };
        const normalizedPlatform = platformRaw.replace(/[^a-z]/g, '');
        const mapped = platformMap[normalizedPlatform];
        if (isValidLoginTabId(mapped)) {
            return mapped;
        }
    }

    const hash = window.location.hash || '';
    const hashId = hash.startsWith('#') ? hash.slice(1) : '';
    if (isValidLoginTabId(hashId)) {
        return hashId;
    }

    return '';
}

function getPreferredLoginTabId() {
    const locationTab = getLoginTabFromLocation();
    if (locationTab) {
        return locationTab;
    }

    if (!isTabPreferenceEnabled()) {
        return 'deezer-login';
    }

    try {
        const stored = sessionStorage.getItem(LOGIN_TAB_STORAGE_KEY) || '';
        if (isValidLoginTabId(stored)) {
            return stored;
        }
    } catch (error) {
        console.warn('Failed to read login tab preference', error);
    }

    return 'deezer-login';
}

function persistLoginTabId(tabId) {
    if (!isValidLoginTabId(tabId)) {
        return;
    }

    try {
        if (!isTabPreferenceEnabled()) {
            sessionStorage.removeItem(LOGIN_TAB_STORAGE_KEY);
            return;
        }

        sessionStorage.setItem(LOGIN_TAB_STORAGE_KEY, tabId);
    } catch (error) {
        console.warn('Failed to persist login tab preference', error);
    }
}

function clearLoginTabNavigationHints() {
    const url = new URL(window.location.href);
    let changed = false;

    ['tab', 'loginTab', 'platform'].forEach((key) => {
        if (url.searchParams.has(key)) {
            url.searchParams.delete(key);
            changed = true;
        }
    });

    const hash = window.location.hash || '';
    const hashId = hash.startsWith('#') ? hash.slice(1) : '';
    if (isValidLoginTabId(hashId)) {
        url.hash = '';
        changed = true;
    }

    if (!changed) {
        return;
    }

    const nextSearch = url.searchParams.toString();
    history.replaceState(
        null,
        '',
        `${url.pathname}${nextSearch ? `?${nextSearch}` : ''}${url.hash || ''}`
    );
}

function initializeLoginTabs() {
    const tabList = document.getElementById('platformLoginTabs');
    if (!tabList) {
        return;
    }

    const triggers = tabList.querySelectorAll('[data-login-target]');
    triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
            const tabId = trigger.getAttribute('data-login-target') || '';
            if (!tabId) {
                return;
            }
            setActiveLoginTab(tabId);
            persistLoginTabId(tabId);
            void bootstrapLoginTab(tabId);
        });
    });

    const preferredTabId = getPreferredLoginTabId();
    const preferredTrigger = document.querySelector(`#platformLoginTabs [data-login-target="${preferredTabId}"]`) || triggers[0];
    if (!preferredTrigger) {
        setLoginTabsVisible(true);
        return;
    }

    const resolvedTabId = preferredTrigger.getAttribute('data-login-target') || preferredTabId;
    setActiveLoginTab(resolvedTabId);
    persistLoginTabId(resolvedTabId);
    void bootstrapLoginTab(resolvedTabId);
    clearLoginTabNavigationHints();
    setLoginTabsVisible(true);
}

function setActiveLoginTab(tabId) {
    if (!tabId || !isValidLoginTabId(tabId)) {
        return;
    }

    const triggers = document.querySelectorAll('#platformLoginTabs [data-login-target]');
    triggers.forEach((trigger) => {
        const isActive = trigger.getAttribute('data-login-target') === tabId;
        trigger.classList.toggle('active', isActive);
        trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    const panes = document.querySelectorAll('#platformLoginTabsContent .tab-pane');
    panes.forEach((pane) => {
        const isActive = pane.id === tabId;
        pane.classList.toggle('active', isActive);
        pane.classList.toggle('show', isActive);
        pane.hidden = !isActive;
        pane.setAttribute('aria-hidden', isActive ? 'false' : 'true');
    });
}

function getActiveLoginTabId() {
    const activePane = document.querySelector('#platformLoginTabsContent .tab-pane.active');
    if (activePane?.id && isValidLoginTabId(activePane.id)) {
        return activePane.id;
    }

    const preferred = getPreferredLoginTabId();
    return isValidLoginTabId(preferred) ? preferred : 'deezer-login';
}

// Check persistent Deezer login state from server and clear stale local cache.
async function checkPersistentLoginState() {
    console.log('=== CHECKING PERSISTENT LOGIN STATE ===');

    try {
        const response = await fetch('/api/login/status', { cache: 'no-store' });
        if (!response.ok) {
            throw new Error(`status ${response.status}`);
        }

        const data = await response.json();
        if (data && data.status > 0 && data.user) {
            console.log('Found persistent login state from server for user:', data.user.name);
            localStorage.setItem('loginUser', JSON.stringify(data.user));
            showLoggedInInfo(data.user);
            return;
        }
    } catch (error) {
        console.warn('Server login status unavailable; defaulting to logged out view', error);
    }

    localStorage.removeItem('arl');
    localStorage.removeItem('loginUser');
    document.getElementById('login_input_arl').value = '';
    showLoginForm();
}

async function loadPlatformAuthState() {
    try {
        const response = await fetch('/api/platform-auth', {
            cache: 'no-store',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
        });
        if (isAuthRedirectResponse(response)) {
            showToast('Login required to load platform credentials', 'error');
            return;
        }
        if (!response.ok) {
            return;
        }

        const data = await response.json();
        if (data.discogs) {
            document.getElementById('discogsToken').value = data.discogs.token || '';
            setStatus('discogsStatus', data.discogs.token);
            renderDiscogsInfo(data.discogs);
            togglePlatformLoginState('discogs', Boolean(data.discogs.token));
        }
        if (data.lastFm) {
            const hasLastFmApiKey = Boolean(data.lastFm.hasApiKey ?? data.lastFm.apiKey);
            document.getElementById('lastfmApiKey').value = data.lastFm.apiKey || '';
            document.getElementById('lastfmUsername').value = data.lastFm.username || '';
            setStatus('lastfmStatus', hasLastFmApiKey);
            renderLastFmInfo(data.lastFm);
            togglePlatformLoginState('lastfm', hasLastFmApiKey);
        }
        if (data.bpmSupreme) {
            document.getElementById('bpmEmail').value = data.bpmSupreme.email || '';
            document.getElementById('bpmPassword').value = data.bpmSupreme.password || '';
            document.getElementById('bpmLibrary').value = data.bpmSupreme.library || 'Supreme';
            setStatus('bpmStatus', data.bpmSupreme.email && data.bpmSupreme.password);
            renderBpmInfo(data.bpmSupreme);
            togglePlatformLoginState('bpm', Boolean(data.bpmSupreme.email && data.bpmSupreme.password));
        }
        if (data.plex) {
            document.getElementById('plexUrl').value = data.plex.url || '';
            document.getElementById('plexToken').value = data.plex.token || '';
            setStatus('plexStatus', data.plex.url && data.plex.token);
            renderPlexInfo(data.plex);
            togglePlatformLoginState('plex', Boolean(data.plex.url && data.plex.token));
        }
        if (data.jellyfin) {
            document.getElementById('jellyfinUrl').value = data.jellyfin.url || '';
            document.getElementById('jellyfinApiKey').value = data.jellyfin.apiKey || '';
            document.getElementById('jellyfinUsername').value = data.jellyfin.username || '';
            setStatus('jellyfinStatus', data.jellyfin.url && (data.jellyfin.apiKey || data.jellyfin.username));
            renderJellyfinInfo(data.jellyfin);
            togglePlatformLoginState('jellyfin', Boolean(data.jellyfin.url && (data.jellyfin.apiKey || data.jellyfin.username)));
        }
        if (data.appleMusic) {
            document.getElementById('appleMusicEmail').value = data.appleMusic.email || '';
            renderAppleMusicInfo(data.appleMusic);
            const appleMusicConnected = Boolean(data.appleMusic.wrapperReady);
            setStatus('appleMusicStatus', appleMusicConnected);
            togglePlatformLoginState('appleMusic', appleMusicConnected);
            if (appleMusicConnected) {
                setAppleMusicLoggedInStatus('Restoring Apple Music session...');
            }
        }
    } catch (error) {
        console.warn('Failed to load platform auth state', error);
    }
}

async function ensurePlatformAuthStateLoaded() {
    if (platformAuthStateRequested) {
        return;
    }
    platformAuthStateRequested = true;
    await loadPlatformAuthState();
}

async function ensureDeezerStatusLoaded() {
    if (deezerStatusRequested) {
        return;
    }
    deezerStatusRequested = true;
    await checkPersistentLoginState();
}

function ensureSpotifyConfigLoaded() {
    if (spotifyConfigRequested) {
        return;
    }
    spotifyConfigRequested = true;
    void loadSpotifyConfig();
}

async function ensureAppleMusicBootstrapLoaded() {
    if (appleMusicBootstrapRequested) {
        return;
    }
    appleMusicBootstrapRequested = true;

    const results = await Promise.allSettled([
        loadAppleMusicSettings(),
        refreshAppleMusicWrapperStatus()
    ]);
    results.forEach((result) => {
        if (result.status === 'rejected') {
            console.warn('Apple Music bootstrap task failed', result.reason);
        }
    });

    beginAppleMusicPassiveStatusPolling();
}

async function bootstrapLoginTab(tabId) {
    if (!tabId) {
        return;
    }

    if (tabId === 'deezer-login') {
        await ensureDeezerStatusLoaded();
        return;
    }

    if (tabId === 'spotify-login') {
        ensureSpotifyConfigLoaded();
        return;
    }

    if (tabId === 'apple-music-login') {
        await ensureAppleMusicBootstrapLoaded();
    }
}

function isAuthRedirectResponse(response) {
    if (!response) {
        return false;
    }
    if (response.status === 401 || response.status === 403) {
        return true;
    }
    if (response.redirected && response.url) {
        return response.url.includes('/Identity/Account/Login');
    }
    return false;
}

async function getApiErrorMessage(response, fallbackMessage) {
    if (!response) {
        return fallbackMessage;
    }

    if (isAuthRedirectResponse(response)) {
        return 'Login required to continue. Refresh the page and sign in again.';
    }

    const contentType = (response.headers?.get('content-type') || '').toLowerCase();

    if (contentType.includes('application/json')) {
        try {
            const payload = await response.clone().json();
            if (payload && typeof payload === 'object') {
                const candidate = payload.message || payload.error || payload.title || payload.detail;
                if (typeof candidate === 'string' && candidate.trim()) {
                    return candidate.trim();
                }
            }
        } catch {
            // Ignore JSON parse failures and continue to plain-text parsing.
        }
    }

    let text = '';
    try {
        text = await response.text();
    } catch {
        return fallbackMessage;
    }

    const trimmed = (text || '').trim();
    if (!trimmed) {
        return fallbackMessage;
    }

    // Avoid surfacing full HTML documents (login/error pages) in toast notifications.
    const leadingChunk = trimmed.slice(0, 512).toLowerCase();
    if (leadingChunk.includes('<!doctype html') || leadingChunk.includes('<html')) {
        return `Request failed (HTTP ${response.status}). Check server logs for details.`;
    }

    const compact = trimmed.replace(/\s+/g, ' ');
    if (compact.length <= 260) {
        return compact;
    }

    return `${compact.slice(0, 257)}...`;
}

