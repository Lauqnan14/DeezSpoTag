    <script>
        // Sidebar state management
        function readSidebarCollapsedPreference() {
            try {
                return localStorage.getItem('sidebarCollapsed') === 'true';
            } catch (error) {
                console.warn('Failed to read sidebar preference from localStorage.', error);
                return false;
            }
        }

        function persistSidebarCollapsedPreference(collapsed) {
            try {
                localStorage.setItem('sidebarCollapsed', collapsed ? 'true' : 'false');
            } catch (error) {
                console.warn('Failed to write sidebar preference to localStorage.', error);
            }
            if (window.UserPrefs) window.UserPrefs.set('sidebarCollapsed', collapsed === true);
        }

        let sidebarCollapsed = readSidebarCollapsedPreference();

        function isSidebarMobile() {
            return window.matchMedia('(max-width: 900px)').matches;
        }

        function applySidebarVisualState(sidebar, mainContent, hamburger, collapsed) {
            sidebar.classList.toggle('collapsed', collapsed);
            mainContent.classList.toggle('sidebar-collapsed', collapsed);
            hamburger.classList.toggle('sidebar-collapsed', collapsed);
            hamburger.classList.toggle('sidebar-expanded', !collapsed);
            const expanded = isSidebarMobile()
                ? sidebar.classList.contains('open')
                : !collapsed;
            hamburger.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        }

        function closeSidebar(sidebar, mainContent, hamburger, collapsed) {
            sidebar.classList.remove('open');
            applySidebarVisualState(sidebar, mainContent, hamburger, collapsed);
        }
        
        // Initialize sidebar state on page load
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            const hamburger = document.querySelector('.hamburger');
            
            if (isSidebarMobile()) {
                closeSidebar(sidebar, mainContent, hamburger, true);
            } else if (sidebarCollapsed) {
                closeSidebar(sidebar, mainContent, hamburger, true);
            } else {
                closeSidebar(sidebar, mainContent, hamburger, false);
            }
            
            // Set active menu item based on current page
            setActiveMenuItem();
            
            // Handle menu item clicks
            setupMenuItemHandlers();

            // Remove pre-init class once explicit sidebar classes are applied.
            document.documentElement.classList.remove('sidebar-precollapsed');
        });

        // Unified toggle function for both desktop and mobile
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            const hamburger = document.querySelector('.hamburger');
            
            if (isSidebarMobile()) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebar.classList.remove('collapsed');
                    sidebar.classList.add('open');
                    applySidebarVisualState(sidebar, mainContent, hamburger, false);
                } else {
                    closeSidebar(sidebar, mainContent, hamburger, true);
                }
            } else {
                sidebarCollapsed = !sidebarCollapsed;
                closeSidebar(sidebar, mainContent, hamburger, sidebarCollapsed);
                
                // Save state to localStorage and server
                persistSidebarCollapsedPreference(sidebarCollapsed);
            }
        }
        
        // Legacy function for backward compatibility
        function toggleSidebarCollapse() {
            toggleSidebar();
        }
        
        // Legacy function for backward compatibility
        function toggleSidebarMobile() {
            if (isSidebarMobile()) {
                toggleSidebar();
            }
        }

        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', function(event) {
            const sidebar = document.getElementById('sidebar');
            const hamburger = document.querySelector('.hamburger');
            const mainContent = document.getElementById('mainContent');
            
            if (isSidebarMobile() &&
                !sidebar.contains(event.target) &&
                !hamburger.contains(event.target) &&
                sidebar.classList.contains('open')) {
                closeSidebar(sidebar, mainContent, hamburger, true);
            }
        });
        
        // Set active menu item based on current page
        function setActiveMenuItem() {
            const currentPath = window.location.pathname.toLowerCase();
            const menuItems = document.querySelectorAll('.menu-item');
            
            // Remove all active classes first
            menuItems.forEach(item => item.classList.remove('active'));
            
            // Set active based on current path
            if (currentPath === '/' || currentPath === '/home') {
                document.querySelector('.menu-item.home')?.classList.add('active');
            } else if (currentPath.startsWith('/library')) {
                document.querySelector('.menu-item.library')?.classList.add('active');
            } else if (currentPath.startsWith('/mediamanagement')) {
                document.querySelector('.menu-item.media-management')?.classList.add('active');
            } else if (currentPath.startsWith('/autotag')) {
                document.querySelector('.menu-item.autotag')?.classList.add('active');
            } else if (currentPath.startsWith('/settings')) {
                document.querySelector('.menu-item.settings')?.classList.add('active');
            } else if (currentPath.startsWith('/activities')) {
                document.querySelector('.menu-item.activities')?.classList.add('active');
            } else if (currentPath.startsWith('/statistics')) {
                document.querySelector('.menu-item.statistics')?.classList.add('active');
            } else if (currentPath.startsWith('/login')) {
                document.querySelector('.menu-item.login')?.classList.add('active');
            } else if (currentPath.startsWith('/about')) {
                document.querySelector('.menu-item.about')?.classList.add('active');
            }
        }
        
        // Setup menu item click handlers
        function setupMenuItemHandlers() {
            document.querySelectorAll('.menu-item').forEach(item => {
                item.addEventListener('click', function(e) {
                    if (this.dataset.menuAction === 'true') {
                        return;
                    }

                    // Don't prevent default for actual links
                    if (this.getAttribute('href') && 
                        this.getAttribute('href').startsWith('/') && 
                        !this.getAttribute('href').startsWith('/#')) {
                        // This is a real link, let it navigate normally
                        return;
                    }
                    
                    e.preventDefault();
                    
                    // Remove active class from all items
                    document.querySelectorAll('.menu-item').forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                });
            });
        }
        
        // Handle window resize
        window.addEventListener('resize', function() {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            const hamburger = document.querySelector('.hamburger');
            
            if (isSidebarMobile()) {
                closeSidebar(sidebar, mainContent, hamburger, true);
            } else {
                closeSidebar(sidebar, mainContent, hamburger, sidebarCollapsed);
            }
        });
        
        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            // Ctrl/Cmd + B to toggle sidebar
            if ((e.ctrlKey || e.metaKey) && e.key === 'b') {
                e.preventDefault();
                toggleSidebar();
            }
        });
        
        // Listen for theme changes and update logo
        window.addEventListener('themeChanged', function(e) {
            updateLogoColors();
        });
        
        // Function to force logo color update
        function updateLogoColors() {
            const logo = document.querySelector('.theme-logo');
            if (logo) {
                // Force a repaint by temporarily changing a property
                logo.style.opacity = '0.99';
                setTimeout(() => {
                    logo.style.opacity = '1';
                }, 10);
            }
        }
        
        // Initial logo color update
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(updateLogoColors, 100);
        });
    </script>

    <script>
        (function () {
            var trigger = document.getElementById('profileTrigger');
            var dropdown = document.getElementById('profileDropdown');
            var avatar = document.getElementById('profileAvatar');
            var avatarLarge = document.getElementById('profileAvatarLarge');
            var profileName = document.getElementById('profileName');
            var profileUsername = document.getElementById('profileUsername');
            var uploadButton = document.getElementById('avatarUploadButton');
            var uploadInput = document.getElementById('avatarUploadInput');

            if (!trigger || !dropdown || !avatar || !profileName) {
                return;
            }

            function toggleDropdown(forceOpen) {
                var isOpen = !dropdown.classList.contains('hidden');
                var shouldOpen = typeof forceOpen === 'boolean' ? forceOpen : !isOpen;
                dropdown.classList.toggle('hidden', !shouldOpen);
                trigger.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
            }

            trigger.addEventListener('click', function () {
                toggleDropdown();
            });

            document.addEventListener('click', function (event) {
                if (!dropdown.contains(event.target) && !trigger.contains(event.target)) {
                    toggleDropdown(false);
                }
            });

            var defaultAvatarUrl = '/images/noavatar.jpg';

            function setAvatarFromUrl(url) {
                if (!url) {
                    return;
                }
                avatar.style.backgroundImage = 'url(' + url + ')';
                avatar.classList.add('image');
                avatar.textContent = '';
                if (avatarLarge) {
                    avatarLarge.style.backgroundImage = 'url(' + url + ')';
                    avatarLarge.classList.add('image');
                    avatarLarge.textContent = '';
                }
            }

            setAvatarFromUrl(defaultAvatarUrl);

            var isAuthenticated = '@(User?.Identity?.IsAuthenticated == true ? "true" : "false")' === 'true';
            if (isAuthenticated) {
                fetch('/api/account/profile')
                    .then(function (res) { return res.ok ? res.json() : null; })
                    .then(function (data) {
                        if (!data) return;
                        var displayName = data.username || 'User';
                        profileName.textContent = displayName;
                        if (profileUsername) {
                            profileUsername.textContent = displayName;
                        }
                        if (data.avatarUrl) {
                            setAvatarFromUrl(data.avatarUrl + '?v=' + Date.now());
                        }
                    });
            }

            if (uploadButton && uploadInput) {
                uploadButton.addEventListener('click', function () {
                    uploadInput.click();
                });
                uploadInput.addEventListener('change', function () {
                    if (!uploadInput.files || !uploadInput.files.length) return;
                    var formData = new FormData();
                    formData.append('avatar', uploadInput.files[0]);
                    fetch('/api/account/avatar', {
                        method: 'POST',
                        body: formData
                    }).then(function (res) {
                        if (!res.ok) {
                            return res.json().then(function (data) {
                                throw new Error(data && data.message ? data.message : 'Upload failed');
                            });
                        }
                        return res.json();
                    }).then(function () {
                        setAvatarFromUrl('/api/account/avatar?v=' + Date.now());
                    }).catch(function (err) {
                        alert(err.message);
                    });
                });
            }

            var changePasswordButton = document.getElementById('changePasswordButton');
            if (changePasswordButton) {
                changePasswordButton.addEventListener('click', function () {
                    var modal = document.getElementById('changePasswordModal');
                    if (modal) {
                        modal.classList.remove('hidden');
                    }
                });
            }

            var changeUsernameButton = document.getElementById('changeUsernameButton');
            if (changeUsernameButton) {
                changeUsernameButton.addEventListener('click', function () {
                    var modal = document.getElementById('changeUsernameModal');
                    if (modal) {
                        modal.classList.remove('hidden');
                    }
                });
            }
        })();
    </script>

    @if (User?.Identity?.IsAuthenticated == true && User.HasClaim("must_change_password", "true"))
    {
        <div id="credentialChangeModal" class="app-modal">
            <div class="app-modal-backdrop"></div>
            <div class="app-modal-dialog">
                <div class="app-modal-header">
                    <h3 class="app-modal-title">Update Login Details</h3>
                </div>
                <form id="credentialChangeForm" novalidate>
                    <div class="app-modal-body">
                        <p class="app-modal-message">For security, change the default login details now.</p>
                        <input id="currentPassword" class="app-modal-input" type="password" placeholder="Current password" autocomplete="current-password" />
                        <input id="newUsername" class="app-modal-input" type="text" placeholder="New username" autocomplete="username" />
                        <input id="newPassword" class="app-modal-input" type="password" placeholder="New password" autocomplete="new-password" />
                        <div id="credentialChangeError" class="text-danger small"></div>
                    </div>
                    <div class="app-modal-footer">
                        <button id="credentialChangeSubmit" class="app-modal-action primary" type="button">Save</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            (function () {
                var modal = document.getElementById('credentialChangeModal');
                if (modal) {
                    modal.classList.remove('hidden');
                    var newUsername = document.getElementById('newUsername');
                    if (newUsername && newUsername.value === '') {
                        newUsername.value = '@User.Identity?.Name';
                    }
                }

                var submit = document.getElementById('credentialChangeSubmit');
                if (!submit) return;

                submit.addEventListener('click', async function () {
                    var currentPassword = document.getElementById('currentPassword');
                    var newUsername = document.getElementById('newUsername');
                    var newPassword = document.getElementById('newPassword');
                    var errorBox = document.getElementById('credentialChangeError');

                    if (errorBox) {
                        errorBox.textContent = '';
                    }

                    if (!currentPassword.value || !newUsername.value || !newPassword.value) {
                        if (errorBox) {
                            errorBox.textContent = 'All fields are required.';
                        }
                        return;
                    }

                    try {
                        var response = await fetch('/api/account/change-credentials', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                currentPassword: currentPassword.value,
                                newUsername: newUsername.value,
                                newPassword: newPassword.value
                            })
                        });

                        if (!response.ok) {
                            var data = await response.json().catch(function () { return null; });
                            if (errorBox) {
                                errorBox.textContent = (data && data.message) ? data.message : 'Unable to update login details.';
                            }
                            return;
                        }

                        window.location.reload();
                    } catch (err) {
                        if (errorBox) {
                            errorBox.textContent = 'Unable to update login details.';
                        }
                    }
                });
            })();
        </script>
    }

    @if (User?.Identity?.IsAuthenticated == true)
    {
        <div id="changeUsernameModal" class="app-modal hidden">
            <div class="app-modal-backdrop"></div>
            <div class="app-modal-dialog">
                <div class="app-modal-header">
                    <h3 class="app-modal-title">Change Username</h3>
                    <button class="app-modal-close" type="button" id="changeUsernameClose">×</button>
                </div>
                <form id="changeUsernameForm" novalidate>
                    <div class="app-modal-body">
                        <input
                            id="changeUsernameCurrentUsername"
                            class="app-modal-input"
                            type="text"
                            value="@User.Identity?.Name"
                            autocomplete="username"
                            tabindex="-1"
                            aria-hidden="true"
                            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;" />
                        <input id="changeUsernameCurrentPassword" class="app-modal-input" type="password" placeholder="Current password" autocomplete="current-password" />
                        <input id="changeUsernameNew" class="app-modal-input" type="text" placeholder="New username" autocomplete="username" />
                        <div id="changeUsernameError" class="text-danger small"></div>
                    </div>
                    <div class="app-modal-footer">
                        <button id="changeUsernameSubmit" class="app-modal-action primary" type="button">Update username</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="changePasswordModal" class="app-modal hidden">
            <div class="app-modal-backdrop"></div>
            <div class="app-modal-dialog">
                <div class="app-modal-header">
                    <h3 class="app-modal-title">Change Password</h3>
                    <button class="app-modal-close" type="button" id="changePasswordClose">×</button>
                </div>
                <form id="changePasswordForm" novalidate>
                    <div class="app-modal-body">
                        <input
                            id="changePasswordUsername"
                            class="app-modal-input"
                            type="text"
                            value="@User.Identity?.Name"
                            autocomplete="username"
                            tabindex="-1"
                            aria-hidden="true"
                            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;" />
                        <input id="changePasswordCurrent" class="app-modal-input" type="password" placeholder="Current password" autocomplete="current-password" />
                        <input id="changePasswordNew" class="app-modal-input" type="password" placeholder="New password" autocomplete="new-password" />
                        <div id="changePasswordError" class="text-danger small"></div>
                    </div>
                    <div class="app-modal-footer">
                        <button id="changePasswordSubmit" class="app-modal-action primary" type="button">Update password</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            (function () {
                var usernameModal = document.getElementById('changeUsernameModal');
                var usernameCloseButton = document.getElementById('changeUsernameClose');
                var usernameSubmitButton = document.getElementById('changeUsernameSubmit');
                var usernameErrorBox = document.getElementById('changeUsernameError');
                var modal = document.getElementById('changePasswordModal');
                var closeButton = document.getElementById('changePasswordClose');
                var submitButton = document.getElementById('changePasswordSubmit');
                var errorBox = document.getElementById('changePasswordError');
                if (!modal || !submitButton) return;

                function closeUsernameModal() {
                    if (!usernameModal) return;
                    usernameModal.classList.add('hidden');
                    if (usernameErrorBox) {
                        usernameErrorBox.textContent = '';
                    }
                }

                function closeModal() {
                    modal.classList.add('hidden');
                    if (errorBox) {
                        errorBox.textContent = '';
                    }
                }

                if (usernameCloseButton) {
                    usernameCloseButton.addEventListener('click', closeUsernameModal);
                }

                if (usernameModal) {
                    usernameModal.addEventListener('click', function (event) {
                        if (event.target.classList.contains('app-modal-backdrop')) {
                            closeUsernameModal();
                        }
                    });
                }

                if (closeButton) {
                    closeButton.addEventListener('click', closeModal);
                }

                modal.addEventListener('click', function (event) {
                    if (event.target.classList.contains('app-modal-backdrop')) {
                        closeModal();
                    }
                });

                submitButton.addEventListener('click', async function () {
                    var currentPassword = document.getElementById('changePasswordCurrent');
                    var newPassword = document.getElementById('changePasswordNew');

                    if (errorBox) {
                        errorBox.textContent = '';
                    }

                    if (!currentPassword.value || !newPassword.value) {
                        if (errorBox) {
                            errorBox.textContent = 'All fields are required.';
                        }
                        return;
                    }

                    try {
                        var response = await fetch('/api/account/change-password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                currentPassword: currentPassword.value,
                                newPassword: newPassword.value
                            })
                        });

                        if (!response.ok) {
                            var data = await response.json().catch(function () { return null; });
                            if (errorBox) {
                                errorBox.textContent = (data && data.message) ? data.message : 'Unable to update password.';
                            }
                            return;
                        }

                        closeModal();
                    } catch (err) {
                        if (errorBox) {
                            errorBox.textContent = 'Unable to update password.';
                        }
                    }
                });

                if (usernameSubmitButton) {
                    usernameSubmitButton.addEventListener('click', async function () {
                        var currentPassword = document.getElementById('changeUsernameCurrentPassword');
                        var newUsername = document.getElementById('changeUsernameNew');

                        if (usernameErrorBox) {
                            usernameErrorBox.textContent = '';
                        }

                        if (!currentPassword.value || !newUsername.value) {
                            if (usernameErrorBox) {
                                usernameErrorBox.textContent = 'All fields are required.';
                            }
                            return;
                        }

                        try {
                            var response = await fetch('/api/account/change-username', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    currentPassword: currentPassword.value,
                                    newUsername: newUsername.value
                                })
                            });

                            if (!response.ok) {
                                var data = await response.json().catch(function () { return null; });
                                if (usernameErrorBox) {
                                    usernameErrorBox.textContent = (data && data.message) ? data.message : 'Unable to update username.';
                                }
                                return;
                            }

                            closeUsernameModal();
                            window.location.reload();
                        } catch (err) {
                            if (usernameErrorBox) {
                                usernameErrorBox.textContent = 'Unable to update username.';
                            }
                        }
                    });
                }
            })();
        </script>
    }

        @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
