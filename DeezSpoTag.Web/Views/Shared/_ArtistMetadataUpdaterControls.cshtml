<p class="metadata-updater-description tool-card-info">Refresh artist metadata and rotate avatar/background artwork before pushing updates to your selected media server.</p>
<select id="metadata-refresh-interval">
    <option value="180">6 months</option>
    <option value="90">3 months</option>
    <option value="30" selected>1 month</option>
    <option value="14">2 weeks</option>
    <option value="7">1 week</option>
    <option value="0">Full refresh</option>
</select>
<select id="metadata-target-server">
    <option value="plex" selected>Plex</option>
    <option value="jellyfin">Jellyfin</option>
    <option value="both">Both</option>
</select>
