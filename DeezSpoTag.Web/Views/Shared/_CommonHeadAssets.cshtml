      rel="stylesheet"
      integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
      crossorigin="anonymous">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
      integrity="sha384-iw3OoTErCYJJB9mCa8LNS2hbsQ7M3C0EpIsO/H5+EGAkPGc6rk+V8i04oW/K5xq0"
      crossorigin="anonymous">
<link href="~/css/material-icons-local.css" rel="stylesheet" asp-append-version="true">
<script src="~/js/spotify-url-helpers.js" asp-append-version="true"></script>
<script>
    (function () {
        try {
            var availableThemes = ['blue', 'purple', 'green', 'orange', 'red', 'teal', 'indigo', 'pink', 'amoled-white', 'amoled-red', 'amoled-yellow', 'amoled-blue', 'amoled-neon', 'amoled-green', 'amoled-purple', 'amoled-inverse'];
            var prefs = globalThis.__userPrefsData || {};
            var preferredTheme = (prefs && typeof prefs.theme === 'string') ? prefs.theme : '';
            var theme = availableThemes.indexOf(preferredTheme) !== -1 ? preferredTheme : 'blue';
            var root = document.documentElement;
            availableThemes.forEach(function (name) { root.classList.remove('theme-' + name); });
            root.classList.add('theme-' + theme);
            root.setAttribute('data-theme', theme);
        } catch (e) {
        }
    })();
</script>
<link href="~/css/themes.css" rel="stylesheet" asp-append-version="true">
<link href="~/css/site.css" rel="stylesheet" asp-append-version="true">
