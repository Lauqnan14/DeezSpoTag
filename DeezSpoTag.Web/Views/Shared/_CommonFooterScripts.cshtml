@inject DeezSpoTag.Web.Services.AppInstanceIdProvider AppInstanceIdProvider
@{
    var includeSignalR = ViewData["IncludeSignalR"] as bool? ?? false;
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
        integrity="sha512-VK2zcvntEufaimc+efOYi622VN5ZacdnufnmX7zIhCPmjhKnOi9ZDMtg1/ug5l183f19gG1/cBstPO4D8N/Img=="
        crossorigin="anonymous"></script>
@if (includeSignalR)
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"
            integrity="sha512-ZqjBuyHOJ5inr58y0trfRo8TgD0zC0WJROOUmgjAIA6iiqXxobgj3ZocloB2Wp9ov2+LB9UM09aiwI3MDpm5HA=="
            crossorigin="anonymous"></script>
}
<script src="~/js/themes.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/deezer-playback-context.js" asp-append-version="true"></script>
<script src="~/js/deezer-resolver.js" asp-append-version="true"></script>
<script src="~/js/deezer-playback-facade.js" asp-append-version="true"></script>
<script src="~/js/deezer-playback-state.js" asp-append-version="true"></script>
<script src="~/js/deezer-unified-playback.js" asp-append-version="true"></script>
<script>
    window.DeezSpoTagAppInstanceId = '@AppInstanceIdProvider.InstanceId';
</script>
<script>
    const isLocalHost = ["localhost", "127.0.0.1", "::1"].includes(window.location.hostname);
    if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
            if (isLocalHost) {
                navigator.serviceWorker.getRegistrations()
                    .then(function (registrations) {
                        return Promise.all((registrations || []).map(function (registration) {
                            return registration.unregister();
                        }));
                    })
                    .catch(function () {
                    });
                if (window.caches && typeof window.caches.keys === "function") {
                    window.caches.keys()
                        .then(function (keys) {
                            return Promise.all((keys || []).map(function (key) {
                                return window.caches.delete(key);
                            }));
                        })
                        .catch(function () {
                        });
                }
                return;
            }

            navigator.serviceWorker.register("/sw.js").catch(function () {
            });
        });
    }
</script>
