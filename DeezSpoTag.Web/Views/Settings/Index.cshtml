            cover: getChecked('tagCover', baseTags.cover ?? true),
            trackNumber: getChecked('tagTrackNumber', baseTags.trackNumber ?? true),
            trackTotal: getChecked('tagTrackTotal', baseTags.trackTotal ?? false),
            discNumber: getChecked('tagDiscNumber', baseTags.discNumber ?? true),
            discTotal: getChecked('tagDiscTotal', baseTags.discTotal ?? false),
            albumArtist: getChecked('tagAlbumArtist', baseTags.albumArtist ?? true),
            genre: getChecked('tagGenre', baseTags.genre ?? true),
            year: getChecked('tagYear', baseTags.year ?? true),
            date: getChecked('tagDate', baseTags.date ?? true),
            explicit: getChecked('tagExplicit', baseTags.explicit ?? false),
            isrc: getChecked('tagISRC', baseTags.isrc ?? true),
            length: getChecked('tagLength', baseTags.length ?? true),
            barcode: getChecked('tagBarcode', baseTags.barcode ?? true),
            bpm: getChecked('tagBPM', baseTags.bpm ?? true),
            replayGain: getChecked('tagReplayGain', baseTags.replayGain ?? false),
            label: getChecked('tagLabel', baseTags.label ?? true),
            lyrics: getChecked('tagLyrics', baseTags.lyrics ?? false),
            tagSyncedLyrics: getChecked('tagSyncedLyrics', baseTags.tagSyncedLyrics ?? baseTags.syncedLyrics ?? false),
            copyright: getChecked('tagCopyright', baseTags.copyright ?? false),
            composer: getChecked('tagComposer', baseTags.composer ?? false),
            involvedPeople: getChecked('tagInvolvedPeople', baseTags.involvedPeople ?? false),
            source: getChecked('tagSource', baseTags.source ?? false),
            rating: baseTags.rating ?? false,
            coverDescriptionUTF8: getChecked('coverDescriptionUTF8', baseTags.coverDescriptionUTF8 ?? false)
        }
    };

    return formData;
}

async function saveSettings(showSuccessToast = true) {
    if (settingsSaveInFlight) {
        settingsSaveQueued = true;
        settingsSaveQueuedToast = settingsSaveQueuedToast || showSuccessToast;
        return;
    }

    settingsSaveInFlight = true;
    try {
        const settings = collectFormData();
        
        const response = await fetch('/api/settings', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(settings),
            credentials: 'same-origin'
        });

        const responseText = await response.text();
        let result = {};
        if (responseText) {
            try {
                result = JSON.parse(responseText);
            } catch {
                result = { error: responseText };
            }
        }
        
        if (response.ok && result?.result !== false) {
            await saveLibraryScanSettings();
            currentSettings = settings;
            if (window.DeezSpoTagDownload && typeof window.DeezSpoTagDownload.applyUpdatedSettings === 'function') {
                window.DeezSpoTagDownload.applyUpdatedSettings(settings);
            }
            window.dispatchEvent(new CustomEvent('deezspotag:settings-updated', {
                detail: {
                    settings
                }
            }));
            persistAppleNotificationPreference();
            if (showSuccessToast) {
                showToast('Settings saved successfully!', 'success');
            }
        } else {
            if (response.status === 429) {
                throw new Error('Too many save requests. Please wait a few seconds and try again.');
            }
            throw new Error(result?.error || `HTTP ${response.status}: Failed to save settings`);
        }
    } catch (error) {
        console.error('Error saving settings:', error);
        showToast(error?.message || 'Failed to save settings.', 'error');
    } finally {
        settingsSaveInFlight = false;
        if (settingsSaveQueued) {
            const queuedToast = settingsSaveQueuedToast;
            settingsSaveQueued = false;
            settingsSaveQueuedToast = false;
            window.setTimeout(() => saveSettings(queuedToast), 0);
        }
    }
}

function showToast(message, type = 'info') {
    if (window.DeezSpoTag?.showNotification) {
        window.DeezSpoTag.showNotification(message, type);
        return;
    }

    const existingToasts = document.querySelectorAll('.toast-notification');
    existingToasts.forEach(toast => toast.remove());
    
    const toast = document.createElement('div');
    toast.className = `toast-notification toast-${type}`;
    toast.textContent = message;
    
    toast.style.position = 'fixed';
    toast.style.top = '20px';
    toast.style.right = '20px';
    toast.style.padding = '12px 20px';
    toast.style.borderRadius = '6px';
    toast.style.fontWeight = '500';
    toast.style.zIndex = '10000';
    toast.style.maxWidth = '300px';
    toast.style.wordWrap = 'break-word';
    
    document.body.appendChild(toast);
    
    setTimeout(() => {
        if (toast.parentNode) {
            toast.remove();
        }
    }, 5000);
}

async function resetSettings() {
    const confirmed = await DeezSpoTag.ui.confirm('Are you sure you want to reset all settings to defaults?', {
        title: 'Reset Settings'
    });
    if (!confirmed) {
        return;
    }
    
    try {
        const response = await fetch('/api/settings/reset', {
            method: 'POST'
        });
        
        const result = await response.json();
        
        if (response.ok) {
            loadSettings(result.settings);
            await saveLibraryScanSettings({
                fuzzyThreshold: 0.85,
                includeAllFolders: true,
                livePreviewIngest: false,
                enableSignalAnalysis: false
            });
            showToast('Settings reset to defaults!', 'success');
        } else {
            throw new Error(result.error || 'Failed to reset settings');
        }
    } catch (error) {
        console.error('Error resetting settings:', error);
    }
}</script>
}
