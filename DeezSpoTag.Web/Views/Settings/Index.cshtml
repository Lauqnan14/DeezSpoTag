function setupArtworkFallbackOrder() {
    const dropdown = document.getElementById('artworkFallbackOrderDropdown');
    const trigger = document.getElementById('artworkFallbackOrderTrigger');
    const menu = document.getElementById('artworkFallbackOrderMenu');
    const list = document.getElementById('artworkFallbackOrderList');
    const input = document.getElementById('artworkFallbackOrder');

    if (!dropdown || !trigger || !menu || !list || !input) {
        return;
    }

    trigger.addEventListener('click', (event) => {
        event.stopPropagation();
        menu.classList.toggle('open');
    });

    document.addEventListener('click', () => menu.classList.remove('open'));

    const labelMap = {
        apple: 'iTunes',
        deezer: 'Deezer',
        spotify: 'Spotify'
    };

    const updateValue = () => {
        const order = Array.from(list.querySelectorAll('.artwork-order-item'))
            .map(item => item.dataset.value || '')
            .filter(Boolean);
        input.value = order.join(',');
        const labels = order.map(value => labelMap[value] || value);
        trigger.textContent = labels.join(' \u2192 ');
    };

    let dragged = null;

    list.addEventListener('dragstart', (event) => {
        const target = event.target.closest('.artwork-order-item');
        if (!target) {
            return;
        }
        dragged = target;
        event.dataTransfer?.setData('text/plain', target.dataset.value || '');
        event.dataTransfer?.setDragImage(target, 10, 10);
        target.classList.add('dragging');
    });

    list.addEventListener('dragend', () => {
        if (dragged) {
            dragged.classList.remove('dragging');
            dragged = null;
        }
        updateValue();
    });

    list.addEventListener('dragover', (event) => {
        event.preventDefault();
        const target = event.target.closest('.artwork-order-item');
        if (!dragged || !target || dragged === target) {
            return;
        }

        const rect = target.getBoundingClientRect();
        const before = event.clientY < rect.top + rect.height / 2;
        list.insertBefore(dragged, before ? target : target.nextSibling);
    });

    const syncFromInput = () => {
        const order = (input.value || '')
            .split(',')
            .map(value => value.trim())
            .filter(Boolean);
        if (order.length === 0) {
            updateValue();
            return;
        }

        const items = Array.from(list.querySelectorAll('.artwork-order-item'));
        const byValue = new Map(items.map(item => [item.dataset.value, item]));
        list.innerHTML = '';
        order.forEach(value => {
            const item = byValue.get(value);
            if (item) {
                list.appendChild(item);
            }
        });
        items.forEach(item => {
            if (!list.contains(item)) {
                list.appendChild(item);
            }
        });
        updateValue();
    };

    syncFromInput();
}


