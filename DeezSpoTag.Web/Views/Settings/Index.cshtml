function setFieldValue(fieldId, value) {
    const field = document.getElementById(fieldId);
    if (field && value !== undefined && value !== null) {
        field.value = value;
        if (field.type === 'hidden') {
            const dropdown = field.closest('.dropdown-select');
            if (dropdown) {
                const trigger = dropdown.querySelector('.dropdown-trigger');
                const option = dropdown.querySelector(`.dropdown-option[data-value="${value}"]`);
                if (trigger && option) {
                    trigger.textContent = option.textContent || String(value);
                    dropdown.querySelectorAll('.dropdown-option').forEach(btn => btn.setAttribute('aria-selected', 'false'));
                    option.setAttribute('aria-selected', 'true');
                }
                if (fieldId === 'downloadSource') {
                    updateQualityDropdownVisibility(String(value), false);
                }
            }
        }
    }
}

function setCheckboxValue(fieldId, value) {
    const field = document.getElementById(fieldId);
    if (field) {
        field.checked = value === true;
    }
}

function setMaxBitrateValue(bitrateValue) {
    let mappedValue;
    switch (bitrateValue) {
        case 9:
            mappedValue = "9";
            break;
        case 3:
            mappedValue = "3";
            break;
        case 1:
        default:
            mappedValue = "1";
            break;
    }

    setFieldValue('maxBitrate', mappedValue);
}

function triggerDependentFields() {
    document.getElementById('createPlaylistFolder')?.dispatchEvent(new Event('change'));
    document.getElementById('createArtistFolder')?.dispatchEvent(new Event('change'));
    document.getElementById('createAlbumFolder')?.dispatchEvent(new Event('change'));
    document.getElementById('saveArtwork')?.dispatchEvent(new Event('change'));
    document.getElementById('saveArtworkArtist')?.dispatchEvent(new Event('change'));
    document.getElementById('realTime')?.dispatchEvent(new Event('change'));
    document.getElementById('convertTo')?.dispatchEvent(new Event('change'));
    document.getElementById('multiQualityEnabled')?.dispatchEvent(new Event('change'));
    document.getElementById('normalizeGenreTags')?.dispatchEvent(new Event('change'));
}

