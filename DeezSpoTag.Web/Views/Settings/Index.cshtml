async function readMediaServerLibraryPinApiError(response, fallback) {
    if (!response) {
        return fallback;
    }

    try {
        const payload = await response.json();
        const error = typeof payload?.error === 'string' ? payload.error.trim() : '';
        if (error) {
            return error;
        }
    } catch {
    }

    return fallback;
}

async function requestMediaServerLibraryPinUnlock(pin, confirmationPin = '') {
    const response = await fetch('/api/media-server/soundtracks/pin/unlock', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        credentials: 'same-origin',
        body: JSON.stringify({
            pin,
            confirmationPin
        })
    });

    if (!response.ok) {
        throw new Error(await readMediaServerLibraryPinApiError(response, `HTTP ${response.status}: ${response.statusText}`));
    }

    const payload = await response.json();
    return {
        unlocked: payload?.unlocked === true,
        created: payload?.created === true
    };
}

async function requestMediaServerLibraryPinChange(currentPin, newPin, confirmationPin) {
    const response = await fetch('/api/media-server/soundtracks/pin/change', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        credentials: 'same-origin',
        body: JSON.stringify({
            currentPin,
            newPin,
            confirmationPin
        })
    });

    if (!response.ok) {
        throw new Error(await readMediaServerLibraryPinApiError(response, `HTTP ${response.status}: ${response.statusText}`));
    }
}

async function requestMediaServerLibraryPinReset(currentPin) {
    const response = await fetch('/api/media-server/soundtracks/pin/reset', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        credentials: 'same-origin',
        body: JSON.stringify({
            currentPin
        })
    });

    if (!response.ok) {
        throw new Error(await readMediaServerLibraryPinApiError(response, `HTTP ${response.status}: ${response.statusText}`));
    }

    const payload = await response.json();
    return payload?.configured === true;
}

async function loadMediaServerLibraryPinState() {
    try {
        const response = await fetch('/api/media-server/soundtracks/pin/status', {
            credentials: 'same-origin'
        });

        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }

        const payload = await response.json();
        mediaServerLibraryPinConfigured = payload?.configured === true;

        if (!mediaServerLibraryPinConfigured) {
            const legacyPin = getLegacyMediaServerLibraryPin();
            if (legacyPin) {
                const migrated = await requestMediaServerLibraryPinUnlock(legacyPin, legacyPin);
                if (migrated.unlocked) {
                    mediaServerLibraryPinConfigured = true;
                    clearLegacyMediaServerLibraryPin();
                }
            }
        }
    } catch (error) {
        console.error('Failed to load media server PIN state.', error);
        mediaServerLibraryPinConfigured = normalizeMediaServerLibraryPin(getLegacyMediaServerLibraryPin()).length > 0;
        setMediaServerLibraryPinStatus('PIN state sync failed. Falling back to local browser PIN state.', true);
    } finally {
        updateMediaServerLibraryPinControls();
    }
}

async function promptForMediaServerLibraryPin(promptMessage, title = 'PIN') {
    if (window.DeezSpoTag?.ui?.prompt) {
        const raw = await window.DeezSpoTag.ui.prompt(promptMessage, {
            title,
            type: 'password',
            placeholder: 'Enter PIN',
            autocomplete: 'off',
            okText: 'Continue'
        });
        if (raw === null) {
            return null;
        }

        const value = normalizeMediaServerLibraryPin(raw);
        return value || null;
    }

    const fallbackRaw = window.prompt(promptMessage);
    if (fallbackRaw === null) {
        return null;
    }

    const fallbackValue = normalizeMediaServerLibraryPin(fallbackRaw);
    return fallbackValue || null;
}

async function confirmMediaServerLibraryPinReset(message, title = 'Reset PIN') {
    if (window.DeezSpoTag?.ui?.confirm) {
        return await window.DeezSpoTag.ui.confirm(message, {
            title,
            okText: 'Reset PIN',
            cancelText: 'Cancel'
        });
    }

    return window.confirm(message);
}

function setMediaServerLibraryUnlockButtonLabel(text) {
    const unlockButton = document.getElementById('unlockServerLibrariesBtn');
    if (!unlockButton) {
        return;
    }

    const label = unlockButton.querySelector('span:not(.material-icons)');
    if (label) {
        label.textContent = text;
    }
}

function updateMediaServerLibraryPinControls() {
    const pinInput = document.getElementById('serverLibraryPinInput');
    const pinConfirmInput = document.getElementById('serverLibraryPinConfirmInput');
    const unlockButton = document.getElementById('unlockServerLibrariesBtn');
    const lockButton = document.getElementById('lockServerLibrariesBtn');
    const changeButton = document.getElementById('changeServerLibrariesPinBtn');
    const resetButton = document.getElementById('resetServerLibrariesPinBtn');
    if (!pinInput || !pinConfirmInput || !unlockButton || !lockButton || !changeButton || !resetButton) {
        return;
    }

    if (mediaServerLibraryAdvancedUnlocked) {
        pinInput.disabled = true;
        pinInput.hidden = true;
        pinInput.value = '';
        pinInput.placeholder = mediaServerLibraryPinConfigured ? 'PIN is set' : 'Create PIN';
        pinConfirmInput.disabled = true;
        pinConfirmInput.value = '';
        pinConfirmInput.placeholder = 'Confirm PIN';
        pinConfirmInput.hidden = true;
        unlockButton.hidden = true;
        lockButton.hidden = false;
        changeButton.hidden = !mediaServerLibraryPinConfigured;
        resetButton.hidden = !mediaServerLibraryPinConfigured;
        setMediaServerLibraryPinStatus('Hidden libraries are unlocked for editing.');
        return;
    }

    pinInput.disabled = false;
    pinInput.hidden = false;
    unlockButton.hidden = false;
    lockButton.hidden = true;
    changeButton.hidden = !mediaServerLibraryPinConfigured;
    resetButton.hidden = !mediaServerLibraryPinConfigured;
    if (mediaServerLibraryPinConfigured) {
        setMediaServerLibraryUnlockButtonLabel('Unlock');
        pinInput.placeholder = 'Enter PIN';
        pinConfirmInput.disabled = true;
        pinConfirmInput.value = '';
        pinConfirmInput.placeholder = 'Confirm PIN (only needed when creating PIN)';
        pinConfirmInput.hidden = true;
        setMediaServerLibraryPinStatus('Hidden libraries are locked. Enter PIN to manage hidden libraries.');
    } else {
        setMediaServerLibraryUnlockButtonLabel('Set PIN & Unlock');
        pinInput.placeholder = 'Create PIN';
        pinConfirmInput.disabled = false;
        pinConfirmInput.placeholder = 'Confirm new PIN';
        pinConfirmInput.hidden = false;
        changeButton.hidden = true;
        resetButton.hidden = true;
        setMediaServerLibraryPinStatus('No PIN configured yet. Enter and confirm a new PIN to unlock.');
    }
}

function setMediaServerLibraryAdvancedUnlocked(unlocked) {
    mediaServerLibraryAdvancedUnlocked = unlocked === true;
    updateMediaServerLibraryPinControls();
    if (mediaServerLibraryConfig) {
        renderMediaServerLibraryConfiguration(mediaServerLibraryConfig);
    }
}

function bindMediaServerLibraryPinActions() {
    const pinInput = document.getElementById('serverLibraryPinInput');
    const pinConfirmInput = document.getElementById('serverLibraryPinConfirmInput');
    const unlockButton = document.getElementById('unlockServerLibrariesBtn');
    const lockButton = document.getElementById('lockServerLibrariesBtn');
    const changeButton = document.getElementById('changeServerLibrariesPinBtn');
    const resetButton = document.getElementById('resetServerLibrariesPinBtn');
    if (!pinInput || !pinConfirmInput || !unlockButton || !lockButton || !changeButton || !resetButton || unlockButton.dataset.bound === 'true') {
        return;
    }

    unlockButton.addEventListener('click', async () => {
        const entered = normalizeMediaServerLibraryPin(pinInput.value);
        if (!entered) {
            setMediaServerLibraryPinStatus('Enter a PIN first.', true);
            return;
        }

        const confirmation = normalizeMediaServerLibraryPin(pinConfirmInput.value);
        if (!mediaServerLibraryPinConfigured) {
            if (entered.length < 4) {
                setMediaServerLibraryPinStatus('PIN must be at least 4 characters.', true);
                return;
            }

            if (!confirmation) {
                setMediaServerLibraryPinStatus('Confirm your new PIN.', true);
                return;
            }

            if (entered !== confirmation) {
                setMediaServerLibraryPinStatus('PIN confirmation does not match.', true);
                return;
            }
        }

        unlockButton.disabled = true;
        try {
            const result = await requestMediaServerLibraryPinUnlock(
                entered,
                mediaServerLibraryPinConfigured ? '' : confirmation);
            if (!result.unlocked) {
                setMediaServerLibraryPinStatus('PIN unlock failed.', true);
                return;
            }

            mediaServerLibraryPinConfigured = true;
            clearLegacyMediaServerLibraryPin();
            pinInput.value = '';
            pinConfirmInput.value = '';
            setMediaServerLibraryAdvancedUnlocked(true);
            if (result.created) {
                setMediaServerLibraryPinStatus('PIN created. Hidden libraries are now unlocked.');
            } else {
                setMediaServerLibraryPinStatus('Hidden libraries are unlocked for editing.');
            }
        } catch (error) {
            setMediaServerLibraryPinStatus(error?.message || 'Failed to unlock hidden libraries.', true);
        } finally {
            unlockButton.disabled = false;
        }
    });

    lockButton.addEventListener('click', () => {
        setMediaServerLibraryAdvancedUnlocked(false);
    });

    changeButton.addEventListener('click', async () => {
        if (!mediaServerLibraryPinConfigured) {
            setMediaServerLibraryPinStatus('No PIN is configured yet.', true);
            return;
        }

        const currentPin = await promptForMediaServerLibraryPin('Enter your current PIN to change it:', 'Change PIN');
        if (!currentPin) {
            setMediaServerLibraryPinStatus('PIN change canceled.', true);
            return;
        }

        const newPin = await promptForMediaServerLibraryPin('Enter your new PIN:', 'Change PIN');
        if (!newPin) {
            setMediaServerLibraryPinStatus('PIN change canceled.', true);
            return;
        }

        const confirmationPin = await promptForMediaServerLibraryPin('Confirm your new PIN:', 'Change PIN');
        if (!confirmationPin) {
            setMediaServerLibraryPinStatus('PIN change canceled.', true);
            return;
        }

        changeButton.disabled = true;
        try {
            await requestMediaServerLibraryPinChange(currentPin, newPin, confirmationPin);
            mediaServerLibraryPinConfigured = true;
            clearLegacyMediaServerLibraryPin();
            pinInput.value = '';
            pinConfirmInput.value = '';
            updateMediaServerLibraryPinControls();
            setMediaServerLibraryPinStatus('PIN changed successfully.');
        } catch (error) {
            setMediaServerLibraryPinStatus(error?.message || 'Failed to change PIN.', true);
        } finally {
            changeButton.disabled = false;
        }
    });

    resetButton.addEventListener('click', async () => {
        if (!mediaServerLibraryPinConfigured) {
            setMediaServerLibraryPinStatus('No PIN is configured yet.', true);
            return;
        }

        const currentPin = await promptForMediaServerLibraryPin('Enter your current PIN to reset it:', 'Reset PIN');
        if (!currentPin) {
            setMediaServerLibraryPinStatus('PIN reset canceled.', true);
            return;
        }

        if (!await confirmMediaServerLibraryPinReset('Reset the PIN? Hidden libraries will lock until a new PIN is set.')) {
            return;
        }

        resetButton.disabled = true;
        try {
            const configured = await requestMediaServerLibraryPinReset(currentPin);
            mediaServerLibraryPinConfigured = configured === true;
            clearLegacyMediaServerLibraryPin();
            pinInput.value = '';
            pinConfirmInput.value = '';
            setMediaServerLibraryAdvancedUnlocked(false);
            setMediaServerLibraryPinStatus('PIN reset. Hidden libraries are now locked.', false);
        } catch (error) {
            setMediaServerLibraryPinStatus(error?.message || 'Failed to reset PIN.', true);
        } finally {
            resetButton.disabled = false;
        }
    });

    unlockButton.dataset.bound = 'true';
    updateMediaServerLibraryPinControls();
    void loadMediaServerLibraryPinState();
}

function applyLibraryHideToggleForRow(row) {
    if (!row) {
        return;
    }

    const includeInput = row.querySelector('[data-library-include]');
    const hideInput = row.querySelector('[data-library-hide]');
    if (!includeInput || !hideInput) {
        return;
    }

    const hidden = hideInput.checked === true;
    if (hidden) {
        includeInput.checked = false;
    }
}

function applyLibraryHideTogglesWithinCard(card) {
    if (!card) {
        return;
    }

    card.querySelectorAll('[data-library-row]').forEach(row => {
        applyLibraryHideToggleForRow(row);
    });
}

function renderMediaServerLibraryConfiguration(configuration) {
    const container = document.getElementById('serverLibraryConfigContainer');
    if (!container) {
        return;
    }

    const servers = Array.isArray(configuration?.servers) ? configuration.servers : [];
    if (servers.length === 0) {
        container.innerHTML = '<p class="server-library-empty">No server libraries discovered yet. Click Refresh Libraries after connecting Plex or Jellyfin.</p>';
        return;
    }

    container.innerHTML = servers.map(server => {
        const serverType = String(server?.serverType || '').trim().toLowerCase();
        const serverIdToken = (serverType || 'server').replace(/[^a-z0-9_-]/gi, '-');
        const serverLabel = String(server?.displayName || serverType || 'Server').trim();
        const connected = server?.connected === true;
        const autoInclude = server?.autoIncludeNewLibraries !== false;
        const autoIncludeToggleId = `server-autoinclude-${serverIdToken}`;
        const libraries = Array.isArray(server?.libraries) ? server.libraries : [];
        const sortedLibraries = libraries
            .slice()
            .sort((left, right) => String(left?.name || left?.libraryId || '').localeCompare(String(right?.name || right?.libraryId || ''), undefined, { sensitivity: 'base' }));

        const visibleLibraries = mediaServerLibraryAdvancedUnlocked
            ? sortedLibraries
            : sortedLibraries.filter(library => !(library?.ignored === true || library?.enabled === false));
        const hiddenCount = sortedLibraries.length - visibleLibraries.length;

        const libraryRows = visibleLibraries.length === 0
            ? `<tr><td colspan="${mediaServerLibraryAdvancedUnlocked ? 5 : 4}" class="server-library-empty">${
                hiddenCount > 0
                    ? `All libraries for this server are currently hidden. Unlock PIN to manage hidden libraries.`
                    : `No libraries discovered for this server yet.`
            }</td></tr>`
            : visibleLibraries.map(library => {
                const libraryId = String(library?.libraryId || '').trim();
                const libraryName = String(library?.name || libraryId || 'Library').trim();
                const libraryIdToken = libraryId.replace(/[^a-z0-9_-]/gi, '-');
                const categoryKey = normalizeMediaServerCategory(library?.category);
                const category = getMediaServerCategoryLabel(categoryKey);
                const libraryConnected = library?.connected === true;
                const include = library?.enabled !== false && library?.ignored !== true;
                const hidden = library?.ignored === true || library?.enabled === false;
                const includeToggleId = `server-include-${serverIdToken}-${libraryIdToken}`;
                const hideToggleId = `server-hide-${serverIdToken}-${libraryIdToken}`;
                return `<tr data-library-row="${escapeHtml(libraryId)}">
                    <td>${escapeHtml(libraryName)}</td>
                    <td>${escapeHtml(category)}</td>
                    <td>${libraryConnected ? '<span class="server-library-badge connected">Connected</span>' : '<span class="server-library-badge">Not connected</span>'}</td>
                    <td class="server-library-include-cell" data-library-category="${escapeHtml(categoryKey)}">
                        <label for="${escapeHtml(includeToggleId)}" class="visually-hidden">Include ${escapeHtml(libraryName)}</label>
                        <span class="switch">
                            <input id="${escapeHtml(includeToggleId)}" type="checkbox" data-library-include="${escapeHtml(libraryId)}" ${include ? 'checked' : ''}>
                            <span class="slider"></span>
                        </span>
                    </td>${
                        mediaServerLibraryAdvancedUnlocked
                            ? `<td class="server-library-include-cell">
                                <label for="${escapeHtml(hideToggleId)}" class="visually-hidden">Hide ${escapeHtml(libraryName)}</label>
                                <span class="switch">
                                    <input id="${escapeHtml(hideToggleId)}" type="checkbox" data-library-hide="${escapeHtml(libraryId)}" ${hidden ? 'checked' : ''}>
                                    <span class="slider"></span>
                                </span>
                            </td>`
                            : ''
                    }
                </tr>`;
            }).join('');

        return `<article class="server-library-card" data-server-card="${escapeHtml(serverType)}">
            <div class="server-library-card-header">
                <div>
                    <h3 class="server-library-card-title">${escapeHtml(serverLabel)}</h3>
                    <div class="server-library-badges">
                        ${connected ? '<span class="server-library-badge connected">Connected</span>' : '<span class="server-library-badge">Not connected</span>'}
                    </div>
                </div>
                <div class="switch-row server-library-header-toggle">
                    <label class="switch-label" for="${escapeHtml(autoIncludeToggleId)}">Auto-include new libraries</label>
                    <span class="switch">
                        <input id="${escapeHtml(autoIncludeToggleId)}" type="checkbox" data-server-autoinclude="${escapeHtml(serverType)}" ${autoInclude ? 'checked' : ''}>
                        <span class="slider"></span>
                    </span>
                </div>
            </div>
            ${hiddenCount > 0 && !mediaServerLibraryAdvancedUnlocked
                ? `<p class="server-library-hidden-note">${hiddenCount} hidden librar${hiddenCount === 1 ? 'y' : 'ies'} are hidden from this view until PIN unlock.</p>`
                : ''}
            <div class="server-library-table-wrap">
                <table class="server-library-table">
                    <thead>
                        <tr>
                            <th>Library</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Include</th>${
                                mediaServerLibraryAdvancedUnlocked
                                    ? '<th>Hidden</th>'
                                    : ''
                            }
                        </tr>
                    </thead>
                    <tbody>${libraryRows}</tbody>
                </table>
            </div>
        </article>`;
    }).join('');

    container.querySelectorAll('[data-server-card]').forEach(card => applyLibraryHideTogglesWithinCard(card));
}

async function loadMediaServerLibraryConfiguration(refresh = false) {
    const container = document.getElementById('serverLibraryConfigContainer');
    if (!container) {
        return;
    }

    setMediaServerLibraryStatus(refresh ? 'Refreshing server libraries...' : 'Loading server libraries...');
    try {
        const endpoint = refresh
            ? '/api/media-server/soundtracks/configuration?refresh=true'
            : '/api/media-server/soundtracks/configuration';
        const response = await fetch(endpoint, { credentials: 'same-origin' });
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }

        const configuration = await response.json();
        mediaServerLibraryConfig = configuration;
        renderMediaServerLibraryConfiguration(configuration);
        const servers = Array.isArray(configuration?.servers) ? configuration.servers : [];
        const libraries = servers.reduce((total, server) => total + (Array.isArray(server?.libraries) ? server.libraries.length : 0), 0);
        setMediaServerLibraryStatus(`Loaded ${libraries} libraries across ${servers.length} server${servers.length === 1 ? '' : 's'}.`);
    } catch (error) {
        console.error('Failed to load media server library configuration.', error);
        container.innerHTML = '<p class="server-library-empty">Failed to load server libraries.</p>';
        setMediaServerLibraryStatus(error?.message || 'Failed to load server libraries.', true);
    }
}

function collectMediaServerLibraryConfigurationUpdateRequest() {
    const container = document.getElementById('serverLibraryConfigContainer');
    if (!container) {
        return { servers: [] };
    }

    const servers = [];
    container.querySelectorAll('[data-server-card]').forEach(card => {
        const serverType = String(card.getAttribute('data-server-card') || '').trim().toLowerCase();
        if (!serverType) {
            return;
        }

        const autoIncludeInput = card.querySelector(`[data-server-autoinclude="${serverType}"]`);
        const libraries = [];
        card.querySelectorAll('[data-library-row]').forEach(row => {
            const libraryId = String(row.getAttribute('data-library-row') || '').trim();
            if (!libraryId) {
                return;
            }

            const includeInput = row.querySelector('[data-library-include]');
            const hideInput = row.querySelector('[data-library-hide]');
            const include = includeInput?.checked === true;
            const hidden = hideInput?.checked === true;
            libraries.push({
                libraryId,
                enabled: include,
                ignored: hidden || !include
            });
        });

        servers.push({
            serverType,
            autoIncludeNewLibraries: autoIncludeInput?.checked === true,
            libraries
        });
    });

    return { servers };
}

async function saveMediaServerLibraryConfiguration() {
    const request = collectMediaServerLibraryConfigurationUpdateRequest();
    setMediaServerLibraryStatus('Saving server libraries...');
    const response = await fetch('/api/media-server/soundtracks/configuration', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(request),
        credentials: 'same-origin'
    });

    if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    mediaServerLibraryConfig = await response.json();
    renderMediaServerLibraryConfiguration(mediaServerLibraryConfig);
    setMediaServerLibraryStatus('Server library configuration saved.');
}

function queueMediaServerLibraryAutoSave() {
    if (mediaServerLibraryAutoSaveTimer) {
        window.clearTimeout(mediaServerLibraryAutoSaveTimer);
        mediaServerLibraryAutoSaveTimer = 0;
    }

    mediaServerLibraryAutoSaveTimer = window.setTimeout(async () => {
        if (mediaServerLibraryAutoSaveInFlight) {
            return;
        }

        mediaServerLibraryAutoSaveInFlight = true;
        try {
            setMediaServerLibraryStatus('Saving server libraries...');
            await saveMediaServerLibraryConfiguration();
        } catch (error) {
            console.error('Failed to auto-save media server library configuration.', error);
            setMediaServerLibraryStatus(error?.message || 'Failed to save server libraries.', true);
        } finally {
            mediaServerLibraryAutoSaveInFlight = false;
        }
    }, 450);
}

function bindMediaServerLibraryActions() {
    const syncButton = document.getElementById('syncServerLibrariesBtn');
    const saveButton = document.getElementById('saveServerLibrariesBtn');
    const container = document.getElementById('serverLibraryConfigContainer');
    if (!syncButton || !saveButton || !container || syncButton.dataset.bound === 'true') {
        return;
    }

    syncButton.addEventListener('click', async () => {
        try {
            syncButton.disabled = true;
            await loadMediaServerLibraryConfiguration(true);
            showToast('Server libraries refreshed.', 'success');
        } catch (error) {
            showToast(error?.message || 'Failed to refresh server libraries.', 'error');
        } finally {
            syncButton.disabled = false;
        }
    });

    saveButton.addEventListener('click', async () => {
        try {
            if (mediaServerLibraryAutoSaveTimer) {
                window.clearTimeout(mediaServerLibraryAutoSaveTimer);
                mediaServerLibraryAutoSaveTimer = 0;
            }
            saveButton.disabled = true;
            await saveMediaServerLibraryConfiguration();
            showToast('Server library configuration saved.', 'success');
        } catch (error) {
            console.error('Failed to save media server library configuration.', error);
            setMediaServerLibraryStatus(error?.message || 'Failed to save server libraries.', true);
            showToast(error?.message || 'Failed to save server libraries.', 'error');
        } finally {
            saveButton.disabled = false;
        }
    });

    container.addEventListener('change', event => {
        const input = event.target;
        if (!(input instanceof HTMLInputElement)) {
            return;
        }

        if (input.matches('[data-library-include]')) {
            if (input.checked) {
                const row = input.closest('[data-library-row]');
                const hideInput = row?.querySelector('[data-library-hide]');
                if (hideInput instanceof HTMLInputElement && hideInput.checked) {
                    hideInput.checked = false;
                }
            }

            queueMediaServerLibraryAutoSave();
            return;
        }

        if (input.matches('[data-server-autoinclude]')) {
            queueMediaServerLibraryAutoSave();
            return;
        }

        if (!input.matches('[data-library-hide]')) {
            return;
        }

        const row = input.closest('[data-library-row]');
        applyLibraryHideToggleForRow(row);
        queueMediaServerLibraryAutoSave();
    });

    syncButton.dataset.bound = 'true';
}

async function initSettings() {
    try {
        const settingsData = await getSettingsData();
        
        if (settingsData) {
            defaultSettings = settingsData.defaultSettings;
            const mergedSettings = mergeWithDefaults(settingsData.settings, defaultSettings);
            
            loadSettings(mergedSettings);
            try {
                await loadLibraryScanSettings();
            } catch (librarySettingsError) {
                console.warn('Failed to load library scan settings:', librarySettingsError);
                showToast(`Library scan settings failed to load: ${librarySettingsError.message}`, 'error');
            }
            loadAppleNotificationPreference();
            await loadMediaServerLibraryConfiguration(false);
            settingsReady = true;
        } else {
            throw new Error('No settings data received');
        }
    } catch (error) {
        console.error('Error loading settings:', error);
        showToast('Failed to load settings: ' + error.message, 'error');
    } finally {
        initializeSettingsTooltips();
    }
}

function mergeWithDefaults(settings, defaults) {
    if (!settings || !defaults) {
        return defaults || {};
    }
    
    const merged = JSON.parse(JSON.stringify(defaults));
    
    Object.keys(settings).forEach(key => {
        if (key === 'tags') {
            if (settings.tags && defaults.tags) {
                merged.tags = { ...defaults.tags, ...settings.tags };
            }
            return;
        }
        if (settings[key] !== undefined && settings[key] !== null) {
            merged[key] = settings[key];
        }
    });
    
    return merged;
}

async function getSettingsData() {
    try {
        const response = await fetch('/api/settings');
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        const data = await response.json();
        
        return {
            settings: data.settings,
            defaultSettings: data.defaultSettings,
        };
    } catch (error) {
        console.error('Failed to fetch settings:', error);
        throw error;
    }
}

function applyLibraryScanSettings(settings) {
    currentLibraryScanSettings = {
        fuzzyThreshold: settings?.fuzzyThreshold ?? settings?.FuzzyThreshold ?? 0.85,
        includeAllFolders: settings?.includeAllFolders ?? settings?.IncludeAllFolders ?? true,
        livePreviewIngest: settings?.livePreviewIngest ?? settings?.LivePreviewIngest ?? false,
        enableSignalAnalysis: settings?.enableSignalAnalysis ?? settings?.EnableSignalAnalysis ?? false
    };

    setCheckboxValue('livePreviewIngest', currentLibraryScanSettings.livePreviewIngest);
    setCheckboxValue('enableSignalAnalysis', currentLibraryScanSettings.enableSignalAnalysis);
}

async function loadLibraryScanSettings() {
    const response = await fetch('/api/library/settings', {
        credentials: 'same-origin'
    });
    if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const settings = await response.json();
    applyLibraryScanSettings(settings);
}

function collectLibraryScanSettings() {
    return {
        fuzzyThreshold: currentLibraryScanSettings.fuzzyThreshold ?? 0.85,
        includeAllFolders: currentLibraryScanSettings.includeAllFolders ?? true,
        livePreviewIngest: document.getElementById('livePreviewIngest')?.checked ?? currentLibraryScanSettings.livePreviewIngest ?? false,
        enableSignalAnalysis: document.getElementById('enableSignalAnalysis')?.checked ?? currentLibraryScanSettings.enableSignalAnalysis ?? false
    };
}

async function saveLibraryScanSettings(payload = null) {
    const libraryScanSettings = payload || collectLibraryScanSettings();
    const response = await fetch('/api/library/settings', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(libraryScanSettings),
        credentials: 'same-origin'
    });
    if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const saved = await response.json();
    applyLibraryScanSettings(saved);
}

function loadSettings(settings) {
    currentSettings = JSON.parse(JSON.stringify(settings));
    
