function renderGenreTagAliasRules(rules) {
    const rowsContainer = document.getElementById('genreTagAliasRows');
    if (!rowsContainer) {
        return;
    }

    rowsContainer.innerHTML = '';
    const source = Array.isArray(rules) ? rules : [];
    source.forEach(rule => {
        const alias = String(rule?.alias || '').trim();
        const canonical = String(rule?.canonical || '').trim();
        if (!alias || !canonical) {
            return;
        }

        rowsContainer.appendChild(createGenreTagAliasRuleRow(alias, canonical));
    });

    toggleGenreTagAliasEmptyState();
}

function collectGenreTagAliasRules() {
    const rowsContainer = document.getElementById('genreTagAliasRows');
    if (!rowsContainer) {
        return [];
    }

    const rules = [];
    const seen = new Set();
    rowsContainer.querySelectorAll('.genre-alias-row').forEach(row => {
        const alias = String(row.querySelector('.genre-alias-alias')?.value || '').trim();
        const canonical = String(row.querySelector('.genre-alias-canonical')?.value || '').trim();
        if (!alias || !canonical) {
            return;
        }

        const key = alias.toLowerCase();
        if (seen.has(key)) {
            return;
        }

        seen.add(key);
        rules.push({ alias, canonical });
    });

    return rules;
}

