@section Scripts {
<script>
let currentSettings = {};
let defaultSettings = {};
let currentLibraryScanSettings = {
    fuzzyThreshold: 0.85,
    includeAllFolders: true,
    livePreviewIngest: false,
    enableSignalAnalysis: false
};
let settingsReady = false;
let settingsSaveInFlight = false;
let settingsSaveQueued = false;
let settingsSaveQueuedToast = false;
let mediaServerLibraryConfig = null;
let mediaServerLibraryAdvancedUnlocked = false;
let mediaServerLibraryPinConfigured = false;
let mediaServerLibraryAutoSaveTimer = 0;
let mediaServerLibraryAutoSaveInFlight = false;
const SERVER_LIBRARY_LEGACY_PIN_STORAGE_KEY = 'deezspotag-server-library-pin';
const APPLE_NOTIFICATION_MODE_KEY = 'apple-download-notification-mode';
const engineQualityOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    DeezSpoTag.Services.Download.QualityCatalog.GetEngineQualityOptions()
        .ToDictionary(
            kvp => kvp.Key,
            kvp => kvp.Value.Select(option => new { value = option.Value, label = option.Label }).ToList(),
            StringComparer.OrdinalIgnoreCase)));

window.DeezSpoTagRevealMaterialIconsWhenReady('.settings-page.material-icons-pending');

document.addEventListener('DOMContentLoaded', function() {
    initSettings();
    setupEventListeners();
    setupAccordionToggle();
    setupTemplateVariableHelpers();
    initTabPreferenceToggle();
    initDownloadSourceDropdowns();
    initLibraryFolderDestinationDropdowns();
    initSecondarySourceControls();
    setupArtworkFallbackOrder();
    initializeSettingsTooltips();
    bindMediaServerLibraryPinActions();
    bindMediaServerLibraryActions();
});

function createSettingsTooltipIcon(message) {
    if (!message) {
        return null;
    }

    const tooltip = document.createElement('span');
    tooltip.className = 'settings-tooltip-icon';
    tooltip.title = message;
    tooltip.setAttribute('aria-label', message);
    tooltip.innerHTML = '<i class="fas fa-question-circle"></i>';
    return tooltip;
}

function appendTooltipToElement(target, message) {
    if (!target || !message) {
        return false;
    }

    if (target.querySelector('.settings-tooltip-icon')) {
        return true;
    }

    const tooltip = createSettingsTooltipIcon(message);
    if (!tooltip) {
        return false;
    }

    target.appendChild(tooltip);
    return true;
}

function upsertSettingsTooltip(target, message, tooltipId) {
    if (!target) {
        return null;
    }

    let tooltip = tooltipId
        ? document.getElementById(tooltipId)
        : target.querySelector('.settings-tooltip-icon');

    if (!tooltip) {
        tooltip = createSettingsTooltipIcon(message || '');
        if (!tooltip) {
            return null;
        }

        if (tooltipId) {
            tooltip.id = tooltipId;
        }

        target.appendChild(tooltip);
    }

    const resolvedMessage = (message || '').trim();
    tooltip.title = resolvedMessage;
    tooltip.setAttribute('aria-label', resolvedMessage);
    tooltip.style.display = resolvedMessage ? '' : 'none';
    return tooltip;
}

function resolveTooltipTarget(warning) {
    if (!warning) {
        return null;
    }

    const explicitTargetId = warning.getAttribute('data-tooltip-target');
    if (explicitTargetId) {
        const explicitTarget = document.getElementById(explicitTargetId);
        if (explicitTarget) {
            const label = document.querySelector(`label[for="${explicitTargetId}"]`);
            return label || explicitTarget.closest('.form-group')?.querySelector('label, .form-label') || explicitTarget;
        }
    }

    const previousGroup = warning.previousElementSibling;
    if (previousGroup?.classList.contains('form-group')) {
        const previousGroupLabel = previousGroup.querySelector('label, .form-label');
        if (previousGroupLabel) {
            return previousGroupLabel;
        }
    }

    const formGroup = warning.closest('.form-group');
    if (formGroup) {
        const label = formGroup.querySelector('label, .form-label');
        if (label) {
            return label;
        }
    }

    const checkboxGroup = warning.previousElementSibling?.classList.contains('checkbox-group')
        ? warning.previousElementSibling
        : warning.closest('.settings-content')?.querySelector('.checkbox-group:last-of-type');
    if (checkboxGroup) {
        const checkboxLabel = checkboxGroup.querySelector('label');
        if (checkboxLabel) {
            return checkboxLabel;
        }
    }

    const switchLabel = warning.previousElementSibling?.querySelector('.switch-label')
        || warning.closest('.settings-section')?.querySelector('.switch-label');
    if (switchLabel) {
        return switchLabel;
    }

    return null;
}

function initializeSettingsTooltips() {
    const targetMessages = new Map();

    document.querySelectorAll('.settings-section .warning-text').forEach((warning) => {
        if (warning.id === 'multiQualitySecondaryFolderWarning') {
            return;
        }

        const message = (warning.innerText || warning.textContent || '').trim();
        if (!message) {
            return;
        }

        const target = resolveTooltipTarget(warning);
        if (!target) {
            return;
        }

        const messages = targetMessages.get(target) || [];
        messages.push(message);
        targetMessages.set(target, messages);
        warning.remove();
    });

    targetMessages.forEach((messages, target) => {
        const mergedMessage = messages.join('\n');
        const tooltip = upsertSettingsTooltip(target, mergedMessage, '');
        if (tooltip) {
            tooltip.dataset.baseMessage = mergedMessage;
        }
    });
}

