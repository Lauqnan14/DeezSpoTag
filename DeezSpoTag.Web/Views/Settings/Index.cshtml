@{
    ViewData["Title"] = "Settings - DeezSpoTag";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<link rel="stylesheet" href="~/css/settings.css" />
<link rel="stylesheet" href="~/css/library.css" />
<link rel="stylesheet" href="~/css/dropdown-select.css" />
<style>
.settings-page {
    padding: 20px;
    padding-bottom: 120px;
    color: var(--text-primary);
}

.settings-width {
    max-width: none;
    width: 100%;
    margin: 0 0 32px 0;
}

.settings-section {
    background: var(--bg-secondary);
    border: 1px solid var(--border-secondary);
    border-radius: 10px;
    margin-bottom: 24px;
    overflow: hidden;
}

.settings-page .settings-width > .settings-section:last-child {
    border-bottom: 1px solid var(--border-secondary);
    margin-bottom: 24px;
    padding-bottom: 30px;
}

.settings-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 18px 20px;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    font-weight: 600;
    cursor: pointer;
    user-select: none;
}

.settings-header::after {
    content: 'expand_more';
    font-family: 'Material Icons';
    font-size: 1.25rem;
    margin-left: auto;
    transition: transform 0.2s ease;
    color: var(--text-muted);
}

.settings-section:has(> .settings-content.active) > .settings-header::after {
    transform: rotate(180deg);
}

.settings-header:hover {
    background: var(--bg-quaternary);
}

.settings-header .material-icons {
    font-size: 1.5rem;
}

.settings-page.material-icons-pending .material-icons,
.settings-page.material-icons-pending .settings-header::after {
    visibility: hidden;
}

.settings-content {
    padding: 20px;
    display: none;
}

.settings-content.active {
    display: block;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 6px;
    color: var(--text-secondary);
    font-weight: 500;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid var(--border-secondary);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: 14px;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 2px var(--primary-color);
}

.form-group input[type="checkbox"] {
    width: auto;
    margin-right: 8px;
    transform: scale(1.2);
}

.form-group input[type="range"] {
    padding: 0;
    height: 6px;
}

.checkbox-group {
    display: flex;
    align-items: center;
    margin-bottom: 12px;
}

.checkbox-group label {
    margin-bottom: 0;
    cursor: pointer;
    user-select: none;
}

#livePreviewIngest + label,
#enableSignalAnalysis + label {
    color: var(--text-primary);
    font-size: 16px !important;
    font-weight: 500;
    line-height: 1.4;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.form-row-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    align-items: start;
}

.form-row-half {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.genre-alias-list {
    display: grid;
    gap: 10px;
}

.genre-alias-header,
.genre-alias-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 10px;
    align-items: center;
}

.genre-alias-header {
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
}

.genre-alias-row input {
    width: 100%;
}

.genre-alias-remove {
    min-width: 40px;
    height: 38px;
    border-radius: 8px;
    border: 1px solid var(--border-secondary);
    background: var(--bg-tertiary);
    color: var(--text-primary);
    cursor: pointer;
}

.genre-alias-remove:hover {
    background: var(--bg-quaternary);
}

.genre-alias-empty {
    color: var(--text-muted);
    font-size: 12px;
    margin: 0;
}

.other-pad-column {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.other-pad-column .checkbox-group {
    margin-bottom: 0;
}

.template-variables {
    background: var(--bg-secondary);
    border-radius: 6px;
    padding: 15px;
    margin-top: 10px;
}

.template-variables h4 {
    margin: 0 0 10px 0;
    color: var(--text-primary);
    font-size: 14px;
}

.template-variables summary {
    cursor: pointer;
    color: var(--text-primary);
    font-weight: 600;
    list-style-position: outside;
}

.template-variables-content {
    margin-top: 14px;
}

.template-variables-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.template-variable {
    display: inline-block;
    background: var(--bg-primary);
    color: var(--text-primary);
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 12px;
    cursor: pointer;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
    user-select: none;
    box-shadow: inset 0 0 0 1px var(--border-secondary);
}

.template-variable:hover {
    background: var(--bg-quaternary);
    box-shadow: inset 0 0 0 1px var(--primary-color);
}

.btn-group {
    display: flex;
    gap: 10px;
    align-items: center;
}

.settings-actions {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 1000;
}

.btn {
    padding: 8px 16px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s ease;
    font-size: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}

.btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 1px solid var(--border-secondary);
}

.btn-secondary:hover {
    background: var(--bg-quaternary);
}

.warning-text {
    color: var(--warning-color);
    font-size: 12px;
    margin-top: 5px;
    display: flex;
    align-items: center;
    gap: 5px;
}

.settings-tooltip-icon {
    color: var(--text-muted);
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    cursor: help;
    margin-left: 6px;
    vertical-align: middle;
}


.loading {
    text-align: center;
    padding: 40px;
    color: var(--text-muted);
}

.range-display {
    display: flex;
    align-items: center;
    gap: 10px;
}

.range-display input[type="range"] {
    flex: 1;
}

.range-display span {
    min-width: 50px;
    text-align: right;
    color: var(--text-primary);
    font-weight: 500;
}

.input-group-text {
    color: var(--text-secondary);
    font-size: 12px;
    margin-bottom: 5px;
}

.secondary-text {
    color: var(--text-muted);
    font-size: 12px;
    margin-bottom: 10px;
    line-height: 1.4;
}

.settings-container {
    display: flex;
    gap: 20px;
}

.settings-container__half {
    flex: 1;
}

.settings-container__third {
    flex: 1;
}

.settings-container__third--only-checkbox {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.settings-page {
    padding-bottom: 100px;
}

.global-settings-wrapper {
    padding-bottom: 30px;
}

.switch-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
}

.switch-label {
    color: var(--text-secondary);
    font-weight: 500;
}

.settings-section--toggle-style .switch-row {
    padding: 12px 14px;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--primary-color) 30%, var(--border-secondary));
    background: var(--bg-secondary);
    margin-bottom: 12px;
}

.settings-section--toggle-style .switch-label {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 14px;
}

.read-only-field {
    background: var(--bg-tertiary);
    color: var(--text-muted);
    border: 1px dashed var(--border-secondary);
}

.settings-link {
    color: var(--primary-color);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
}

.settings-link:hover {
    border-bottom-color: var(--primary-color);
}

.server-library-controls {
    margin-bottom: 14px;
}

.server-library-pin-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
}

.server-library-pin-label {
    margin: 0;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
}

.server-library-pin-controls input {
    width: 100%;
    min-width: 180px;
    max-width: 280px;
    flex: 1 1 220px;
    padding: 8px 10px;
}

.server-library-pin-status {
    color: var(--text-muted);
    font-size: 12px;
    margin-bottom: 10px;
}

.server-library-status {
    color: var(--text-muted);
    font-size: 12px;
    margin-bottom: 12px;
}

.server-library-config {
    display: grid;
    gap: 14px;
}

.server-library-card {
    border: 1px solid var(--border-secondary);
    border-radius: 10px;
    background: var(--bg-tertiary);
    padding: 14px;
}

.server-library-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
}

.server-library-card-title {
    margin: 0;
    color: var(--text-primary);
    font-size: 15px;
    font-weight: 700;
}

.server-library-badges {
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.server-library-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 11px;
    border: 1px solid var(--border-secondary);
    color: var(--text-muted);
    background: var(--bg-secondary);
}

.server-library-badge.connected {
    color: var(--success-color);
    border-color: color-mix(in srgb, var(--success-color) 35%, var(--border-secondary));
}

.server-library-table-wrap {
    overflow-x: auto;
}

.server-library-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
}

.server-library-table th,
.server-library-table td {
    border-top: 1px solid var(--border-secondary);
    padding: 9px 10px;
    text-align: left;
    font-size: 12px;
    color: var(--text-primary);
}

.server-library-table th {
    font-weight: 600;
    color: var(--text-secondary);
}

.server-library-empty {
    color: var(--text-muted);
    font-size: 12px;
    margin: 0;
}

.server-library-hidden-note {
    margin: 0 0 10px 0;
    color: var(--text-muted);
    font-size: 12px;
}

.server-library-advanced {
    border: 1px dashed var(--border-secondary);
    border-radius: 8px;
    padding: 10px;
    margin-bottom: 10px;
    display: grid;
    gap: 8px;
}

.server-library-advanced-title {
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
}

.server-library-advanced-options {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
}

.server-library-inline-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 12px;
    color: var(--text-primary);
    min-width: 180px;
}

.server-library-header-toggle {
    margin: 0;
    min-width: 250px;
}

.server-library-include-cell {
    text-align: center;
}

.lyrics-order-hint,
.artwork-order-hint {
    font-size: 12px;
    color: var(--text-muted);
    margin: 4px 6px 8px;
}

.lyrics-order-list,
.artwork-order-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.lyrics-order-item,
.artwork-order-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 6px;
    border: 1px solid var(--border-secondary);
    background: var(--bg-tertiary);
    cursor: grab;
}

.lyrics-order-item.dragging,
.artwork-order-item.dragging {
    opacity: 0.65;
}

.drag-handle {
    color: var(--text-muted);
    font-size: 16px;
}

@@media (max-width: 768px) {
    .form-row,
    .form-row-3,
    .form-row-half,
    .settings-container {
        grid-template-columns: 1fr;
        flex-direction: column;
    }
    
    .settings-page {
        padding: 10px 10px 100px 10px;
    }
    
    .btn-group {
        flex-direction: column;
    }

    .server-library-pin-controls {
        align-items: stretch;
    }

    .server-library-pin-controls input,
    .server-library-pin-controls .action-btn {
        min-width: 0;
        max-width: none;
        width: 100%;
    }
}
</style>
}

<div class="settings-page material-icons-pending">
    <h1 style="margin-bottom: 30px; color: var(--text-primary);">Settings</h1>
    <p class="secondary-text" style="margin-top: -16px; margin-bottom: 20px;">
        This page controls global download/runtime behavior. AutoTag profile tag choices are configured separately on the AutoTag page.
    </p>

    <div class="settings-width">
        <div class="settings-section" id="download-settings">
            <div class="settings-header">
                <span class="material-icons">get_app</span>
                Download Settings
            </div>
            <div class="settings-content">
                <div class="form-row">
                    <div class="form-group">
                        <label for="downloadSource">Source</label>
                        <div class="dropdown-select" data-dropdown="downloadSource">
                            <button type="button" class="dropdown-trigger" id="downloadSourceTrigger">Deezer</button>
                            <div class="dropdown-menu" id="downloadSourceMenu">
                                <button type="button" class="dropdown-option" data-value="auto">Auto</button>
                                <button type="button" class="dropdown-option" data-value="amazon">Amazon Music</button>
                                <button type="button" class="dropdown-option" data-value="apple">Apple Music</button>
                                <button type="button" class="dropdown-option" data-value="deezer">Deezer</button>
                                <button type="button" class="dropdown-option" data-value="qobuz">Qobuz</button>
                                <button type="button" class="dropdown-option" data-value="tidal">Tidal</button>
                            </div>
                            <input type="hidden" id="downloadSource" value="deezer">
                        </div>
                    </div>
                    <div class="form-group" id="multiQualityGroup">
                        <div class="form-label">Multi-quality downloads</div>
                        <div class="checkbox-group">
                            <input type="checkbox" id="multiQualityEnabled">
                            <label for="multiQualityEnabled">Enable dual-profile downloads (Atmos + Stereo)</label>
                        </div>
                        <div class="warning-text">Queues both Atmos and Stereo and uses separate destination folders to avoid overwrites; best paired with automation (watchlists/playlist monitor).</div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <div class="engine-quality-stack">
                            <div class="form-group" id="multisource-tidalQualityGroup" style="display: none;">
                                <label for="multisource-tidalQuality">Tidal Quality</label>
                                <div class="dropdown-select" data-dropdown="multisource-tidalQuality">
                                    <button type="button" class="dropdown-trigger" id="multisource-tidalQualityTrigger">Hi-Res Lossless (24-bit/48kHz+)</button>
                                    <div class="dropdown-menu" id="multisource-tidalQualityMenu">
                                        <button type="button" class="dropdown-option" data-value="HI_RES_LOSSLESS">Hi-Res Lossless (24-bit/48kHz+)</button>
                                        <button type="button" class="dropdown-option" data-value="LOSSLESS">Lossless (16-bit/CD)</button>
                                    </div>
                                    <input type="hidden" id="multisource-tidalQuality" value="HI_RES_LOSSLESS">
                                </div>
                            </div>
                            <div class="form-group" id="multisource-qobuzQualityGroup" style="display: none;">
                                <label for="multisource-qobuzQuality">Qobuz Quality</label>
                                <div class="dropdown-select" data-dropdown="multisource-qobuzQuality">
                                    <button type="button" class="dropdown-trigger" id="multisource-qobuzQualityTrigger">Hi-Res (24-bit/96kHz+)</button>
                                    <div class="dropdown-menu" id="multisource-qobuzQualityMenu">
                                        <button type="button" class="dropdown-option" data-value="27">Hi-Res (24-bit/96kHz+)</button>
                                        <button type="button" class="dropdown-option" data-value="7">FLAC 24-bit</button>
                                        <button type="button" class="dropdown-option" data-value="6">FLAC 16-bit (CD)</button>
                                    </div>
                                    <input type="hidden" id="multisource-qobuzQuality" value="27">
                                </div>
                            </div>
                            <div class="form-group" id="apple-qualityGroup" style="display: none;">
                                <label for="applePreferredAudioProfile">Apple Music Quality</label>
                                <div class="dropdown-select" data-dropdown="applePreferredAudioProfile">
                                    <button type="button" class="dropdown-trigger" id="applePreferredAudioProfileTrigger">ATMOS</button>
                                    <div class="dropdown-menu" id="applePreferredAudioProfileMenu">
                                        <button type="button" class="dropdown-option" data-value="atmos">ATMOS</button>
                                        <button type="button" class="dropdown-option" data-value="alac">ALAC</button>
                                        <button type="button" class="dropdown-option" data-value="aac">AAC</button>
                                    </div>
                                    <input type="hidden" id="applePreferredAudioProfile" value="atmos">
                                </div>
                                <div class="warning-text">ATMOS = spatial (wrapper), ALAC = lossless stereo (wrapper), AAC = compressed stereo (no wrapper).</div>
                                <div class="warning-text">Advanced Apple controls (Manifest mode, AAC type, ALAC max, Atmos max) are in the Apple Music section below.</div>
                            </div>
                            <div class="form-group" id="deezer-maxBitrateGroup" style="display: none;">
                                <label for="maxBitrate">Deezer Quality</label>
                                <div class="dropdown-select" data-dropdown="maxBitrate">
                                    <button type="button" class="dropdown-trigger" id="maxBitrateTrigger">FLAC (Hi-Fi)</button>
                                    <div class="dropdown-menu" id="maxBitrateMenu">
                                        <button type="button" class="dropdown-option" data-value="9">FLAC (Hi-Fi)</button>
                                        <button type="button" class="dropdown-option" data-value="3">MP3 320kbps</button>
                                        <button type="button" class="dropdown-option" data-value="1">MP3 128kbps (Free)</button>
                                    </div>
                                    <input type="hidden" id="maxBitrate" value="9">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group" id="multiQualityConfigGroup" style="display: none;">
                        <label for="multiQualitySecondaryDestinationFolderId">Atmos destination folder id</label>
                        <select id="multiQualitySecondaryDestinationFolderId">
                            <option value="">(Select destination)</option>
                        </select>
                        <div class="warning-text">Atmos downloads require a dedicated folder (Apple only).</div>
                        <div class="warning-text" id="multiQualitySecondaryFolderWarning" style="display:none;">
                            Select an Atmos destination to enable the secondary download.
                        </div>
                        <div class="warning-text" style="margin-top: 12px;">Stereo uses the selected source and its configured quality automatically.</div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="queueOrder">Queue Order</label>
                    <select id="queueOrder">
                        <option value="fifo">First in, first out (FIFO)</option>
                        <option value="recent">Recent first</option>
                    </select>
                </div>
                <div class="form-row-3">
                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" id="fallbackBitrate">
                            <label for="fallbackBitrate">Fallback Quality</label>
                        </div>
                        <div class="warning-text">Allows lower quality if the requested quality is unavailable for the same engine.</div>
                    </div>
                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" id="fallbackSearch">
                            <label for="fallbackSearch">Fallback Search</label>
                        </div>
                        <div class="warning-text">Uses title/artist search when an exact match fails. Can result in a different version.</div>
                    </div>
                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" id="strictSpotifyDeezerMode">
                            <label for="strictSpotifyDeezerMode">Strict Spotify->Deezer Mode</label>
                        </div>
                        <div class="warning-text">Enforces ISRC-only Spotify->Deezer matching for mapping and downloads. No Song.link or metadata fallback.</div>
                    </div>
                    <div class="checkbox-group">
                        <input type="checkbox" id="preferAlbumLayoutForPlaylists">
                        <label for="preferAlbumLayoutForPlaylists">Prefer album/artist layout for playlist downloads</label>
                    </div>
                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" id="autoMaxBitrate">
                            <label for="autoMaxBitrate">Auto-select max bitrate on login</label>
                        </div>
                        <div class="warning-text">Deezer only: on successful Deezer login, Max Bitrate is automatically set to your account's highest supported quality.</div>
                    </div>
                    <div class="checkbox-group">
                        <input type="checkbox" id="logErrors">
                        <label for="logErrors">Log Errors</label>
                    </div>
                </div>

            </div>
        </div>

        <div class="settings-section" id="spotify-settings">
            <div class="settings-header">
                <span class="material-icons">music_note</span>
                Spotify
            </div>
            <div class="settings-content">
                <div class="form-row">
                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" id="spotifyHomeFeedCacheEnabled">
                            <label for="spotifyHomeFeedCacheEnabled">Cache Spotify home feed</label>
                        </div>
                        <div class="warning-text">Keeps the trending/Spotify feed cached to speed up home load.</div>
                    </div>
                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" id="spotifyHomeFeedAutoRefreshEnabled">
                            <label for="spotifyHomeFeedAutoRefreshEnabled">Auto-refresh home feed</label>
                        </div>
                        <div class="warning-text">Refreshes the Spotify home feed in the background.</div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="spotifyBrowseCacheMinutes">Spotify browse cache (minutes)</label>
                        <input type="number" id="spotifyBrowseCacheMinutes" min="1" max="1440" value="30">
                        <div class="warning-text">Caches Spotify browse categories/playlists to reduce rate limits.</div>
                    </div>
                    <div class="form-group">
                        <label for="spotifyHomeFeedAutoRefreshHours">Auto-refresh interval (hours)</label>
                        <input type="number" id="spotifyHomeFeedAutoRefreshHours" min="2" max="24" value="2">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="spotifyArtistMetadataFetchBatchSize">Artist metadata batch size</label>
                        <input type="number" id="spotifyArtistMetadataFetchBatchSize" min="1" max="500" value="25">
