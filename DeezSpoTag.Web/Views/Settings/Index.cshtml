function createGenreTagAliasRuleRow(alias = '', canonical = '') {
    const row = document.createElement('div');
    row.className = 'genre-alias-row';

    const aliasInput = document.createElement('input');
    aliasInput.type = 'text';
    aliasInput.className = 'genre-alias-alias';
    aliasInput.placeholder = 'Afro-Pop';
    aliasInput.value = alias;

    const canonicalInput = document.createElement('input');
    canonicalInput.type = 'text';
    canonicalInput.className = 'genre-alias-canonical';
    canonicalInput.placeholder = 'Afropop';
    canonicalInput.value = canonical;

    const removeButton = document.createElement('button');
    removeButton.type = 'button';
    removeButton.className = 'genre-alias-remove';
    removeButton.textContent = 'x';
    removeButton.title = 'Remove rule';
    removeButton.addEventListener('click', () => {
        row.remove();
        toggleGenreTagAliasEmptyState();
    });

    row.appendChild(aliasInput);
    row.appendChild(canonicalInput);
    row.appendChild(removeButton);
    return row;
