function updateSecondaryFolderRequirement() {
    const secondarySelect = document.getElementById('multiQualitySecondaryDestinationFolderId');
    const enabledCheckbox = document.getElementById('multiQualityEnabled');
    const configGroup = document.getElementById('multiQualityConfigGroup');
    const targetLabel = document.querySelector('label[for="multiQualitySecondaryDestinationFolderId"]');
    if (!secondarySelect) {
        return;
    }

    if (configGroup && enabledCheckbox) {
        configGroup.style.display = enabledCheckbox.checked ? 'block' : 'none';
    }

    const dynamicWarningMessage = 'Select an Atmos destination to enable the secondary download.';
    const hasDestination = !!(secondarySelect.value || '').trim();
    const shouldShowWarning = Boolean(enabledCheckbox?.checked) && !hasDestination;
    const existingTooltip = targetLabel?.querySelector('.settings-tooltip-icon');
    const baseMessage = (existingTooltip?.dataset.baseMessage || '').trim();
    const resolvedMessage = shouldShowWarning
        ? [baseMessage, dynamicWarningMessage].filter(Boolean).join('\n')
        : baseMessage;
    const tooltip = upsertSettingsTooltip(targetLabel, resolvedMessage, '');
    if (tooltip) {
        tooltip.dataset.baseMessage = baseMessage;
    }
}

async function initLibraryFolderDestinationDropdowns() {
    const primarySelect = document.getElementById('multiQualityPrimaryDestinationFolderId');
    const secondarySelect = document.getElementById('multiQualitySecondaryDestinationFolderId');
    const videoSelect = document.getElementById('videoDownloadLocation');
    if (!primarySelect && !secondarySelect && !videoSelect) {
        return;
    }

    try {
        const response = await fetch('/api/library/folders');
        if (!response.ok) {
            return;
        }

        const folders = await response.json();
        if (!Array.isArray(folders)) {
            return;
        }

        const sorted = folders
            .filter(folder => folder && folder.id != null && folder.displayName)
            .slice()
            .sort((a, b) => String(a.displayName).localeCompare(String(b.displayName), undefined, { sensitivity: 'base' }));

        const buildOptionsHtml = () => {
            return [
                '<option value="">(Use request destination)</option>',
                ...sorted.map(folder =>
                    `<option value="${String(folder.id)}">${escapeHtml(String(folder.displayName))}</option>`)
            ].join('');
        };

        const currentPrimary = primarySelect ? (primarySelect.value || '').trim() : '';
        const currentSecondary = secondarySelect ? (secondarySelect.value || '').trim() : '';
        const currentVideo = videoSelect ? (videoSelect.value || '').trim() : '';
        const hasFolderIdOption = (value) => {
            const normalized = String(value ?? '').trim();
            if (!normalized) {
                return false;
            }

            return sorted.some(folder => String(folder.id).trim() === normalized);
        };

        if (primarySelect) {
            primarySelect.innerHTML = buildOptionsHtml();
        }
        if (secondarySelect) {
            secondarySelect.innerHTML = buildOptionsHtml();
        }
        if (videoSelect) {
            const videoOptions = [
                '<option value="">(required: select video destination folder)</option>',
                ...sorted
                    .filter(folder => folder.enabled !== false && folder.rootPath)
                    .map(folder => `<option value="${escapeHtml(String(folder.rootPath))}">${escapeHtml(String(folder.displayName))}</option>`)
            ];

            const hasCurrent = currentVideo
                && sorted.some(folder =>
                    folder.enabled !== false
                    && String(folder.rootPath || '').trim().toLowerCase() === currentVideo.toLowerCase());
            if (currentVideo && !hasCurrent) {
                videoOptions.push(`<option value="${escapeHtml(currentVideo)}">Current (unmapped): ${escapeHtml(currentVideo)}</option>`);
            }

            videoSelect.innerHTML = videoOptions.join('');
        }

        if (primarySelect && currentPrimary) {
            primarySelect.value = currentPrimary;
        }
        if (secondarySelect) {
            if (hasFolderIdOption(currentSecondary)) {
                secondarySelect.value = currentSecondary;
            }
            updateSecondaryFolderRequirement();
        }
        if (videoSelect && currentVideo) {
            videoSelect.value = currentVideo;
        }
    } catch {
        // Non-fatal: keep the default "(Use request destination)" option.
    }
}

function escapeHtml(text) {
    return String(text)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
}

