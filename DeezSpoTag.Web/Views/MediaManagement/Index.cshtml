@{
    ViewData["Title"] = "Media Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/library.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/auto-playlists.css" asp-append-version="true" />

<div class="container-fluid">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="welcome-title mb-2">Media Management</h1>
            <p class="text-muted">Manage your playlists, watchlists, soundtracks, and media integrations</p>
        </div>
    </div>

    <!-- Main Navigation Tabs -->
    <ul class="nav nav-tabs nav-fill mb-4 ds-mobile-tabs" id="mediaManagementTabs">
        <li class="nav-item">
            <button class="nav-link active" id="recommendations-tab" data-bs-toggle="tab" data-bs-target="#recommendations-content" type="button" role="tab" aria-controls="recommendations-content" aria-selected="true">
                <i class="fas fa-broadcast-tower me-2"></i>Recommendations
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="watchlist-tab" data-bs-toggle="tab" data-bs-target="#watchlist-content" type="button" role="tab" aria-controls="watchlist-content" aria-selected="false">
                <i class="fas fa-eye me-2"></i>Watchlist
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="soundtracks-tab" data-bs-toggle="tab" data-bs-target="#soundtracks-content" type="button" role="tab" aria-controls="soundtracks-content" aria-selected="false">
                <i class="fas fa-film me-2"></i>Soundtracks
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="auto-playlists-tab" data-bs-toggle="tab" data-bs-target="#auto-playlists-content" type="button" role="tab" aria-controls="auto-playlists-content" aria-selected="false">
                <i class="fas fa-layer-group me-2"></i>Auto Playlists
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="library-playlists-tab" data-bs-toggle="tab" data-bs-target="#library-playlists-content" type="button" role="tab" aria-controls="library-playlists-content" aria-selected="false">
                <i class="fas fa-list me-2"></i>Library Playlists
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="favorites-tab" data-bs-toggle="tab" data-bs-target="#favorites-content" type="button" role="tab" aria-controls="favorites-content" aria-selected="false">
                <i class="fas fa-heart me-2"></i>Favorites
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings-content" type="button" role="tab" aria-controls="settings-content" aria-selected="false">
                <i class="fas fa-cog me-2"></i>Settings
            </button>
        </li>
    </ul>

    <div class="tab-content" id="mediaManagementTabsContent">
        <!-- Recommendations Tab -->
        <div class="tab-pane fade show active" id="recommendations-content" role="tabpanel" aria-labelledby="recommendations-tab">
            <div class="media-tab-header">
                <div>
                    <h2>Recommendations</h2>
                    <p>Daily recommendations generated based on the tracks in your library.</p>
                </div>
            </div>
            <section class="auto-section">
                <div id="recommendationsGrid" class="auto-tools-grid auto-tools-grid--recommendations"></div>
                <div id="recommendationsEmpty" class="auto-playlists-empty" hidden>
                    No recommendations available yet.
                </div>
            </section>
        </div>

        <!-- Watchlist Tab -->
        <div class="tab-pane fade" id="watchlist-content" role="tabpanel" aria-labelledby="watchlist-tab">
            <ul class="nav nav-tabs nav-fill mb-3 ds-mobile-tabs" id="watchlistSubTabs">
                <li class="nav-item">
                    <button class="nav-link active" id="watchlist-playlists-tab" data-bs-toggle="tab" data-bs-target="#watchlist-playlists-content" type="button" role="tab" aria-selected="true">
                        Playlists
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="watchlist-artists-tab" data-bs-toggle="tab" data-bs-target="#watchlist-artists-content" type="button" role="tab" aria-selected="false">
                        Artists
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="watchlist-blocked-tab" data-bs-toggle="tab" data-bs-target="#watchlist-blocked-content" type="button" role="tab" aria-selected="false">
                        Blocked
                    </button>
                </li>
            </ul>
            <div class="tab-content" id="watchlistSubTabsContent">
                <div class="tab-pane fade show active" id="watchlist-playlists-content" role="tabpanel" aria-labelledby="watchlist-playlists-tab">
                    <div class="media-tab-header">
                        <div>
                            <h2>Playlists Watchlist</h2>
                            <p>Manage monitored playlists. Open the actions menu on a playlist to configure folders, routing rules, and blocked tracks.</p>
                        </div>
                        <div>
                            <button id="mergePlaylistWatchlistBtn" class="btn btn-primary action-btn btn-sm" type="button">Merge Playlists</button>
                        </div>
                    </div>
                    <div id="playlistWatchlistContainer" class="watchlist-playlist-grid"></div>
                </div>
                <div class="tab-pane fade" id="watchlist-artists-content" role="tabpanel" aria-labelledby="watchlist-artists-tab">
                    <div class="media-tab-header">
                        <div>
                            <h2>Artists Watchlist</h2>
                            <p>Choose where each watched artist's new releases should be saved.</p>
                        </div>
                        <div>
                            <button id="saveArtistPreferences" class="btn btn-primary action-btn btn-sm">Save Preferences</button>
                        </div>
                    </div>
                    <div id="watchlistContainer" class="watchlist-artist-grid"></div>
                </div>
                <div class="tab-pane fade" id="watchlist-blocked-content" role="tabpanel" aria-labelledby="watchlist-blocked-tab">
                    <div class="media-tab-header">
                        <div>
                            <h2>Blocked Items</h2>
                            <p>Review blocked tracks, artists, and albums.</p>
                        </div>
                    </div>
                    <div id="blockedWatchlistContainer" class="watchlist-blocked-grid"></div>
                </div>
            </div>
        </div>

        <!-- Soundtracks Tab -->
        <div class="tab-pane fade" id="soundtracks-content" role="tabpanel" aria-labelledby="soundtracks-tab">
            <ul class="nav nav-tabs nav-fill mb-3 ds-mobile-tabs" id="soundtrackSubTabs">
                <li class="nav-item">
                    <button class="nav-link active" id="soundtrack-movies-tab" type="button" role="tab" data-soundtrack-category="movie" aria-selected="true">
                        Movies
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="soundtrack-tv-tab" type="button" role="tab" data-soundtrack-category="tv_show" aria-selected="false">
                        TV Shows
                    </button>
                </li>
            </ul>
            <div class="media-tab-header">
                <div>
                    <h2>Soundtracks</h2>
                    <p>Browse soundtrack from the media in your library.</p>
                </div>
            </div>
            <section class="auto-section">
                <div class="soundtrack-toolbar">
                    <div id="soundtrackServerFilterGroup" class="soundtrack-filter-group">
                        <div id="soundtrackServerFilterLabel" class="soundtrack-filter-label">Servers</div>
                        <div id="soundtrackServerPills" class="soundtrack-pill-row"></div>
                    </div>
                    <div id="soundtrackLibraryFilterGroup" class="soundtrack-filter-group">
                        <div id="soundtrackLibraryFilterLabel" class="soundtrack-filter-label">Libraries</div>
                        <div id="soundtrackLibraryPills" class="soundtrack-pill-row"></div>
                    </div>
                    <button id="soundtrackRefreshItems" class="btn btn-secondary action-btn btn-sm" type="button">Refresh</button>
                    <button id="soundtrackSyncLibraries" class="btn btn-primary action-btn btn-sm" type="button">Sync Libraries</button>
                </div>
                <div id="soundtrackStatus" class="auto-playlists-meta"></div>
                <div id="soundtrackSyncStatus" class="auto-playlists-meta"></div>
                <div id="soundtrackTvNav" class="soundtrack-tv-nav" hidden>
                    <button id="soundtrackTvBack" type="button" class="btn btn-secondary action-btn btn-sm">Back to TV Shows</button>
                    <div class="soundtrack-tv-show">
                        <span class="soundtrack-filter-label">Selected Show</span>
                        <strong id="soundtrackTvShowTitle"></strong>
                    </div>
                    <div id="soundtrackTvSeasonFilterGroup" class="soundtrack-filter-group" style="display:none;">
                        <div class="soundtrack-filter-label">Seasons</div>
                        <div id="soundtrackTvSeasonPills" class="soundtrack-pill-row"></div>
                    </div>
                </div>
                <nav id="soundtrackLetterNav" class="alpha-jump-nav alpha-jump-nav--soundtrack" aria-label="Soundtrack letter navigation" hidden></nav>
                <div id="soundtrackGrid" class="soundtrack-grid"></div>
                <div id="soundtrackEmpty" class="auto-playlists-empty" hidden>
                    No soundtrack items available for this category and filter.
                </div>
            </section>
        </div>

        <!-- Auto Playlists Tab -->
        <div class="tab-pane fade" id="auto-playlists-content" role="tabpanel" aria-labelledby="auto-playlists-tab">
            <div class="media-tab-header">
                <div>
                    <h2>Auto Playlists</h2>
                    <p>Autogenerated playlists.</p>
                </div>
            </div>
            <section class="auto-section">
                <div id="autoToolsGrid" class="auto-tools-grid"></div>
                <div id="autoPlaylistsEmpty" class="auto-playlists-empty" hidden>
                    No auto playlists yet. Once generation runs, they will appear here.
                </div>
                <div id="autoPlaylistsWarning" class="auto-playlists-empty" hidden></div>
            </section>
        </div>

        <!-- Library Playlists Tab -->
        <div class="tab-pane fade" id="library-playlists-content" role="tabpanel" aria-labelledby="library-playlists-tab">
            <div class="media-tab-header">
                <div>
                    <h2>Library Playlists</h2>
                    <p>Playlists already in your Plex/Jellyfin library.</p>
                </div>
                <div class="auto-playlists-meta">
                    <span id="autoPlaylistsCount">0 playlists</span>
                    <span id="autoPlaylistsSource">Plex</span>
                </div>
            </div>
            <section class="auto-section">
                <div class="auto-section-header">
                    <div></div>
                </div>
                <div id="libraryPlaylistsGrid" class="library-playlist-grid"></div>
                <div id="libraryPlaylistsEmpty" class="auto-playlists-empty" hidden>
                    No library playlists yet.
                </div>
            </section>
        </div>

        <!-- Favorites Tab -->
        <div class="tab-pane fade" id="favorites-content" role="tabpanel" aria-labelledby="favorites-tab">
            <div class="media-tab-header">
                <div>
                    <h2>Favorites</h2>
                    <p>Favorites pulled from Spotify and Deezer accounts.</p>
                </div>
            </div>
            <div id="favoritesContainer" class="favorites-root">
                <div class="favorites-section" id="spotifyFavoritesSection">
                    <div class="favorites-section-header">
                        <div class="favorites-brand">
                            <img src="/images/icons/spotify.png" alt="Spotify" class="favorites-icon" />
                            <h3>Spotify</h3>
                        </div>
                        <span id="spotifyFavoritesStatus" class="favorites-status">Loading...</span>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Playlists</h4>
                        <div id="spotifyFavoritePlaylists" class="favorites-grid"></div>
                        <div id="spotifyFavoritePlaylistsEmpty" class="favorites-empty">No playlists found.</div>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Tracks</h4>
                        <div id="spotifyFavoriteTracks" class="favorites-grid"></div>
                        <div id="spotifyFavoriteTracksEmpty" class="favorites-empty">No tracks found.</div>
                    </div>
                </div>

                <div class="favorites-section" id="deezerFavoritesSection">
                    <div class="favorites-section-header">
                        <div class="favorites-brand">
                            <img src="/images/icons/deezer.png" alt="Deezer" class="favorites-icon" />
                            <h3>Deezer</h3>
                        </div>
                        <span id="deezerFavoritesStatus" class="favorites-status">Loading...</span>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Albums</h4>
                        <div id="deezerFavoriteAlbums" class="favorites-grid"></div>
                        <div id="deezerFavoriteAlbumsEmpty" class="favorites-empty">No albums found.</div>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Playlists</h4>
                        <div id="deezerFavoritePlaylists" class="favorites-grid"></div>
                        <div id="deezerFavoritePlaylistsEmpty" class="favorites-empty">No playlists found.</div>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Tracks</h4>
                        <div id="deezerFavoriteTracks" class="favorites-grid"></div>
                        <div id="deezerFavoriteTracksEmpty" class="favorites-empty">No tracks found.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Tab -->
        <div class="tab-pane fade" id="settings-content" role="tabpanel" aria-labelledby="settings-tab">
            <div class="card bg-darker border-secondary">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-cog me-2"></i>Settings
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">Configure your DeezSpoTag preferences</p>

                    <div class="mm-section">
                        <div class="mm-section-header">
                            <h2>Library Settings</h2>
                            <p>Control fuzzy matching and folder scope.</p>
                        </div>
                        <div class="mm-card">
                            <div class="mm-form">
                                <div class="form-row">
                                    <label for="fuzzyThreshold">Fuzzy threshold</label>
                                    <input id="fuzzyThreshold" type="number" min="0" max="1" step="0.01" />
                                    <small>Lower values match more aggressively. Recommended 0.80–0.90.</small>
                                </div>
                                <div class="form-row inline">
                                    <label for="includeAllFolders">Include all folders</label>
                                    <input id="includeAllFolders" type="checkbox" />
                                </div>
                                <div class="form-actions">
                                    <button id="saveSettings" class="btn btn-primary action-btn">Save Settings</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mm-section">
                        <div class="mm-section-header">
                            <h2>Media Operations</h2>
                            <p>Operational tools are managed in Activities.</p>
                        </div>
                        <div class="mm-card">
                            <p class="text-muted mb-3">
                                Meloday, Artist Metadata Updater, Quality Scanner, and Media Server Scan are available in the
                                <strong>Activities → Media Operations</strong> tab.
                            </p>
                            <a class="btn btn-primary action-btn" asp-controller="Activities" asp-action="Index">Open Activities</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('#mediaManagementTabs button[data-bs-toggle="tab"]').forEach((button) => {
        button.addEventListener('shown.bs.tab', function (e) {
            if (window.matchMedia('(max-width: 992px)').matches) {
                e.target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'nearest',
                    inline: 'center'
                });
            }
        });
    });

    document.querySelectorAll('button[disabled]').forEach((button) => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            DeezSpoTag.ui.alert('This feature is not yet implemented.', { title: 'Not Implemented' });
        });
    });
});
</script>

<script src="~/js/library-interactions.js" asp-append-version="true"></script>
<script src="~/js/library.js" asp-append-version="true"></script>
<script src="~/js/library-soundtracks.js" asp-append-version="true"></script>
<script src="~/js/library-watchlists.js" asp-append-version="true"></script>
<script src="~/js/library-bootstrap.js" asp-append-version="true"></script>
<script src="~/js/auto-playlists.js" asp-append-version="true"></script>

<style>
/* Media Management specific styles */
.welcome-title {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--primary-color);
}

#mediaManagementTabs,
#watchlistSubTabs,
#soundtrackSubTabs {
    border-bottom: 2px solid var(--border-primary);
    margin-bottom: 2rem;
    gap: 8px;
    align-items: stretch;
}

#mediaManagementTabs .nav-item,
#watchlistSubTabs .nav-item,
#soundtrackSubTabs .nav-item {
    min-width: 0;
}

#mediaManagementTabs .nav-link,
#watchlistSubTabs .nav-link,
#soundtrackSubTabs .nav-link {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-weight: 500;
    padding: 1rem 1.5rem;
    transition: all 0.3s ease;
    border-radius: 8px 8px 0 0;
    margin-bottom: -2px;
    width: 100%;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
}

#mediaManagementTabs .nav-link:hover,
#watchlistSubTabs .nav-link:hover,
#soundtrackSubTabs .nav-link:hover {
    background: color-mix(in srgb, var(--primary-color) 12%, transparent);
    color: var(--primary-color);
    border-bottom: 2px solid var(--primary-color);
}

#mediaManagementTabs .nav-link.active,
#watchlistSubTabs .nav-link.active,
#soundtrackSubTabs .nav-link.active {
    background: color-mix(in srgb, var(--primary-color) 12%, transparent) !important;
    color: var(--primary-color) !important;
    border-bottom: 2px solid var(--primary-color) !important;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--primary-color) 20%, transparent);
}
#mediaManagementTabs .nav-link.active i,
#watchlistSubTabs .nav-link.active i,
#soundtrackSubTabs .nav-link.active i {
    color: var(--primary-color) !important;
}

#mediaManagementTabs .nav-link i,
#watchlistSubTabs .nav-link i,
#soundtrackSubTabs .nav-link i {
    margin-right: 0.5rem;
    font-size: 1.1rem;
    color: inherit;
}

.bg-darker {
    background-color: var(--bg-secondary) !important;
}

.border-secondary {
    border-color: var(--border-primary) !important;
}

.card {
    background-color: var(--bg-tertiary);
    border-color: var(--border-secondary);
    color: var(--text-primary);
}

.card-header h5,
.card-body h6,
.card-body p,
.card-body {
    color: var(--text-primary);
}

.text-muted,
.card-body .text-muted,
.card-header .text-muted {
    color: var(--text-muted) !important;
}

.mm-section {
    margin-top: 28px;
}

.mm-section-header {
    margin-bottom: 16px;
}

.mm-section-header h2 {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 6px;
}

.mm-section-header p {
    color: var(--text-muted);
    margin: 0;
}

.mm-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: 14px;
    padding: 20px;
}

.mm-form .form-row + .form-row {
    margin-top: 16px;
}

.soundtrack-toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) max-content max-content;
    gap: 10px;
    align-items: end;
    margin-bottom: 14px;
}

.soundtrack-toolbar #soundtrackRefreshItems,
.soundtrack-toolbar #soundtrackSyncLibraries {
    width: 160px;
    min-width: 160px;
    justify-self: stretch;
}

.soundtrack-toolbar #soundtrackRefreshItems {
    grid-column: 3;
}

.soundtrack-toolbar #soundtrackSyncLibraries {
    grid-column: 4;
}

.soundtrack-filter-group {
    display: grid;
    gap: 6px;
}

.soundtrack-filter-label {
    color: var(--text-muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
}

.soundtrack-pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    min-height: 40px;
}

.soundtrack-pill {
    border: 1px solid var(--border-secondary);
    background: var(--bg-secondary);
    color: var(--text-primary);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    transition: all 0.2s ease;
}

.soundtrack-pill:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
}

.soundtrack-pill.is-active {
    background: color-mix(in srgb, var(--primary-color) 14%, transparent);
    border-color: var(--primary-color);
    color: var(--primary-color);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--primary-color) 22%, transparent);
}

.soundtrack-pill.is-empty {
    cursor: default;
    opacity: 0.75;
}

.soundtrack-tv-nav {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 10px 16px;
    align-items: end;
    margin-bottom: 12px;
}

.soundtrack-tv-show {
    display: grid;
    gap: 3px;
}

.soundtrack-tv-show strong {
    color: var(--text-primary);
    font-size: 14px;
    line-height: 1.2;
}

.soundtrack-tv-nav .soundtrack-filter-group {
    grid-column: 1 / -1;
}

.soundtrack-grid {
    --soundtrack-card-min: 208px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--soundtrack-card-min), 1fr));
    gap: 14px;
    padding-right: 52px;
}

.soundtrack-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
}

.soundtrack-card-art {
    width: 100%;
    object-fit: cover;
    background: var(--bg-secondary);
}

.soundtrack-card-poster-btn {
    display: block;
    border: 0;
    margin: 0;
    padding: 0;
    width: 100%;
    background: transparent;
    cursor: pointer;
    text-align: left;
}

.soundtrack-card-media-btn {
    display: block;
    border: 0;
    margin: 0;
    padding: 0;
    width: 100%;
    background: transparent;
    cursor: pointer;
    text-align: left;
}

.soundtrack-card-poster-btn:disabled {
    cursor: default;
}

.soundtrack-card-media-btn:disabled {
    cursor: default;
}

.soundtrack-card-art--poster {
    aspect-ratio: 2 / 3;
}

.soundtrack-card-art--landscape {
    aspect-ratio: 16 / 9;
}

.soundtrack-card--skeleton {
    pointer-events: none;
}

.soundtrack-skeleton-block,
.soundtrack-skeleton-line {
    background: linear-gradient(
        90deg,
        color-mix(in srgb, var(--bg-secondary) 70%, transparent) 0%,
        color-mix(in srgb, var(--bg-secondary) 88%, transparent) 45%,
        color-mix(in srgb, var(--bg-secondary) 70%, transparent) 100%
    );
    background-size: 220% 100%;
    animation: soundtrackSkeletonPulse 1.2s ease-in-out infinite;
}

.soundtrack-skeleton-line {
    height: 12px;
    border-radius: 8px;
}

.soundtrack-skeleton-line--title {
    width: 80%;
    height: 14px;
}

.soundtrack-skeleton-line--meta {
    width: 62%;
}

.soundtrack-skeleton-line.short {
    width: 40%;
}

@@keyframes soundtrackSkeletonPulse {
    0% {
        background-position: 100% 0;
    }
    100% {
        background-position: -100% 0;
    }
}

.soundtrack-card-body {
    padding: 12px;
    display: grid;
