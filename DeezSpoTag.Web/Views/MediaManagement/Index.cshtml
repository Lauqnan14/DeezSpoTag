@{
    ViewData["Title"] = "Media Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/library.css" />
<link rel="stylesheet" href="~/css/auto-playlists.css" asp-append-version="true" />

<div class="container-fluid">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="welcome-title mb-2">Media Management</h1>
            <p class="text-muted">Manage your playlists, watchlists, soundtracks, and media integrations</p>
        </div>
    </div>

    <!-- Main Navigation Tabs -->
    <ul class="nav nav-tabs nav-fill mb-4" id="mediaManagementTabs">
        <li class="nav-item">
            <button class="nav-link active" id="recommendations-tab" data-bs-toggle="tab" data-bs-target="#recommendations-content" type="button" role="tab">
                <i class="fas fa-broadcast-tower me-2"></i>Recommendations
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="watchlist-tab" data-bs-toggle="tab" data-bs-target="#watchlist-content" type="button" role="tab">
                <i class="fas fa-eye me-2"></i>Watchlist
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="soundtracks-tab" data-bs-toggle="tab" data-bs-target="#soundtracks-content" type="button" role="tab">
                <i class="fas fa-film me-2"></i>Soundtracks
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="auto-playlists-tab" data-bs-toggle="tab" data-bs-target="#auto-playlists-content" type="button" role="tab">
                <i class="fas fa-layer-group me-2"></i>Auto Playlists
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="library-playlists-tab" data-bs-toggle="tab" data-bs-target="#library-playlists-content" type="button" role="tab">
                <i class="fas fa-list me-2"></i>Library Playlists
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="favorites-tab" data-bs-toggle="tab" data-bs-target="#favorites-content" type="button" role="tab">
                <i class="fas fa-heart me-2"></i>Favorites
            </button>
        </li>
    </ul>

    <div class="tab-content" id="mediaManagementTabsContent">
        <!-- Recommendations Tab -->
        <div class="tab-pane fade show active" id="recommendations-content" role="tabpanel">
            <div class="media-tab-header">
                <div>
                    <h2>Recommendations</h2>
                    <p>Daily recommendations generated from your library.</p>
                </div>
            </div>
            <section class="auto-section">
                <div id="recommendationsGrid" class="auto-tools-grid auto-tools-grid--recommendations"></div>
                <div id="recommendationsEmpty" class="auto-playlists-empty" hidden>
                    No recommendations available yet.
                </div>
            </section>
        </div>

        <!-- Watchlist Tab -->
        <div class="tab-pane fade" id="watchlist-content" role="tabpanel">
            <ul class="nav nav-tabs nav-fill mb-3" id="watchlistSubTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="watchlist-playlists-tab" data-bs-toggle="tab" data-bs-target="#watchlist-playlists-content" type="button" role="tab" aria-selected="true">
                        Playlists
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="watchlist-artists-tab" data-bs-toggle="tab" data-bs-target="#watchlist-artists-content" type="button" role="tab" aria-selected="false">
                        Artists
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="watchlist-blocked-tab" data-bs-toggle="tab" data-bs-target="#watchlist-blocked-content" type="button" role="tab" aria-selected="false">
                        Blocked
                    </button>
                </li>
            </ul>
            <div class="tab-content" id="watchlistSubTabsContent">
                <div class="tab-pane fade show active" id="watchlist-playlists-content" role="tabpanel" aria-labelledby="watchlist-playlists-tab">
                    <div class="media-tab-header">
                        <div>
                            <h2>Playlists Watchlist</h2>
                            <p>Manage monitored playlists. Click <i class="fa-solid fa-gear"></i> on a card to configure folder, autotag, routing rules and blocked tracks.</p>
                        </div>
                    </div>
                    <div id="playlistWatchlistContainer" class="watchlist-playlist-grid"></div>
                </div>
                <div class="tab-pane fade" id="watchlist-artists-content" role="tabpanel" aria-labelledby="watchlist-artists-tab">
                    <div class="media-tab-header">
                        <div>
                            <h2>Artists Watchlist</h2>
                            <p>Choose where each watched artist's new releases should be saved.</p>
                        </div>
                        <div>
                            <button id="saveArtistPreferences" class="btn btn-primary action-btn btn-sm">Save Preferences</button>
                        </div>
                    </div>
                    <div id="watchlistContainer" class="watchlist-artist-grid"></div>
                </div>
                <div class="tab-pane fade" id="watchlist-blocked-content" role="tabpanel" aria-labelledby="watchlist-blocked-tab">
                    <div class="media-tab-header">
                        <div>
                            <h2>Blocked Items</h2>
                            <p>Review blocked tracks, artists, and albums.</p>
                        </div>
                    </div>
                    <div id="blockedWatchlistContainer" class="watchlist-blocked-grid"></div>
                </div>
            </div>
        </div>

        <!-- Soundtracks Tab -->
        <div class="tab-pane fade" id="soundtracks-content" role="tabpanel">
            <ul class="nav nav-tabs nav-fill mb-3" id="soundtrackSubTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="soundtrack-movies-tab" type="button" data-soundtrack-category="movie" aria-selected="true">
                        Movies
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="soundtrack-tv-tab" type="button" data-soundtrack-category="tv_show" aria-selected="false">
                        TV Shows
                    </button>
                </li>
            </ul>
            <div class="media-tab-header">
                <div>
                    <h2>Soundtracks</h2>
                    <p>Browse soundtrack from the media in your library.</p>
                </div>
            </div>
            <section class="auto-section">
                <div class="soundtrack-toolbar">
                    <div id="soundtrackServerFilterGroup" class="soundtrack-filter-group">
                        <div id="soundtrackServerFilterLabel" class="soundtrack-filter-label">Servers</div>
                        <div id="soundtrackServerPills" class="soundtrack-pill-row"></div>
                    </div>
                    <div id="soundtrackLibraryFilterGroup" class="soundtrack-filter-group">
                        <div id="soundtrackLibraryFilterLabel" class="soundtrack-filter-label">Libraries</div>
                        <div id="soundtrackLibraryPills" class="soundtrack-pill-row"></div>
                    </div>
                    <button id="soundtrackRefreshItems" class="btn btn-secondary action-btn btn-sm" type="button">Refresh</button>
                    <button id="soundtrackSyncLibraries" class="btn btn-primary action-btn btn-sm" type="button">Sync Libraries</button>
                </div>
                <div id="soundtrackStatus" class="auto-playlists-meta"></div>
                <div id="soundtrackSyncStatus" class="auto-playlists-meta"></div>
                <div id="soundtrackTvNav" class="soundtrack-tv-nav" hidden>
                    <button id="soundtrackTvBack" type="button" class="btn btn-secondary action-btn btn-sm">Back to TV Shows</button>
                    <div class="soundtrack-tv-show">
                        <span class="soundtrack-filter-label">Selected Show</span>
                        <strong id="soundtrackTvShowTitle"></strong>
                    </div>
                    <div id="soundtrackTvSeasonFilterGroup" class="soundtrack-filter-group" style="display:none;">
                        <div class="soundtrack-filter-label">Seasons</div>
                        <div id="soundtrackTvSeasonPills" class="soundtrack-pill-row"></div>
                    </div>
                </div>
                <div id="soundtrackGrid" class="soundtrack-grid"></div>
                <div id="soundtrackEmpty" class="auto-playlists-empty" hidden>
                    No soundtrack items available for this category and filter.
                </div>
            </section>
        </div>

        <!-- Auto Playlists Tab -->
        <div class="tab-pane fade" id="auto-playlists-content" role="tabpanel">
            <div class="media-tab-header">
                <div>
                    <h2>Auto Playlists</h2>
                    <p>Autogenerated playlists.</p>
                </div>
            </div>
            <section class="auto-section">
                <div id="autoToolsGrid" class="auto-tools-grid"></div>
                <div id="autoPlaylistsEmpty" class="auto-playlists-empty" hidden>
                    No auto playlists yet. Once generation runs, they will appear here.
                </div>
                <div id="autoPlaylistsWarning" class="auto-playlists-empty" hidden></div>
            </section>
        </div>

        <!-- Library Playlists Tab -->
        <div class="tab-pane fade" id="library-playlists-content" role="tabpanel">
            <div class="media-tab-header">
                <div>
                    <h2>Library Playlists</h2>
                    <p>Playlists already in your Plex/Jellyfin library.</p>
                </div>
                <div class="auto-playlists-meta">
                    <span id="autoPlaylistsCount">0 playlists</span>
                    <span id="autoPlaylistsSource">Plex</span>
                </div>
            </div>
            <section class="auto-section">
                <div class="auto-section-header">
                    <div></div>
                </div>
                <div id="libraryPlaylistsGrid" class="library-playlist-grid"></div>
                <div id="libraryPlaylistsEmpty" class="auto-playlists-empty" hidden>
                    No library playlists yet.
                </div>
            </section>
        </div>

        <!-- Favorites Tab -->
        <div class="tab-pane fade" id="favorites-content" role="tabpanel">
            <div class="media-tab-header">
                <div>
                    <h2>Favorites</h2>
                    <p>Favorites pulled from Spotify and Deezer accounts.</p>
                </div>
            </div>
            <div id="favoritesContainer" class="favorites-root">
                <div class="favorites-section" id="spotifyFavoritesSection">
                    <div class="favorites-section-header">
                        <div class="favorites-brand">
                            <img src="/images/icons/spotify.png" alt="Spotify" class="favorites-icon" />
                            <h3>Spotify</h3>
                        </div>
                        <span id="spotifyFavoritesStatus" class="favorites-status">Loading...</span>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Playlists</h4>
                        <div id="spotifyFavoritePlaylists" class="favorites-grid"></div>
                        <div id="spotifyFavoritePlaylistsEmpty" class="favorites-empty">No playlists found.</div>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Tracks</h4>
                        <div id="spotifyFavoriteTracks" class="favorites-grid"></div>
                        <div id="spotifyFavoriteTracksEmpty" class="favorites-empty">No tracks found.</div>
                    </div>
                </div>

                <div class="favorites-section" id="deezerFavoritesSection">
                    <div class="favorites-section-header">
                        <div class="favorites-brand">
                            <img src="/images/icons/deezer.png" alt="Deezer" class="favorites-icon" />
                            <h3>Deezer</h3>
                        </div>
                        <span id="deezerFavoritesStatus" class="favorites-status">Loading...</span>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Albums</h4>
                        <div id="deezerFavoriteAlbums" class="favorites-grid"></div>
                        <div id="deezerFavoriteAlbumsEmpty" class="favorites-empty">No albums found.</div>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Playlists</h4>
                        <div id="deezerFavoritePlaylists" class="favorites-grid"></div>
                        <div id="deezerFavoritePlaylistsEmpty" class="favorites-empty">No playlists found.</div>
                    </div>
                    <div class="favorites-subsection">
                        <h4>Tracks</h4>
                        <div id="deezerFavoriteTracks" class="favorites-grid"></div>
                        <div id="deezerFavoriteTracksEmpty" class="favorites-empty">No tracks found.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Tab -->
        <div class="tab-pane fade" id="settings-content" role="tabpanel">
            <div class="card bg-darker border-secondary">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-cog me-2"></i>Settings
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">Configure your DeezSpoTag preferences</p>

                    <div class="mm-section">
                        <div class="mm-section-header">
                            <h2>Library Settings</h2>
                            <p>Control fuzzy matching and folder scope.</p>
                        </div>
                        <div class="mm-card">
                            <div class="mm-form">
                                <div class="form-row">
                                    <label for="fuzzyThreshold">Fuzzy threshold</label>
                                    <input id="fuzzyThreshold" type="number" min="0" max="1" step="0.01" />
                                    <small>Lower values match more aggressively. Recommended 0.80–0.90.</small>
                                </div>
                                <div class="form-row inline">
                                    <label for="includeAllFolders">Include all folders</label>
                                    <input id="includeAllFolders" type="checkbox" />
                                </div>
                                <div class="form-actions">
                                    <button id="saveSettings" class="btn btn-primary action-btn">Save Settings</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mm-section">
                        <div class="mm-section-header">
                            <h2>Media Operations</h2>
                            <p>Database refresh and maintenance tools.</p>
                        </div>
                        <div class="tools-grid">
                            <div class="tool-card" id="meloday-card">
                                <div class="tool-card-header">
                                    <h4 class="tool-card-title">Meloday</h4>
                                </div>
                                <p class="tool-card-info">Generate a daypart playlist from Plex listening history.</p>
                                <div class="tool-card-body">
                                    <div class="analysis-status" id="melodayStatus">Loading Meloday status...</div>
                                    <div class="analysis-meta">Last run: <span id="melodayLastRun">Never</span></div>
                                    <div class="analysis-meta" id="melodayConfig"></div>
                                    <div class="form-actions">
                                        <button id="runMeloday" class="btn btn-primary action-btn" type="button">Run Meloday</button>
                                    </div>
                                </div>
                            </div>
                            <div class="tool-card" id="metadata-updater-card">
                                <div class="tool-card-header">
                                    <h4 class="tool-card-title">Artist Metadata Updater</h4>
                                    <button class="tool-help-button" title="Learn more about this tool">?</button>
                                </div>
                                <div class="tool-card-controls">
                                    <partial name="_ArtistMetadataUpdaterControls" />
                                    <button id="metadata-update-button" class="btn action-btn">Begin Update</button>
                                </div>
                                 <div class="tool-card-progress-section">
                                    <p class="progress-phase-label" id="metadata-phase-label">Current Artist: Not running</p>
                                    <div class="progress-bar-container">
                                         <div class="progress-bar-fill" id="metadata-progress-bar" style="width: 0%;"></div>
                                    </div>
                                    <p class="progress-details-label" id="metadata-progress-label">0 / 0 artists (0.0%)</p>
                                </div>
                            </div>

                            <div class="tool-card" id="quality-scanner-card">
                                <div class="tool-card-header">
                                    <h4 class="tool-card-title">Quality Scanner</h4>
                                    <button class="tool-help-button" title="Learn more about this tool">?</button>
                                </div>
                                <p class="tool-card-info">Scan library for tracks below quality preferences</p>
                                <div class="tool-card-stats">
                                    <div class="stat-item">
                                        <span class="stat-item-label">Processed:</span>
                                        <span class="stat-item-value" id="quality-stat-processed">0</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-item-label">Quality Met:</span>
                                        <span class="stat-item-value" id="quality-stat-met">0</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-item-label">Low Quality:</span>
                                        <span class="stat-item-value" id="quality-stat-low">0</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-item-label">Matched:</span>
                                        <span class="stat-item-value" id="quality-stat-matched">0</span>
                                    </div>
                                </div>
                                <div class="tool-card-controls">
                                    <select id="quality-scan-scope">
                                        <option value="watchlist">Watchlist Artists Only</option>
                                        <option value="all">All Library Tracks</option>
                                    </select>
                                    <button id="quality-scan-button" class="btn action-btn">Scan Library</button>
                                </div>
                                <div class="tool-card-progress-section">
                                    <p class="progress-phase-label" id="quality-phase-label">Ready to scan</p>
                                    <div class="progress-bar-container">
                                         <div class="progress-bar-fill" id="quality-progress-bar" style="width: 0%;"></div>
                                    </div>
                                    <p class="progress-details-label" id="quality-progress-label">0 / 0 tracks scanned (0.0%)</p>
                                </div>
                            </div>

                            <div class="tool-card" id="media-scan-card">
                                <div class="tool-card-header">
                                    <h4 class="tool-card-title">Media Server Scan</h4>
                                    <button class="tool-help-button" title="Learn more about this tool">?</button>
                                </div>
                                <p class="tool-card-info">Manually trigger Plex media library scan for music</p>
                                <div class="tool-card-stats">
                                    <div class="stat-item">
                                        <span class="stat-item-label">Last Scan:</span>
                                        <span class="stat-item-value" id="media-scan-last-time">Never</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-item-label">Status:</span>
                                        <span class="stat-item-value" id="media-scan-status">Idle</span>
                                    </div>
                                </div>
                                <div class="tool-card-controls">
                                    <button id="media-scan-button" class="btn action-btn media-scan-btn">
                                        <span class="scan-text">Scan Library</span>
                                    </button>
                                </div>
                                <div class="tool-card-progress-section">
                                    <p class="progress-phase-label" id="media-scan-phase-label">Ready to scan</p>
                                    <div class="progress-bar-container">
                                         <div class="progress-bar-fill" id="media-scan-progress-bar" style="width: 0%;"></div>
                                    </div>
                                    <p class="progress-details-label" id="media-scan-progress-label">Waiting for scan request</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('Media Management page loaded');

    document.querySelectorAll('#mediaManagementTabs button[data-bs-toggle="tab"]').forEach((button) => {
        button.addEventListener('shown.bs.tab', function (e) {
            const targetTab = e.target?.getAttribute('data-bs-target') || '';
            console.log('Tab switched to:', targetTab);
            if (window.matchMedia('(max-width: 992px)').matches) {
                e.target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'nearest',
                    inline: 'center'
                });
            }
        });
    });

    document.querySelectorAll('button[disabled]').forEach((button) => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            DeezSpoTag.ui.alert('This feature is not yet implemented.', { title: 'Not Implemented' });
        });
    });
});
</script>

<script src="~/js/library.js" asp-append-version="true"></script>
<script src="~/js/meloday.js"></script>
<script src="~/js/auto-playlists.js" asp-append-version="true"></script>

<style>
/* Media Management specific styles */
.welcome-title {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--primary-color);
}

#mediaManagementTabs,
#watchlistSubTabs,
#soundtrackSubTabs {
    border-bottom: 2px solid var(--border-primary);
    margin-bottom: 2rem;
    gap: 8px;
    align-items: stretch;
}

#mediaManagementTabs .nav-item,
#watchlistSubTabs .nav-item,
#soundtrackSubTabs .nav-item {
    min-width: 0;
}

#mediaManagementTabs .nav-link,
#watchlistSubTabs .nav-link,
#soundtrackSubTabs .nav-link {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-weight: 500;
    padding: 1rem 1.5rem;
    transition: all 0.3s ease;
    border-radius: 8px 8px 0 0;
    margin-bottom: -2px;
    width: 100%;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
}

#mediaManagementTabs .nav-link:hover,
#watchlistSubTabs .nav-link:hover,
#soundtrackSubTabs .nav-link:hover {
    background: color-mix(in srgb, var(--primary-color) 12%, transparent);
    color: var(--primary-color);
    border-bottom: 2px solid var(--primary-color);
}

#mediaManagementTabs .nav-link.active,
#watchlistSubTabs .nav-link.active,
#soundtrackSubTabs .nav-link.active {
    background: color-mix(in srgb, var(--primary-color) 12%, transparent) !important;
    color: var(--primary-color) !important;
    border-bottom: 2px solid var(--primary-color) !important;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--primary-color) 20%, transparent);
}
#mediaManagementTabs .nav-link.active i,
#watchlistSubTabs .nav-link.active i,
#soundtrackSubTabs .nav-link.active i {
    color: var(--primary-color) !important;
}

#mediaManagementTabs .nav-link i,
#watchlistSubTabs .nav-link i,
#soundtrackSubTabs .nav-link i {
    margin-right: 0.5rem;
    font-size: 1.1rem;
    color: inherit;
}

.bg-darker {
    background-color: var(--bg-secondary) !important;
}

.border-secondary {
    border-color: var(--border-primary) !important;
}

.card {
    background-color: var(--bg-tertiary);
    border-color: var(--border-secondary);
    color: var(--text-primary);
}

.card-header h5,
.card-body h6,
.card-body p,
.card-body {
    color: var(--text-primary);
}

.text-muted,
.card-body .text-muted,
.card-header .text-muted {
    color: var(--text-muted) !important;
}

.mm-section {
    margin-top: 28px;
}

.mm-section-header {
    margin-bottom: 16px;
}

.mm-section-header h2 {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 6px;
}

.mm-section-header p {
    color: var(--text-muted);
    margin: 0;
}

.mm-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-secondary);
    border-radius: 14px;
    padding: 20px;
}

.mm-form .form-row + .form-row {
    margin-top: 16px;
}

/* Media operations cards */
.tools-grid {
    display: flex;
    flex-direction: column;
    gap: 18px;
    width: 100%;
}

.tool-card {
    background: var(--bg-tertiary);
    border-radius: 16px;
    border: 1px solid var(--border-secondary);
    padding: 24px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.35);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: all 0.2s ease;
}

.tool-card:hover {
    transform: translateY(-1px);
    border-color: var(--border-primary);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.45);
}

.tool-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    gap: 12px;
}

.tool-card-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
}

.tool-help-button {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid var(--border-primary);
    background: transparent;
    color: var(--text-muted);
