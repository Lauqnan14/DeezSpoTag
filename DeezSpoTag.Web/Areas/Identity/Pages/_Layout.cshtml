<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"] - DeezSpoTag</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="theme-color" content="#0f172a">
    <link rel="icon" href="~/images/logo.svg" type="image/svg+xml">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
          crossorigin="anonymous">
    <link href="~/css/themes.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true">
    <style>
        body.auth-page {
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }
        .auth-logo {
            width: 320px;
            height: auto;
        }
        .auth-title {
            font-weight: 600;
            font-size: 18px;
            letter-spacing: 0.01em;
        }

        .identity-shell {
            width: min(980px, 92vw);
            margin: 0 auto;
        }

        .identity-shell h1,
        .identity-shell h2,
        .identity-shell h3,
        .identity-shell h4 {
            color: var(--text-primary);
        }

        .identity-shell .nav-pills .nav-link {
            color: var(--text-secondary);
            background: transparent;
            border-radius: 10px;
            padding: 8px 12px;
            border: 1px solid transparent;
        }

        .identity-shell .nav-pills .nav-link.active,
        .identity-shell .nav-pills .show > .nav-link {
            color: var(--text-primary);
            background: var(--bg-tertiary);
            border-color: var(--primary-color);
        }

        .identity-shell .card,
        .identity-shell .card-body {
            background: transparent;
            border: 0;
            color: var(--text-primary);
        }

        .identity-shell .form-control {
            background: var(--bg-secondary);
            border: 1px solid var(--border-secondary);
            color: var(--text-primary);
            border-radius: 10px;
            padding: 10px 12px;
        }

        .identity-shell .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary-color) 30%, transparent);
        }

        .identity-shell .btn {
            border-radius: 10px;
        }

        .identity-shell .btn-primary {
            background: var(--primary-color);
            border-color: var(--primary-color);
        }

        .identity-shell .btn-primary:hover {
            filter: brightness(1.1);
        }

        .identity-shell .text-danger {
            color: #f87171;
        }
    </style>
</head>
<body class="auth-page">
    <div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
        <div class="identity-shell">
            @RenderBody()
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
