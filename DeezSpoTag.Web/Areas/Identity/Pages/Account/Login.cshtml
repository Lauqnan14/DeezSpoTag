@page
@model DeezSpoTag.Web.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = "/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-center">
    <form class="auth-card text-center" method="post">
        <div class="mb-4">
            <a class="d-inline-flex align-items-center justify-content-center" asp-area="" asp-controller="Home" asp-action="Index">
                <svg width="400" height="180" viewBox="0 0 400 180" xmlns="http://www.w3.org/2000/svg" class="auth-logo theme-logo auth-theme-logo" role="img" aria-label="DeezSpoTag logo">
                    <defs>
                        <linearGradient id="authPremiumGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" class="logo-primary-stop" />
                            <stop offset="100%" class="logo-secondary-stop" />
                        </linearGradient>
                        <filter id="authNeonGlow">
                            <feGaussianBlur stdDeviation="3" result="coloredBlur" />
                            <feOffset result="offsetblur" in="coloredBlur" dx="0" dy="0" />
                            <feFlood class="logo-glow-flood" flood-opacity="0.5" />
                            <feComposite in2="offsetblur" operator="in" />
                            <feMerge><feMergeNode /><feMergeNode in="SourceGraphic" /></feMerge>
                        </filter>
                        <filter id="authTextShadow">
                            <feGaussianBlur in="SourceAlpha" stdDeviation="2" />
                            <feOffset dx="0" dy="2" result="offsetblur" />
                            <feComponentTransfer><feFuncA type="linear" slope="0.3" /></feComponentTransfer>
                            <feMerge><feMergeNode /><feMergeNode in="SourceGraphic" /></feMerge>
                        </filter>
                    </defs>
                    <g transform="translate(200, 50)">
                        <path d="M-45,0 L-22.5,-39 L22.5,-39 L45,0 L22.5,39 L-22.5,39 Z" fill="none" stroke="url(#authPremiumGrad)" stroke-width="2" filter="url(#authNeonGlow)" />
                        <path d="M-35,0 L-17.5,-30 L17.5,-30 L35,0 L17.5,30 L-17.5,30 Z" fill="none" stroke="url(#authPremiumGrad)" stroke-width="1" opacity="0.5" />
                        <g filter="url(#authNeonGlow)">
                            <rect x="-20" y="-15" width="5" height="30" class="logo-bar-1">
                                <animate attributeName="height" values="30;45;30" dur="0.8s" repeatCount="indefinite" />
                                <animate attributeName="y" values="-15;-22.5;-15" dur="0.8s" repeatCount="indefinite" />
                            </rect>
                            <rect x="-10" y="-20" width="5" height="40" class="logo-bar-2">
                                <animate attributeName="height" values="40;25;40" dur="1s" repeatCount="indefinite" />
                                <animate attributeName="y" values="-20;-12.5;-20" dur="1s" repeatCount="indefinite" />
                            </rect>
                            <rect x="0" y="-12" width="5" height="24" class="logo-bar-3">
                                <animate attributeName="height" values="24;42;24" dur="0.6s" repeatCount="indefinite" />
                                <animate attributeName="y" values="-12;-21;-12" dur="0.6s" repeatCount="indefinite" />
                            </rect>
                            <rect x="10" y="-18" width="5" height="36" class="logo-bar-4">
                                <animate attributeName="height" values="36;20;36" dur="0.9s" repeatCount="indefinite" />
                                <animate attributeName="y" values="-18;-10;-18" dur="0.9s" repeatCount="indefinite" />
                            </rect>
                        </g>
                    </g>
                    <text x="200" y="140" font-family="Helvetica Neue, Arial, sans-serif" font-size="52" font-weight="700" text-anchor="middle" filter="url(#authTextShadow)" fill="url(#authPremiumGrad)" letter-spacing="0">DeezSpoTag</text>
                    <line x1="50" y1="155" x2="350" y2="155" stroke="url(#authPremiumGrad)" stroke-width="1" opacity="0.4" />
                    <text x="200" y="175" font-family="Montserrat, sans-serif" font-size="13" font-weight="300" class="logo-tagline" letter-spacing="3" text-anchor="middle">AUTOMATED MUSIC EXPERIENCE</text>
                    <circle cx="50" cy="155" r="2" fill="url(#authPremiumGrad)" opacity="0.8" />
                    <circle cx="350" cy="155" r="2" fill="url(#authPremiumGrad)" opacity="0.8" />
                </svg>
            </a>
            <h2 class="auth-title mt-3">Sign In</h2>
        </div>
        @if (ViewData.ModelState.TryGetValue(string.Empty, out var modelErrorEntry) &&
             modelErrorEntry?.Errors.Count > 0)
        {
            <div class="text-danger small mb-3" role="alert" aria-live="polite">
                @foreach (var error in modelErrorEntry.Errors)
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }
        <div class="mb-3">
            <label for="Input_Username" class="visually-hidden">Username</label>
            <input asp-for="Input.Username" id="Input_Username" type="text" class="app-modal-input" autocomplete="username" />
            <span asp-validation-for="Input.Username" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label for="Input_Password" class="visually-hidden">Password</label>
            <input asp-for="Input.Password" id="Input_Password" type="password" class="app-modal-input" autocomplete="current-password" />
            <span asp-validation-for="Input.Password" class="text-danger small"></span>
        </div>
        <button class="btn btn-lg btn-primary w-100" type="submit">Let me in</button>
    </form>
</div>
